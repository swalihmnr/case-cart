<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CaseCart — Luxury Phone Craftsmanship</title>
    <meta name="description" content="Shop premium phone cases for iPhone, Samsung, and OnePlus. Designed with modern luxury retail and premium craftsmanship.">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        obsidian: '#0A0A0A',
                        'obsidian-light': '#121212',
                        'obsidian-surface': '#1A1A1A',
                        'obsidian-hover': '#262626',
                        ivory: '#F7F5F2',
                        gold: {
                            light: '#E8D5B0',
                            accent: '#C9A84C'
                        }
                    },
                    fontFamily: {
                        display: ['Cormorant Garamond', 'serif'],
                        sans: ['Inter', 'DM Sans', 'sans-serif']
                    }
                }
            }
        }
    </script>

    <!-- Icons and Toastify -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <!-- SweetAlert2 — loaded here so all pages get it from the shared header -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Override SweetAlert2 popup to match Obsidian-Dark brand */
        .swal2-popup {
            background: #161616 !important;
            border: 1px solid rgba(232, 213, 176, 0.12) !important;
            border-radius: 4px !important;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.8) !important;
            font-family: 'Inter', sans-serif !important;
        }
        .swal2-title {
            color: #E8D5B0 !important;
            font-family: 'Cormorant Garamond', serif !important;
            font-weight: 400 !important;
            font-size: 1.6rem !important;
            letter-spacing: 0.02em !important;
        }
        .swal2-html-container, .swal2-content {
            color: #a0a0a0 !important;
            font-size: 0.8rem !important;
        }
        .swal2-icon.swal2-warning {
            border-color: #C9A84C !important;
            color: #C9A84C !important;
        }
        .swal2-icon.swal2-success {
            border-color: #4ade80 !important;
            color: #4ade80 !important;
        }
        .swal2-icon.swal2-success [class^='swal2-success-line'] {
            background-color: #4ade80 !important;
        }
        .swal2-icon.swal2-success .swal2-success-ring {
            border-color: rgba(74, 222, 128, 0.3) !important;
        }
        .swal2-icon.swal2-error {
            border-color: #f87171 !important;
            color: #f87171 !important;
        }
        .swal2-icon.swal2-error [class^='swal2-x-mark-line'] {
            background-color: #f87171 !important;
        }
        .swal2-icon.swal2-question {
            border-color: #E8D5B0 !important;
            color: #E8D5B0 !important;
        }
        .swal2-icon.swal2-info {
            border-color: #E8D5B0 !important;
            color: #E8D5B0 !important;
        }
        .swal2-confirm {
            background-color: #E8D5B0 !important;
            color: #0A0A0A !important;
            font-size: 0.65rem !important;
            font-weight: 600 !important;
            letter-spacing: 0.1em !important;
            text-transform: uppercase !important;
            border-radius: 3px !important;
            padding: 0.65rem 1.5rem !important;
        }
        .swal2-confirm:hover {
            background-color: #C9A84C !important;
        }
        .swal2-cancel {
            background-color: transparent !important;
            color: #E8D5B0 !important;
            border: 1px solid rgba(232, 213, 176, 0.15) !important;
            font-size: 0.65rem !important;
            font-weight: 600 !important;
            letter-spacing: 0.1em !important;
            text-transform: uppercase !important;
            border-radius: 3px !important;
            padding: 0.65rem 1.5rem !important;
        }
        .swal2-cancel:hover {
            background-color: rgba(232, 213, 176, 0.05) !important;
            border-color: rgba(232, 213, 176, 0.35) !important;
        }
        .swal2-input, .swal2-textarea {
            background: #0A0A0A !important;
            border: 1px solid rgba(232, 213, 176, 0.15) !important;
            color: #F7F5F2 !important;
            border-radius: 3px !important;
            font-size: 0.85rem !important;
        }
        .swal2-input:focus, .swal2-textarea:focus {
            border-color: #C9A84C !important;
            box-shadow: none !important;
        }
        .swal2-input::placeholder, .swal2-textarea::placeholder {
            color: #4a4a4a !important;
        }
        .swal2-validation-message {
            background: transparent !important;
            color: #f87171 !important;
            border: none !important;
        }
        .swal2-close {
            color: rgba(232, 213, 176, 0.5) !important;
        }
        .swal2-close:hover {
            color: #E8D5B0 !important;
        }
        /* Toast overrides */
        .swal2-container.swal2-top-end .swal2-popup,
        .swal2-container.swal2-top-right .swal2-popup {
            border-radius: 4px !important;
        }
    </style>

    <!-- Custom Style Sheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="antialiased">

    <!-- Global Loading Overlay -->
    <div id="global-loading-overlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[9999] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div class="flex flex-col items-center">
            <span class="w-12 h-12 border-2 border-gold-light border-b-transparent rounded-full animate-spin"></span>
            <p class="mt-4 text-gold-light font-display text-sm tracking-widest uppercase">Loading...</p>
        </div>
    </div>

    <!-- Navigation Header -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-[100] border-b border-transparent transition-all duration-300 py-4 sm:py-6">
        <% 
        let fName = ''; 
        let lName = ''; 
        if (typeof user !== 'undefined' && user) { 
            fName = user.firstName ? user.firstName.charAt(0).toUpperCase() : (user.name ? user.name.charAt(0).toUpperCase() : 'U');
            lName = user.lastName ? user.lastName.charAt(0).toUpperCase() : ''; 
        } 
        %>
        <div class="max-w-7xl mx-auto px-6 sm:px-8">
            <div class="flex justify-between items-center h-10">
                <!-- Logo -->
                <div class="flex-shrink-0">
                    <a href="/" class="flex items-center space-x-3">
                        <img src="/img/Pasted image.png" alt="CaseCart Logo" class="h-8 w-auto object-contain rounded-md">
                        <span class="font-display text-3xl font-light tracking-wide text-gold-light hover:text-gold-accent transition-colors">CASE CART</span>
                    </a>
                </div>

                <!-- Desktop Category Navigation (Center) -->
                <div class="hidden md:flex items-center space-x-10">
                    <a href="/product" class="text-xs uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium">All Cases</a>
                    <a href="/product?search=leather" class="text-xs uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium">Leather</a>
                    <a href="/product?Categories=69f5b2cd9ec325a798c4d6cb" class="text-xs uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium">MagSafe</a>
                    <a href="/product?Categories=69f5b2ec9ec325a798c4d6d1" class="text-xs uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium">Premium Collection</a>
                </div>

                <!-- Right Side Actions -->
                <div class="flex items-center space-x-5">
                    <!-- Theme Toggle -->
                    <button onclick="toggleTheme()" class="p-2 text-gold-light hover:text-gold-accent transition-colors text-sm" title="Toggle Theme">
                        <i id="theme-icon" class="fas fa-sun"></i>
                    </button>

                    <!-- Search Trigger -->
                    <button onclick="toggleSearch()" class="p-2 text-gold-light hover:text-gold-accent transition-colors text-sm" title="Search">
                        <i class="fas fa-search"></i>
                    </button>

                    <!-- Wishlist -->
                    <a href="/wishlist" class="p-2 text-gold-light hover:text-gold-accent transition-colors text-sm relative" title="Wishlist">
                        <i class="far fa-heart"></i>
                        <span id="wishlist-count-badge" class="absolute -top-1 -right-1 bg-gold-accent text-obsidian text-[9px] font-bold rounded-full w-4 h-4 flex items-center justify-center border border-obsidian <%= (wishlistcount > 0) ? '' : 'hidden' %>">
                            <%= wishlistcount %>
                        </span>
                    </a>

                    <!-- Cart Drawer Trigger -->
                    <button onclick="openCartDrawer()" class="p-2 text-gold-light hover:text-gold-accent transition-colors text-sm relative" title="Cart">
                        <i class="fas fa-shopping-bag"></i>
                        <span id="cart-count-badge" class="absolute -top-1 -right-1 bg-gold-accent text-obsidian text-[9px] font-bold rounded-full w-4 h-4 flex items-center justify-center border border-obsidian <%= (cartCount > 0) ? '' : 'hidden' %>">
                            <%= cartCount %>
                        </span>
                    </button>

                    <!-- User Account -->
                    <div class="relative group">
                        <% if (!user) { %>
                            <a href="/login" class="text-xs uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium">Login</a>
                        <% } else { %>
                            <button class="flex items-center space-x-2 focus:outline-none p-1">
                                <div class="w-7 h-7 bg-gold-light/10 border border-gold-light/30 rounded-full flex items-center justify-center text-gold-light text-xs font-bold uppercase overflow-hidden">
                                    <% if (user.profileUrl) { %>
                                        <img src="<%= user.profileUrl %>" alt="Profile" class="w-full h-full object-cover">
                                    <% } else { %>
                                        <%= fName %><%= lName %>
                                    <% } %>
                                </div>
                            </button>
                            <!-- Dropdown -->
                            <div class="absolute right-0 top-full mt-2 w-48 bg-obsidian-light border border-gold-light/20 rounded shadow-xl py-2 hidden group-hover:block animate-fade-in">
                                <div class="px-4 py-2 border-b border-gold-light/10 mb-1">
                                    <p class="text-[10px] text-gray-500 uppercase tracking-widest">Account</p>
                                    <p class="text-xs font-medium text-gold-light truncate"><%= user.name %></p>
                                </div>
                                <a href="/user-profile" class="block px-4 py-2 text-xs text-gray-400 hover:text-gold-light hover:bg-obsidian-surface transition-colors">My Profile</a>
                                <a href="/order" class="block px-4 py-2 text-xs text-gray-400 hover:text-gold-light hover:bg-obsidian-surface transition-colors">My Orders</a>
                                <a href="/logout" class="block px-4 py-2 text-xs text-red-400 hover:bg-red-950/20 hover:text-red-300 transition-colors border-t border-gold-light/10 mt-1">Logout</a>
                            </div>
                        <% } %>
                    </div>

                    <!-- Mobile Menu Trigger -->
                    <button onclick="toggleMobileMenu()" class="md:hidden p-2 text-gold-light hover:text-gold-accent transition-colors">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile Navigation Drawer Overlay -->
    <div id="mobileMenu" class="fixed inset-0 z-[999] bg-obsidian/95 backdrop-blur-md px-8 py-10 hidden flex-col">
        <div class="flex justify-between items-center mb-12">
            <span class="font-display text-2xl tracking-wider text-gold-light">CASE CART</span>
            <button onclick="toggleMobileMenu()" class="p-2 text-gold-light">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <div class="flex flex-col space-y-8 text-center">
            <a href="/product" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">All Cases</a>
            <a href="/product?search=leather" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">Leather</a>
            <a href="/product?Categories=69f5b2cd9ec325a798c4d6cb" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">MagSafe</a>
            <a href="/product?Categories=69f5b2ec9ec325a798c4d6d1" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">Premium Collection</a>
            <a href="/wishlist" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">Wishlist (<%= wishlistcount %>)</a>
            <a href="/cart" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-light">Cart (<%= cartCount %>)</a>
            <% if (user) { %>
                <a href="/user-profile" onclick="toggleMobileMenu()" class="font-display text-xl tracking-wide text-gray-400">My Profile</a>
                <a href="/order" onclick="toggleMobileMenu()" class="font-display text-xl tracking-wide text-gray-400">My Orders</a>
                <a href="/logout" onclick="toggleMobileMenu()" class="font-display text-xl tracking-wide text-red-400">Logout</a>
            <% } else { %>
                <a href="/login" onclick="toggleMobileMenu()" class="font-display text-2xl tracking-wide text-gold-accent">Login</a>
            <% } %>
        </div>
    </div>

    <!-- Search Overlay -->
    <div id="search-overlay" class="fixed inset-0 z-[200] bg-obsidian/95 backdrop-blur-md flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <button onclick="toggleSearch()" class="absolute top-8 right-8 text-gold-light hover:text-gold-accent transition-colors text-2xl">
            <i class="fas fa-times"></i>
        </button>
        <form action="/product" method="GET" class="w-full max-w-xl px-6">
            <div class="relative border-b border-gold-light/30 focus-within:border-gold-accent transition-colors py-2">
                <input type="text" name="search" placeholder="Type to search phone cases..." class="w-full bg-transparent border-none text-gold-light placeholder-gray-600 focus:outline-none focus:ring-0 text-xl font-display tracking-wider">
                <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 text-gold-light hover:text-gold-accent transition-colors">
                    <i class="fas fa-arrow-right text-xl"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- Slide-In Cart Drawer Overlay & Drawer -->
    <div id="cartDrawerOverlay" onclick="closeCartDrawer()" class="cart-drawer-overlay"></div>
    <div id="cartDrawer" class="cart-drawer">
        <!-- Header -->
        <div class="p-6 border-b border-gold-light/10 flex justify-between items-center">
            <h3 class="font-display text-2xl uppercase tracking-wider text-gold-light">Your Collection</h3>
            <button onclick="closeCartDrawer()" class="text-gold-light hover:text-gold-accent transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        
        <!-- Cart Items Container -->
        <div id="cartDrawerItems" class="flex-1 overflow-y-auto p-6 space-y-6">
            <!-- Dynamically populated via AJAX -->
            <div class="flex flex-col items-center justify-center h-full text-center space-y-4">
                <span class="w-8 h-8 border-2 border-gold-light border-b-transparent rounded-full animate-spin"></span>
                <p class="text-xs text-gray-500">Loading your items...</p>
            </div>
        </div>

        <!-- Cart Footer -->
        <div id="cartDrawerFooter" class="p-6 border-t border-gold-light/10 space-y-4 bg-obsidian-light hidden">
            <!-- Free shipping progress bar -->
            <div id="shippingProgressContainer" class="space-y-1.5">
                <div class="flex justify-between text-[10px] uppercase tracking-wider text-gray-400">
                    <span id="shippingProgressText">Add ₹500 more for Free Shipping</span>
                    <span id="shippingProgressPercent" class="font-medium text-gold-light">₹0 / ₹1500</span>
                </div>
                <div class="w-full bg-obsidian-surface h-1 rounded-full overflow-hidden">
                    <div id="shippingProgressBar" class="bg-gold-accent h-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
            
            <!-- Upsell chip -->
            <div class="bg-obsidian-surface p-3 rounded flex items-center justify-between border border-gold-light/10 text-xs">
                <span class="text-gray-400">Complete your collection</span>
                <a href="/product" class="text-gold-light hover:text-gold-accent transition-colors font-medium flex items-center gap-1">
                    Shop Collection <i class="fas fa-arrow-right text-[10px]"></i>
                </a>
            </div>

            <!-- Price Breakdown -->
            <div class="space-y-2 text-xs">
                <div class="flex justify-between text-gray-400">
                    <span>Subtotal</span>
                    <span id="cartDrawerSubtotal" class="font-medium text-gold-light">₹0.00</span>
                </div>
                <div class="flex justify-between text-gray-400">
                    <span>Shipping</span>
                    <span id="cartDrawerShipping" class="font-medium text-gold-light">₹0.00</span>
                </div>
                <div class="flex justify-between text-sm font-bold border-t border-gold-light/10 pt-3 mt-1">
                    <span class="text-gold-light">Total</span>
                    <span id="cartDrawerTotal" class="text-gold-accent text-base">₹0.00</span>
                </div>
            </div>

            <!-- CTA -->
            <a href="/checkout" class="block w-full text-center bg-gold-light hover:bg-gold-accent text-obsidian py-3.5 rounded font-medium tracking-wider uppercase text-xs transition-colors duration-200">
                Proceed to Checkout
            </a>
        </div>
    </div>

    <!-- Navigation Scroll and Theme Toggle Scripts -->
    <script>
        // Scroll aware navigation filling
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('bg-obsidian-light/95', 'backdrop-blur-md', 'border-gold-light/10');
                navbar.classList.remove('py-6');
                navbar.classList.add('py-4');
            } else {
                navbar.classList.remove('bg-obsidian-light/95', 'backdrop-blur-md', 'border-gold-light/10');
                navbar.classList.add('py-6');
                navbar.classList.remove('py-4');
            }
        });

        // Theme Management
        const LIGHT_THEME_CSS = `
            body.light-theme { background-color: #F7F5F2 !important; color: #1a1a1a !important; }
            body.light-theme .bg-obsidian { background-color: #F7F5F2 !important; }
            body.light-theme .bg-obsidian-light { background-color: #FFFFFF !important; }
            body.light-theme .bg-obsidian-surface { background-color: #F0EDE9 !important; }
            body.light-theme .bg-obsidian-hover { background-color: #E6E2DC !important; }
            body.light-theme main { background-color: #F7F5F2 !important; }
            body.light-theme section { background-color: transparent !important; }
            body.light-theme #navbar { background-color: rgba(247,245,242,0.97) !important; border-bottom-color: rgba(140,117,68,0.2) !important; }
            body.light-theme #navbar a { color: #5a4a20 !important; }
            body.light-theme #navbar button { color: #5a4a20 !important; }
            body.light-theme .text-ivory { color: #1a1a1a !important; }
            body.light-theme .text-gold-light { color: #7a5c28 !important; }
            body.light-theme .text-gold-accent { color: #9a7030 !important; }
            body.light-theme .text-gray-400 { color: #5a5a5a !important; }
            body.light-theme .text-gray-500 { color: #6a6a6a !important; }
            body.light-theme .text-gray-600 { color: #4a4a4a !important; }
            body.light-theme .border-gold-light\\/5 { border-color: rgba(140,117,68,0.12) !important; }
            body.light-theme .border-gold-light\\/10 { border-color: rgba(140,117,68,0.2) !important; }
            body.light-theme .border-gold-light\\/20 { border-color: rgba(140,117,68,0.25) !important; }
            body.light-theme input:not([type="radio"]):not([type="checkbox"]) { background-color: #FFFFFF !important; border-color: rgba(140,117,68,0.3) !important; color: #1a1a1a !important; }
            body.light-theme textarea { background-color: #FFFFFF !important; border-color: rgba(140,117,68,0.3) !important; color: #1a1a1a !important; }
            body.light-theme select { background-color: #FFFFFF !important; border-color: rgba(140,117,68,0.3) !important; color: #1a1a1a !important; }
            body.light-theme .cart-drawer { background-color: #F7F5F2 !important; border-left-color: rgba(140,117,68,0.2) !important; }
            body.light-theme .swal2-popup { background: #FFFFFF !important; }
            body.light-theme .swal2-title { color: #1a1a1a !important; }
            body.light-theme .swal2-html-container { color: #4a4a4a !important; }
            body.light-theme * { transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease !important; }
        `;

        function applyLightThemeOverride(isLight) {
            let styleEl = document.getElementById('light-theme-overrides');
            if (isLight) {
                if (!styleEl) {
                    styleEl = document.createElement('style');
                    styleEl.id = 'light-theme-overrides';
                    document.head.appendChild(styleEl);
                }
                styleEl.textContent = LIGHT_THEME_CSS;
            } else {
                if (styleEl) styleEl.remove();
            }
        }

        function initTheme() {
            const currentTheme = localStorage.getItem('cc-theme') || 'dark';
            if (currentTheme === 'light') {
                document.body.classList.add('light-theme');
                document.documentElement.classList.remove('dark');
                document.getElementById('theme-icon').className = 'fas fa-moon';
                applyLightThemeOverride(true);
            } else {
                document.body.classList.remove('light-theme');
                document.documentElement.classList.add('dark');
                document.getElementById('theme-icon').className = 'fas fa-sun';
                applyLightThemeOverride(false);
            }
        }
        document.addEventListener('DOMContentLoaded', initTheme);

        function toggleTheme() {
            const body = document.body;
            const themeIcon = document.getElementById('theme-icon');
            const isLight = body.classList.toggle('light-theme');
            
            if (isLight) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('cc-theme', 'light');
                themeIcon.className = 'fas fa-moon';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('cc-theme', 'dark');
                themeIcon.className = 'fas fa-sun';
            }
            applyLightThemeOverride(isLight);
        }


        // Mobile Menu Toggle
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            if (menu.classList.contains('hidden')) {
                menu.classList.remove('hidden');
                menu.classList.add('flex');
                document.body.style.overflow = 'hidden';
            } else {
                menu.classList.add('hidden');
                menu.classList.remove('flex');
                document.body.style.overflow = '';
            }
        }

        // Search Toggle
        function toggleSearch() {
            const search = document.getElementById('search-overlay');
            if (search.classList.contains('hidden')) {
                search.classList.remove('hidden');
                setTimeout(() => {
                    search.classList.remove('opacity-0');
                }, 50);
                search.querySelector('input').focus();
            } else {
                search.classList.add('opacity-0');
                setTimeout(() => {
                    search.classList.add('hidden');
                }, 300);
            }
        }

        // Cart Drawer Operations
        function openCartDrawer() {
            document.getElementById('cartDrawerOverlay').classList.add('active');
            document.getElementById('cartDrawer').classList.add('active');
            document.body.style.overflow = 'hidden';
            loadCartDrawerItems();
        }

        function closeCartDrawer() {
            document.getElementById('cartDrawerOverlay').classList.remove('active');
            document.getElementById('cartDrawer').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Load Cart items via AJAX
        async function loadCartDrawerItems() {
            const container = document.getElementById('cartDrawerItems');
            const footer = document.getElementById('cartDrawerFooter');
            
            try {
                const response = await fetch('/cart?json=true');
                const data = await response.json();
                
                if (!response.ok || !data.success) {
                    throw new Error("Failed to load cart");
                }

                // Update counts
                updateCartCountBadges(data.totalDocs);
                
                if (data.products.length === 0) {
                    container.innerHTML = `
                        <div class="flex flex-col items-center justify-center h-full text-center space-y-4">
                            <i class="fas fa-shopping-bag text-gray-600 text-3xl"></i>
                            <p class="font-display text-lg text-gold-light">Your cart is empty.</p>
                            <a href="/product" onclick="closeCartDrawer()" class="text-xs uppercase tracking-widest text-gold-accent hover:underline">Browse Products</a>
                        </div>
                    `;
                    footer.classList.add('hidden');
                    return;
                }

                // Render products
                let html = '';
                data.products.forEach(item => {
                    const mainImg = (item.productId.productImages && item.productId.productImages.find(i => i.isMain)?.url) || 
                                    (item.variantId?.images && item.variantId.images.find(i => i.isMain)?.url) || 
                                    item.variantId?.images?.[0]?.url || 
                                    '/img/placeholder.jpg';
                    const hasOffer = item.appliedOffer;
                    const stock = item.variantId.stock;
                    
                    html += `
                        <div class="flex items-start space-x-4 border-b border-gold-light/5 pb-4 last:border-0 last:pb-0">
                            <!-- Image -->
                            <div class="w-16 h-16 bg-obsidian-surface rounded overflow-hidden flex-shrink-0 border border-gold-light/10">
                                <img src="${mainImg}" alt="${item.productId.name}" class="w-full h-full object-contain">
                            </div>
                            <!-- Details -->
                            <div class="flex-1 min-w-0">
                                <h4 class="text-xs font-medium text-gold-light truncate">${item.productId.name}</h4>
                                <p class="text-[10px] text-gray-500 mt-0.5">${item.variantId.deviceModel}</p>
                                
                                <!-- Quantity controls -->
                                <div class="flex items-center space-x-3 mt-2">
                                    <button onclick="updateDrawerQuantity('${item._id}', -1)" class="w-5 h-5 bg-obsidian-surface border border-gold-light/10 text-gold-light flex items-center justify-center hover:bg-gold-light hover:text-obsidian rounded transition-colors text-[10px]">-</button>
                                    <span class="text-xs text-gold-light font-medium">${item.quantity}</span>
                                    <button onclick="updateDrawerQuantity('${item._id}', 1)" class="w-5 h-5 bg-obsidian-surface border border-gold-light/10 text-gold-light flex items-center justify-center hover:bg-gold-light hover:text-obsidian rounded transition-colors text-[10px]">+</button>
                                </div>
                            </div>
                            <!-- Price & Remove -->
                            <div class="text-right">
                                <div class="text-xs font-semibold text-gold-light">₹${Math.floor(item.finalPrice ?? (item.variantId.salePrice * item.quantity))}</div>
                                ${(item.variantId?.orgPrice > (item.variantId?.salePrice)) ? `<div class="text-[10px] text-gray-500 line-through">₹${Math.floor(item.variantId.orgPrice * item.quantity)}</div>` : ''}
                                <button onclick="removeDrawerItem('${item._id}')" class="text-[10px] text-red-400 hover:text-red-300 mt-2 block ml-auto">
                                    <i class="far fa-trash-alt"></i>
                                </button>
                            </div>
                        </div>
                    `;
                });
                
                container.innerHTML = html;
                footer.classList.remove('hidden');

                // Update totals
                document.getElementById('cartDrawerSubtotal').textContent = `₹${data.subtotal}`;
                document.getElementById('cartDrawerShipping').textContent = data.shipping === 0 ? 'Free' : `₹${data.shipping}`;
                document.getElementById('cartDrawerTotal').textContent = `₹${data.finalAmount}`;

                // Update shipping progress
                const progressText = document.getElementById('shippingProgressText');
                const progressPercent = document.getElementById('shippingProgressPercent');
                const progressBar = document.getElementById('shippingProgressBar');
                
                const freeShippingThreshold = 1500;
                if (data.finalAmount >= freeShippingThreshold || data.shipping === 0) {
                    progressText.textContent = "Congrats! You qualify for Free Shipping";
                    progressPercent.textContent = `₹${data.finalAmount} / ₹${freeShippingThreshold}`;
                    progressBar.style.width = '100%';
                } else {
                    const needed = freeShippingThreshold - data.finalAmount;
                    progressText.textContent = `Add ₹${Math.floor(needed)} more for Free Shipping`;
                    progressPercent.textContent = `₹${data.finalAmount} / ₹${freeShippingThreshold}`;
                    const pct = Math.min((data.finalAmount / freeShippingThreshold) * 100, 100);
                    progressBar.style.width = `${pct}%`;
                }

            } catch (err) {
                console.error(err);
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-center space-y-2 p-6">
                        <i class="fas fa-exclamation-circle text-red-500 text-2xl"></i>
                        <p class="text-xs text-gray-500">Could not retrieve your cart. Please ensure you are logged in.</p>
                        <a href="/login" class="text-xs font-semibold text-gold-accent uppercase tracking-wider underline">Login</a>
                    </div>
                `;
            }
        }

        // Helper to update badges
        function updateCartCountBadges(count) {
            const badge = document.getElementById('cart-count-badge');
            if (badge) {
                badge.textContent = count;
                if (count > 0) {
                    badge.classList.remove('hidden');
                } else {
                    badge.classList.add('hidden');
                }
            }
        }

        // AJAX update drawer quantity
        async function updateDrawerQuantity(cartId, change) {
            try {
                const response = await fetch(`/cart/quantity/${cartId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ change })
                });
                const data = await response.json();
                if (data.success) {
                    loadCartDrawerItems();
                    if (window.location.pathname === '/cart') {
                        // Refresh cart page if we are on standalone cart page too!
                        window.location.reload();
                    }
                } else {
                    showToast(data.message || "Failed to update quantity", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Network error updating quantity", "error");
            }
        }

        // AJAX remove item
        async function removeDrawerItem(cartId) {
            try {
                const response = await fetch(`/product/cart/${cartId}`, {
                    method: 'PATCH'
                });
                const data = await response.json();
                if (data.success) {
                    showToast("Item removed from cart", "success");
                    loadCartDrawerItems();
                    if (window.location.pathname === '/cart') {
                        // Refresh cart page if we are on standalone cart page
                        window.location.reload();
                    }
                } else {
                    showToast(data.message || "Failed to remove item", "error");
                }
            } catch (err) {
                console.error(err);
                showToast("Network error removing item", "error");
            }
        }

        // Utility Toast function
        function showToast(message, type = "success") {
            Toastify({
                text: message,
                duration: 3000,
                gravity: "bottom",
                position: "right",
                backgroundColor: type === "success" ? "#C9A84C" : "#EF4444",
                textColor: type === "success" ? "#0A0A0A" : "#FFFFFF"
            }).showToast();
        }
    </script>

    <!-- Overlay loading animation triggers -->
    <script>
        function showLoading() {
            const overlay = document.getElementById('global-loading-overlay');
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
        }

        function hideLoading() {
            const overlay = document.getElementById('global-loading-overlay');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
        }
    </script>
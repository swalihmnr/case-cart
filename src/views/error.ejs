<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Page Not Found | Case Cart</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @keyframes float-1 { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-20px) rotate(5deg); } }
    @keyframes float-2 { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-30px) rotate(-5deg); } }
    @keyframes float-3 { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-15px) rotate(3deg); } }
    @keyframes bounce-slow { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @keyframes gradient-shift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
    @keyframes crack { 0% { stroke-dasharray: 0 200; } 100% { stroke-dasharray: 200 0; } }
    @keyframes fade-in { 0% { opacity: 0; transform: translateY(20px); } 100% { opacity: 1; transform: translateY(0); } }
    @keyframes head-scratch { 0%, 100% { transform: rotate(0deg); } 25% { transform: rotate(-5deg); } 75% { transform: rotate(5deg); } }
    @keyframes arm-wave { 0%, 100% { transform: rotate(0deg); } 50% { transform: rotate(-15deg); } }
    @keyframes blink { 0%, 90%, 100% { transform: scaleY(1); } 95% { transform: scaleY(0.1); } }
    @keyframes question-float { 0%, 100% { transform: translateY(0) scale(1); opacity: 1; } 50% { transform: translateY(-10px) scale(1.1); opacity: 0.8; } }
    
    .animate-float-1 { animation: float-1 6s ease-in-out infinite; }
    .animate-float-2 { animation: float-2 8s ease-in-out infinite; }
    .animate-float-3 { animation: float-3 7s ease-in-out infinite; }
    .animate-bounce-slow { animation: bounce-slow 3s ease-in-out infinite; }
    .animate-gradient { background-size: 200% 200%; animation: gradient-shift 3s ease infinite; }
    .animate-crack { animation: crack 2s ease-out forwards; }
    .animate-crack-delay { animation: crack 2s ease-out 0.5s forwards; stroke-dasharray: 0 200; }
    .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
    .animate-fade-in-delay { animation: fade-in 0.8s ease-out 0.3s forwards; opacity: 0; }
    .animate-fade-in-delay-2 { animation: fade-in 0.8s ease-out 0.6s forwards; opacity: 0; }
    .animate-head-scratch { animation: head-scratch 2s ease-in-out infinite; transform-origin: bottom center; }
    .animate-arm-wave { animation: arm-wave 1.5s ease-in-out infinite; transform-origin: top right; }
    .animate-blink { animation: blink 4s ease-in-out infinite; transform-origin: center; }
    .animate-question-float { animation: question-float 2s ease-in-out infinite; }
    .animate-question-float-delay { animation: question-float 2s ease-in-out 0.5s infinite; }
  </style>
</head>
<body class="m-0 p-0">
  <div class="min-h-screen bg-gradient-to-br from-purple-900 via-purple-800 to-indigo-900 flex items-center justify-center p-4 overflow-hidden relative">
    
    <!-- Floating Cases Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[10%] left-[10%] w-16 h-28 bg-gradient-to-br from-pink-400 to-pink-600 rounded-2xl opacity-20 animate-float-1"></div>
      <div class="absolute top-[20%] right-[15%] w-14 h-24 bg-gradient-to-br from-blue-400 to-cyan-500 rounded-2xl opacity-20 animate-float-2"></div>
      <div class="absolute bottom-[30%] left-[20%] w-12 h-20 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-xl opacity-20 animate-float-3"></div>
      <div class="absolute bottom-[20%] right-[10%] w-16 h-28 bg-gradient-to-br from-green-400 to-emerald-500 rounded-2xl opacity-20 animate-float-1"></div>
      <div class="absolute top-[50%] left-[5%] w-10 h-16 bg-gradient-to-br from-purple-400 to-violet-500 rounded-xl opacity-15 animate-float-2"></div>
      <div class="absolute top-[40%] right-[5%] w-12 h-20 bg-gradient-to-br from-red-400 to-rose-500 rounded-xl opacity-15 animate-float-3"></div>
    </div>

    <!-- Main Content -->
    <div class="text-center z-10 max-w-2xl mx-auto">
      
      <!-- Person with Phone Illustration -->
      <div class="relative mx-auto w-64 h-72 sm:w-80 sm:h-80 mb-6">
        <svg viewBox="0 0 300 280" class="w-full h-full">
          <!-- Person Body -->
          <g class="animate-bounce-slow" style="animation-duration: 4s;">
            <!-- Shadow -->
            <ellipse cx="150" cy="270" rx="50" ry="8" fill="rgba(0,0,0,0.2)"/>
            
            <!-- Legs -->
            <rect x="125" y="200" width="20" height="60" rx="10" fill="#4B5563"/>
            <rect x="155" y="200" width="20" height="60" rx="10" fill="#374151"/>
            
            <!-- Shoes -->
            <ellipse cx="135" cy="260" rx="15" ry="8" fill="#1F2937"/>
            <ellipse cx="165" cy="260" rx="15" ry="8" fill="#1F2937"/>
            
            <!-- Body/Torso -->
            <path d="M110 120 Q100 150 105 200 L195 200 Q200 150 190 120 Z" fill="#8B5CF6"/>
            
            <!-- Arms -->
            <!-- Left arm scratching head -->
            <g class="animate-arm-wave">
              <path d="M105 130 Q70 140 65 100 Q60 80 80 70" stroke="#FBBF24" stroke-width="16" stroke-linecap="round" fill="none"/>
              <!-- Hand -->
              <circle cx="80" cy="70" r="10" fill="#FBBF24"/>
            </g>
            
            <!-- Right arm holding phone -->
            <path d="M195 130 Q220 150 210 180" stroke="#FBBF24" stroke-width="16" stroke-linecap="round" fill="none"/>
            <circle cx="210" cy="180" r="10" fill="#FBBF24"/>
            
            <!-- Phone in hand -->
            <g transform="translate(200, 160) rotate(15)">
              <rect x="0" y="0" width="30" height="50" rx="5" fill="#1F2937" stroke="#374151" stroke-width="2"/>
              <rect x="3" y="5" width="24" height="40" rx="3" fill="#374151"/>
              <!-- 404 on screen -->
              <text x="15" y="30" text-anchor="middle" fill="#EF4444" font-size="10" font-weight="bold">404</text>
            </g>
            
            <!-- Neck -->
            <rect x="140" y="95" width="20" height="25" fill="#FBBF24"/>
            
            <!-- Head -->
            <g class="animate-head-scratch">
              <!-- Face -->
              <ellipse cx="150" cy="70" rx="40" ry="45" fill="#FBBF24"/>
              
              <!-- Hair -->
              <path d="M110 55 Q110 20 150 15 Q190 20 190 55 Q185 40 150 35 Q115 40 110 55" fill="#4B5563"/>
              
              <!-- Eyes -->
              <g class="animate-blink">
                <ellipse cx="135" cy="65" rx="8" ry="10" fill="white"/>
                <ellipse cx="165" cy="65" rx="8" ry="10" fill="white"/>
                <circle cx="137" cy="67" r="4" fill="#1F2937"/>
                <circle cx="167" cy="67" r="4" fill="#1F2937"/>
                <!-- Eye shine -->
                <circle cx="139" cy="65" r="1.5" fill="white"/>
                <circle cx="169" cy="65" r="1.5" fill="white"/>
              </g>
              
              <!-- Eyebrows (confused) -->
              <path d="M125 52 Q135 48 145 55" stroke="#4B5563" stroke-width="3" stroke-linecap="round" fill="none"/>
              <path d="M155 55 Q165 48 175 52" stroke="#4B5563" stroke-width="3" stroke-linecap="round" fill="none"/>
              
              <!-- Mouth (confused) -->
              <path d="M140 90 Q150 85 160 90" stroke="#B45309" stroke-width="3" stroke-linecap="round" fill="none"/>
            </g>
          </g>
          
          <!-- Floating Question Marks -->
          <text x="85" y="40" font-size="24" class="animate-question-float" fill="#F472B6">?</text>
          <text x="200" y="30" font-size="20" class="animate-question-float-delay" fill="#A78BFA">?</text>
          <text x="70" y="70" font-size="16" class="animate-question-float" style="animation-delay: 0.3s;" fill="#22D3EE">?</text>
        </svg>
      </div>

      <!-- Error Text -->
      <h1 class="text-6xl sm:text-7xl md:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 mb-4 animate-gradient">404</h1>
      <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-white mb-4 animate-fade-in">Oops! Case Not Found</h2>
      <p class="text-purple-200 text-base sm:text-lg mb-8 animate-fade-in-delay px-4">
        Looks like this page slipped out of its case!<br class="hidden sm:block">
        Don't worry, let's get you back to our collection.
      </p>
      
      <!-- CTA Button -->
      <a href="/" class="group relative inline-flex items-center gap-3 px-6 sm:px-8 py-3 sm:py-4 bg-gradient-to-r from-pink-500 to-purple-600 text-white font-bold text-base sm:text-lg rounded-full shadow-lg hover:shadow-pink-500/30 hover:scale-105 transition-all duration-300 overflow-hidden">
        <span class="relative z-10 flex items-center gap-2">
          <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Shop
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-pink-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </a>
      
      <p class="mt-6 text-purple-300/70 text-sm animate-fade-in-delay-2">Or try searching for your perfect case</p>
    </div>

    <!-- Bottom Wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" class="w-full h-auto">
        <path fill="rgba(255,255,255,0.05)" d="M0,64L48,69.3C96,75,192,85,288,80C384,75,480,53,576,48C672,43,768,53,864,64C960,75,1056,85,1152,80C1248,75,1344,53,1392,42.7L1440,32L1440,120L1392,120C1344,120,1248,120,1152,120C1056,120,960,120,864,120C768,120,672,120,576,120C480,120,384,120,288,120C192,120,96,120,48,120L0,120Z"></path>
      </svg>
    </div>
  </div>
</body>
</html>

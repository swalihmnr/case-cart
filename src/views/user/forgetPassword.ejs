<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - CaseCart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        obsidian: {
                            DEFAULT: '#0A0A0A',
                            light: '#161616',
                            muted: '#262626'
                        },
                        gold: {
                            light: '#E8D5B0',
                            accent: '#C9A84C'
                        },
                        ivory: {
                            DEFAULT: '#F7F5F2',
                            muted: '#E5E3E0'
                        }
                    },
                    fontFamily: {
                        display: ['"Cormorant Garamond"', 'serif'],
                        sans: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300&family=Inter:wght@300;400;500;600&display=swap');
        
        .font-display {
            font-family: 'Cormorant Garamond', serif;
        }
        
        body {
            font-family: 'Inter', sans-serif;
        }

        .input-focus:focus {
            border-color: #C9A84C !important;
            box-shadow: 0 0 0 1px rgba(201, 168, 76, 0.2);
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-fade-in {
            animation: fadeIn 0.5s ease-out forwards;
        }
    </style>
</head>
<body class="bg-obsidian min-h-screen text-ivory font-sans flex flex-col justify-between">
    <!-- Navigation Bar -->
    <nav class="border-b border-gold-light/10 bg-obsidian/90 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 sm:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center space-x-3 cursor-pointer" onclick="window.location.href='/'">
                    <img src="/img/Pasted image.png" alt="CaseCart Logo" class="h-8 w-auto object-contain rounded-md">
                    <span class="font-display text-2xl tracking-widest text-gold-light font-light uppercase">Case Cart</span>
                </div>
            </div>
        </div>
    </nav>

    <div id="forgot-password" class="page active flex-grow flex items-center justify-center py-12 px-6 sm:px-8">
        <div class="max-w-md w-full animate-fade-in">
            <div class="bg-obsidian-light border border-gold-light/5 rounded p-8 sm:p-10 shadow-2xl relative">
                <div class="text-center mb-8">
                    <div class="w-12 h-12 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-key text-gold-accent text-lg"></i>
                    </div>
                    <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium mb-1">Account recovery</p>
                    <h2 class="font-display text-3xl sm:text-4xl font-light tracking-wide text-gold-light">Forgot Password?</h2>
                    <p class="text-gray-400 text-[10px] uppercase tracking-wider mt-2">Enter your email for instructions</p>
                </div>

                <form class="space-y-6" novalidate>
                    <div>
                        <label for="email" class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">Email Address</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gold-light/40 text-xs"></i>
                            </div>
                            <input type="email" id="email" required 
                                class="input-focus block w-full pl-10 pr-3 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none transition text-ivory placeholder-gray-600 text-sm" 
                                placeholder="you@example.com">
                        </div>
                        <p id="emailErr" class="text-red-500 text-xs mt-1"></p>
                    </div>

                    <button type="submit" 
                        class="w-full bg-gold-light text-obsidian py-3 rounded text-xs uppercase tracking-widest font-semibold hover:bg-gold-accent transition duration-300">
                        Submit
                    </button>
                    
                    <button type="button" onclick="window.location.href='/login'"
                        class="w-full flex items-center justify-center gap-2 bg-obsidian border border-gold-light/10 text-gold-light py-3 rounded text-xs uppercase tracking-widest font-semibold hover:border-gold-accent hover:bg-gold-light/5 transition">
                        <i class="fas fa-arrow-left text-xs"></i>
                        Back to Login
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer Space -->
    <div class="h-10"></div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="/js/user/forgotPassword.js"></script>
</body>
</html>
<%- include('../partials/user/header') %>

<main class="bg-obsidian min-h-screen text-ivory pt-24 pb-16">
    <!-- Hero Section -->
    <section class="relative min-h-[75vh] flex items-center justify-center overflow-hidden py-16 px-6 border-b border-gold-light/5">
        <!-- Background Vignette/Glow -->
        <div class="absolute inset-0 bg-radial-gradient from-gold-light/5 via-transparent to-transparent opacity-80 pointer-events-none"></div>
        
        <div class="max-w-6xl mx-auto text-center relative z-10 space-y-8">
            <div class="space-y-4">
                <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">Autumn / Winter Collection 2026</p>
                <h1 class="font-display text-5xl sm:text-7xl lg:text-8xl font-light tracking-wide leading-none text-gold-light">
                    SARTORIAL<br>PROTECTION
                </h1>
            </div>
            
            <p class="text-xs sm:text-sm tracking-wide text-gray-400 max-w-md mx-auto leading-relaxed font-light">
                Discover bespoke protective cases crafted from Italian leather and premium alloys. Engineered to protect. Designed to be seen.
            </p>
            
            <div class="pt-4">
                <a href="/product" class="inline-block bg-gold-light hover:bg-gold-accent text-obsidian text-[11px] uppercase tracking-widest font-medium px-10 py-4 transition-all duration-300 rounded-sm">
                    Explore Collection
                </a>
            </div>
        </div>
    </section>

    <!-- Editorial Values Section -->
    <section class="max-w-6xl mx-auto px-6 sm:px-8 py-20 border-b border-gold-light/5">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 text-center">
            <div class="space-y-3">
                <div class="text-gold-light text-lg"><i class="fas fa-gem"></i></div>
                <h3 class="font-display text-lg tracking-wider text-gold-light">Italian Leather</h3>
                <p class="text-xs text-gray-500 max-w-xs mx-auto leading-relaxed">Sourced from the historic tanneries of Tuscany, developing a rich patina over time.</p>
            </div>
            <div class="space-y-3">
                <div class="text-gold-light text-lg"><i class="fas fa-shield-alt"></i></div>
                <h3 class="font-display text-lg tracking-wider text-gold-light">Architectural Strength</h3>
                <p class="text-xs text-gray-500 max-w-xs mx-auto leading-relaxed">Integrated shock-absorbent cores certified for military grade drop standards.</p>
            </div>
            <div class="space-y-3">
                <div class="text-gold-light text-lg"><i class="fas fa-magic"></i></div>
                <h3 class="font-display text-lg tracking-wider text-gold-light">MagSafe Compatible</h3>
                <p class="text-xs text-gray-500 max-w-xs mx-auto leading-relaxed">Perfectly aligned magnets engineered for optimal 15W wireless charging speed.</p>
            </div>
        </div>
    </section>

    <!-- Featured Products Grid -->
    <section class="max-w-6xl mx-auto px-6 sm:px-8 py-24">
        <div class="flex flex-col md:flex-row justify-between items-baseline mb-16 gap-4">
            <div class="space-y-2">
                <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">Curated Essentials</p>
                <h2 class="font-display text-3xl sm:text-4xl font-light tracking-wide text-gold-light">Featured Artifacts</h2>
            </div>
            <a href="/product" class="text-[10px] uppercase tracking-widest text-gold-light hover:text-gold-accent transition-colors font-medium border-b border-gold-light/20 pb-1">
                View All Artifacts
            </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-16">
            <% products.forEach((product, index) => { %>
                <% const isInWishlist = wishlistItems && wishlistItems.some(item => 
                    item.variantId && item.variantId.toString() === product.minVariant._id.toString()
                ); %>
                <!-- Product Card -->
                <div class="group relative flex flex-col space-y-4">
                    <!-- Wishlist Button -->
                    <% if (user) { %>
                        <button onclick="addHomeWishlist('<%= product._id %>', '<%= product.minVariant._id %>')" 
                                class="absolute top-4 right-4 z-20 text-gold-light hover:text-gold-accent transition-all duration-300 p-2 bg-obsidian/40 backdrop-blur-md rounded-full">
                            <i id="wish-icon-<%= product._id %>-<%= product.minVariant._id %>" 
                               class="fa-heart <%= isInWishlist ? 'fas text-red-500' : 'far text-gold-light' %> text-sm"></i>
                        </button>
                    <% } %>

                    <!-- Image (65% Height Area) -->
                    <div class="relative aspect-[3/4] bg-obsidian-light border border-gold-light/5 group-hover:border-gold-light/20 overflow-hidden flex items-center justify-center transition-colors duration-300">
                        <a href="/product/<%= product._id %>/detials" class="block w-full h-full">
                            <% 
                              let mainImageUrl = '/img/placeholder.jpg';
                              if (product.productImages && product.productImages.length > 0) {
                                  const mainImg = product.productImages.find(img => img.isMain);
                                  if (mainImg) mainImageUrl = mainImg.url;
                                  else if (product.productImages[0]) mainImageUrl = product.productImages[0].url;
                              } else if (product.minVariant && product.minVariant.images && product.minVariant.images.length > 0) {
                                  const mainImg = product.minVariant.images.find(img => img.isMain);
                                  if (mainImg) mainImageUrl = mainImg.url;
                                  else if (product.minVariant.images[0]) mainImageUrl = product.minVariant.images[0].url;
                              } else if (product.variants && product.variants[0] && product.variants[0].images && product.variants[0].images.length > 0) {
                                  const mainImg = product.variants[0].images.find(img => img.isMain);
                                  if (mainImg) mainImageUrl = mainImg.url;
                                  else if (product.variants[0].images[0]) mainImageUrl = product.variants[0].images[0].url;
                              }
                            %>
                            <img src="<%= mainImageUrl %>" 
                                 alt="<%= product.name %>" 
                                 class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out">
                        </a>
                        
                        <!-- Quick Add Hover Overlay (Desktop) -->
                        <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-obsidian via-obsidian/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:block">
                            <button onclick="addHomeToCart('<%= product._id %>', '<%= product.minVariant._id %>')"
                                    class="w-full bg-gold-light hover:bg-gold-accent text-obsidian py-2.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-colors duration-200">
                                Quick Add
                            </button>
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="space-y-1">
                        <p class="text-[9px] uppercase tracking-widest text-gold-accent font-medium">
                            <%= product.catgId ? product.catgId.name : 'Premium Case' %>
                        </p>
                        <h3 class="font-display text-base tracking-wide text-gold-light font-light truncate">
                            <a href="/product/<%= product._id %>/detials" class="hover:text-gold-accent transition-colors">
                                <%= product.name %>
                            </a>
                        </h3>
                        <div class="flex items-center space-x-2 pt-0.5">
                            <span class="text-xs text-gold-light font-medium">₹<%= Math.floor(product.minVariant.salePrice || product.minVariant.orgPrice) %></span>
                            <% if (product.minVariant.salePrice && product.minVariant.salePrice < product.minVariant.orgPrice) { %>
                                <span class="text-[10px] text-gray-500 line-through">₹<%= Math.floor(product.minVariant.orgPrice) %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
</main>

<script>
    // AJAX Add Wishlist with Toastify
    async function addHomeWishlist(productId, variantId) {
        try {
            const response = await fetch('/product/wishlist/toggle', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId })
            });
            const data = await response.json();
            
            if (data.success) {
                const heart = document.getElementById(`wish-icon-${productId}-${variantId}`);
                if (data.action === "added") {
                    heart.className = "fas fa-heart text-red-500 text-sm";
                    showToast("Added to Wishlist", "success");
                } else {
                    heart.className = "far fa-heart text-gold-light text-sm";
                    showToast("Removed from Wishlist", "success");
                }
                
                // Update badge if exists
                const badge = document.getElementById('wishlist-count-badge');
                if (badge && data.wishlistCount !== undefined) {
                    badge.textContent = data.wishlistCount;
                    if (data.wishlistCount > 0) badge.classList.remove('hidden');
                    else badge.classList.add('hidden');
                }
            } else {
                showToast(data.message || "Failed to update wishlist", "error");
            }
        } catch (err) {
            console.error(err);
            showToast("Network error updating wishlist", "error");
        }
    }

    // AJAX Add to Cart with Toastify
    async function addHomeToCart(productId, variantId) {
        try {
            const response = await fetch('/cart/add', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId })
            });
            
            // Check if redirect required (e.g. login)
            if (response.status === 401) {
                const data = await response.json();
                showToast(data.message || "Please login first", "error");
                setTimeout(() => window.location.href = data.redirectUrl || '/login', 1500);
                return;
            }

            const data = await response.json();
            if (data.success) {
                showToast("Added to Cart Collection", "success");
                updateCartCountBadges(data.cartCount);
                
                // Automatically open sliding drawer to show feedback!
                openCartDrawer();
            } else {
                showToast(data.message || "Failed to add to cart", "error");
            }
        } catch (err) {
            console.error(err);
            showToast("Network error adding to cart", "error");
        }
    }
</script>

<%- include('../partials/user/footer') %>
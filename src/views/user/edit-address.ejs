<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your account settings and preferences</p>
        </div>
        
        <div class="grid lg:grid-cols-4 gap-8">
            <%- include('../partials/user/sidebar') %>
            
            <div class="lg:col-span-3">
                <div class="bg-obsidian-light border border-gold-light/5 rounded p-6 md:p-8 shadow-2xl">
                    <h3 class="font-display text-2xl font-light text-gold-light tracking-wide mb-6">Edit Address</h3>
                    
                    <div id="addressForm">
                        <form class="space-y-6" id="addressForm">
                            <!-- First Name & Last Name -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- First Name -->
                                <div>
                                    <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                        First Name *
                                    </label>
                                    <input
                                        value="<%= address.firstName %>"
                                        type="text"
                                        id="first-name"
                                        class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                        placeholder="Enter first name"
                                    >
                                    <p class="text-xs text-red-500 mt-1" id="firstNameError"></p>
                                </div>

                                <!-- Last Name -->
                                <div>
                                    <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                        Last Name *
                                    </label>
                                    <input
                                        value="<%= address.lastName %>"
                                        type="text"
                                        id="last-name"
                                        class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                        placeholder="Enter last name"
                                    >
                                    <p class="text-xs text-red-500 mt-1" id="lastNameError"></p>
                                </div>
                            </div>

                            <!-- Phone Number -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    Phone Number *
                                </label>
                                <input
                                    value="<%= address.phone %>"
                                    type="tel"
                                    id="phone"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="Enter phone number"
                                >
                                <p class="text-xs text-red-500 mt-1" id="phoneError"></p>
                            </div>

                            <!-- Street Address -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    Street Address *
                                </label>
                                <input
                                    value="<%= address.streetAddress %>"
                                    type="text"
                                    id="line1"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="House No, Building Name"
                                >
                                <p class="text-xs text-red-500 mt-1" id="line1Error"></p>
                            </div>

                            <!-- Landmark -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    Landmark (Optional)
                                </label>
                                <input
                                    value="<%= address.landMark %>"
                                    type="text"
                                    id="landmark"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="Near school, hospital etc."
                                >
                            </div>

                            <!-- City / State / PIN -->
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                <!-- City -->
                                <div>
                                    <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                        City *
                                    </label>
                                    <input
                                        value="<%= address.city %>"
                                        type="text"
                                        id="city"
                                        class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                        placeholder="City"
                                    >
                                    <p class="text-xs text-red-500 mt-1" id="cityError"></p>
                                </div>

                                <!-- State -->
                                <div>
                                    <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                        State *
                                    </label>
                                    <select
                                        id="state"
                                        name="state"
                                        class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm appearance-none"
                                        required
                                    >
                                        <option value="" class="bg-obsidian">Select State</option>
                                        <option value="Andhra Pradesh" <%= address.state === 'Andhra Pradesh' ? 'selected' : '' %> class="bg-obsidian">Andhra Pradesh</option>
                                        <option value="Arunachal Pradesh" <%= address.state === 'Arunachal Pradesh' ? 'selected' : '' %> class="bg-obsidian">Arunachal Pradesh</option>
                                        <option value="Assam" <%= address.state === 'Assam' ? 'selected' : '' %> class="bg-obsidian">Assam</option>
                                        <option value="Bihar" <%= address.state === 'Bihar' ? 'selected' : '' %> class="bg-obsidian">Bihar</option>
                                        <option value="Chhattisgarh" <%= address.state === 'Chhattisgarh' ? 'selected' : '' %> class="bg-obsidian">Chhattisgarh</option>
                                        <option value="Goa" <%= address.state === 'Goa' ? 'selected' : '' %> class="bg-obsidian">Goa</option>
                                        <option value="Gujarat" <%= address.state === 'Gujarat' ? 'selected' : '' %> class="bg-obsidian">Gujarat</option>
                                        <option value="Haryana" <%= address.state === 'Haryana' ? 'selected' : '' %> class="bg-obsidian">Haryana</option>
                                        <option value="Himachal Pradesh" <%= address.state === 'Himachal Pradesh' ? 'selected' : '' %> class="bg-obsidian">Himachal Pradesh</option>
                                        <option value="Jharkhand" <%= address.state === 'Jharkhand' ? 'selected' : '' %> class="bg-obsidian">Jharkhand</option>
                                        <option value="Karnataka" <%= address.state === 'Karnataka' ? 'selected' : '' %> class="bg-obsidian">Karnataka</option>
                                        <option value="Kerala" <%= address.state === 'Kerala' ? 'selected' : '' %> class="bg-obsidian">Kerala</option>
                                        <option value="Madhya Pradesh" <%= address.state === 'Madhya Pradesh' ? 'selected' : '' %> class="bg-obsidian">Madhya Pradesh</option>
                                        <option value="Maharashtra" <%= address.state === 'Maharashtra' ? 'selected' : '' %> class="bg-obsidian">Maharashtra</option>
                                        <option value="Manipur" <%= address.state === 'Manipur' ? 'selected' : '' %> class="bg-obsidian">Manipur</option>
                                        <option value="Meghalaya" <%= address.state === 'Meghalaya' ? 'selected' : '' %> class="bg-obsidian">Meghalaya</option>
                                        <option value="Mizoram" <%= address.state === 'Mizoram' ? 'selected' : '' %> class="bg-obsidian">Mizoram</option>
                                        <option value="Nagaland" <%= address.state === 'Nagaland' ? 'selected' : '' %> class="bg-obsidian">Nagaland</option>
                                        <option value="Odisha" <%= address.state === 'Odisha' ? 'selected' : '' %> class="bg-obsidian">Odisha</option>
                                        <option value="Punjab" <%= address.state === 'Punjab' ? 'selected' : '' %> class="bg-obsidian">Punjab</option>
                                        <option value="Rajasthan" <%= address.state === 'Rajasthan' ? 'selected' : '' %> class="bg-obsidian">Rajasthan</option>
                                        <option value="Sikkim" <%= address.state === 'Sikkim' ? 'selected' : '' %> class="bg-obsidian">Sikkim</option>
                                        <option value="Tamil Nadu" <%= address.state === 'Tamil Nadu' ? 'selected' : '' %> class="bg-obsidian">Tamil Nadu</option>
                                        <option value="Telangana" <%= address.state === 'Telangana' ? 'selected' : '' %> class="bg-obsidian">Telangana</option>
                                        <option value="Tripura" <%= address.state === 'Tripura' ? 'selected' : '' %> class="bg-obsidian">Tripura</option>
                                        <option value="Uttar Pradesh" <%= address.state === 'Uttar Pradesh' ? 'selected' : '' %> class="bg-obsidian">Uttar Pradesh</option>
                                        <option value="Uttarakhand" <%= address.state === 'Uttarakhand' ? 'selected' : '' %> class="bg-obsidian">Uttarakhand</option>
                                        <option value="West Bengal" <%= address.state === 'West Bengal' ? 'selected' : '' %> class="bg-obsidian">West Bengal</option>
                                        <option value="Delhi" <%= address.state === 'Delhi' ? 'selected' : '' %> class="bg-obsidian">Delhi</option>
                                    </select>
                                    <p class="text-xs text-red-500 mt-1" id="stateError"></p>
                                </div>

                                <!-- PIN -->
                                <div>
                                    <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                        PIN Code *
                                    </label>
                                    <input
                                        value="<%= address.pinCode %>"
                                        type="text"
                                        id="pincode"
                                        class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                        placeholder="PIN Code"
                                    >
                                    <p class="text-xs text-red-500 mt-1" id="pincodeError"></p>
                                </div>
                            </div>

                            <!-- Address Type -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-3 font-medium">
                                    Address Type *
                                </label>
                                <div class="flex space-x-6">
                                    <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                        <input
                                            type="radio"
                                            name="addressType"
                                            value="Home"
                                            <%= address.addressType === 'Home' ? 'checked' : '' %>
                                            class="accent-gold-accent w-4 h-4 mr-2"
                                        >
                                        Home
                                    </label>
                                    <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                        <input
                                            type="radio"
                                            name="addressType"
                                            value="Work"
                                            <%= address.addressType === 'Work' ? 'checked' : '' %>
                                            class="accent-gold-accent w-4 h-4 mr-2"
                                        >
                                        Work
                                    </label>
                                    <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                        <input
                                            type="radio"
                                            name="addressType"
                                            value="Other"
                                            <%= address.addressType === 'Other' ? 'checked' : '' %>
                                            class="accent-gold-accent w-4 h-4 mr-2"
                                        >
                                        Other
                                    </label>
                                </div>
                                <p class="text-xs text-red-500 mt-1" id="addressTypeError"></p>
                            </div>

                            <!-- Default Address -->
                            <div class="flex items-center">
                                <input
                                    type="checkbox"
                                    id="isDefault"
                                    name="isDefault"
                                    <%= address.isDefault ? 'checked' : '' %>
                                    class="w-4 h-4 accent-gold-accent rounded"
                                >
                                <label class="ml-2 text-xs uppercase tracking-wider text-gray-400 cursor-pointer">
                                    Set as default address
                                </label>
                            </div>

                            <!-- Buttons -->
                            <div class="flex flex-col sm:flex-row gap-3 pt-4">
                                <button
                                    type="submit"
                                    class="bg-gold-light text-obsidian hover:bg-gold-accent px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold transition"
                                >
                                    Update Address
                                </button>
                                <button
                                    type="button"
                                    onclick="window.history.back()"
                                    class="px-6 py-3 border border-gold-light/10 text-gold-light hover:bg-gold-light/5 hover:border-gold-accent rounded text-xs uppercase tracking-widest font-semibold transition"
                                >
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/validationEditAddress.js"></script>
<%- include('../partials/user/footer') %>

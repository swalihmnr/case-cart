<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your settings and preferences</p>
        </div>
        
        <div class="grid lg:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>
            
            <!-- Main Content Area -->
            <div class="lg:col-span-3 space-y-6">
                <div>
                    <h3 class="font-display text-2xl font-light text-gold-light tracking-wide mb-6">My Wishlist</h3>

                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                        <% if (products && products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <div class="bg-obsidian-light border border-gold-light/5 rounded overflow-hidden shadow-2xl hover:border-gold-accent/30 transition duration-300 group">
                                    <div class="relative overflow-hidden aspect-[4/5] bg-obsidian">
                                        <%
                                          let wishlistImageUrl = '/img/placeholder.jpg';
                                          if (product.productId.productImages && product.productId.productImages.length > 0) {
                                              const mainImg = product.productId.productImages.find(img => img.isMain);
                                              if (mainImg) wishlistImageUrl = mainImg.url;
                                              else if (product.productId.productImages[0]) wishlistImageUrl = product.productId.productImages[0].url;
                                          } else if (product.variantId && product.variantId.images && product.variantId.images.length > 0) {
                                              const mainImg = product.variantId.images.find(img => img.isMain);
                                              if (mainImg) wishlistImageUrl = mainImg.url;
                                              else if (product.variantId.images[0]) wishlistImageUrl = product.variantId.images[0].url;
                                          }
                                        %>
                                        <img src="<%= wishlistImageUrl %>"
                                             alt="<%= product.productId.name %>"
                                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                        
                                        <button onclick="remWishlist('<%= product._id %>')"
                                            class="absolute top-4 right-4 bg-obsidian/70 backdrop-blur-md rounded-full p-2.5 shadow-md hover:bg-red-500/10 transition z-10 border border-gold-light/10">
                                            <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="p-5">
                                        <p class="text-[9px] text-gray-500 uppercase tracking-widest mb-1 truncate">
                                            <%= product.productId.catgId.name %>
                                        </p>
                                        <h4 class="font-display text-lg font-light text-gold-light mb-1 truncate">
                                            <%= product.productId.name %>
                                        </h4>
                                        <p class="text-xs text-gray-400 mb-3 truncate">
                                            Model: <%= product.variantId.deviceModel %>
                                        </p>
                                        
                                        <div class="flex items-baseline gap-2 mb-4">
                                            <p class="text-lg font-semibold text-gold-accent">₹<%= product.variantId.salePrice %></p>
                                            <% if (product.variantId.orgPrice > product.variantId.salePrice) { %>
                                                <span class="text-xs text-gray-550 line-through">₹<%= product.variantId.orgPrice %></span>
                                            <% } %>
                                        </div>
                                        
                                        <% if (product.variantId.stock > 0) { %>
                                            <button
                                                onclick="addToCart('<%= product.productId._id %>', '<%= product.variantId._id %>')"
                                                class="w-full bg-gold-light text-obsidian hover:bg-gold-accent py-3 rounded text-xs uppercase tracking-widest font-semibold transition duration-300">
                                                Add to Cart
                                            </button>
                                        <% } else { %>
                                            <button
                                                class="w-full bg-obsidian border border-gold-light/10 text-gray-500 py-3 rounded text-xs uppercase tracking-widest font-semibold cursor-not-allowed"
                                                disabled>
                                                Out of Stock
                                            </button>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-full py-16 text-center">
                                <div class="w-16 h-16 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center mx-auto mb-6">
                                    <i class="far fa-heart text-gold-accent text-xl"></i>
                                </div>
                                <h3 class="font-display text-2xl font-light text-gold-light mb-2">Your wishlist is empty</h3>
                                <p class="text-gray-400 text-xs uppercase tracking-widest mb-8 max-w-sm mx-auto leading-relaxed">
                                    Looks like you haven't added anything to your wishlist yet. Add items you love to keep track of them!
                                </p>
                                <a href="/product"
                                    class="inline-flex items-center gap-2 bg-gold-light text-obsidian hover:bg-gold-accent px-8 py-3 rounded text-xs uppercase tracking-widest font-semibold transition duration-300 shadow-md">
                                    Discover Products
                                    <i class="fas fa-arrow-right text-[10px]"></i>
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/cart.js"></script>
<script type="module" src="/js/user/wishlist.js"></script>

<%- include('../partials/user/footer') %>
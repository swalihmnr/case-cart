<%- include('../partials/user/header') %>


<div class="flex">
    
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
        <div class="mb-8 fade-in">
            <h1 class="text-3xl md:text-4xl font-bold mb-2">My Account</h1>
            <p class="text-gray-600">Manage your account settings and preferences</p>
        </div>
        <div class="grid lg:grid-cols-4 gap-8">
            <%- include('../partials/user/sidebar') %>
            <div class="lg:col-span-3 space-y-6">
                <div class="lg:col-span-3">
                <h3 class="text-2xl font-bold text-gray-900 mb-6">My Wishlist</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    <% products.forEach(product => { %>
                     
                        <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition">
                            <div class="relative">
                                <img src="<%= product.productId.productImages.find(img=>img.isMain).url %>" alt="Silicone Phone Case - Blue" class="w-full h-56 object-cover">
                                <button onclick="remWishlist('<%= product._id %>')"
                                     class="absolute top-3 right-3 bg-white rounded-full p-2 shadow-md hover:bg-red-50 transition">
                                    <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
                                    </svg>
                                </button>
                            </div>
                            <div class="p-4">
                                <h4 class="font-semibold text-gray-900 mb-2"><%= product.productId.name %></h4>
                                <div class="flex items-center mb-3">
                                    <div class="flex text-yellow-400">
                                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        <svg class="w-4 h-4 fill-current text-gray-300" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                    </div>
                                    <span class="ml-2 text-sm text-gray-600">4.2</span>
                                </div>
                                <p class="text-2xl font-bold text-purple-600 mb-3"><%= product.variantId.salePrice %></p>
                                <% if (product.variantId.stock>0) { %>
                                    <button class="w-full bg-purple-600 text-white py-2 rounded-lg hover:bg-purple-700 transition font-medium">
                                        Add to Cart
                                    </button>
                                    <% } else { %>
                                        <button class="w-full bg-purple-500 text-white py-2 rounded-lg hover:bg-purple-400 transition font-medium ">
                                        out of stock
                                    </button>
                                        <% } %>
                            </div>
                        </div>
                    <% }) %>
                    <!-- Product Card  -->
                    </div>
                </div>
            </div>
            </div>
        </div>

  </main>
  
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/wishlist.js"></script>
<%- include('../partials/user/footer') %>

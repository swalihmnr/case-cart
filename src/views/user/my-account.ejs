<%- include('../partials/user/header') %>


<div class="flex">
    
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
        <div class="mb-8 fade-in">
            <h1 class="text-3xl md:text-4xl font-bold mb-2">My Account</h1>
            <p class="text-gray-600">Manage your account settings and preferences</p>
        </div>
        <div class="grid lg:grid-cols-4 gap-8">
            <%- include('../partials/user/sidebar') %>
            <div class="lg:col-span-3 space-y-6">
                <section id="section-profile" class="account-section">
                    <div class="bg-white rounded-2xl shadow-md p-6 md:p-8 fade-in">
                        <h2 class="text-2xl font-bold mb-6">Profile Information</h2>
                        
                        <form class="space-y-6">
                            <!-- Profile Picture -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-3">Profile Picture</label>
                                <div class="flex items-center gap-6">
                                    <div class="w-24 h-24 bg-gradient-to-br from-purple-600 to-pink-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
                                        JD
                                    </div>
                                    <div>
                                        <button type="button" class="px-4 py-2 border-2 border-purple-600 text-purple-600 rounded-lg font-semibold hover:bg-purple-50 transition mb-2">
                                            Change Photo
                                        </button>
                                        <p class="text-sm text-gray-600">JPG, PNG or GIF. Max size 2MB.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-900 mb-2">First Name</label>
                                    <input type="text" value="John" class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:border-purple-600 transition">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-gray-900 mb-2">Last Name</label>
                                    <input type="text" value="Doe" class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:border-purple-600 transition">
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-2">Email Address</label>
                                <input type="email" value="john.doe@email.com" class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:border-purple-600 transition">
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-2">Phone Number</label>
                                <input type="tel" value="+1 (555) 123-4567" class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:border-purple-600 transition">
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-900 mb-2">Date of Birth</label>
                                <input type="date" value="1990-01-15" class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:border-purple-600 transition">
                            </div>

                            <div class="flex gap-3">
                                <button type="submit" class="gradient-bg text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition">
                                    Save Changes
                                </button>
                                <button type="button" class="px-8 py-3 border-2 border-gray-200 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 transition">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </section>
            </div>
        </div>

  </main>
  
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/admin/category-filter.js"></script>
<script type="module" src="/js/admin/block-category.js"></script>
<%- include('../partials/user/footer') %>

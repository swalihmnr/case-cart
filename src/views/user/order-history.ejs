<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders - CaseCart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .product-image {
            width: 80px;
            height: 80px;
            object-fit: contain;
            border-radius: 4px;
            border: 1px solid #e5e7eb;
            background-color: #f9fafb;
        }
    </style>
</head>

<body class="bg-gray-50">
    <%- include('../partials/user/header') %>

        <!-- Breadcrumb -->
        <div class="bg-white border-b">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
                <div class="flex items-center space-x-2 text-sm">
                    <a href="/" class="text-gray-600 hover:text-purple-600">Home</a>
                    <span class="text-gray-400">/</span>
                    <a href="/profile" class="text-gray-600 hover:text-purple-600">My Account</a>
                    <span class="text-gray-400">/</span>
                    <span class="text-gray-800 font-medium">My Orders</span>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            <!-- Page Title -->
            <h1 class="text-2xl font-bold text-gray-900 mb-6" id="pageTitle">My Orders</h1>

            <!-- Filter Section -->
            <div class="mb-6 flex justify-end">
                <form class="flex items-center gap-2" method="GET" action="/order">
                    <select name="status" onchange="this.form.submit()"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                        <option value="">All Orders</option>
                        <option value="pending" <%=status==='pending' ? 'selected' : '' %>>Pending</option>
                        <option value="delivered" <%=status==='delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="cancelled" <%=status==='cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </form>
            </div>

            <!-- Orders List View -->
            <div id="ordersListView" class="space-y-4">
                <% if (orders && orders.length> 0) { %>
                    <% orders.forEach(order=> { %>
                        <div
                            class="bg-white rounded-lg border border-gray-200 overflow-hidden order-card hover:shadow-md transition-shadow">
                            <!-- Order Header -->
                            <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
                                <div class="flex flex-wrap items-center justify-between gap-2">
                                    <div class="flex flex-wrap items-center gap-6 text-sm">
                                        <div>
                                            <span class="text-gray-500 text-xs block">ORDER ID</span>
                                            <span class="font-medium text-gray-900">#<%= order.orderId %></span>
                                        </div>
                                        <div>
                                            <span class="text-gray-500 text-xs block">ORDER DATE</span>
                                            <span class="font-medium text-gray-900">
                                                <%= new Date(order.createdAt).toLocaleDateString() %>
                                            </span>
                                        </div>
                                        <div>
                                            <span class="text-gray-500 text-xs block">TOTAL AMOUNT</span>
                                            <span class="font-medium text-gray-900">₹<%= order.totalPrice %></span>
                                        </div>
                                        <div>
                                            <div>
                                                <% // Determine overall status based on items let
                                                    overallStatus='Processing' ; if (order.paymentStatus==='Failed' ||
                                                    order.paymentStatus==='failed' ) { overallStatus='Payment Failed' ;
                                                    } else if (order.orderItems.every(i=> i.status
                                                    === 'cancelled')) {
                                                    overallStatus = 'Cancelled';
                                                    } else if (order.orderItems.some(i => i.status === 'delivered')) {
                                                    overallStatus = 'Delivered';
                                                    } else if (order.orderItems.some(i => i.status === 'shipped')) {
                                                    overallStatus = 'Shipped';
                                                    }
                                                    %>
                                                    <span class="text-gray-500 text-xs block">STATUS</span>
                                                    <span
                                                        class="font-medium <%= overallStatus === 'Cancelled' ? 'text-red-600' : overallStatus === 'Payment Failed' ? 'text-red-600' : overallStatus === 'Delivered' ? 'text-green-600' : 'text-blue-600' %>">
                                                        <%= overallStatus %>
                                                    </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Order Items with Images (Preview) -->
                                <div class="p-4 space-y-4 cursor-pointer"
                                    onclick="window.location.href='/order/<%= order._id %>'">
                                    <% order.orderItems.slice(0, 3).forEach(item=> { %>
                                        <div class="flex items-center gap-4">
                                            <img src="<%= item.product.productImages[0].url %>"
                                                alt="<%= item.product.name %>"
                                                class="w-16 h-16 object-contain border border-gray-200 rounded-md bg-gray-50">
                                            <div class="flex-1">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <p
                                                            class="font-medium text-gray-900 hover:text-purple-600 transition">
                                                            <%= item.product.name %>
                                                        </p>
                                                        <p class="text-sm text-gray-500">
                                                            Qty: <%= item.quantity %>
                                                        </p>
                                                    </div>
                                                    <span class="font-medium text-gray-900">₹<%= item.finalPrice %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% if (order.orderItems.length> 3) { %>
                                                <div
                                                    class="text-center text-sm text-gray-500 pt-2 border-t border-dashed">
                                                    + <%= order.orderItems.length - 3 %> more items
                                                </div>
                                                <% } %>
                                </div>

                                <!-- Order Actions -->
                                <div class="px-4 py-3 bg-gray-50 border-t border-gray-200 flex justify-end gap-3">
                                    <a href="/order/<%= order._id %>"
                                        class="px-4 py-2 text-sm border border-purple-600 text-purple-600 rounded-lg hover:bg-purple-50 font-medium transition">
                                        View Details
                                    </a>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="text-center py-12">
                                        <div
                                            class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                                            <i class="fas fa-box-open text-gray-400 text-3xl"></i>
                                        </div>
                                        <h3 class="text-lg font-medium text-gray-900">No orders found</h3>
                                        <p class="text-gray-500 mt-1">Start shopping to see your orders here.</p>
                                        <a href="/product"
                                            class="inline-block mt-4 text-purple-600 font-medium hover:underline">Browse
                                            Products</a>
                                    </div>
                                    <% } %>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages> 1) { %>
                            <div class="mt-8 flex justify-center">
                                <nav class="flex items-center gap-2">
                                    <% if (currentPage> 1) { %>
                                        <a href="/order?page=<%= currentPage - 1 %><%= status ? '&status=' + status : '' %>"
                                            class="px-3 py-2 border rounded-lg hover:bg-gray-50 transition text-sm">Previous</a>
                                        <% } else { %>
                                            <span
                                                class="px-3 py-2 border rounded-lg text-gray-400 cursor-not-allowed text-sm">Previous</span>
                                            <% } %>

                                                <% for(let i=1; i <=totalPages; i++) { %>
                                                    <% if (i===currentPage) { %>
                                                        <span
                                                            class="px-3 py-2 bg-purple-600 text-white rounded-lg text-sm">
                                                            <%= i %>
                                                        </span>
                                                        <% } else { %>
                                                            <a href="/order?page=<%= i %><%= status ? '&status=' + status : '' %>"
                                                                class="px-3 py-2 border rounded-lg hover:bg-gray-50 transition text-sm">
                                                                <%= i %>
                                                            </a>
                                                            <% } %>
                                                                <% } %>

                                                                    <% if (currentPage < totalPages) { %>
                                                                        <a href="/order?page=<%= currentPage + 1 %><%= status ? '&status=' + status : '' %>"
                                                                            class="px-3 py-2 border rounded-lg hover:bg-gray-50 transition text-sm">Next</a>
                                                                        <% } else { %>
                                                                            <span
                                                                                class="px-3 py-2 border rounded-lg text-gray-400 cursor-not-allowed text-sm">Next</span>
                                                                            <% } %>
                                </nav>
                            </div>
                            <% } %>
            </div>

            <%- include('../partials/footer') %>
</body>

</html>
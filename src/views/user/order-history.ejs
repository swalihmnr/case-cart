<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your settings and preferences</p>
        </div>

        <div class="grid lg:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>

            <!-- Main Content Area -->
            <div class="lg:col-span-3 space-y-6">
                <!-- Page Title & Filter -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                    <h3 class="font-display text-2xl font-light text-gold-light tracking-wide" id="pageTitle">My Orders</h3>
                    
                    <form class="flex items-center w-full sm:w-auto" method="GET" action="/order">
                        <select name="status" onchange="this.form.submit()"
                            class="w-full sm:w-auto bg-obsidian-light text-gold-light border border-gold-light/10 rounded px-4 py-2.5 text-xs uppercase tracking-wider font-semibold focus:outline-none focus:border-gold-accent appearance-none">
                            <option value="">All Orders</option>
                            <option value="payment_failed" <%=status==='payment_failed' ? 'selected' : '' %>>Payment Failed</option>
                            <option value="processing" <%=status==='processing' ? 'selected' : '' %>>Processing</option>
                            <option value="shipped" <%=status==='shipped' ? 'selected' : '' %>>Shipped</option>
                            <option value="delivered" <%=status==='delivered' ? 'selected' : '' %>>Delivered</option>
                            <option value="cancelled" <%=status==='cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                    </form>
                </div>

                <!-- Orders List View -->
                <div id="ordersListView" class="space-y-6">
                    <% if (orders && orders.length> 0) { %>
                        <% orders.forEach(order=> { %>
                            <div class="bg-obsidian-light border border-gold-light/5 rounded overflow-hidden shadow-2xl hover:border-gold-accent/30 transition duration-300">
                                <!-- Order Header -->
                                <div class="bg-obsidian px-6 py-5 border-b border-gold-light/10">
                                    <div class="flex flex-col gap-4">
                                        <!-- Top Row: ID and Status -->
                                        <div class="flex flex-wrap items-center justify-between gap-2">
                                            <div>
                                                <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest block mb-1">ORDER ID</span>
                                                <span class="font-display text-base text-gold-light tracking-wide">#<%= order.orderId %></span>
                                            </div>
                                            <div>
                                                <% // Determine overall status based on items
                                                let overallStatus = 'Processing';
                                                if (order.paymentStatus === 'Failed' || order.paymentStatus === 'failed') {
                                                    overallStatus = 'Payment Failed';
                                                } else if (order.orderItems.every(i => i.status === 'cancelled')) {
                                                    overallStatus = 'Cancelled';
                                                } else if (order.orderItems.some(i => i.status === 'delivered')) {
                                                    overallStatus = 'Delivered';
                                                } else if (order.orderItems.some(i => i.status === 'shipped')) {
                                                    overallStatus = 'Shipped';
                                                }
                                                %>
                                                <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest block mb-1 text-right">STATUS</span>
                                                <span class="px-2.5 py-1 rounded text-[9px] font-bold uppercase tracking-widest <%= overallStatus === 'Cancelled' || overallStatus === 'Payment Failed' ? 'bg-red-950/30 text-red-400 border border-red-500/20' : overallStatus === 'Delivered' ? 'bg-green-950/30 text-green-400 border border-green-500/20' : 'bg-gold-light/10 text-gold-light border border-gold-light/20' %>">
                                                    <%= overallStatus %>
                                                </span>
                                            </div>
                                        </div>

                                        <!-- Bottom Row: Date -->
                                        <div class="flex flex-wrap items-center justify-between gap-4 text-xs pt-3 border-t border-gold-light/5">
                                            <div>
                                                <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest block mb-0.5">DATE</span>
                                                <span class="font-medium text-ivory">
                                                    <%= new Date(order.createdAt).toLocaleDateString() %>
                                                </span>
                                            </div>
                                            <div>
                                                <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest block mb-0.5 text-right">ITEMS count</span>
                                                <span class="font-medium text-gold-light tracking-wider">
                                                    <%= order.orderItems.length %> <%= order.orderItems.length === 1 ? 'Item' : 'Items' %>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Order Items Preview -->
                                <div class="p-6 space-y-4 cursor-pointer" onclick="window.location.href='/order/<%= order._id %>'">
                                    <% order.orderItems.slice(0, 3).forEach(item=> { 
                                        let itemImageUrl = '/img/placeholder.jpg';
                                        if (item.product && item.product.productImages && item.product.productImages.length > 0) {
                                            const mainImg = item.product.productImages.find(img => img.isMain);
                                            if (mainImg) itemImageUrl = mainImg.url;
                                            else if (item.product.productImages[0]) itemImageUrl = item.product.productImages[0].url;
                                        } else if (item.variant && item.variant.images && item.variant.images.length > 0) {
                                            const mainImg = item.variant.images.find(img => img.isMain);
                                            if (mainImg) itemImageUrl = mainImg.url;
                                            else if (item.variant.images[0]) itemImageUrl = item.variant.images[0].url;
                                        }
                                    %>
                                        <div class="flex items-center gap-4 py-2 first:pt-0 last:pb-0">
                                            <img src="<%= itemImageUrl %>"
                                                alt="<%= item.product.name %>"
                                                class="w-16 h-16 object-cover border border-gold-light/10 rounded bg-obsidian">
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-center justify-between gap-4">
                                                    <div>
                                                        <p class="font-display text-base text-gold-light hover:text-gold-accent transition truncate">
                                                            <%= item.product.name %>
                                                        </p>
                                                        <p class="text-xs text-gray-500 mt-0.5">
                                                            Qty: <%= item.quantity %>
                                                        </p>
                                                    </div>
                                                    <span class="font-semibold text-gold-accent whitespace-nowrap">₹<%= item.finalPrice %></span>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                        
                                        <% if (order.orderItems.length> 3) { %>
                                            <div class="text-center text-xs text-gray-500 pt-3 border-t border-dashed border-gold-light/10 uppercase tracking-widest">
                                                + <%= order.orderItems.length - 3 %> more items
                                            </div>
                                        <% } %>
                                </div>

                                <!-- Order Actions -->
                                <div class="px-6 py-4 bg-obsidian border-t border-gold-light/10 flex justify-end">
                                    <a href="/order/<%= order._id %>"
                                        class="px-5 py-2.5 text-xs border border-gold-light/10 text-gold-light hover:border-gold-accent hover:text-gold-accent rounded uppercase tracking-widest font-semibold transition">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-16">
                            <div class="w-16 h-16 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center mx-auto mb-6">
                                <i class="fas fa-box-open text-gold-accent text-xl"></i>
                            </div>
                            <h3 class="font-display text-2xl font-light text-gold-light mb-2">No orders found</h3>
                            <p class="text-gray-400 text-xs uppercase tracking-widest mb-8 max-w-sm mx-auto leading-relaxed">
                                Start shopping to see your orders here.
                            </p>
                            <a href="/product"
                                class="inline-flex items-center gap-2 bg-gold-light text-obsidian hover:bg-gold-accent px-8 py-3 rounded text-xs uppercase tracking-widest font-semibold transition duration-300 shadow-md">
                                Discover Products
                                <i class="fas fa-arrow-right text-[10px]"></i>
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Pagination -->
                <% if (totalPages> 1) { %>
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gold-light/5 pt-8">
                        <p class="text-xs uppercase tracking-widest text-gray-500 order-2 sm:order-1">
                            Showing <span class="text-gold-light font-bold"><%= (currentPage - 1) * limit + 1 %></span>
                            to <span class="text-gold-light font-bold"><%= Math.min(currentPage * limit, totalItems) %></span>
                            of <span class="text-gold-light font-bold"><%= totalItems %></span> orders
                        </p>

                        <nav class="flex items-center gap-2 order-1 sm:order-2">
                            <% if (currentPage> 1) { %>
                                <a href="?page=<%= currentPage - 1 %><%= status ? '&status=' + status : '' %>"
                                    class="w-10 h-10 flex items-center justify-center rounded border border-gold-light/10 bg-obsidian-light text-gold-light hover:border-gold-accent hover:text-gold-accent transition">
                                    <i class="fas fa-chevron-left text-xs"></i>
                                </a>
                            <% } %>

                            <% let startPage = Math.max(1, currentPage - 1);
                               let endPage = Math.min(totalPages, startPage + 2);
                               if (endPage - startPage < 2) startPage = Math.max(1, endPage - 2);
                               if (startPage > 1) { %>
                                <a href="?page=1<%= status ? '&status=' + status : '' %>"
                                    class="w-10 h-10 flex items-center justify-center rounded border border-gold-light/10 text-gold-light hover:border-gold-accent hover:text-gold-accent transition font-bold text-xs">1</a>
                                <% if (startPage > 2) { %>
                                    <span class="w-10 h-10 flex items-center justify-center text-gray-600">...</span>
                                <% } %>
                            <% } %>

                            <% for(let i=startPage; i<=endPage; i++) { %>
                                <a href="?page=<%= i %><%= status ? '&status=' + status : '' %>"
                                    class="w-10 h-10 flex items-center justify-center rounded border <%= i === currentPage ? 'bg-gold-light border-gold-light text-obsidian' : 'border-gold-light/10 text-gold-light hover:border-gold-accent hover:text-gold-accent' %> transition font-bold text-xs">
                                    <%= i %>
                                </a>
                            <% } %>

                            <% if (endPage < totalPages) { %>
                                <% if (endPage < totalPages - 1) { %>
                                    <span class="w-10 h-10 flex items-center justify-center text-gray-600">...</span>
                                <% } %>
                                <a href="?page=<%= totalPages %><%= status ? '&status=' + status : '' %>"
                                    class="w-10 h-10 flex items-center justify-center rounded border border-gold-light/10 text-gold-light hover:border-gold-accent hover:text-gold-accent transition font-bold text-xs">
                                    <%= totalPages %>
                                </a>
                            <% } %>

                            <% if (currentPage < totalPages) { %>
                                <a href="?page=<%= currentPage + 1 %><%= status ? '&status=' + status : '' %>"
                                    class="w-10 h-10 flex items-center justify-center rounded border border-gold-light/10 bg-obsidian-light text-gold-light hover:border-gold-accent hover:text-gold-accent transition">
                                    <i class="fas fa-chevron-right text-xs"></i>
                                </a>
                            <% } %>
                        </nav>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/user/footer') %>
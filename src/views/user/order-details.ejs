<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details - CaseCart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom styling to guarantee Obsidian-Dark colors override tailwind defaults if needed -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Inter:wght@300;400;500;600;700&display=swap');
        
        .font-display {
            font-family: 'Cormorant Garamond', serif;
        }
        .font-sans {
            font-family: 'Inter', sans-serif;
        }
        .bg-obsidian {
            background-color: #0A0A0A;
        }
        .bg-obsidian-light {
            background-color: #161616;
        }
        .text-gold-light {
            color: #E8D5B0;
        }
        .text-gold-accent {
            color: #C9A84C;
        }
        .text-ivory {
            color: #F7F5F2;
        }
        .border-gold-light\/5 {
            border-color: rgba(232, 213, 176, 0.05);
        }
        .border-gold-light\/10 {
            border-color: rgba(232, 213, 176, 0.1);
        }
        .bg-gold-light\/5 {
            background-color: rgba(232, 213, 176, 0.05);
        }
        .bg-gold-light\/10 {
            background-color: rgba(232, 213, 176, 0.1);
        }
        .text-gray-550 {
            color: #9ca3af;
        }
    </style>
</head>

<body class="bg-obsidian text-ivory font-sans min-h-screen">
    <%- include('../partials/user/header') %>

    <!-- Breadcrumb -->
    <div class="bg-obsidian-light border-b border-gold-light/10">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex items-center space-x-2 text-xs uppercase tracking-wider font-semibold">
                <a href="/" class="text-gold-light/60 hover:text-gold-accent transition">Home</a>
                <span class="text-gray-600">/</span>
                <a href="/order" class="text-gold-light/60 hover:text-gold-accent transition">My Orders</a>
                <span class="text-gray-600">/</span>
                <span class="text-gold-light font-medium"><%= order.orderId %></span>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
        <!-- Back Button -->
        <div class="mb-8">
            <a href="/order" class="inline-flex items-center text-xs uppercase tracking-widest font-semibold text-gold-light/80 hover:text-gold-accent transition">
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Orders
            </a>
        </div>

        <!-- Order Details Card -->
        <div class="bg-obsidian-light border border-gold-light/5 rounded overflow-hidden shadow-2xl">
            <!-- Order Header -->
            <div class="p-6 md:p-8 border-b border-gold-light/10 bg-obsidian">
                <div class="flex justify-between items-start">
                    <div>
                        <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest block mb-1">ORDER ID</span>
                        <h2 class="font-display text-3xl font-light text-gold-light mb-2">#<%= order.orderId %></h2>
                        <p class="text-gray-400 text-xs">
                            Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %> - <%= new Date(order.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Order Items Section -->
            <div class="p-6 md:p-8 border-b border-gold-light/10">
                <h3 class="font-display text-xl font-light text-gold-light tracking-wide mb-6">
                    Order Items (<%= order.orderItems.length %>)
                </h3>

                <div class="space-y-6">
                    <% order.orderItems.forEach((item, index)=> { 
                        let itemImageUrl = '/img/placeholder.jpg';
                        if (item.product && item.product.productImages && item.product.productImages.length > 0) {
                            const mainImg = item.product.productImages.find(img => img.isMain);
                            if (mainImg) itemImageUrl = mainImg.url;
                            else if (item.product.productImages[0]) itemImageUrl = item.product.productImages[0].url;
                        } else if (item.variant && item.variant.images && item.variant.images.length > 0) {
                            const mainImg = item.variant.images.find(img => img.isMain);
                            if (mainImg) itemImageUrl = mainImg.url;
                            else if (item.variant.images[0]) itemImageUrl = item.variant.images[0].url;
                        }
                    %>
                        <div class="flex items-start gap-5 <%= index > 0 ? 'pt-6 border-t border-gold-light/5' : '' %>">
                            <div class="w-20 h-20 flex-shrink-0 bg-obsidian border border-gold-light/10 rounded overflow-hidden">
                                <img src="<%= itemImageUrl %>" alt="<%= item.product.name %>" class="w-full h-full object-cover">
                            </div>
                            
                            <div class="flex-1">
                                <div class="flex flex-col md:flex-row justify-between gap-4">
                                    <div>
                                        <p class="font-display text-lg text-gold-light mb-1">
                                            <%= item.product.name %>
                                        </p>
                                        <p class="text-xs text-gray-400 uppercase tracking-wider">
                                            Color: <%= item.variant.color %> | Qty: <%= item.quantity %>
                                        </p>
                                        <div class="flex items-center gap-2 mt-2">
                                            <span class="text-[9px] text-gray-500 font-semibold uppercase tracking-widest">Status:</span>
                                            <% if (order.paymentStatus==='Failed' || order.paymentStatus==='failed') { %>
                                                <span class="px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-widest bg-red-950/30 text-red-400 border border-red-500/20">
                                                    Payment Failed
                                                </span>
                                            <% } else { %>
                                                <span class="px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-widest <%= item.status === 'delivered' ? 'bg-green-950/30 text-green-400 border border-green-500/20' : item.status === 'cancelled' ? 'bg-red-950/30 text-red-400 border border-red-500/20' : 'bg-gold-light/10 text-gold-light border border-gold-light/20' %>">
                                                    <%= item.status %>
                                                </span>
                                            <% } %>
                                        </div>
                                        
                                        <!-- Actions per Item -->
                                        <div class="flex items-center gap-3 mt-3">
                                            <% if (['pending', 'processing', 'placed'].includes(item.status) && order.paymentStatus !=='Failed' && order.paymentStatus !=='failed') { %>
                                                <button onclick="cancelItem('<%= item._id %>', '<%= item.product.name %>', '<%= order._id %>')"
                                                    class="text-xs text-red-400 hover:text-red-500 uppercase tracking-wider font-semibold">
                                                    Cancel Item
                                                </button>
                                            <% } else if (item.status==='delivered' && order.paymentStatus !=='Failed' && order.paymentStatus !=='failed') { %>
                                                <% if (!item.isReject) { %>
                                                    <button onclick="returnItem('<%= item._id %>', '<%= item.product.name %>', '<%= order._id %>')"
                                                        class="text-xs text-gold-light hover:text-gold-accent uppercase tracking-wider font-semibold">
                                                        Return Item
                                                    </button>
                                                <% } %>
                                                <button onclick="downloadInvoice('<%= order._id %>', '<%= item._id %>')"
                                                    class="text-xs text-gray-400 hover:text-gold-light uppercase tracking-wider font-semibold flex items-center gap-1 ml-2">
                                                    <i class="fas fa-download text-[10px]"></i> Invoice
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="text-left md:text-right">
                                        <p class="text-xs text-gray-500">₹<%= Math.floor(item.price).toFixed(2) %> x <%= item.quantity %></p>
                                        <p class="font-semibold text-gold-accent mt-0.5">₹<%= Math.floor(item.price * item.quantity).toFixed(2) %></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>

            <!-- Order Summary -->
            <% if (order.paymentStatus!=='cancelled') { %>
                <div class="p-6 md:p-8 border-b border-gold-light/10">
                    <h3 class="font-display text-xl font-light text-gold-light tracking-wide mb-4">Order Summary</h3>

                    <div class="space-y-3">
                        <div class="flex justify-between text-xs uppercase tracking-wider text-gray-450">
                            <span>Subtotal</span>
                            <span class="font-medium text-gold-light">₹<%= Math.floor(order.totalPrice).toFixed(2) %></span>
                        </div>
                        <% if (order.totalDiscount > 0) { %>
                            <div class="flex justify-between text-xs uppercase tracking-wider text-gray-450">
                                <span>Discount</span>
                                <span class="font-medium text-green-400">-₹<%= Math.floor(order.totalDiscount).toFixed(2) %></span>
                            </div>
                        <% } %>
                        <% if (order.couponDiscount > 0) { %>
                            <div class="flex justify-between text-xs uppercase tracking-wider text-gray-450">
                                <span>Coupon Discount</span>
                                <span class="font-medium text-green-400">-₹<%= Math.floor(order.couponDiscount).toFixed(2) %></span>
                            </div>
                        <% } %>
                        <div class="flex justify-between text-xs uppercase tracking-wider text-gray-450">
                            <span>Shipping</span>
                            <span class="font-medium text-green-400">
                                <%= order.shipping > 0 ? '₹' + Math.floor(order.shipping).toFixed(2) : 'FREE' %>
                            </span>
                        </div>
                        <div class="flex justify-between text-sm uppercase tracking-wider text-gold-light font-semibold pt-4 border-t border-gold-light/10">
                            <span>Total Amount</span>
                            <span class="text-base text-gold-accent">₹<%= (Math.floor(order.finalAmount) || (order.totalPrice - (order.totalDiscount || 0) - (order.couponDiscount || 0))).toFixed(2) %></span>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="p-6 bg-red-950/20 border-b border-red-500/10 text-red-200 text-xs uppercase tracking-widest font-semibold p-4">
                    <strong>Note:</strong> Shipping charges will not be refunded if you cancel or return this product.
                </div>
            <% } %>

            <!-- Payment Details & Address -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6 md:p-8 border-b border-gold-light/10">
                <div>
                    <h3 class="font-display text-xl font-light text-gold-light tracking-wide mb-4">Payment Details</h3>
                    <div class="space-y-2 text-xs uppercase tracking-wider">
                        <div class="flex justify-between">
                            <span class="text-gray-500">Method</span>
                            <span class="font-medium text-gold-light"><%= order.paymentMethod %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-500">Status</span>
                            <span class="font-medium <%= order.paymentStatus === 'Completed' ? 'text-green-400' : 'text-gold-accent' %>">
                                <%= order.paymentStatus %>
                            </span>
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="font-display text-xl font-light text-gold-light tracking-wide mb-4">Shipping Address</h3>
                    <% if (order.shippingAddress) { %>
                        <p class="text-gray-400 text-xs leading-relaxed">
                            <strong class="text-gold-light font-medium text-sm"><%= order.shippingAddress.firstName %> <%= order.shippingAddress.lastName %></strong><br>
                            <%= order.shippingAddress.streetAddress %><br>
                            <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pinCode %><br>
                            Phone: <%= order.shippingAddress.phone %>
                        </p>
                    <% } else { %>
                        <p class="text-gray-500 text-xs uppercase tracking-wider">Address not available</p>
                    <% } %>
                </div>
            </div>

            <!-- Global Actions -->
            <% // Check if any item is cancellable to show "Cancel Entire Order"
               const hasCancellableItems = order.orderItems.some(item => ['pending', 'processing', 'placed'].includes(item.status));
            %>
            <div class="p-6 md:p-8">
                <div class="flex flex-col sm:flex-row gap-4">
                    <% if (order.paymentStatus==='Failed' || order.paymentStatus==='failed') { %>
                        <button onclick="retryPayment('<%= order._id %>')"
                            class="flex-1 bg-gold-light text-obsidian hover:bg-gold-accent px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold transition text-center shadow-md">
                            Retry Payment
                        </button>
                    <% } %>
                    <% if (hasCancellableItems && order.paymentStatus !=='Failed' && order.paymentStatus !=='failed') { %>
                        <button onclick="cancelFullOrder('<%= order._id %>')"
                            class="flex-1 bg-red-950/50 border border-red-500/30 text-red-400 hover:bg-red-500/10 px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold transition text-center">
                            Cancel Entire Order
                        </button>
                    <% } %>
                    <a href="/order" class="flex-1">
                        <button class="w-full px-6 py-3 border border-gold-light/10 text-gold-light hover:bg-gold-light/5 hover:border-gold-accent rounded text-xs uppercase tracking-widest font-semibold transition text-center">
                            View All Orders
                        </button>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/user/footer') %>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module">
        import api from '/js/api.js';

        window.retryPayment = async (orderId) => {
            try {
                Swal.fire({
                    title: 'Processing',
                    html: 'Please wait while we prepare your payment...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const res = await api.createRazorpayOrderAxios(orderId);
                Swal.close();

                if (!res.data.success) {
                    return Swal.fire('Error', 'Could not initiate payment. Please try again.', 'error');
                }

                const options = {
                    key: res.data.key,
                    amount: res.data.order.amount,
                    currency: res.data.order.currency,
                    name: "CaseCart",
                    description: "Order Payment",
                    image: "/img/Pasted image.png",
                    order_id: res.data.order.id,
                    handler: async function (response) {
                        try {
                            Swal.fire({
                                title: 'Verifying Payment',
                                text: 'Please wait while we verify your payment...',
                                allowOutsideClick: false,
                                didOpen: () => Swal.showLoading()
                            });

                            const data = {
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature,
                                orderId: orderId
                            };

                            const verifyRes = await api.verifyRazorpayPaymentAxios(data);
                            Swal.close();

                            if (verifyRes.data.success || verifyRes.data.status === 'success' || verifyRes.data.paymentStatus === 'success') {
                                await Swal.fire({
                                    icon: 'success',
                                    title: 'Payment Successful!',
                                    text: 'Your payment was successful.',
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                                window.location.reload();
                            } else {
                                Swal.fire('Error', verifyRes.data.message || 'Payment verification failed', 'error');
                            }
                        } catch (error) {
                            Swal.close();
                            Swal.fire('Error', 'An error occurred during verification', 'error');
                        }
                    },
                    theme: { color: "#C9A84C" },
                    modal: {
                        ondismiss: function () {
                            Swal.fire('Cancelled', 'Payment was cancelled', 'info');
                        }
                    }
                };

                const retryRazorpayInstance = new Razorpay(options);
                retryRazorpayInstance.on('payment.failed', function (response) {
                    Swal.fire('Payment Failed', response.error.description || 'Payment could not be processed', 'error');
                });
                retryRazorpayInstance.open();
            } catch (error) {
                Swal.close();
                console.error("Error during payment retry:", error);
                Swal.fire('Error', 'An error occurred while retrying payment', 'error');
            }
        };

        window.cancelFullOrder = async (orderId) => {
            const result = await Swal.fire({
                title: 'Cancel Entire Order?',
                text: 'Are you sure you want to cancel this entire order? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c9a84c',
                cancelButtonColor: '#161616',
                confirmButtonText: 'Yes, cancel order',
                cancelButtonText: 'No, keep it'
            });

            if (result.isConfirmed) {
                try {
                    const response = await api.cancelWholeOrderAxios(orderId, { reason: 'User requested cancellation' });
                    if (response.data.success) {
                        await Swal.fire({
                            title: 'Order Cancelled!',
                            text: 'Your order has been cancelled successfully.',
                            icon: 'success',
                            confirmButtonColor: '#c9a84c'
                        });
                        window.location.reload();
                    } else {
                        Swal.fire('Error', response.data.message || 'Failed to cancel order', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    Swal.fire('Error', 'Something went wrong', 'error');
                }
            }
        }

        window.cancelItem = async (itemId, itemName, orderId) => {
            const result = await Swal.fire({
                title: 'Cancel Item?',
                text: `Are you sure you want to cancel ${itemName}?`,
                input: 'text',
                inputPlaceholder: 'Reason for cancellation (optional)',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c9a84c',
                cancelButtonColor: '#161616',
                confirmButtonText: 'Yes, cancel item',
                cancelButtonText: 'No, keep it'
            });

            if (result.isConfirmed) {
                try {
                    const response = await api.ordCancelAxios({
                        orderId: orderId,
                        reason: result.value || 'User requested cancellation'
                    }, itemId);

                    if (response.data.success) {
                        await Swal.fire({
                            title: 'Item Cancelled!',
                            text: 'Item has been cancelled successfully.',
                            icon: 'success',
                            confirmButtonColor: '#c9a84c'
                        });
                        window.location.reload();
                    } else {
                        Swal.fire('Error', response.data.message || 'Failed to cancel item', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    Swal.fire('Error', 'Something went wrong', 'error');
                }
            }
        }

        window.returnItem = async (itemId, itemName, orderId) => {
            const result = await Swal.fire({
                title: 'Return Item?',
                text: `Are you sure you want to return ${itemName}?`,
                input: 'text',
                inputPlaceholder: 'Reason for return',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#c9a84c',
                cancelButtonColor: '#161616',
                confirmButtonText: 'Yes, return item',
                cancelButtonText: 'No, keep it',
                inputValidator: (value) => {
                    if (!value) {
                        return 'You need to write something!'
                    }
                }
            });

            if (result.isConfirmed) {
                try {
                    const response = await api.ordReturnAxios({
                        orderId: orderId,
                        reason: result.value
                    }, itemId);

                    if (response.data.success) {
                        await Swal.fire({
                            title: 'Return Requested!',
                            text: 'Your return request has been submitted.',
                            icon: 'success',
                            confirmButtonColor: '#c9a84c'
                        });
                        window.location.reload();
                    } else {
                        Swal.fire('Error', response.data.message || 'Failed to request return', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    Swal.fire('Error', 'Something went wrong', 'error');
                }
            }
        }

        window.downloadInvoice = (orderId, itemId) => {
            api.orderInvoice(orderId, itemId);
        }
    </script>
</body>

</html>
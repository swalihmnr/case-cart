<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your account settings and preferences</p>
        </div>

        <!-- Main Grid Layout -->
        <div class="grid lg:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>
            
            <!-- Main Content Area -->
            <div class="lg:col-span-3">
                <div class="bg-obsidian-light border border-gold-light/5 rounded shadow-2xl overflow-hidden">
                    <!-- Header Section -->
                    <div class="bg-obsidian border-b border-gold-light/10 p-6 md:p-8">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                            <div>
                                <h2 class="font-display text-2xl md:text-3xl font-light text-gold-light tracking-wide mb-1">Saved Addresses</h2>
                                <p class="text-gray-400 text-[10px] uppercase tracking-widest">Manage your delivery locations</p>
                            </div>
                            <a href="address/add" class="w-full sm:w-auto">
                                <button class="w-full sm:w-auto bg-gold-light text-obsidian hover:bg-gold-accent font-semibold px-6 py-3 rounded text-xs uppercase tracking-widest flex items-center justify-center gap-2 transition duration-300 shadow-md">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                    </svg>
                                    Add New Address
                                </button>
                            </a>
                        </div>
                    </div>

                    <!-- Address Cards Grid -->
                    <div class="p-6 md:p-8">
                        <% if(addresses && addresses.length > 0) { %>
                            <div class="grid md:grid-cols-2 gap-6">
                                <% addresses.forEach(address => { %>
                                    <div class="group border border-gold-light/10 bg-obsidian rounded p-6 hover:border-gold-accent transition-all duration-300">
                                        <!-- Address Header -->
                                        <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="inline-flex items-center bg-gold-light/5 text-gold-light text-[10px] font-medium uppercase tracking-widest px-3 py-1.5 rounded border border-gold-light/10">
                                                    <i class="fas fa-map-marker-alt mr-1 text-gold-accent"></i>
                                                    <%= address.addressType %>
                                                </span>
                                                <% if(address.isDefault) { %>
                                                    <span class="inline-flex items-center bg-gold-accent text-obsidian text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded">
                                                        Default
                                                    </span>
                                                <% } %>
                                            </div>
                                            <div class="flex gap-2">
                                                <button onclick="editForm('<%= address._id %>')" class="text-gold-light hover:text-gold-accent hover:border-gold-accent px-3 py-1.5 border border-gold-light/10 rounded text-[10px] uppercase tracking-widest font-semibold transition">
                                                    Edit
                                                </button>
                                                <button onclick="deleteAddress('<%= address._id %>')" class="text-red-400 hover:text-red-500 px-3 py-1.5 border border-red-500/10 hover:bg-red-500/5 rounded text-[10px] uppercase tracking-widest font-semibold transition">
                                                    Delete
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Address Details -->
                                        <div class="space-y-3">
                                            <div class="flex items-center gap-2">
                                                <i class="far fa-user text-gold-light/40 text-xs"></i>
                                                <p class="font-display font-medium text-lg text-gold-light"><%= address.firstName %> <%= address.lastName %></p>
                                            </div>
                                            
                                            <div class="flex items-center gap-2 text-xs">
                                                <i class="fas fa-phone-alt text-gold-light/40 text-[10px]"></i>
                                                <p class="text-ivory font-medium"><%= address.phone %></p>
                                            </div>

                                            <div class="space-y-1 text-xs text-gray-400 pt-3 border-t border-gold-light/5 leading-relaxed">
                                                <p class="text-ivory"><%= address.streetAddress %></p>
                                                <% if(address.landMark) { %>
                                                    <p>Landmark: <%= address.landMark %></p>
                                                <% } %>
                                                <p class="text-gold-light font-medium mt-1"><%= address.city %>, <%= address.state %> - <%= address.pinCode %></p>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <!-- Empty State -->
                            <div class="text-center py-16">
                                <div class="w-16 h-16 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-map-marked-alt text-gold-accent text-xl"></i>
                                </div>
                                <h3 class="font-display text-xl text-gold-light mb-2">No addresses saved yet</h3>
                                <p class="text-gray-450 text-xs uppercase tracking-wider mb-6">Add your first address to get started</p>
                                <a href="address/add">
                                    <button class="bg-gold-light text-obsidian hover:bg-gold-accent font-semibold px-8 py-3 rounded text-xs uppercase tracking-widest transition duration-300 shadow-md">
                                        Add Your First Address
                                    </button>
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/editAddress.js"></script>

<%- include('../partials/user/footer') %>
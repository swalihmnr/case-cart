<%- include('../partials/user/header') %>

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
        <!-- Page Header -->
        <div class="mb-8 fade-in">
            <h1 class="text-3xl md:text-4xl font-bold mb-2 text-gray-900">My Account</h1>
            <p class="text-gray-600">Manage your account settings and preferences</p>
        </div>

        <!-- Main Grid Layout -->
        <div class="grid lg:grid-cols-4 gap-6 lg:gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>
            
            <!-- Main Content Area -->
            <div class="lg:col-span-3">
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                    <!-- Header Section -->
                    <div class="bg-gradient-to-r from-purple-600 to-purple-700 p-6 md:p-8">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                            <div>
                                <h2 class="text-2xl md:text-3xl font-bold text-white mb-1">Saved Addresses</h2>
                                <p class="text-purple-100 text-sm">Manage your delivery locations</p>
                            </div>
                            <a href="address/add" class="w-full sm:w-auto">
                                <button class="w-full sm:w-auto bg-white hover:bg-purple-50 text-purple-600 font-semibold px-6 py-3 rounded-xl flex items-center justify-center gap-2 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                    </svg>
                                    Add New Address
                                </button>
                            </a>
                        </div>
                    </div>

                    <!-- Address Cards Grid -->
                    <div class="p-4 md:p-6 lg:p-8">
                        <% if(addresses && addresses.length > 0) { %>
                            <div class="grid md:grid-cols-2 gap-4 md:gap-6">
                                <% addresses.forEach(address => { %>
                                    <div class="group border-2 border-gray-200 rounded-xl p-6 hover:border-purple-400 hover:shadow-xl transition-all duration-300 bg-white">
                                        <!-- Address Header -->
                                        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="inline-flex items-center bg-gradient-to-r from-green-500 to-green-600 text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-sm">
                                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                                    </svg>
                                                    <%= address.addressType %>
                                                </span>
                                                <% if(address.isDefault) { %>
                                                    <span class="inline-flex items-center bg-gradient-to-r from-purple-500 to-purple-600 text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-sm animate-pulse">
                                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                                        </svg>
                                                        Default
                                                    </span>
                                                <% } %>
                                            </div>
                                            <div class="flex gap-2">
                                                <button onclick="editForm('<%= address._id %>')" class="text-purple-600 hover:text-white hover:bg-purple-600 px-4 py-2 border-2 border-purple-600 rounded-lg font-medium transition-all duration-300 transform hover:scale-105">
                                                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                                    </svg>
                                                    Edit
                                                </button>
                                                <button onclick="deleteAddress('<%= address._id %>')" class="text-red-600 hover:text-white hover:bg-red-600 px-4 py-2 border-2 border-red-600 rounded-lg font-medium transition-all duration-300 transform hover:scale-105">
                                                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                    </svg>
                                                    Delete
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Address Details -->
                                        <div class="space-y-2">
                                            <div class="flex items-center gap-2">
                                                <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                                <p class="font-bold text-lg text-gray-900"><%= address.firstName %> <%= address.lastName %></p>
                                            </div>
                                            
                                            <div class="flex items-center gap-2">
                                                <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                                </svg>
                                                <p class="text-gray-700 font-medium"><%= address.phone %></p>
                                            </div>

                                            <div class="flex items-start gap-2 mt-3 pt-3 border-t border-gray-100">
                                                <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                </svg>
                                                <div class="text-gray-600 text-sm leading-relaxed">
                                                    <p><%= address.streetAddress %></p>
                                                    <% if(address.landMark) { %>
                                                        <p><%= address.landMark %></p>
                                                    <% } %>
                                                    <p class="font-medium text-gray-800 mt-1"><%= address.city %>, <%= address.state %> - <%= address.pinCode %></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <!-- Empty State -->
                            <div class="text-center py-16">
                                <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <h3 class="text-xl font-semibold text-gray-900 mb-2">No addresses saved yet</h3>
                                <p class="text-gray-500 mb-6">Add your first address to get started</p>
                                <a href="address/add">
                                    <button class="bg-purple-600 hover:bg-purple-700 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                        Add Your First Address
                                    </button>
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/editAddress.js"></script>

<%- include('../partials/user/footer') %>
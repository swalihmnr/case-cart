<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .page {
            display: none;
        }
        .page.active {
            display: block;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .btn-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <!-- Email Verification Page -->
    <div id="email-verification" class="page active">
        <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
            <div class="max-w-md w-full fade-in">
                <div class="bg-white rounded-2xl shadow-xl p-8 text-center">
                    <div class="w-20 h-20 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fas fa-envelope-open-text text-purple-600 text-3xl"></i>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Verify Your Email</h2>
                    <p class="text-gray-600 mb-6">We've sent a verification link to<br><strong id="user-email" class="text-gray-800">user@example.com</strong></p>
                    
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 text-left">
                        <p class="text-sm text-blue-800">
                            <i class="fas fa-info-circle mr-2"></i>
                            Please check your email and click the verification link to continue.
                        </p>
                    </div>

                    <button onclick="showPage('otp-verification')" class="btn-hover w-full gradient-bg text-white py-3 rounded-lg font-semibold transition duration-300 mb-4">
                        Enter OTP Manually
                    </button>

                    <p class="text-sm text-gray-600">
                        Didn't receive the email? 
                        <button onclick="resendVerificationEmail()" class="text-purple-600 hover:text-purple-700 font-semibold">
                            Resend
                        </button>
                        <span id="resend-timer" class="hidden text-gray-500 ml-2"></span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- OTP Verification Page -->
    <div id="otp-verification" class="page">
        <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
            <div class="max-w-md w-full fade-in">
                <div class="bg-white rounded-2xl shadow-xl p-8 text-center">
                    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fas fa-key text-green-600 text-3xl"></i>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Enter OTP</h2>
                    <p class="text-gray-600 mb-6">Enter the 6-digit code sent to<br><strong id="otp-email" class="text-gray-800">user@example.com</strong></p>
                    
                    <div class="flex justify-between mb-6">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 1)">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 2)">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 3)">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 4)">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 5)">
                        <input type="text" maxlength="1" class="w-12 h-12 border-2 border-gray-300 rounded-lg text-center text-xl font-bold otp-input" oninput="moveToNext(this, 6)">
                    </div>

                    <button onclick="verifyOTP()" class="btn-hover w-full gradient-bg text-white py-3 rounded-lg font-semibold transition duration-300 mb-4">
                        Verify OTP
                    </button>

                    <button onclick="showPage('email-verification')" class="text-purple-600 hover:text-purple-700 font-semibold">
                        ← Back to Email Verification
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Page navigation
        function showPage(pageId) {
            // Hide all pages
            document.querySelectorAll('.page').forEach(page => {
                page.classList.remove('active');
            });
            
            // Show selected page
            document.getElementById(pageId).classList.add('active');
        }

        // Resend verification email with timer
        function resendVerificationEmail() {
            const resendButton = event.target;
            const timerElement = document.getElementById('resend-timer');
            
            // Disable button and start timer
            resendButton.disabled = true;
            timerElement.classList.remove('hidden');
            
            let timeLeft = 30;
            const timer = setInterval(() => {
                timerElement.textContent = `(${timeLeft}s)`;
                timeLeft--;
                
                if (timeLeft < 0) {
                    clearInterval(timer);
                    resendButton.disabled = false;
                    timerElement.classList.add('hidden');
                    
                    // Simulate email resend
                    alert('Verification email has been resent!');
                }
            }, 1000);
        }

        // OTP input navigation
        function moveToNext(input, nextIndex) {
            if (input.value.length === 1) {
                const nextInput = document.querySelectorAll('.otp-input')[nextIndex];
                if (nextInput) {
                    nextInput.focus();
                }
            }
        }

        // Verify OTP
        function verifyOTP() {
            const otpInputs = document.querySelectorAll('.otp-input');
            let otp = '';
            
            otpInputs.forEach(input => {
                otp += input.value;
            });
            
            if (otp.length === 6) {
                // Simulate OTP verification
                alert('OTP verified successfully!');
                // Here you would typically make an API call to verify the OTP
            } else {
                alert('Please enter the complete 6-digit OTP');
            }
        }

        // Set user email dynamically (you would get this from your backend)
        function setUserEmail(email) {
            document.getElementById('user-email').textContent = email;
            document.getElementById('otp-email').textContent = email;
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Set a sample email (replace with actual user email)
            setUserEmail('user@example.com');
        });
    </script>
</body>
</html>
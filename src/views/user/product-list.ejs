<%- include('../partials/user/header') %>

<main class="bg-obsidian min-h-screen text-ivory pt-28 pb-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
        
        <!-- Page Title & Editorial Header -->
        <div class="mb-12 text-center md:text-left space-y-2">
            <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">Bespoke Protection</p>
            <h1 class="font-display text-4xl sm:text-5xl font-light tracking-wide text-gold-light">Case Collection</h1>
        </div>

        <!-- Horizontal Pill-Tab Filters & Sort/Price Toolbar -->
        <div class="flex flex-col gap-6 mb-12 border-b border-gold-light/10 pb-8">
            <!-- Scrollable Category Pills (Max 6) -->
            <div class="flex items-center space-x-3 overflow-x-auto no-scrollbar pb-2">
                <!-- All Products Pill -->
                <button onclick="selectCategory('')" 
                        class="px-5 py-2 rounded-full text-xs uppercase tracking-widest font-medium border transition-200 whitespace-nowrap
                        <%= selectedCategories.length === 0 ? 'bg-gold-light text-obsidian border-gold-light' : 'border-gold-light/20 text-gold-light hover:border-gold-accent hover:text-gold-accent' %>">
                    All Cases
                </button>
                
                <% categories.forEach(cat => { %>
                    <button onclick="selectCategory('<%= cat._id %>')" 
                            class="px-5 py-2 rounded-full text-xs uppercase tracking-widest font-medium border transition-200 whitespace-nowrap
                            <%= selectedCategories.includes(String(cat._id)) ? 'bg-gold-light text-obsidian border-gold-light' : 'border-gold-light/20 text-gold-light hover:border-gold-accent hover:text-gold-accent' %>">
                        <%= cat.name.replace(' Cases', '') %>
                    </button>
                <% }) %>
            </div>

            <!-- Scrollable Brand Pills -->
            <div class="flex items-center space-x-3 overflow-x-auto no-scrollbar pb-2">
                <!-- All Brands Pill -->
                <button onclick="selectBrand('')" 
                        class="px-5 py-2 rounded-full text-xs uppercase tracking-widest font-medium border transition-200 whitespace-nowrap
                        <%= selectedBrands.length === 0 ? 'bg-gold-light text-obsidian border-gold-light' : 'border-gold-light/20 text-gold-light hover:border-gold-accent hover:text-gold-accent' %>">
                    All Brands
                </button>
                
                <% brands.forEach(brand => { %>
                    <button onclick="selectBrand('<%= brand._id %>')" 
                            class="px-5 py-2 rounded-full text-xs uppercase tracking-widest font-medium border transition-200 whitespace-nowrap
                            <%= selectedBrands.includes(String(brand._id)) ? 'bg-gold-light text-obsidian border-gold-light' : 'border-gold-light/20 text-gold-light hover:border-gold-accent hover:text-gold-accent' %>">
                        <%= brand.name %>
                    </button>
                <% }) %>
            </div>

            <!-- Sorting & Price Ranges -->
            <div class="flex flex-wrap items-center justify-between gap-4 text-xs">
                <!-- Sorting & Price filters -->
                <div class="flex flex-wrap items-center gap-4">
                    <!-- Price Pills -->
                    <div class="flex items-center space-x-2">
                        <span class="text-gray-500 uppercase tracking-wider text-[10px]">Price:</span>
                        <select id="priceSelect" onchange="handleListFilterChange()" class="bg-obsidian-light border border-gold-light/20 text-gold-light px-3 py-1.5 rounded focus:outline-none focus:border-gold-accent">
                            <option value="all" <%= price === "all" || !price ? "selected" : "" %>>All Prices</option>
                            <option value="under-150" <%= price === "under-150" ? "selected" : "" %>>Under ₹150</option>
                            <option value="500-700" <%= price === "500-700" ? "selected" : "" %>>₹500 – ₹700</option>
                            <option value="above-1000" <%= price === "above-1000" ? "selected" : "" %>>Above ₹1000</option>
                        </select>
                    </div>

                    <!-- Sort -->
                    <div class="flex items-center space-x-2">
                        <span class="text-gray-500 uppercase tracking-wider text-[10px]">Sort:</span>
                        <select id="sortSelect" onchange="handleListFilterChange()" class="bg-obsidian-light border border-gold-light/20 text-gold-light px-3 py-1.5 rounded focus:outline-none focus:border-gold-accent">
                            <option value="">Default</option>
                            <option value="priceLowHigh" <%= sort === "priceLowHigh" ? "selected" : "" %>>Price: Low → High</option>
                            <option value="priceHighLow" <%= sort === "priceHighLow" ? "selected" : "" %>>Price: High → Low</option>
                            <option value="aToZ" <%= sort === "aToZ" ? "selected" : "" %>>A → Z</option>
                            <option value="zToA" <%= sort === "zToA" ? "selected" : "" %>>Z → A</option>
                        </select>
                    </div>
                </div>

                <!-- Counts -->
                <div class="text-gray-500 tracking-wide">
                    Showing <span class="text-gold-light font-medium"><%= products.length %></span> of <span class="text-gold-light font-medium"><%= totalItems %></span> artifacts
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <% if (products.length > 0) { %>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-12">
                <% products.forEach(product => { %>
                    <% const isInWishlist = wishlistItems && wishlistItems.some(item =>
                        item.variantId && item.variantId.toString() === product.minVariant._id.toString()
                    ); %>
                    
                    <!-- Product Card -->
                    <div class="group relative flex flex-col space-y-4 animate-fade-in">
                        <!-- Wishlist Toggle (Always visible on mobile, hover on desktop) -->
                        <% if (user) { %>
                            <button onclick="addListWishlist('<%= product._id %>', '<%= product.minVariant._id %>')" 
                                    class="absolute top-3 right-3 z-20 text-gold-light hover:text-gold-accent transition-all duration-300 p-2 bg-obsidian/40 backdrop-blur-md rounded-full md:opacity-0 md:group-hover:opacity-100">
                                <i id="wish-icon-<%= product._id %>-<%= product.minVariant._id %>" 
                                   class="fa-heart <%= isInWishlist ? 'fas text-red-500 font-bold' : 'far text-gold-light' %> text-xs sm:text-sm"></i>
                            </button>
                        <% } %>

                        <!-- Image Section (65% height area) -->
                        <div class="relative aspect-[3/4] bg-obsidian-light border border-gold-light/5 group-hover:border-gold-light/20 overflow-hidden flex items-center justify-center transition-colors duration-300">
                            <a href="/product/<%= product._id %>/detials" class="block w-full h-full">
                                <% 
                                  let mainImageUrl = '/img/placeholder.jpg';
                                  if (product.productImages && product.productImages.length > 0) {
                                      const mainImg = product.productImages.find(img => img.isMain);
                                      if (mainImg) mainImageUrl = mainImg.url;
                                      else if (product.productImages[0]) mainImageUrl = product.productImages[0].url;
                                  } else if (product.minVariant && product.minVariant.images && product.minVariant.images.length > 0) {
                                      const mainImg = product.minVariant.images.find(img => img.isMain);
                                      if (mainImg) mainImageUrl = mainImg.url;
                                      else if (product.minVariant.images[0]) mainImageUrl = product.minVariant.images[0].url;
                                  } else if (product.variants && product.variants[0] && product.variants[0].images && product.variants[0].images.length > 0) {
                                      const mainImg = product.variants[0].images.find(img => img.isMain);
                                      if (mainImg) mainImageUrl = mainImg.url;
                                      else if (product.variants[0].images[0]) mainImageUrl = product.variants[0].images[0].url;
                                  }
                                %>
                                <img src="<%= mainImageUrl %>" 
                                     alt="<%= product.name %>" 
                                     class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out">
                            </a>

                            <!-- Offer Badge -->
                            <% if (product.offerValue > 0) { %>
                                <span class="absolute bottom-3 left-3 bg-red-950/40 backdrop-blur-md border border-red-500/20 text-red-400 text-[9px] uppercase tracking-widest font-semibold px-2 py-0.5 rounded">
                                    <%= product.offerType === 'percentage' ? product.offerValue + '% OFF' : '₹' + product.offerValue + ' OFF' %>
                                </span>
                            <% } %>

                            <!-- Quick Add CTA (Overlay on Desktop, Hidden on mobile) -->
                            <div class="absolute inset-x-0 bottom-0 p-3 bg-gradient-to-t from-obsidian via-obsidian/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:block z-10">
                                <button onclick="addListToCart('<%= product._id %>', '<%= product.minVariant._id %>')"
                                        class="w-full bg-gold-light hover:bg-gold-accent text-obsidian py-2 rounded-sm text-[9px] uppercase tracking-widest font-bold transition-colors duration-200">
                                    Quick Add
                                </button>
                            </div>
                        </div>

                        <!-- Card Info -->
                        <div class="space-y-1">
                            <p class="text-[9px] uppercase tracking-widest text-gold-accent font-medium">
                                <%= product.catgId ? product.catgId.name : 'Case Collection' %>
                            </p>
                            <h3 class="font-display text-sm sm:text-base tracking-wide text-gold-light font-light truncate">
                                <a href="/product/<%= product._id %>/detials" class="hover:text-gold-accent transition-colors">
                                    <%= product.name %>
                                </a>
                            </h3>
                            <div class="flex items-center space-x-2 pt-0.5">
                                <span class="text-xs text-gold-light font-semibold">₹<%= Math.floor(product.minPrice) %></span>
                                <% if (product.originalPrice && product.originalPrice > product.minPrice) { %>
                                    <span class="text-[10px] text-gray-500 line-through">₹<%= Math.floor(product.originalPrice) %></span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Premium Pagination -->
            <% if (totalPages > 1) { %>
                <div class="flex justify-center items-center space-x-6 mt-20 border-t border-gold-light/5 pt-8 text-xs">
                    <% if (currentPage > 1) { %>
                        <a href="javascript:goToPage(<%= currentPage - 1 %>)" class="text-gold-light hover:text-gold-accent transition-colors uppercase tracking-widest flex items-center gap-1.5">
                            <i class="fas fa-chevron-left text-[10px]"></i> Previous
                        </a>
                    <% } else { %>
                        <span class="text-gray-600 uppercase tracking-widest flex items-center gap-1.5 pointer-events-none">
                            <i class="fas fa-chevron-left text-[10px]"></i> Previous
                        </span>
                    <% } %>

                    <div class="flex items-center space-x-3 text-gold-light">
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <a href="javascript:goToPage(<%= i %>)" 
                               class="w-6 h-6 flex items-center justify-center rounded-full font-medium transition-colors
                               <%= i === currentPage ? 'bg-gold-light text-obsidian font-bold' : 'hover:bg-gold-light/10' %>">
                                <%= i %>
                            </a>
                        <% } %>
                    </div>

                    <% if (currentPage < totalPages) { %>
                        <a href="javascript:goToPage(<%= currentPage + 1 %>)" class="text-gold-light hover:text-gold-accent transition-colors uppercase tracking-widest flex items-center gap-1.5">
                            Next <i class="fas fa-chevron-right text-[10px]"></i>
                        </a>
                    <% } else { %>
                        <span class="text-gray-600 uppercase tracking-widest flex items-center gap-1.5 pointer-events-none">
                            Next <i class="fas fa-chevron-right text-[10px]"></i>
                        </span>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <!-- Empty state -->
            <div class="text-center py-24 space-y-4">
                <i class="fas fa-filter text-gray-700 text-3xl"></i>
                <p class="font-display text-xl text-gold-light">No cases match your filters.</p>
                <button onclick="clearAllFilters()" class="text-xs uppercase tracking-widest text-gold-accent hover:underline">Clear All Filters</button>
            </div>
        <% } %>
    </div>
</main>

<script>
    // Filters, category and brand management
    let currentCategoryId = '<%= selectedCategories[0] || "" %>';
    let currentBrandId = '<%= selectedBrands[0] || "" %>';

    function selectCategory(catId) {
        currentCategoryId = catId;
        handleListFilterChange();
    }

    function selectBrand(brandId) {
        currentBrandId = brandId;
        handleListFilterChange();
    }

    function handleListFilterChange() {
        const sort = document.getElementById('sortSelect').value;
        const price = document.getElementById('priceSelect').value;
        
        const params = new URLSearchParams();
        params.append('page', '1');
        
        // Retain search if present in URL
        const urlParams = new URLSearchParams(window.location.search);
        const search = urlParams.get('search');
        if (search) params.append('search', search);

        if (sort) params.append('sort', sort);
        if (currentCategoryId) params.append('Categories', currentCategoryId);
        if (currentBrandId) params.append('Brands', currentBrandId);
        if (price) params.append('price', price);

        window.location.href = `/product?${params.toString()}`;
    }

    function goToPage(page) {
        const urlParams = new URLSearchParams(window.location.search);
        urlParams.set('page', page);
        window.location.href = `/product?${urlParams.toString()}`;
    }

    function clearAllFilters() {
        window.location.href = '/product';
    }

    // AJAX actions with Toastify
    async function addListWishlist(productId, variantId) {
        try {
            const response = await fetch('/product/wishlist/toggle', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId })
            });
            const data = await response.json();
            
            if (data.success) {
                const heart = document.getElementById(`wish-icon-${productId}-${variantId}`);
                if (data.action === "added") {
                    heart.className = "fas fa-heart text-red-500 text-xs sm:text-sm font-bold";
                    showToast("Added to Wishlist", "success");
                } else {
                    heart.className = "far fa-heart text-gold-light text-xs sm:text-sm";
                    showToast("Removed from Wishlist", "success");
                }
                
                const badge = document.getElementById('wishlist-count-badge');
                if (badge && data.wishlistCount !== undefined) {
                    badge.textContent = data.wishlistCount;
                    if (data.wishlistCount > 0) badge.classList.remove('hidden');
                    else badge.classList.add('hidden');
                }
            } else {
                showToast(data.message || "Failed to update wishlist", "error");
            }
        } catch (err) {
            console.error(err);
            showToast("Network error updating wishlist", "error");
        }
    }

    async function addListToCart(productId, variantId) {
        try {
            const response = await fetch('/cart/add', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId })
            });
            
            if (response.status === 401) {
                const data = await response.json();
                showToast(data.message || "Please login first", "error");
                setTimeout(() => window.location.href = data.redirectUrl || '/login', 1500);
                return;
            }

            const data = await response.json();
            if (data.success) {
                showToast("Added to Cart Collection", "success");
                updateCartCountBadges(data.cartCount);
                openCartDrawer();
            } else {
                showToast(data.message || "Failed to add to cart", "error");
            }
        } catch (err) {
            console.error(err);
            showToast("Network error adding to cart", "error");
        }
    }
</script>

<style>
    /* Hide scrollbar for category pills container */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<%- include('../partials/user/footer') %>
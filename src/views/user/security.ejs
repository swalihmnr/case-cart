<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your settings and preferences</p>
        </div>

        <div class="grid lg:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>
            
            <div class="lg:col-span-3 space-y-6">
                <div class="bg-obsidian-light border border-gold-light/5 rounded p-6 md:p-8 shadow-2xl">
                    <div class="max-w-2xl mx-auto lg:mx-0">
                        <!-- Section Title -->
                        <div class="mb-8">
                            <h3 class="font-display text-2xl md:text-3xl font-light text-gold-light tracking-wide">
                                Security Settings
                            </h3>
                            <p class="text-gray-400 text-[10px] uppercase tracking-widest mt-2">
                                Manage your password and security preferences
                            </p>
                        </div>

                        <!-- Change Password Form -->
                        <form id="passwordForm" class="space-y-6">
                            <div>
                                <h4 class="font-display text-lg font-light text-gold-light mb-4">
                                    Change Password
                                </h4>

                                <div class="space-y-4">
                                    <!-- Current Password -->
                                    <div>
                                        <label for="currentPassword" class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                            Current Password
                                        </label>
                                        <div class="relative">
                                            <input type="password" id="currentPassword" name="currentPassword"
                                                placeholder="Enter current password"
                                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm">
                                            <button type="button"
                                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gold-light/50 hover:text-gold-accent toggle-password"
                                                data-target="currentPassword">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                            </button>
                                        </div>
                                        <span id="currentPassErr" class="text-red-400 text-xs block mt-1"></span>
                                    </div>

                                    <!-- New Password -->
                                    <div>
                                        <label for="newPassword" class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                            New Password
                                        </label>
                                        <div class="relative">
                                            <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password"
                                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm">
                                            <button type="button"
                                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gold-light/50 hover:text-gold-accent toggle-password"
                                                data-target="newPassword">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                            </button>
                                        </div>
                                        <span id="newPassErr" class="text-red-400 text-xs block mt-1"></span>

                                        <!-- Password Strength Indicator -->
                                        <div class="mt-3 hidden" id="passwordStrength">
                                            <div class="flex gap-1 mb-1.5">
                                                <div class="h-1 flex-1 bg-obsidian border border-gold-light/5 rounded strength-bar"></div>
                                                <div class="h-1 flex-1 bg-obsidian border border-gold-light/5 rounded strength-bar"></div>
                                                <div class="h-1 flex-1 bg-obsidian border border-gold-light/5 rounded strength-bar"></div>
                                                <div class="h-1 flex-1 bg-obsidian border border-gold-light/5 rounded strength-bar"></div>
                                            </div>
                                            <p class="text-[9px] uppercase tracking-wider text-gray-500" id="strengthText">Password strength</p>
                                        </div>
                                    </div>

                                    <!-- Confirm Password -->
                                    <div>
                                        <label for="confirmPassword" class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                            Confirm New Password
                                        </label>
                                        <div class="relative">
                                            <input type="password" id="confirmPassword" name="confirmPassword"
                                                placeholder="Re-enter new password"
                                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm">
                                            <button type="button"
                                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gold-light/50 hover:text-gold-accent toggle-password"
                                                data-target="confirmPassword">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                            </button>
                                        </div>
                                        <span id="confirmPassErr" class="text-red-400 text-xs block mt-1"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="flex flex-col sm:flex-row gap-3 pt-4">
                                <button type="submit"
                                    class="bg-gold-light text-obsidian hover:bg-gold-accent px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold transition">
                                    Update Password
                                </button>
                                <a href="/user-profile" class="w-full sm:w-auto">
                                    <button type="button" id="cancelBtn"
                                        class="w-full text-center px-6 py-3 border border-gold-light/10 text-gold-light hover:bg-gold-light/5 hover:border-gold-accent rounded text-xs uppercase tracking-widest font-semibold transition">
                                        Cancel
                                    </button>
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function () {
            const targetId = this.getAttribute('data-target');
            const input = document.getElementById(targetId);

            if (input.type === 'password') {
                input.type = 'text';
                this.innerHTML = `
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
                    </svg>
                `;
            } else {
                input.type = 'password';
                this.innerHTML = `
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                `;
            }
        });
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/security.js"></script>

<%- include('../partials/user/footer') %>
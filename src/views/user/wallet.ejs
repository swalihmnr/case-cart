<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your settings and preferences</p>
        </div>

        <div class="grid lg:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <%- include('../partials/user/sidebar') %>
            
            <!-- Main Content Area -->
            <div class="lg:col-span-3 space-y-6">
                <!-- Wallet Card -->
                <div class="bg-obsidian-light border border-gold-light/5 rounded p-6 shadow-2xl">
                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
                        <div>
                            <h3 class="font-display text-2xl font-light text-gold-light tracking-wide mb-1">Wallet</h3>
                            <p class="text-[10px] uppercase tracking-widest text-gray-400">Available Balance</p>
                            <p class="text-3xl font-display font-light text-gold-accent mt-2">
                                ₹ <%= wallet?.balance %>
                            </p>
                        </div>
                        <button onclick="openAddMoneyModal()"
                            class="w-full sm:w-auto bg-gold-light text-obsidian hover:bg-gold-accent px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold flex items-center justify-center space-x-2 transition duration-300 shadow-md">
                            <i class="fas fa-plus text-[10px]"></i>
                            <span>Add Money</span>
                        </button>
                    </div>
                </div>

                <!-- Transaction History -->
                <div class="bg-obsidian-light border border-gold-light/5 rounded overflow-hidden shadow-2xl">
                    <div class="p-6 border-b border-gold-light/10">
                        <h3 class="font-display text-xl font-light text-gold-light tracking-wide">Transaction History</h3>
                    </div>

                    <!-- Desktop Table -->
                    <div class="hidden sm:block overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-obsidian border-b border-gold-light/10">
                                <tr>
                                    <th class="px-6 py-4 text-left text-[10px] font-semibold text-gold-light/85 uppercase tracking-widest">Date</th>
                                    <th class="px-6 py-4 text-left text-[10px] font-semibold text-gold-light/85 uppercase tracking-widest">Description</th>
                                    <th class="px-6 py-4 text-left text-[10px] font-semibold text-gold-light/85 uppercase tracking-widest">Type</th>
                                    <th class="px-6 py-4 text-left text-[10px] font-semibold text-gold-light/85 uppercase tracking-widest">Amount</th>
                                    <th class="px-6 py-4 text-left text-[10px] font-semibold text-gold-light/85 uppercase tracking-widest">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gold-light/5">
                                <% wallet?.transactions.forEach(transaction=> {
                                    const isCredited = transaction.transactionType.toLowerCase() === 'credited';
                                    %>
                                    <tr class="hover:bg-gold-light/5 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-xs text-ivory">
                                            <%= new Date(transaction.date).toLocaleDateString('en-IN') %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-xs text-ivory">
                                            <%= transaction.description %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="px-2.5 py-1 text-[9px] font-bold uppercase tracking-widest rounded <%= isCredited ? 'bg-green-950/30 text-green-400 border border-green-500/20' : 'bg-red-950/30 text-red-400 border border-red-500/20' %>">
                                                <%= transaction.transactionType %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-xs font-semibold <%= isCredited ? 'text-green-400' : 'text-red-400' %>">
                                            <%= (isCredited ? '+' : '-' ) %> ₹<%= transaction.amount %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="flex items-center text-xs <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'text-green-400' : 'text-gray-400' %>">
                                                <i class="fas <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'fa-check-circle' : 'fa-clock' %> mr-1.5 text-[10px]"></i>
                                                <%= transaction.status || 'Success' %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Mobile Card View -->
                    <div class="sm:hidden divide-y divide-gold-light/5">
                        <% if (wallet?.transactions && wallet.transactions.length> 0) { %>
                            <% wallet.transactions.forEach(transaction=> {
                                const isCredited = transaction.transactionType.toLowerCase() === 'credited';
                                %>
                                <div class="p-5 space-y-3">
                                    <div class="flex justify-between items-start">
                                        <div class="max-w-[70%]">
                                            <p class="text-sm font-semibold text-gold-light leading-tight">
                                                <%= transaction.description %>
                                            </p>
                                            <p class="text-[9px] text-gray-500 uppercase tracking-widest mt-1">
                                                <%= new Date(transaction.date).toLocaleDateString('en-IN') %>
                                            </p>
                                        </div>
                                        <span class="px-2 py-0.5 text-[8px] font-bold uppercase tracking-widest rounded <%= isCredited ? 'bg-green-950/30 text-green-400 border border-green-500/20' : 'bg-red-950/30 text-red-400 border border-red-500/20' %>">
                                            <%= transaction.transactionType %>
                                        </span>
                                    </div>
                                    <div class="flex justify-between items-center pt-1">
                                        <p class="text-lg font-display font-light <%= isCredited ? 'text-green-400' : 'text-red-400' %>">
                                            <%= (isCredited ? '+' : '-' ) %> ₹<%= transaction.amount %>
                                        </p>
                                        <span class="flex items-center text-[9px] uppercase tracking-widest font-semibold <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'text-green-400' : 'text-gray-400' %>">
                                            <i class="fas <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i>
                                            <%= transaction.status || 'Success' %>
                                        </span>
                                    </div>
                                </div>
                                <% }) %>
                            <% } else { %>
                                <div class="p-8 text-center bg-obsidian-light">
                                    <div class="w-12 h-12 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center mx-auto mb-3">
                                        <i class="fas fa-receipt text-gold-accent text-sm"></i>
                                    </div>
                                    <p class="text-xs text-gray-550 uppercase tracking-wider">No transactions yet</p>
                                </div>
                            <% } %>
                    </div>
                </div>

                <!-- Pagination Section -->
                <% if (totalPages> 1) { %>
                    <div class="flex items-center justify-center space-x-2 mt-8 pb-8">
                        <!-- Previous Button -->
                        <% if (currentPage> 1) { %>
                            <a href="/wallet?page=<%= currentPage - 1 %>"
                                class="flex items-center justify-center w-10 h-10 rounded border border-gold-light/10 bg-obsidian-light text-gold-light hover:border-gold-accent hover:text-gold-accent transition font-bold">
                                <i class="fas fa-chevron-left text-xs"></i>
                            </a>
                            <% } else { %>
                                <span class="flex items-center justify-center w-10 h-10 rounded border border-gold-light/5 bg-obsidian-light/50 text-gray-600 cursor-not-allowed">
                                    <i class="fas fa-chevron-left text-xs"></i>
                                </span>
                                <% } %>

                        <!-- Page Numbers -->
                        <div class="flex items-center space-x-2">
                            <% let startPage=Math.max(1, currentPage - 2); 
                               let endPage=Math.min(totalPages, startPage + 4); 
                               if (endPage - startPage < 4) startPage=Math.max(1, endPage - 4); 
                               for(let i=startPage; i<=endPage; i++) { %>
                                <a href="/wallet?page=<%= i %>"
                                    class="flex items-center justify-center min-w-[2.5rem] h-10 px-2 rounded border font-semibold text-xs transition
                                          <%= i === currentPage 
                                              ? 'bg-gold-light border-gold-light text-obsidian shadow' 
                                              : 'bg-obsidian-light border-gold-light/10 text-gold-light hover:border-gold-accent hover:text-gold-accent' %>">
                                    <%= i %>
                                </a>
                                <% } %>
                        </div>

                        <!-- Next Button -->
                        <% if (currentPage < totalPages) { %>
                            <a href="/wallet?page=<%= currentPage + 1 %>"
                                class="flex items-center justify-center w-10 h-10 rounded border border-gold-light/10 bg-obsidian-light text-gold-light hover:border-gold-accent hover:text-gold-accent transition font-bold">
                                <i class="fas fa-chevron-right text-xs"></i>
                            </a>
                            <% } else { %>
                                <span class="flex items-center justify-center w-10 h-10 rounded border border-gold-light/5 bg-obsidian-light/50 text-gray-600 cursor-not-allowed">
                                    <i class="fas fa-chevron-right text-xs"></i>
                                </span>
                                <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<!-- Add Money Modal -->
<div id="addMoneyModal"
    class="fixed inset-0 bg-obsidian bg-opacity-75 backdrop-blur-sm hidden items-center justify-center z-50 transition-opacity duration-300">
    <div class="bg-obsidian-light border border-gold-light/10 rounded shadow-2xl w-full max-w-md mx-4 transform transition-all duration-300 scale-95 opacity-0"
        id="modalContent">
        <!-- Modal Header -->
        <div class="p-6 border-b border-gold-light/10">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 border border-gold-light/10 bg-gold-light/5 rounded-full flex items-center justify-center">
                        <i class="fas fa-wallet text-gold-accent text-base"></i>
                    </div>
                    <h3 class="font-display text-xl font-light text-gold-light tracking-wide">Add Money to Wallet</h3>
                </div>
                <button onclick="closeAddMoneyModal()" class="text-gray-400 hover:text-gold-accent transition">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
        </div>

        <!-- Modal Body -->
        <div class="p-6 space-y-6">
            <!-- Current Balance Display -->
            <div class="bg-obsidian border border-gold-light/5 rounded p-4">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1">Current Balance</p>
                <p class="text-2xl font-display font-light text-gold-accent">₹<%= wallet?.balance %></p>
            </div>

            <!-- Amount Input -->
            <div>
                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                    Enter Amount <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gold-light/50 font-medium text-sm">₹</span>
                    <input type="number" id="amount" min="1" step="0.01" placeholder="0.00"
                        class="w-full pl-10 pr-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                        onkeyup="validateAmount()">
                </div>
                <p id="amountError" class="text-red-400 text-xs mt-1 hidden">Please enter a valid amount (minimum ₹1)</p>
            </div>
            
            <!-- Convenience Fee Info -->
            <div class="bg-obsidian border border-gold-light/5 rounded p-4 text-xs">
                <div class="flex justify-between items-center text-gray-400 uppercase tracking-wider">
                    <span>Convenience Fee</span>
                    <span class="font-medium text-gold-light">₹ 0.00</span>
                </div>
                <div class="flex justify-between items-center text-gold-light font-semibold mt-3 pt-3 border-t border-gold-light/10 uppercase tracking-wider">
                    <span>Total Amount</span>
                    <span class="text-base text-gold-accent" id="totalAmount">₹ 0.00</span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                <button onclick="closeAddMoneyModal()"
                    class="flex-1 px-4 py-3 border border-gold-light/10 text-gold-light rounded text-xs uppercase tracking-widest font-semibold hover:bg-gold-light/5 transition">
                    Cancel
                </button>
                <button onclick="processAddMoney()" id="addMoneyBtn"
                    class="flex-1 bg-gold-light text-obsidian hover:bg-gold-accent px-4 py-3 rounded text-xs uppercase tracking-widest font-semibold transition disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center space-x-2">
                    <span>Add Money</span>
                    <i class="fas fa-arrow-right text-[10px]"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/wallet.js"></script>

<%- include('../partials/user/footer') %>
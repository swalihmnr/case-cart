<%- include('../partials/user/header') %>

    <div class="min-h-screen bg-gray-50/50">
        <main class="max-w-7xl mx-auto px-4 py-6 md:py-12">
            <!-- Header Section -->
            <div class="mb-6 md:mb-10 fade-in">
                <h1 class="text-2xl md:text-4xl font-black text-gray-900 mb-1 md:mb-2 italic">My Account</h1>
                <p class="text-gray-500 text-sm md:text-base font-medium">Manage your settings and preferences</p>
            </div>

            <div class="grid lg:grid-cols-4 gap-4 md:gap-8">
                <!-- Sidebar - Mobile Responsive -->
                <%- include('../partials/user/sidebar') %>
                    <!-- Main Content Area -->
                    <div class="lg:col-span-3 space-y-6">
                        <!-- Wallet Section - Responsive Card -->
                        <div class="bg-white rounded-lg shadow p-4 sm:p-6">
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
                                <div>
                                    <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1">Wallet
                                    </h3>
                                    <p class="text-xs sm:text-sm text-gray-600">Available Balance</p>
                                    <p class="text-2xl sm:text-3xl font-bold text-gray-900 mt-1 sm:mt-2">₹ <%=
                                            wallet?.balance %>
                                    </p>
                                </div>
                                <button onclick="openAddMoneyModal()"
                                    class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-4 sm:px-6 py-2.5 sm:py-2 rounded-lg flex items-center justify-center space-x-2 text-sm sm:text-base transition-colors shadow-sm hover:shadow">
                                    <i class="fas fa-plus"></i>
                                    <span>Add Money</span>
                                </button>
                            </div>
                        </div>

                        <!-- Transaction History - Responsive Table -->
                        <div class="bg-white rounded-lg shadow overflow-hidden">
                            <div class="p-4 sm:p-6 border-b">
                                <h3 class="text-base sm:text-lg font-semibold text-gray-900">Transaction History
                                </h3>
                            </div>

                            <!-- Desktop Table (hidden on mobile) -->
                            <div class="hidden sm:block overflow-x-auto">
                                <table class="w-full">
                                    <thead class="bg-gray-50 border-b">
                                        <tr>
                                            <th
                                                class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                Date</th>
                                            <th
                                                class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                Description</th>
                                            <th
                                                class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                Type</th>
                                            <th
                                                class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                Amount</th>
                                            <th
                                                class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200">
                                        <% wallet?.transactions.forEach(transaction=> {
                                            const isCredited = transaction.transactionType.toLowerCase() === 'credited';
                                            %>
                                            <tr class="hover:bg-gray-50 transition-colors">
                                                <td
                                                    class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm text-gray-900">
                                                    <%= new Date(transaction.date).toLocaleDateString('en-IN') %>
                                                </td>
                                                <td
                                                    class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm text-gray-900">
                                                    <%= transaction.description %>
                                                </td>
                                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                                    <span
                                                        class="px-2.5 py-1 text-[10px] font-black uppercase tracking-wider rounded-full <%= isCredited ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                                        <%= transaction.transactionType %>
                                                    </span>
                                                </td>
                                                <td
                                                    class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm font-bold <%= isCredited ? 'text-green-600' : 'text-red-600' %>">
                                                    <%= (isCredited ? '+' : '-' ) %> ₹<%= transaction.amount %>
                                                </td>
                                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                                    <span
                                                        class="flex items-center text-xs sm:text-sm font-medium <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'text-green-600' : 'text-gray-500' %>">
                                                        <i
                                                            class="fas <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i>
                                                        <%= transaction.status || 'Success' %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Mobile Card View (hidden on desktop) -->
                            <div class="sm:hidden divide-y divide-gray-100">
                                <% if (wallet?.transactions && wallet.transactions.length> 0) { %>
                                    <% wallet.transactions.forEach(transaction=> {
                                        const isCredited = transaction.transactionType.toLowerCase() === 'credited';
                                        %>
                                        <div class="p-4 space-y-3">
                                            <div class="flex justify-between items-start">
                                                <div class="max-w-[70%]">
                                                    <p class="text-sm font-bold text-gray-900 leading-tight">
                                                        <%= transaction.description %>
                                                    </p>
                                                    <p
                                                        class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mt-1">
                                                        <%= new Date(transaction.date).toLocaleDateString('en-IN') %>
                                                    </p>
                                                </div>
                                                <span
                                                    class="px-2.5 py-1 text-[9px] font-black uppercase tracking-wider rounded-full <%= isCredited ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' %>">
                                                    <%= transaction.transactionType %>
                                                </span>
                                            </div>
                                            <div class="flex justify-between items-center pt-1">
                                                <p
                                                    class="text-lg font-black <%= isCredited ? 'text-green-600' : 'text-red-600' %>">
                                                    <%= (isCredited ? '+' : '-' ) %> ₹<%= transaction.amount %>
                                                </p>
                                                <span
                                                    class="flex items-center text-[10px] font-black uppercase tracking-wider <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'text-green-600' : 'text-gray-400' %>">
                                                    <i
                                                        class="fas <%= transaction.status === 'Completed' || transaction.status === 'Success' ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i>
                                                    <%= transaction.status || 'Success' %>
                                                </span>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div class="p-8 text-center bg-gray-50">
                                                    <div
                                                        class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                                        <i class="fas fa-receipt text-gray-300"></i>
                                                    </div>
                                                    <p class="text-sm text-gray-500 font-medium">No transactions yet</p>
                                                </div>
                                                <% } %>
                            </div>

                        </div>

                        <!-- Pagination Section -->
                        <% if (totalPages> 1) { %>
                            <div class="flex items-center justify-center space-x-2 mt-8 pb-8">
                                <!-- Previous Button -->
                                <% if (currentPage> 1) { %>
                                    <a href="/wallet?page=<%= currentPage - 1 %>"
                                        class="flex items-center justify-center w-10 h-10 rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-blue-600 transition-all font-bold">
                                        <i class="fas fa-chevron-left text-xs"></i>
                                    </a>
                                    <% } else { %>
                                        <span
                                            class="flex items-center justify-center w-10 h-10 rounded-xl border border-gray-100 bg-gray-50 text-gray-300 cursor-not-allowed">
                                            <i class="fas fa-chevron-left text-xs"></i>
                                        </span>
                                        <% } %>

                                            <!-- Page Numbers -->
                                            <div class="flex items-center space-x-1 sm:space-x-2">
                                                <% let startPage=Math.max(1, currentPage - 2); let
                                                    endPage=Math.min(totalPages, startPage + 4); if (endPage - startPage
                                                    < 4) startPage=Math.max(1, endPage - 4); for(let i=startPage; i
                                                    <=endPage; i++) { %>
                                                    <a href="/wallet?page=<%= i %>"
                                                        class="flex items-center justify-center min-w-[2.5rem] h-10 px-2 rounded-xl border font-bold text-sm transition-all
                                              <%= i === currentPage 
                                                  ? 'bg-blue-600 border-blue-600 text-white shadow-lg shadow-blue-200' 
                                                  : 'bg-white border-gray-200 text-gray-600 hover:border-blue-400 hover:text-blue-600 hover:bg-blue-50' %>">
                                                        <%= i %>
                                                    </a>
                                                    <% } %>
                                            </div>

                                            <!-- Next Button -->
                                            <% if (currentPage < totalPages) { %>
                                                <a href="/wallet?page=<%= currentPage + 1 %>"
                                                    class="flex items-center justify-center w-10 h-10 rounded-xl border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-blue-600 transition-all font-bold">
                                                    <i class="fas fa-chevron-right text-xs"></i>
                                                </a>
                                                <% } else { %>
                                                    <span
                                                        class="flex items-center justify-center w-10 h-10 rounded-xl border border-gray-100 bg-gray-50 text-gray-300 cursor-not-allowed">
                                                        <i class="fas fa-chevron-right text-xs"></i>
                                                    </span>
                                                    <% } %>
                            </div>
                            <% } %>
                    </div>
            </div>
        </main>
    </div>

    <!-- Add Money Modal -->
    <div id="addMoneyModal"
        class="fixed inset-0 bg-gray-900 bg-opacity-50 backdrop-blur-sm hidden items-center justify-center z-50 transition-opacity duration-300">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 transform transition-all duration-300 scale-95 opacity-0"
            id="modalContent">
            <!-- Modal Header -->
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                            <i class="fas fa-wallet text-blue-600 text-lg"></i>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900">Add Money to Wallet</h3>
                    </div>
                    <button onclick="closeAddMoneyModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
            </div>

            <!-- Modal Body -->
            <div class="p-6 space-y-6">
                <!-- Current Balance Display -->
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-4">
                    <p class="text-sm text-gray-600 mb-1">Current Balance</p>
                    <!-- <p class="text-2xl font-bold text-gray-900">₹<%= wallet?.balance %> </p> -->
                </div>

                <!-- Amount Input -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Enter Amount <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <span
                            class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500 font-medium">₹</span>
                        <input type="number" id="amount" min="1" step="0.01" placeholder="0.00"
                            class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                            onkeyup="validateAmount()">
                    </div>
                    <p id="amountError" class="text-red-500 text-xs mt-1 hidden">Please enter a valid amount
                        (minimum ₹1)</p>
                </div>
                <!-- Convenience Fee Info -->
                <div class="bg-gray-50 rounded-xl p-4 text-sm">
                    <div class="flex justify-between items-center text-gray-600">
                        <span>Convenience Fee</span>
                        <span class="font-medium">₹ 0.00</span>
                    </div>
                    <div
                        class="flex justify-between items-center text-gray-900 font-semibold mt-2 pt-2 border-t border-gray-200">
                        <span>Total Amount</span>
                        <span class="text-lg" id="totalAmount">₹ 0.00</span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-3 pt-2">
                    <button onclick="closeAddMoneyModal()"
                        class="flex-1 px-4 py-3 border border-gray-300 text-gray-700 rounded-xl hover:bg-gray-50 transition-colors font-medium">
                        Cancel
                    </button>
                    <button onclick="processAddMoney()" id="addMoneyBtn"
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-4 py-3 rounded-xl transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center space-x-2">
                        <span>Add Money</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Menu Toggle Script -->

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://kit.fontawesome.com/your-fontawesome-kit.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="/js/user/wallet.js"></script>

    <%- include('../partials/user/footer') %>
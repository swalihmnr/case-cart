<%- include('../partials/user/header') %>

<main class="bg-obsidian min-h-screen text-ivory pt-28 pb-16">
    <%
      let displayImages = [];
      if (product.productImages && product.productImages.length > 0) {
          displayImages = product.productImages;
      } else if (product.variants && product.variants.length > 0) {
          // Find the first variant that has images
          const variantWithImages = product.variants.find(v => v.images && v.images.length > 0);
          if (variantWithImages) {
              displayImages = variantWithImages.images;
          } else if (product.variants[0] && product.variants[0].images) {
              displayImages = product.variants[0].images;
          }
      }
      
      let mainImgUrl = '/img/placeholder.jpg';
      if (displayImages.length > 0) {
          const mainImg = displayImages.find(img => img.isMain);
          if (mainImg) mainImgUrl = mainImg.url;
          else mainImgUrl = displayImages[0].url;
      }
    %>
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
        
        <!-- Breadcrumb -->
        <div class="flex items-center space-x-2 text-[10px] uppercase tracking-widest text-gray-500 mb-8 border-b border-gold-light/5 pb-4">
            <a href="/" class="hover:text-gold-light transition-colors">Home</a>
            <span>/</span>
            <a href="/product" class="hover:text-gold-light transition-colors">Products</a>
            <span>/</span>
            <span class="text-gold-accent"><%= product.name %></span>
        </div>

        <!-- Product Grid -->
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
            
            <!-- Left Side: Interactive Gallery (5/12 columns) -->
            <div class="lg:col-span-6 space-y-6">
                <div class="product-image-container relative flex flex-col md:flex-row gap-4">
                    <!-- Thumbnails -->
                    <div id="thumbnailContainer" class="flex md:flex-col gap-3 order-2 md:order-1 overflow-x-auto md:overflow-x-visible pb-2 md:pb-0">
                        <% displayImages.forEach((img, idx) => { %>
                            <button onclick="changeMainImage('<%= img.url %>', this)" 
                                    class="thumbnail-item w-14 h-18 md:w-16 md:h-20 bg-obsidian-light border rounded flex-shrink-0 p-2 flex items-center justify-center transition-all duration-300
                                    <%= (img.isMain || (!displayImages.some(i => i.isMain) && idx === 0)) ? 'border-gold-accent bg-gold-light/5' : 'border-gold-light/10 hover:border-gold-light/40' %>">
                                <img src="<%= img.url %>" alt="Thumbnail" class="w-full h-full object-contain">
                            </button>
                        <% }) %>
                    </div>

                    <!-- Main Image Wrapper -->
                    <div class="main-image-wrapper flex-1 bg-obsidian-light border border-gold-light/5 rounded p-8 flex items-center justify-center relative min-h-[400px] sm:min-h-[500px] cursor-crosshair order-1 md:order-2"
                         onmousemove="handleImageHover(event)"
                         onmouseenter="showZoomPreview()"
                         onmouseleave="hideZoomPreview()">
                        
                        <img id="mainImageTag" 
                             src="<%= mainImgUrl %>" 
                             alt="<%= product.name %>" 
                             class="max-h-[400px] object-contain transition-transform duration-300">
                        
                        <div id="zoomLens" class="zoom-lens absolute border border-gold-accent/40 bg-gold-light/5 pointer-events-none hidden"></div>
                        
                        <!-- Zoom Hint overlay -->
                        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-obsidian/80 border border-gold-light/10 text-[9px] uppercase tracking-widest px-3 py-1.5 rounded-full flex items-center gap-1.5 text-gray-400">
                            <i class="fas fa-search-plus text-gold-light"></i> Hover to Zoom
                        </div>
                    </div>

                    <!-- Zoom Preview Box (positioned dynamically by JS) -->
                    <div id="zoomPreviewContainer" class="zoom-preview-container absolute border border-gold-light/10 bg-obsidian-light overflow-hidden hidden shadow-2xl rounded z-[110] w-[400px] h-[400px]">
                        <div id="zoomPreviewImage" class="zoom-preview-image w-full h-full bg-no-repeat"></div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Details & Actions (6/12 columns) -->
            <div class="lg:col-span-6 space-y-8">
                <!-- Header Info -->
                <div class="space-y-3">
                    <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">
                        <%= product.catgId ? product.catgId.name : 'Premium Protective Wear' %>
                    </p>
                    <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-light tracking-wide text-gold-light leading-tight">
                        <%= product.name %>
                    </h1>
                </div>

                <!-- Price display -->
                <div class="space-y-2">
                    <div class="flex items-baseline space-x-3">
                        <span id="sale-span" class="text-3xl font-light text-gold-light">₹<%= Math.floor(product.variants[0]?.salePrice || product.variants[0]?.orgPrice) %></span>
                        <span id="org-span" class="text-sm text-gray-500 line-through">₹<%= Math.floor(product.variants[0]?.orgPrice) %></span>
                    </div>
                    <p id="stock-count" class="text-[10px] uppercase tracking-widest font-semibold text-gray-400"></p>
                </div>

                <!-- Special Offer Banner -->
                <div id="special-offer-badge" class="border border-gold-accent/20 bg-gold-light/5 p-4 rounded-sm hidden flex items-start gap-3">
                    <span class="text-gold-accent mt-0.5"><i class="fas fa-bolt"></i></span>
                    <div class="space-y-1">
                        <div class="flex items-center gap-2">
                            <span id="offer-name" class="text-xs uppercase tracking-wider font-semibold text-gold-light"></span>
                            <span id="offer-discount" class="bg-gold-accent text-obsidian text-[9px] uppercase tracking-widest font-bold px-2 py-0.5 rounded-full"></span>
                        </div>
                        <p class="text-[10px] text-gray-400">Exclusive discount applied instantly upon checkout.</p>
                    </div>
                </div>

                <!-- Description -->
                <div class="space-y-2">
                    <h4 class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">Description</h4>
                    <p class="text-xs text-gray-400 leading-relaxed font-light"><%= product.description %></p>
                </div>

                <!-- Device selection list -->
                <div class="space-y-3">
                    <label class="block text-[10px] uppercase tracking-widest text-gold-accent font-medium">Select Device Model</label>
                    <div class="flex flex-wrap gap-2.5">
                        <% product.variants.forEach((variant, index) => { %>
                            <% if (variant.isListed) { %>
                                <button type="button" 
                                        onclick="selectVariant('<%= product._id %>', '<%= variant._id %>', this)"
                                        class="device-btn px-4 py-2 border rounded text-xs uppercase tracking-wider transition-all duration-300
                                        <%= index === 0 ? 'border-gold-accent bg-gold-light/10 text-gold-light' : 'border-gold-light/10 text-gray-400 hover:border-gold-light/40' %>"
                                        data-index="<%= index %>">
                                    <%= variant.deviceModel %>
                                </button>
                            <% } %>
                        <% }) %>
                    </div>
                </div>

                <!-- Action Button Matrix -->
                <div class="flex flex-col sm:flex-row gap-4 border-t border-gold-light/5 pt-8">
                    <button onclick="addToCart()" 
                            class="flex-1 bg-gold-light hover:bg-gold-accent text-obsidian py-4 rounded-sm text-xs uppercase tracking-widest font-semibold transition-colors duration-300">
                        Add to Cart
                    </button>
                    
                    <button onclick="buyNow()" 
                            class="flex-1 border border-gold-light text-gold-light hover:bg-gold-light hover:text-obsidian py-4 rounded-sm text-xs uppercase tracking-widest font-semibold transition-all duration-300">
                        Buy Now
                    </button>
                    
                    <% if (user) { %>
                        <button onclick="toggleWishlist()" id="wishlist-btn" 
                                class="w-14 h-14 border border-gold-light/10 hover:border-gold-accent rounded-sm flex items-center justify-center transition-colors duration-300">
                            <i id="wishlist-icon" class="far fa-heart text-gold-light text-lg"></i>
                        </button>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Related Products Section -->
        <% if (relatedProducts && relatedProducts.length > 0) { %>
            <div class="mt-32 border-t border-gold-light/5 pt-16 space-y-12">
                <div class="space-y-2 text-center md:text-left">
                    <p class="text-[10px] uppercase tracking-widest text-gold-accent font-medium">Elevate Your Set</p>
                    <h2 class="font-display text-2xl sm:text-3xl font-light tracking-wide text-gold-light">You May Also Like</h2>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% relatedProducts.forEach(rel => { 
                        let relImageUrl = '/img/placeholder.jpg';
                        if (rel.productImages && rel.productImages.length > 0) {
                            const mainImg = rel.productImages.find(img => img.isMain);
                            if (mainImg) relImageUrl = mainImg.url;
                            else if (rel.productImages[0]) relImageUrl = rel.productImages[0].url;
                        } else if (rel.minVariant && rel.minVariant.images && rel.minVariant.images.length > 0) {
                            const mainImg = rel.minVariant.images.find(img => img.isMain);
                            if (mainImg) relImageUrl = mainImg.url;
                            else if (rel.minVariant.images[0]) relImageUrl = rel.minVariant.images[0].url;
                        } else if (rel.variants && rel.variants[0] && rel.variants[0].images && rel.variants[0].images.length > 0) {
                            const mainImg = rel.variants[0].images.find(img => img.isMain);
                            if (mainImg) relImageUrl = mainImg.url;
                            else if (rel.variants[0].images[0]) relImageUrl = rel.variants[0].images[0].url;
                        }
                    %>
                        <!-- Product Card -->
                        <div class="group flex flex-col space-y-4">
                            <!-- Image container -->
                            <div class="relative aspect-[3/4] bg-obsidian-light border border-gold-light/5 group-hover:border-gold-light/20 overflow-hidden flex items-center justify-center transition-colors duration-300">
                                <a href="/product/<%= rel._id %>/detials" class="block w-full h-full">
                                    <img src="<%= relImageUrl %>" 
                                         alt="<%= rel.name %>" 
                                         class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out">
                                </a>
                            </div>

                            <!-- Info -->
                            <div class="space-y-1 text-center md:text-left">
                                <p class="text-[9px] uppercase tracking-widest text-gold-accent font-medium">Artifact</p>
                                <h3 class="font-display text-sm tracking-wide text-gold-light font-light truncate">
                                    <a href="/product/<%= rel._id %>/detials" class="hover:text-gold-accent transition-colors">
                                        <%= rel.name %>
                                    </a>
                                </h3>
                                <p class="text-xs text-gold-light/70">₹<%= Math.floor(rel.minVariant ? (rel.minVariant.salePrice || rel.minVariant.orgPrice) : 399) %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>
</main>

<script>
    // Initial wishlistItems state
    window.wishlistItems = <%- JSON.stringify(wishlistItems || []) %>;
</script>
<script type="module" src="/js/user/product-detials.js"></script>

<%- include('../partials/user/footer') %>
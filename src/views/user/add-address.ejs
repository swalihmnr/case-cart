<%- include('../partials/user/header') %>

<div class="min-h-screen bg-obsidian text-ivory font-sans">
    <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
        <!-- Page Header -->
        <div class="mb-10 fade-in">
            <h1 class="font-display text-4xl font-light text-gold-light tracking-wide mb-2">My Account</h1>
            <p class="text-gray-400 text-xs uppercase tracking-wider">Manage your account settings and preferences</p>
        </div>
        
        <div class="grid lg:grid-cols-4 gap-8">
            <%- include('../partials/user/sidebar') %>
            
            <div class="lg:col-span-3">
                <div class="bg-obsidian-light border border-gold-light/5 rounded p-6 md:p-8 shadow-2xl">
                    <h3 class="font-display text-2xl font-light text-gold-light tracking-wide mb-6">Add Address</h3>
                    
                    <form class="space-y-6" id="addressForm">
                        <!-- First Name & Last Name -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- First Name -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    First Name *
                                </label>
                                <input
                                    type="text"
                                    id="first-name"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="Enter first name"
                                >
                                <p class="text-xs text-red-500 mt-1" id="firstNameError"></p>
                            </div>

                            <!-- Last Name -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    Last Name *
                                </label>
                                <input
                                    type="text"
                                    id="last-name"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="Enter last name"
                                >
                                <p class="text-xs text-red-500 mt-1" id="lastNameError"></p>
                            </div>
                        </div>

                        <!-- Phone Number -->
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                Phone Number *
                            </label>
                            <input
                                type="tel"
                                id="phone"
                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                placeholder="Enter phone number"
                            >
                            <p class="text-xs text-red-500 mt-1" id="phoneError"></p>
                        </div>

                        <!-- Street Address -->
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                Street Address *
                            </label>
                            <input
                                type="text"
                                id="line1"
                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                placeholder="House No, Building Name"
                            >
                            <p class="text-xs text-red-500 mt-1" id="line1Error"></p>
                        </div>

                        <!-- Landmark -->
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                Landmark (Optional)
                            </label>
                            <input
                                type="text"
                                id="landmark"
                                class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                placeholder="Near school, hospital etc."
                            >
                        </div>

                        <!-- City / State / PIN -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <!-- City -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    City *
                                </label>
                                <input
                                    type="text"
                                    id="city"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="City"
                                >
                                <p class="text-xs text-red-500 mt-1" id="cityError"></p>
                            </div>

                            <!-- State -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    State *
                                </label>
                                <select
                                    id="state"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm appearance-none"
                                >
                                    <option value="" class="bg-obsidian">Select State</option>
                                    <option class="bg-obsidian">Andhra Pradesh</option>
                                    <option class="bg-obsidian">Arunachal Pradesh</option>
                                    <option class="bg-obsidian">Assam</option>
                                    <option class="bg-obsidian">Bihar</option>
                                    <option class="bg-obsidian">Chhattisgarh</option>
                                    <option class="bg-obsidian">Goa</option>
                                    <option class="bg-obsidian">Gujarat</option>
                                    <option class="bg-obsidian">Haryana</option>
                                    <option class="bg-obsidian">Himachal Pradesh</option>
                                    <option class="bg-obsidian">Jharkhand</option>
                                    <option class="bg-obsidian">Karnataka</option>
                                    <option class="bg-obsidian">Kerala</option>
                                    <option class="bg-obsidian">Madhya Pradesh</option>
                                    <option class="bg-obsidian">Maharashtra</option>
                                    <option class="bg-obsidian">Manipur</option>
                                    <option class="bg-obsidian">Meghalaya</option>
                                    <option class="bg-obsidian">Mizoram</option>
                                    <option class="bg-obsidian">Nagaland</option>
                                    <option class="bg-obsidian">Odisha</option>
                                    <option class="bg-obsidian">Punjab</option>
                                    <option class="bg-obsidian">Rajasthan</option>
                                    <option class="bg-obsidian">Sikkim</option>
                                    <option class="bg-obsidian">Tamil Nadu</option>
                                    <option class="bg-obsidian">Telangana</option>
                                    <option class="bg-obsidian">Tripura</option>
                                    <option class="bg-obsidian">Uttar Pradesh</option>
                                    <option class="bg-obsidian">Uttarakhand</option>
                                    <option class="bg-obsidian">West Bengal</option>
                                    <option class="bg-obsidian">Delhi</option>
                                </select>
                                <p class="text-xs text-red-500 mt-1" id="stateError"></p>
                            </div>

                            <!-- PIN -->
                            <div>
                                <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-2 font-medium">
                                    PIN Code *
                                </label>
                                <input
                                    type="text"
                                    id="pincode"
                                    class="w-full px-4 py-3 bg-obsidian border border-gold-light/10 rounded focus:outline-none focus:border-gold-accent transition text-ivory text-sm"
                                    placeholder="PIN Code"
                                >
                                <p class="text-xs text-red-500 mt-1" id="pincodeError"></p>
                            </div>
                        </div>

                        <!-- Address Type -->
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-gold-light/80 mb-3 font-medium">
                                Address Type *
                            </label>
                            <div class="flex space-x-6">
                                <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                    <input type="radio" name="addressType" value="Home" checked class="accent-gold-accent w-4 h-4 mr-2">
                                    Home
                                </label>
                                <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                    <input type="radio" name="addressType" value="Work" class="accent-gold-accent w-4 h-4 mr-2">
                                    Work
                                </label>
                                <label class="flex items-center cursor-pointer text-xs uppercase tracking-wider text-gray-400 hover:text-gold-light transition">
                                    <input type="radio" name="addressType" value="Other" class="accent-gold-accent w-4 h-4 mr-2">
                                    Other
                                </label>
                            </div>
                            <p class="text-xs text-red-500 mt-1" id="addressTypeError"></p>
                        </div>

                        <!-- Default Address -->
                        <div class="flex items-center">
                            <input
                                type="checkbox"
                                id="isDefault"
                                checked
                                class="w-4 h-4 accent-gold-accent rounded"
                            >
                            <label class="ml-2 text-xs uppercase tracking-wider text-gray-400 cursor-pointer">
                                Set as default address
                            </label>
                        </div>

                        <!-- Buttons -->
                        <div class="flex flex-col sm:flex-row gap-3 pt-4">
                            <button
                                type="submit"
                                class="bg-gold-light text-obsidian hover:bg-gold-accent px-6 py-3 rounded text-xs uppercase tracking-widest font-semibold transition"
                            >
                                Save Address
                            </button>
                            <a href="/address">
                                <button
                                    type="button"
                                    class="px-6 py-3 border border-gold-light/10 text-gold-light hover:bg-gold-light/5 hover:border-gold-accent rounded text-xs uppercase tracking-widest font-semibold transition"
                                >
                                    Cancel
                                </button>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/address.js"></script>
<%- include('../partials/user/footer') %>

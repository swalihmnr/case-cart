<%- include('../partials/user/header') %>

<main class="container mx-auto px-4 py-8 md:py-12">
    <!-- Success Animation -->
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10 mb-6">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-4">
                    <i class="fas fa-check text-green-600 text-4xl checkmark-animate"></i>
                </div>
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
                <p class="text-gray-600 text-lg">Thank you for your purchase</p>
                <% if (order.userEmail) { %>
                <p class="text-sm text-gray-500 mt-2">A confirmation email has been sent to <span class="font-semibold"><%= order.userEmail %></span></p>
                <% } %>
            </div>

            <!-- Order Info Cards -->
            <div class="grid md:grid-cols-3 gap-4 mb-8">
                <div class="bg-purple-50 rounded-xl p-4 text-center">
                    <i class="fas fa-receipt text-purple-600 text-2xl mb-2"></i>
                    <p class="text-sm text-gray-600">Order Number</p>
                    <p class="font-bold text-gray-900">#<%= order.orderId %></p>
                </div>
                <div class="bg-blue-50 rounded-xl p-4 text-center">
                    <i class="fas fa-calendar text-blue-600 text-2xl mb-2"></i>
                    <p class="text-sm text-gray-600">Order Date</p>
                    <p class="font-bold text-gray-900">
                        <%= new Date(order.createdAt).toLocaleDateString("en-US", {
                            month: "short",
                            day: "2-digit",
                            year: "numeric"
                        }) %>
                    </p>
                </div>
                <div class="bg-green-50 rounded-xl p-4 text-center">
                    <i class="fas fa-truck text-green-600 text-2xl mb-2"></i>
                    <p class="text-sm text-gray-600">Estimated Delivery</p>
                    <%
                        const date = new Date(order.createdAt);
                        date.setDate(date.getDate() + 7);
                    %>
                    <p class="font-bold text-gray-900">
                        <%= date.toLocaleDateString("en-US", {
                            month: "short",
                            day: "2-digit",
                            year: "numeric"
                        }) %>
                    </p>
                </div>
            </div>

            <!-- Order Timeline -->
            <%
                function formatDateTime(date) {
                    if (!date) return "Pending";
                    return new Date(date).toLocaleString("en-US", {
                        month: "short",
                        day: "2-digit",
                        year: "numeric",
                        hour: "2-digit",
                        minute: "2-digit",
                        hour12: true
                    });
                }

                // Find the first order item for timeline
                const firstItem = order.orderItems && order.orderItems.length > 0 ? order.orderItems[0] : null;
                
                const isProcessing = firstItem && firstItem.status === "processing";
                const isShipped = firstItem && firstItem.status === "shipped";
                const isDelivered = firstItem && firstItem.status === "delivered";
            %>

            <div class="bg-gray-50 rounded-xl p-6 mb-8">
                <h3 class="font-semibold text-gray-900 mb-4">Order Status</h3>
                <div class="space-y-4">
                    <!-- Order Placed -->
                    <div class="flex items-center">
                        <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                            <i class="fas fa-check text-white text-sm"></i>
                        </div>
                        <div class="ml-4">
                            <p class="font-semibold text-gray-900">Order Placed</p>
                            <p class="text-sm text-gray-500">
                                <%= formatDateTime(order.createdAt) %>
                            </p>
                        </div>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex items-center ml-4">
                        <div class="w-0.5 h-8 bg-gray-300"></div>
                    </div>
                    
                    <!-- Payment Confirmed -->
                    <div class="flex items-center">
                        <div class="w-8 h-8 <%= order.paymentStatus === 'paid' ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                            <% if (order.paymentStatus === 'paid') { %>
                                <i class="fas fa-check text-white text-sm"></i>
                            <% } else { %>
                                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                            <% } %>
                        </div>
                        <div class="ml-4">
                            <p class="font-semibold <%= order.paymentStatus === 'paid' ? 'text-gray-900' : 'text-gray-500' %>">
                                Payment Confirmed
                            </p>
                            <p class="text-sm text-gray-400">
                                <%= formatDateTime(order.paymentConfirmedAt) %>
                            </p>
                        </div>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex items-center ml-4">
                        <div class="w-0.5 h-8 bg-gray-300"></div>
                    </div>
                    
                    <!-- Processing -->
                    <div class="flex items-center">
                        <div class="w-8 h-8 <%= isProcessing ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                            <% if (isProcessing) { %>
                                <i class="fas fa-check text-white text-sm"></i>
                            <% } else { %>
                                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                            <% } %>
                        </div>
                        <div class="ml-4">
                            <p class="font-semibold <%= isProcessing ? 'text-gray-900' : 'text-gray-500' %>">
                                Processing
                            </p>
                            <p class="text-sm text-gray-400">
                                <%= firstItem && firstItem.status === 'processing' ? formatDateTime(firstItem.updatedAt) : 'Pending' %>
                            </p>
                        </div>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex items-center ml-4">
                        <div class="w-0.5 h-8 bg-gray-300"></div>
                    </div>
                    
                    <!-- Shipped -->
                    <div class="flex items-center">
                        <div class="w-8 h-8 <%= isShipped ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                            <% if (isShipped) { %>
                                <i class="fas fa-check text-white text-sm"></i>
                            <% } else { %>
                                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                            <% } %>
                        </div>
                        <div class="ml-4">
                            <p class="font-semibold <%= isShipped ? 'text-gray-900' : 'text-gray-500' %>">
                                Shipped
                            </p>
                            <p class="text-sm text-gray-400">
                                <%= firstItem && firstItem.shippedAt ? formatDateTime(firstItem.shippedAt) : 'Pending' %>
                            </p>
                        </div>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex items-center ml-4">
                        <div class="w-0.5 h-8 bg-gray-300"></div>
                    </div>
                    
                    <!-- Delivered -->
                    <div class="flex items-center">
                        <div class="w-8 h-8 <%= isDelivered ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                            <% if (isDelivered) { %>
                                <i class="fas fa-check text-white text-sm"></i>
                            <% } else { %>
                                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                            <% } %>
                        </div>
                        <div class="ml-4">
                            <p class="font-semibold <%= isDelivered ? 'text-gray-900' : 'text-gray-500' %>">
                                Delivered
                            </p>
                            <p class="text-sm text-gray-400">
                                <%= firstItem && firstItem.deliveredAt ? formatDateTime(firstItem.deliveredAt) : 'Pending' %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Details -->
            <div class="border-t border-gray-200 pt-6 mb-8">
                <h3 class="font-semibold text-gray-900 mb-4">Order Items</h3>
                
                <% if (order.orderItems && order.orderItems.length > 0) { %>
                    <% order.orderItems.forEach(item => { 
                        // Find main image
                        let mainImageUrl = 'https://via.placeholder.com/150';
                        if (item.productId && item.productId.productImages) {
                            const mainImage = item.productId.productImages.find(img => img.isMain);
                            if (mainImage && mainImage.url) {
                                mainImageUrl = mainImage.url;
                            }
                        }
                        
                        // Calculate savings
                        const originalPrice = item.variantId ? item.variantId.salePrice : (item.productId ? item.productId.minPrice : 0);
                        const savings = originalPrice - item.finalPrice;
                    %>
                        <div class="flex items-center space-x-4 mb-4 pb-4 border-b border-gray-100">
                            <img src="<%= mainImageUrl %>" 
                                 alt="<%= item.productId ? item.productId.name : 'Product' %>" 
                                 class="w-20 h-20 object-cover rounded-lg">
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-900"><%= item.productId ? item.productId.name : 'Product' %></h4>
                                <% if (item.variantId && item.variantId.deviceModel) { %>
                                <p class="text-sm text-gray-500"><%= item.variantId.deviceModel %></p>
                                <% } %>
                                <p class="text-sm text-gray-600 mt-1">Qty: <%= item.quantity %></p>
                                
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-gray-900">₹<%= item.finalPrice.toFixed(2) %></p>
                                <% if (savings > 0) { %>
                                <p class="text-sm text-gray-400 line-through">₹<%= originalPrice.toFixed(2) %></p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-4">No items found in this order</p>
                <% } %>
            </div>

            <!-- Order Summary -->
            <div class="bg-gray-50 rounded-xl p-6">
                <h3 class="font-semibold text-gray-900 mb-4">Order Summary</h3>
                <div class="space-y-2">
                    <!-- Subtotal -->
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal (<%= order.orderItems ? order.orderItems.length : 0 %> items)</span>
                        <span>₹<%= order.totalPrice ? order.totalPrice.toFixed(2) : '0.00' %></span>
                    </div>
                    
                    <!-- Product Discount -->
                    <% if (order.totalDiscount && order.totalDiscount > 0) { %>
                    <div class="flex justify-between text-green-600">
                        <span>Product Discount</span>
                        <span>-₹<%= order.totalDiscount.toFixed(2) %></span>
                    </div>
                    <% } %>
                    
                    <!-- Coupon Discount -->
                    <% if (order.couponDiscount && order.couponDiscount > 0) { %>
                    <div class="flex justify-between text-green-600">
                        <span>Coupon Discount</span>
                        <span>-₹<%= order.couponDiscount.toFixed(2) %></span>
                    </div>
                    
                    <!-- Coupon Details -->
                    <div class="bg-green-50 rounded-lg p-3 mt-2 mb-2">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-medium text-green-800">
                                    <i class="fas fa-ticket-alt mr-2"></i>
                                    <%= order.couponCode || 'Coupon Applied' %>
                                </p>
                                <% if (order.couponDetails) { %>
                                <p class="text-xs text-green-600 mt-1"><%= order.couponDetails %></p>
                                <% } %>
                            </div>
                            <span class="text-xs bg-green-200 text-green-800 px-2 py-1 rounded-full">
                                <% if (order.couponType === 'percentage') { %>
                                <%= order.couponValue %>% OFF
                                <% } else { %>
                                ₹<%= order.couponValue %> OFF
                                <% } %>
                            </span>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Shipping -->
                    <div class="flex justify-between text-gray-600">
                        <span>Shipping</span>
                        <span class="<%= order.shipping === 0 ? 'text-green-600 font-semibold' : '' %>">
                            <%= order.shipping === 0 ? 'Free' : '₹' + order.shipping.toFixed(2) %>
                        </span>
                    </div>
                    
                    <!-- Total Savings -->
                    <%
                        const totalSavings = (order.totalDiscount || 0) + (order.couponDiscount || 0);
                        if (totalSavings > 0) {
                    %>
                    <div class="flex justify-between items-center pt-2 mt-2 border-t border-gray-300">
                        <span class="text-sm font-medium text-green-700">Total Savings</span>
                        <span class="text-lg font-bold text-green-700">-₹<%= totalSavings.toFixed(2) %></span>
                    </div>
                    <% } %>
                    
                    <!-- Grand Total -->
                    <div class="border-t border-gray-300 pt-2 mt-2">
                        <div class="flex justify-between text-xl font-bold text-gray-900">
                            <span>Total Amount</span>
                            <span>₹<%= order.finalAmount ? order.finalAmount.toFixed(2) : '0.00' %></span>
                        </div>
                        <p class="text-xs text-gray-500 mt-1 text-right">(Inclusive of all taxes)</p>
                    </div>
                </div>
            </div>

            <!-- Shipping & Payment Info -->
            <div class="grid md:grid-cols-2 gap-6 mt-8 pt-6 border-t border-gray-200">
                <div>
                    <h3 class="font-semibold text-gray-900 mb-3 flex items-center">
                        <i class="fas fa-shipping-fast text-purple-600 mr-2"></i>
                        Shipping Address
                    </h3>
                    <div class="text-gray-600 text-sm space-y-1">
                        <% if (order.shippingAddress) { %>
                            <p class="font-semibold text-gray-900">
                                <%= order.shippingAddress.firstName || '' %> <%= order.shippingAddress.lastName || '' %>
                            </p>
                            <p><%= order.shippingAddress.streetAddress || '' %></p>
                            <% if (order.shippingAddress.landMark) { %>
                            <p><%= order.shippingAddress.landMark %></p>
                            <% } %>
                            <p><%= order.shippingAddress.city || '' %>, <%= order.shippingAddress.state || '' %> - <%= order.shippingAddress.pinCode || '' %></p>
                            <p class="mt-2">Phone: +91 <%= order.shippingAddress.phone || '' %></p>
                        <% } else { %>
                            <p class="text-gray-500">No shipping address available</p>
                        <% } %>
                    </div>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-900 mb-3 flex items-center">
                        <i class="fas fa-credit-card text-purple-600 mr-2"></i>
                        Payment Information
                    </h3>
                    <div class="text-gray-600 text-sm space-y-1">
                        <div class="flex items-center space-x-2">
                            <% if (order.paymentMethod === 'cod') { %>
                                <i class="fas fa-money-bill-wave text-green-600"></i>
                                <span>Cash on Delivery</span>
                            <% } else if (order.paymentMethod === 'razorpay') { %>
                                <i class="fas fa-credit-card text-blue-600"></i>
                                <span>Online Payment (Razorpay)</span>
                            <% } else if (order.paymentMethod === 'wallet') { %>
                                <i class="fas fa-wallet text-yellow-600"></i>
                                <span>Wallet Payment</span>
                            <% } else { %>
                                <span><%= order.paymentMethod || 'Not specified' %></span>
                            <% } %>
                        </div>
                        
                        <div class="mt-2">
                            <% if (order.paymentStatus === "paid") { %>
                                <p class="text-green-600 font-semibold flex items-center">
                                    <i class="fas fa-check-circle mr-2"></i>
                                    Payment Successful
                                </p>
                                <% if (order.transactionId) { %>
                                <p class="text-xs text-gray-500 mt-1">Transaction ID: <%= order.transactionId %></p>
                                <% } %>
                            <% } else if (order.paymentStatus === "pending") { %>
                                <p class="text-yellow-600 font-semibold flex items-center">
                                    <i class="fas fa-clock mr-2"></i>
                                    Payment Pending
                                </p>
                            <% } else if (order.paymentStatus === "failed") { %>
                                <p class="text-red-600 font-semibold flex items-center">
                                    <i class="fas fa-times-circle mr-2"></i>
                                    Payment Failed
                                </p>
                            <% } else { %>
                                <p class="text-gray-500 font-semibold">Payment Status: <%= order.paymentStatus || 'Unknown' %></p>
                            <% } %>
                        </div>
                        
                        <% if (order.paymentDate) { %>
                        <p class="text-xs text-gray-500 mt-2">
                            Paid on: <%= formatDateTime(order.paymentDate) %>
                        </p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 mt-8 pt-6 border-t border-gray-200">
                <a href="/orders" 
                   class="flex-1 bg-purple-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-700 transition flex items-center justify-center space-x-2">
                    <i class="fas fa-list"></i>
                    <span>View All Orders</span>
                </a>
                <a href="/products" 
                   class="flex-1 bg-white border-2 border-purple-600 text-purple-600 px-6 py-3 rounded-lg font-semibold hover:bg-purple-50 transition flex items-center justify-center space-x-2">
                    <i class="fas fa-shopping-bag"></i>
                    <span>Continue Shopping</span>
                </a>
            </div>

            <!-- Continue Shopping Link -->
            <div class="text-center mt-6">
                <a href="/products" class="text-purple-600 hover:text-purple-700 font-semibold inline-flex items-center space-x-2">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Products</span>
                </a>
            </div>
        </div>

        <!-- Help Section -->
        <div class="bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl shadow-lg p-6 md:p-8 text-white mb-6">
            <div class="flex flex-col md:flex-row items-center justify-between">
                <div class="mb-4 md:mb-0">
                    <h3 class="text-2xl font-bold mb-2">Need Help?</h3>
                    <p class="text-purple-100">Our support team is here to assist you 24/7</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="/contact" 
                       class="bg-white text-purple-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition flex items-center space-x-2">
                        <i class="fas fa-headset"></i>
                        <span>Contact Support</span>
                    </a>
                    <a href="mailto:support@yourstore.com" 
                       class="bg-purple-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-800 transition flex items-center space-x-2">
                        <i class="fas fa-envelope"></i>
                        <span>Email Support</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Important Notes -->
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6">
            <h3 class="font-semibold text-yellow-800 mb-3 flex items-center">
                <i class="fas fa-exclamation-circle mr-2"></i>
                Important Information
            </h3>
            <ul class="text-sm text-yellow-700 space-y-2">
                <li class="flex items-start">
                    <i class="fas fa-check mr-2 mt-1"></i>
                    Your order will be processed within 24 hours.
                </li>
                <li class="flex items-start">
                    <i class="fas fa-check mr-2 mt-1"></i>
                    You will receive tracking information via email once your order ships.
                </li>
                <li class="flex items-start">
                    <i class="fas fa-check mr-2 mt-1"></i>
                    For COD orders, please keep exact change ready.
                </li>
                <li class="flex items-start">
                    <i class="fas fa-check mr-2 mt-1"></i>
                    Returns are accepted within 7 days of delivery.
                </li>
            </ul>
        </div>
    </div>
</main>

<!-- CSS Styles for this page -->
<style>
.checkmark-animate {
    animation: checkmark 0.5s ease-in-out;
}

@keyframes checkmark {
    0% {
        transform: scale(0);
        opacity: 0;
    }
    50% {
        transform: scale(1.2);
    }
    100% {
        transform: scale(1);
        opacity: 1;
    }
}

.line-through {
    text-decoration: line-through;
}

/* Smooth transitions */
.transition {
    transition: all 0.3s ease;
}

/* Hover effects */
.hover\:bg-purple-700:hover {
    background-color: #6d28d9;
}

.hover\:bg-purple-50:hover {
    background-color: #f5f3ff;
}

.hover\:bg-gray-100:hover {
    background-color: #f3f4f6;
}

.hover\:bg-purple-800:hover {
    background-color: #5b21b6;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .grid-cols-3 {
        grid-template-columns: repeat(1, 1fr);
    }
    
    .md\:grid-cols-2 {
        grid-template-columns: repeat(1, 1fr);
    }
    
    .flex-col {
        flex-direction: column;
    }
    
    .space-x-4 > :not([hidden]) ~ :not([hidden]) {
        --space-x-reverse: 0;
        margin-right: calc(1rem * var(--space-x-reverse));
        margin-left: calc(1rem * calc(1 - var(--space-x-reverse)));
    }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<%- include('../partials/footer') %>
<%- include('../partials/user/header') %>


 <main class="container mx-auto px-4 py-8 md:py-12">
        <!-- Success Animation -->
        <div class="max-w-4xl mx-auto">
            <div class="bg-white rounded-2xl shadow-lg p-6 md:p-10 mb-6">
                <div class="text-center mb-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-4">
                        <i class="fas fa-check text-green-600 text-4xl checkmark-animate"></i>
                    </div>
                    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
                    <p class="text-gray-600 text-lg">Thank you for your purchase</p>
                    <p class="text-sm text-gray-500 mt-2">A confirmation email has been sent to <span class="font-semibold">john.doe@example.com</span></p>
                </div>

                <!-- Order Info Cards -->
                <div class="grid md:grid-cols-3 gap-4 mb-8">
                    <div class="bg-purple-50 rounded-xl p-4 text-center">
                        <i class="fas fa-receipt text-purple-600 text-2xl mb-2"></i>
                        <p class="text-sm text-gray-600">Order Number</p>
                        <p class="font-bold text-gray-900">#<%= order.orderId %></p>
                    </div>
                    <div class="bg-blue-50 rounded-xl p-4 text-center">
                        <i class="fas fa-calendar text-blue-600 text-2xl mb-2"></i>
                        <p class="text-sm text-gray-600">Order Date</p>
                        <p class="font-bold text-gray-900"><%= new Date(order.createdAt).toLocaleDateString("en-US", {
                           month: "short",
                           day: "2-digit",
                           year: "numeric"
                         }) %>
                         </p>
                    </div>
                    <div class="bg-green-50 rounded-xl p-4 text-center">
                        <i class="fas fa-truck text-green-600 text-2xl mb-2"></i>
                        <p class="text-sm text-gray-600">Estimated Delivery</p>
                        <%
                          const date = new Date(order.createdAt);
                          date.setDate(date.getDate() + 7);
                        %>
                        <p class="font-bold text-gray-900"><%= date.toLocaleDateString("en-US", {
                           month: "short",
                           day: "2-digit",
                           year: "numeric"
                         }) %>
                        </p>
                    </div>
                </div>

                <!-- Order Timeline -->
                <%
                 function formatDateTime(date) {
                   if (!date) return "Pending";
                   return new Date(date).toLocaleString("en-US", {
                     month: "short",
                     day: "2-digit",
                     year: "numeric",
                     hour: "2-digit",
                     minute: "2-digit",
                     hour12: true
                   });
                 }
               
                 const isProcessing = order.orderItems.some(i => i.status === "processing");
                 const isShipped = order.orderItems.some(i => i.status === "shipped");
                 const isDelivered = order.orderItems.some(i => i.status === "delivered");
               %>
               

                <div class="bg-gray-50 rounded-xl p-6 mb-8">
                    <h3 class="font-semibold text-gray-900 mb-4">Order Status</h3>
                    <div class="space-y-4">
                        <div class="flex items-center">
                       <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                         <i class="fas fa-check text-white text-sm"></i>
                       </div>
                       <div class="ml-4">
                         <p class="font-semibold text-gray-900">Order Placed</p>
                         <p class="text-sm text-gray-500">
                           <%= formatDateTime(order.createdAt) %>
                         </p>
                       </div>
                     </div>
                    </div>
                        <div class="flex items-center ml-4">
                            <div class="w-0.5 h-8 bg-gray-300"></div>
                        </div>
                       <div class="flex items-center">
                         <div class="w-8 h-8 <%= order.paymentStatus === 'paid' ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                           <% if (order.paymentStatus === 'paid') { %>
                             <i class="fas fa-check text-white text-sm"></i>
                           <% } else { %>
                             <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                           <% } %>
                         </div>
                         <div class="ml-4">
                           <p class="font-semibold <%= order.paymentStatus === 'paid' ? 'text-gray-900' : 'text-gray-500' %>">
                             Payment Confirmed
                           </p>
                           <p class="text-sm text-gray-400">
                             <%= formatDateTime(order.paymentConfirmedAt) %>
                           </p>
                         </div>
                       </div>

                    <div class="flex items-center ml-4">
                        <div class="w-0.5 h-8 bg-gray-300"></div>
                    </div>
                    <div class="flex items-center">
                       <div class="w-8 h-8 <%= isProcessing ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                         <% if (isProcessing) { %>
                           <i class="fas fa-check text-white text-sm"></i>
                         <% } else { %>
                           <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                         <% } %>
                       </div>
                       <div class="ml-4">
                         <p class="font-semibold <%= isProcessing ? 'text-gray-900' : 'text-gray-500' %>">
                           Processing
                         </p>
                         <p class="text-sm text-gray-400">
                           <%= formatDateTime(order.orderItems[0].processingAt) %>
                         </p>
                       </div>
                     </div>

                        <div class="flex items-center ml-4">
                            <div class="w-0.5 h-8 bg-gray-300"></div>
                        </div>
                        <div class="flex items-center">
                          <div class="w-8 h-8 <%= isShipped ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                            <% if (isShipped) { %>
                              <i class="fas fa-check text-white text-sm"></i>
                            <% } else { %>
                              <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                            <% } %>
                          </div>
                          <div class="ml-4">
                            <p class="font-semibold <%= isShipped ? 'text-gray-900' : 'text-gray-500' %>">
                              Shipped
                            </p>
                            <p class="text-sm text-gray-400">
                              <%= formatDateTime(order.orderItems[0].shippedAt) %>
                            </p>
                          </div>
                        </div>

                        <div class="flex items-center ml-4">
                            <div class="w-0.5 h-8 bg-gray-300"></div>
                        </div>
                    <div class="flex items-center">
                       <div class="w-8 h-8 <%= isDelivered ? 'bg-green-600' : 'bg-gray-300' %> rounded-full flex items-center justify-center">
                         <% if (isDelivered) { %>
                           <i class="fas fa-check text-white text-sm"></i>
                         <% } else { %>
                           <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
                         <% } %>
                       </div>
                       <div class="ml-4">
                         <p class="font-semibold <%= isDelivered ? 'text-gray-900' : 'text-gray-500' %>">
                           Delivered
                         </p>
                         <p class="text-sm text-gray-400">
                           <%= formatDateTime(order.orderItems[0].deliveredAt) %>
                         </p>
                       </div>
                     </div>
                     
                    </div>
                </div>

                <!-- Order Details -->
                <div class="border-t border-gray-200 pt-6 mb-8">
                    <h3 class="font-semibold text-gray-900 mb-4">Order Items</h3>
                    
                    <% order.orderItems.forEach(order => { %>
                        <div class="flex items-center space-x-4 mb-4 pb-4 border-b border-gray-100">
                            <img src="<%= order.productId.productImages.find(img=>img.isMain).url %>" class="w-20 h-20 bg-gradient-to-br from-purple-100 to-pink-100 rounded-lg flex items-center justify-center">
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-900"><%= order.productId.name %></h4>
                                <p class="text-sm text-gray-500"><%= order.variantId.deviceModel %></p>
                                <p class="text-sm text-gray-600 mt-1">Qty: <%= order.quantity %></p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-gray-900"><%= order.price %></p>
                                <p class="text-sm text-gray-500"><%= order.variantId.salePrice %></p>
                            </div>
                        </div>
                    <% }) %>

                </div>

                <!-- Order Summary -->
                <div class="bg-gray-50 rounded-xl p-6">
                    <h3 class="font-semibold text-gray-900 mb-4">Order Summary</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between text-gray-600">
                            <span>Subtotal (<%= (order.orderItems.length) %>)</span>
                            <span><%= order.totalPrice %></span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Shipping</span>
                            <span>free</span>
                        </div>
                        <!-- <div class="flex justify-between text-green-600">
                            <span>Discount (FIRST10)</span>
                            <span>-$7.50</span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Tax</span>
                            <span>$6.53</span>
                        </div> -->
                        <div class="border-t border-gray-300 pt-2 mt-2">
                            <div class="flex justify-between text-xl font-bold text-gray-900">
                                <span>Total</span>
                                <span><%= order.totalPrice %></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Shipping & Payment Info -->
                <div class="grid md:grid-cols-2 gap-6 mt-8 pt-6 border-t border-gray-200">
                    <div>
                        <h3 class="font-semibold text-gray-900 mb-3 flex items-center">
                            <i class="fas fa-shipping-fast text-purple-600 mr-2"></i>
                            Shipping Address
                        </h3>
                        <div class="text-gray-600 text-sm space-y-1">
                            <p class="font-semibold text-gray-900"> <%= order.firstName %> <%= order.lastName %> </p>
                            <p><%= order.shippingAddress.streetAddress %>,<%= order.shippingAddress.landMark %></p>
                            <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %></p>
                            <p class="mt-2">Phone: +91 <%= order.shippingAddress.phone %></p>
                        </div>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900 mb-3 flex items-center">
                            <i class="fas fa-credit-card text-purple-600 mr-2"></i>
                            Payment Method
                        </h3>
                        <div class="text-gray-600 text-sm space-y-1">
                            <div class="flex items-center space-x-2">
                                <span><%= order.paymentMethod %></span>
                            </div>
                            <% if (order.paymentStatus==="paid") { %>
                                <p class="text-green-600 font-semibold mt-2">✓ Payment Successful</p>
                                <% } else { %>
                                    <p class="text-green-600 font-semibold mt-2"> Payment Pending</p>
                                    <% } %>
                            <p class="text-xs text-gray-500">Transaction ID: TXN2025104870001</p>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 mt-8 pt-6 border-t border-gray-200">
                    <button class="flex-1 bg-purple-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-700 transition flex items-center justify-center space-x-2">
                        <i class="fas fa-download"></i>
                        <span>Download Invoice</span>
                    </button>
                    <button class="flex-1 bg-white border-2 border-purple-600 text-purple-600 px-6 py-3 rounded-lg font-semibold hover:bg-purple-50 transition flex items-center justify-center space-x-2">
                        <i class="fas fa-eye"></i>
                        <span>Track Order</span>
                    </button>
                </div>

                <!-- Continue Shopping -->
                <div class="text-center mt-6">
                    <a href="#" class="text-purple-600 hover:text-purple-700 font-semibold inline-flex items-center space-x-2">
                        <i class="fas fa-arrow-left"></i>
                        <span>Continue Shopping</span>
                    </a>
                </div>
            </div>

            <!-- Help Section -->
            <div class="bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl shadow-lg p-6 md:p-8 text-white">
                <div class="flex flex-col md:flex-row items-center justify-between">
                    <div class="mb-4 md:mb-0">
                        <h3 class="text-2xl font-bold mb-2">Need Help?</h3>
                        <p class="text-purple-100">Our support team is here to assist you 24/7</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-3">
                        <button class="bg-white text-purple-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition flex items-center space-x-2">
                            <i class="fas fa-headset"></i>
                            <span>Live Chat</span>
                        </button>
                        <button class="bg-purple-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-purple-800 transition flex items-center space-x-2">
                            <i class="fas fa-envelope"></i>
                            <span>Email Support</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> 
<script type="module" src="/js/user/list-product.js"></script>
<script type="module" src="/js/user/cart.js"></script>

<%- include('../partials/footer') %>
<%- include('../partials/user/header') %>

    <div class="flex">
        <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
            <div class="mb-8">
                <h1 class="text-3xl md:text-4xl font-bold mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                    </svg>
                    Shopping Cart
                </h1>
                <p class="text-gray-600 ml-11">Review your items before checkout</p>
            </div>

            <!-- UX: Progress indicator with better icons -->
            <div class="mb-12">
                <div class="flex items-center justify-center">
                    <div class="flex items-center">
                        <!-- Step 1 - Active -->
                        <div class="flex items-center">
                            <div
                                class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-semibold shadow-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                </svg>
                            </div>
                            <span class="ml-3 font-semibold text-purple-600">Cart</span>
                        </div>
                        <!-- Connector with arrow -->
                        <div class="w-16 md:w-32 flex items-center mx-2">
                            <div class="w-full h-0.5 bg-gradient-to-r from-purple-200 to-gray-200"></div>
                            <svg class="w-4 h-4 text-gray-400 -ml-1" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </div>
                        <!-- Step 2 -->
                        <div class="flex items-center">
                            <div
                                class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-500 font-semibold border-2 border-gray-200">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z">
                                    </path>
                                </svg>
                            </div>
                            <span class="ml-3 font-medium text-gray-500">Checkout</span>
                        </div>
                        <!-- Connector with arrow -->
                        <div class="w-16 md:w-32 flex items-center mx-2">
                            <div class="w-full h-0.5 bg-gray-200"></div>
                            <svg class="w-4 h-4 text-gray-400 -ml-1" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7">
                                </path>
                            </svg>
                        </div>
                        <!-- Step 3 -->
                        <div class="flex items-center">
                            <div
                                class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-500 font-semibold border-2 border-gray-200">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 12l2 2 4-5m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <span class="ml-3 font-medium text-gray-500 hidden md:inline">Complete</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid lg:grid-cols-3 gap-8">

                <!-- Cart Items - UX: Clear item display with easy modification options -->
                <div class="lg:col-span-2 space-y-4">
                    <% products.forEach(product=> { %>
                        <div
                            class="bg-white rounded-2xl shadow-md p-4 md:p-6 fade-in cart-item hover:shadow-xl transition-shadow duration-300 border border-gray-100">
                            <div class="flex gap-4">
                                <!-- Product Image with zoom effect -->
                                <div class="relative flex-shrink-0">
                                    <img src="<%= product.productId.productImages.find(img => img.isMain)?.url %>"
                                        class="w-24 h-24 md:w-32 md:h-32 rounded-xl object-cover flex-shrink-0 hover:scale-105 transition-transform duration-300"
                                        onerror="this.src='/images/default-product.jpg'">
                                    <% if (product.variantId.stock < 5 && product.variantId.stock> 0) { %>
                                        <span
                                            class="absolute -top-2 -right-2 bg-orange-500 text-white text-xs px-2 py-1 rounded-full shadow-md">
                                            Only <%= product.variantId.stock %> left
                                        </span>
                                        <% } %>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-start mb-2">
                                        <div>
                                            <h3 class="font-bold text-lg mb-1 text-gray-800">
                                                <%= product.productId.name %>
                                            </h3>
                                            <p class="text-gray-500 text-sm flex items-center gap-1">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                                </svg>
                                                <%= product.variantId.deviceModel %> • <%= product.productId.catgId.name
                                                        %>
                                            </p>
                                        </div>

                                        <button
                                            onclick="removeFromCart('<%= product._id %>', '<%= product.variantId._id %>')"
                                            class="text-gray-400 hover:text-red-600 transition-all duration-300 p-2 ml-2 flex-shrink-0 hover:bg-red-50 rounded-full"
                                            title="Remove from cart">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
                                                viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7h6m2 0H7m3-3h4a1 1 0 011 1v1H9V5a1 1 0 011-1z" />
                                            </svg>
                                        </button>
                                    </div>

                                    <% if (product.appliedOffer) { %>
                                        <div class="mb-3">
                                            <div
                                                class="inline-flex items-center gap-1.5 bg-gradient-to-r from-green-50 to-emerald-50 text-green-700 text-xs font-medium px-3 py-1.5 rounded-full border border-green-200 shadow-sm">
                                                <span>🎉 <strong>
                                                        <%= product.appliedOffer.disType==='percentage' ?
                                                            product.appliedOffer.discountValue + '%' : '₹' +
                                                            product.appliedOffer.discountValue %> OFF
                                                    </strong> applied</span>
                                            </div>
                                        </div>
                                        <% } %>

                                            <% if
                                                (!product.variantId.isListed||product.productId.isBlock||product.productId.catgId.isActive===false)
                                                { %>
                                                <div class="text-red-600 text-sm font-medium mt-2">⛔ Unavailable</div>
                                                <% } %>

                                                    <% if (product.variantId.stock < 1) { %>
                                                        <div class="text-red-600 text-sm font-medium mt-2">📦 Out of
                                                            stock</div>
                                                        <% } %>

                                                            <div class="flex justify-between items-center mt-4">
                                                                <div class="flex flex-col">
                                                                    <div
                                                                        class="flex items-center border-2 border-gray-200 rounded-lg bg-gray-50">
                                                                        <button id="dec-btn-<%= product._id %>"
                                                                            onclick="updateQuantity(this, '<%= product._id %>', -1)"
                                                                            class="px-3 py-2 text-gray-600 hover:text-purple-600 hover:bg-white transition-all rounded-l disabled:opacity-50"
                                                                            <%=product.quantity <=1 ? 'disabled' : '' %>
                                                                            >
                                                                            <svg class="w-4 h-4" fill="none"
                                                                                stroke="currentColor"
                                                                                viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round"
                                                                                    stroke-linejoin="round"
                                                                                    stroke-width="2" d="M20 12H4" />
                                                                            </svg>
                                                                        </button>
                                                                        <span id="qty-<%= product._id %>"
                                                                            class="w-12 text-center font-semibold text-gray-700">
                                                                            <%= product.quantity %>
                                                                        </span>
                                                                        <button id="inc-btn-<%= product._id %>"
                                                                            onclick="updateQuantity(this, '<%= product._id %>', +1)"
                                                                            class="px-3 py-2 text-gray-600 hover:text-purple-600 hover:bg-white transition-all rounded-r disabled:opacity-50"
                                                                            <%=product.quantity>=
                                                                            product.variantId.stock ||
                                                                            product.quantity >= 5 ? 'disabled' : '' %>
                                                                            >
                                                                            <svg class="w-4 h-4" fill="none"
                                                                                stroke="currentColor"
                                                                                viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round"
                                                                                    stroke-linejoin="round"
                                                                                    stroke-width="2"
                                                                                    d="M12 4v16m8-8H4" />
                                                                            </svg>
                                                                        </button>
                                                                    </div>
                                                                    <span id="limit-msg-<%= product._id %>"
                                                                        class="text-[10px] text-orange-500 font-medium mt-1 h-3">
                                                                        <%= product.quantity>= product.variantId.stock ?
                                                                            'Stock limit reached' : (product.quantity >=
                                                                            5 ? 'Max 5 units allowed' : '') %>
                                                                    </span>
                                                                </div>

                                                                <div class="text-right">
                                                                    <% if (product.appliedOffer ||
                                                                        product.variantId.orgPrice>
                                                                        product.variantId.salePrice) { %>
                                                                        <span
                                                                            class="block text-sm text-gray-400 line-through">₹
                                                                            <%= product.variantId.orgPrice *
                                                                                product.quantity %>
                                                                        </span>
                                                                        <% } %>
                                                                            <p id="price-<%= product._id %>"
                                                                                class="text-2xl font-bold text-purple-600">
                                                                                ₹ <%= product.finalPrice %>
                                                                            </p>
                                                                </div>
                                                            </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>

                            <!-- Continue Shopping Button - Enhanced -->
                            <div class="pt-4">
                                <a href="/product"
                                    class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold transition-all duration-300 group">
                                    <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform duration-300"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                                    </svg>
                                    Continue Shopping
                                    <span
                                        class="text-sm text-gray-500 group-hover:text-purple-500 transition-colors">→</span>
                                </a>
                            </div>
                </div>

                <!-- Order Summary Sidebar - Enhanced -->
                <div class="lg:col-span-1">
                    <div
                        class="bg-white rounded-2xl shadow-xl p-6 sticky top-24 border border-gray-100 hover:shadow-2xl transition-shadow duration-300">
                        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 text-gray-800">
                            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z">
                                </path>
                            </svg>
                            Order Summary
                        </h2>

                        <!-- Price Breakdown - Enhanced -->
                        <div class="space-y-4 mb-6">
                            <div class="flex justify-between items-center text-gray-700">
                                <span class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                    </svg>
                                    Subtotal (<%= totalDocs %> items)
                                </span>
                                <span class="font-semibold text-gray-900" id="subtotal">₹ <%= subtotal %></span>
                            </div>

                            <% if (totalDiscount && totalDiscount> 0) { %>
                                <div class="flex justify-between items-center text-green-600">
                                    <span class="flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd"
                                                d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        Total Discount
                                    </span>
                                    <span class="font-semibold">- ₹ <span id="totalDiscount">
                                            <%= totalDiscount %>
                                        </span></span>
                                </div>
                                <% } %>

                                    <div class="flex justify-between items-center text-gray-700">
                                        <span class="flex items-center gap-2">
                                            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4">
                                                </path>
                                            </svg>
                                            Shipping
                                        </span>
                                        <span class="font-semibold text-green-600 flex items-center gap-1"
                                            id="shipping">
                                            <% if (shipping===0) { %>
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                </svg>
                                                Free
                                                <% } else { %>
                                                    ₹ <%= shipping %>
                                                        <% } %>
                                        </span>
                                    </div>
                        </div>

                        <!-- Total - Enhanced -->
                        <div class="border-t-2 border-gray-100 pt-4 mb-6">
                            <div class="flex justify-between items-baseline">
                                <span class="text-xl font-bold text-gray-900 flex items-center gap-2">
                                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                                        </path>
                                    </svg>
                                    Total
                                </span>
                                <div class="text-right">
                                    <p class="text-3xl font-bold bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent"
                                        id="total">
                                        ₹ <%= finalAmount %>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- UX: Prominent primary CTA - Enhanced -->
                        <% let isCheck=false; products.forEach(product=> {
                            if(product.variantId.stock<1){ isCheck=true; } if(product.variantId.isListed===false){
                                isCheck=true; } if(product.productId.isBlock===true){ isCheck=true } if(
                                product.productId.catgId.isActive===false){ isCheck=true } }); %>
                                <% if (isCheck) { %>
                                    <button
                                        class="w-full bg-gradient-to-r from-gray-400 to-gray-500 text-white py-4 rounded-lg font-semibold text-lg cursor-not-allowed opacity-75 flex items-center justify-center gap-2">
                                        <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        Proceed to Checkout
                                    </button>
                                    <div
                                        class="bg-gradient-to-r from-red-50 to-rose-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg flex items-center gap-3 mt-3 shadow-sm">
                                        <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
                                        </svg>
                                        <span class="font-medium">⚠️ Kindly remove unavailable items before
                                            checkout.</span>
                                    </div>
                                    <% } else { %>
                                        <a href="/checkout">
                                            <button
                                                class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white py-4 rounded-lg font-semibold text-lg hover:from-purple-700 hover:to-indigo-700 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl flex items-center justify-center gap-2 group">
                                                Proceed to Checkout
                                                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300"
                                                    fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                                </svg>
                                            </button>
                                        </a>
                                        <% } %>

                                            <!-- UX: Trust signals with better icons -->
                                            <div class="space-y-3 pt-4 border-t border-gray-100 mt-4">
                                                <div
                                                    class="flex items-center gap-3 text-sm text-gray-600 group hover:text-gray-900 transition-colors">
                                                    <div
                                                        class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center group-hover:bg-green-200 transition-colors">
                                                        <svg class="w-4 h-4 text-green-600" fill="currentColor"
                                                            viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd"
                                                                d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                                clip-rule="evenodd"></path>
                                                        </svg>
                                                    </div>
                                                    <span>Secure checkout with <span class="font-semibold">SSL
                                                            encryption</span></span>
                                                </div>
                                                <div
                                                    class="flex items-center gap-3 text-sm text-gray-600 group hover:text-gray-900 transition-colors">
                                                    <div
                                                        class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center group-hover:bg-blue-200 transition-colors">
                                                        <svg class="w-4 h-4 text-blue-600" fill="currentColor"
                                                            viewBox="0 0 20 20">
                                                            <path
                                                                d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z">
                                                            </path>
                                                            <path
                                                                d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z">
                                                            </path>
                                                        </svg>
                                                    </div>
                                                    <span><span class="font-semibold">Free returns</span> within 30
                                                        days</span>
                                                </div>
                                                <div
                                                    class="flex items-center gap-3 text-sm text-gray-600 group hover:text-gray-900 transition-colors">
                                                    <div
                                                        class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                                                        <svg class="w-4 h-4 text-purple-600" fill="currentColor"
                                                            viewBox="0 0 20 20">
                                                            <path
                                                                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z">
                                                            </path>
                                                        </svg>
                                                    </div>
                                                    <span><span class="font-semibold">24/7</span> customer
                                                        support</span>
                                                </div>
                                            </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="/js/user/cart.js"></script>
    <%- include('../partials/user/footer') %>
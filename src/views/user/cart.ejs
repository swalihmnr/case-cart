<%- include('../partials/user/header') %>


<div class="flex">
    
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
        <div class="mb-8">
            <h1 class="text-3xl md:text-4xl font-bold mb-2">Shopping Cart</h1>
            <p class="text-gray-600">Review your items before checkout</p>
        </div>

        <!-- UX: Progress indicator shows user where they are in the process -->
        <div class="mb-12">
            <div class="flex items-center justify-center">
                <div class="flex items-center">
                    <!-- Step 1 - Active -->
                    <div class="flex items-center">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-purple-600 text-white font-semibold">1</div>
                        <span class="ml-3 font-semibold text-purple-600">Cart</span>
                    </div>
                    <!-- Connector -->
                    <div class="w-16 md:w-32 h-1 bg-gray-200 mx-4"></div>
                    <!-- Step 2 -->
                    <div class="flex items-center">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-200 text-gray-500 font-semibold">2</div>
                        <span class="ml-3 font-medium text-gray-500">Checkout</span>
                    </div>
                    <!-- Connector -->
                    <div class="w-16 md:w-32 h-1 bg-gray-200 mx-4"></div>
                    <!-- Step 3 -->
                    <div class="flex items-center">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-200 text-gray-500 font-semibold">3</div>
                        <span class="ml-3 font-medium text-gray-500 hidden md:inline">Complete</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
            
            <!-- Cart Items - UX: Clear item display with easy modification options -->
                  <div class="lg:col-span-2 space-y-4">
                      
                    <% products.forEach(product => { %>
                     <div class="bg-white rounded-2xl shadow-md p-4 md:p-6 fade-in cart-item">
                       <div class="flex gap-4">
                     
                         <img 
                           src="<%= product.productId.productImages.find(img => img.isMain)?.url %>" 
                           class="w-24 h-24 md:w-32 md:h-32 rounded-xl object-cover flex-shrink-0"
                         >
                     
                        
                         <div class="flex-1 min-w-0">
                           <div class="flex justify-between items-start mb-2">
                             <div>
                               <h3 class="font-bold text-lg mb-1"><%= product.productId.name %></h3>
                               <p class="text-gray-600 text-sm">
                                 <%= product.variantId.deviceModel %> • <%= product.productId.catgId.name %>
                               </p>
                             </div>
                             
                             
                             <button 
                               onclick="removeFromCart('<%= product._id %>', '<%= product.variantId._id %>')"
                               class="text-gray-400 hover:text-red-600 transition-colors p-2 ml-2 flex-shrink-0"
                               title="Remove from cart"
                               aria-label="Remove item from cart"
                             >
                               <svg xmlns="http://www.w3.org/2000/svg" 
                                    class="w-5 h-5" 
                                    fill="none" 
                                    viewBox="0 0 24 24" 
                                    stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                   d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7h6m2 0H7m3-3h4a1 1 0 011 1v1H9V5a1 1 0 011-1z"/>
                               </svg>
                             </button>
                           </div>
                           
                           <% if (!product.variantId.isListed||product.productId.isBlock||product.productId.catgId.isActive === false) { %>
                             <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-3 py-2 rounded-lg inline-flex items-center gap-2 mt-2">
                               <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                   d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z"/>
                               </svg>
                               <span>This product is currently unavailable</span>
                             </div>
                           <% } %>
                            <% if (product.variantId.stock<1) { %>
                             <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-3 py-2 rounded-lg inline-flex items-center gap-2 mt-2">
                               <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                   d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z"/>
                               </svg>
                               <span>This product is currently stock out</span>
                             </div>
                           <% } %>
                         
                           <div class="flex justify-between items-center mt-4">
                     
                             <div class="flex items-center border-2 border-gray-200 rounded-lg">
                               <button
                                 onclick="updateQuantity(this, '<%= product._id %>', -1)"
                                 class="px-3 py-2 font-bold hover:text-purple-600 hover:bg-gray-50 transition-colors rounded-l"
                               >−</button>
                               <p class="w-12 text-center font-semibold quantity-text">
                                 <%= product.quantity %>
                               </p>
                               <button
                                 onclick="updateQuantity(this, '<%= product._id %>', +1)"
                                 class="px-3 py-2 font-bold hover:text-purple-600 hover:bg-gray-50 transition-colors rounded-r"
                               >+</button>
                             </div>
                     
                         
                             <p class="text-2xl price-field font-bold text-purple-600">
                               ₹ <%= product.quantity * product.variantId.salePrice %>
                             </p>
                           </div>
                         </div>
                       </div>
                     </div>
                     <% }) %>

                <!-- Continue Shopping Button - UX: Easy way to add more items -->
                <div class="pt-4">
                    <a href="/product" class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Order Summary Sidebar - UX: Sticky sidebar keeps total visible -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-md p-6 sticky top-24">
                    <h2 class="text-2xl font-bold mb-6">Order Summary</h2>
                    
                    <!-- Price Breakdown - UX: Transparent pricing builds trust -->
                    <div class="space-y-4 mb-6">
                        <div class="flex justify-between text-gray-700">
                            <span>Subtotal (<%= totalDocs %> items)</span>
                            <span class="font-semibold" id="subtotal"><%= subtotal %></span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span>Shipping</span>
                            <span class="font-semibold text-green-600" id="shipping">FREE</span>
                        </div>
                        
                        <!-- Coupon Code - UX: Easy way to apply discounts -->
                       
                    </div>
                    
                    <!-- Total -->
                    <div class="border-t pt-4 mb-6">
                        <div class="flex justify-between items-baseline mb-2">
                            <span class="text-xl font-bold text-gray-900">Total</span>
                            <div class="text-right">
                                <p class="text-3xl font-bold text-purple-600" id="total"><%= subtotal %></p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- UX: Prominent primary CTA -->
                   <% 
                   let isCheck=false
                   products.forEach(product => {
                    if(product.variantId.stock<1){
                      isCheck=true;
                    }
                    if(product.variantId.isListed===false){
                      isCheck=true;
                    }
                    if(product.productId.isBlock===true){
                      isCheck=true
                    }
                    if( product.productId.catgId.isActive === false){
                      isCheck=true
                    }
                   });
                   %>
                   <% if (isCheck) { %>
                      <button  class="w-full gradient-bg text-white py-4 rounded-lg font-semibold text-lg hover:opacity-90 transition mb-3 cursor-not-allowed">
                        Proceed to Checkout
                    </button>
                    <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-3 py-2 rounded-lg inline-flex items-center gap-2 mt-2">
                               <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                   d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z"/>
                               </svg>
                               <span>Kindly remove unavailable items before checkout.</span>
                             </div>
                    <% } else { %>
                      
                      <a href="/checkout">
                        <button  class="w-full gradient-bg text-white py-4 rounded-lg font-semibold text-lg hover:opacity-90 transition mb-3">
                          Proceed to Checkout
                        </button>
                      </a>
                      <% } %>
                    
                    <!-- UX: Trust signals reduce anxiety -->
                    <div class="space-y-3 pt-4 border-t">
                        <div class="flex items-center gap-3 text-sm text-gray-600">
                            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span>Secure checkout with SSL encryption</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-gray-600">
                            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path>
                                <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path>
                            </svg>
                            <span>Free returns within 30 days</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-gray-600">
                            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
                            </svg>
                            <span>24/7 customer support</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>  

        </div>

  </main>
  
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/cart.js"></script>
<%- include('../partials/user/footer') %>

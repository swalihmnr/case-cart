                                            <path fill-rule="evenodd"
                                                d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z"
                                                clip-rule="evenodd" />
                                        </svg>
                                        You saved ₹<%= subtotal-finalAmount %> on this order!
                                    </p>

                                </div>
                            </div>

                            <!-- Place Order Button -->
                            <button onclick="placeOrder()"
                                class="w-full gradient-bg text-white py-3 sm:py-4 rounded-lg font-semibold hover:opacity-90 transition-all duration-200 mb-3 sm:mb-4 text-sm sm:text-base shadow-lg hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transform hover:-translate-y-0.5">
                                Place Order
                            </button>

                            <!-- Terms and Conditions -->
                            <div class="text-center text-xs text-gray-500 px-1 sm:px-2">
                                <p>By placing your order, you agree to our</p>

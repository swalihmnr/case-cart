<%- include('../partials/user/header') %>

<div class="flex">
    <main class="w-full">
        <!-- Progress Steps - Made responsive -->
        <div class="bg-white border-b">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6">
                <div class="flex items-center justify-between max-w-3xl mx-auto">
                    <!-- Step 1: Cart -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="step w-8 h-8 sm:w-10 sm:h-10 bg-green-300 rounded-full flex items-center justify-center font-semibold mb-1 sm:mb-2">
                            <svg class="w-4 h-4 sm:w-6 sm:h-6 text-green-700" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        <span class="text-xs text-gray-600 font-medium text-center">Cart</span>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex-1 h-1 bg-green-500 mx-1 sm:mx-2"></div>
                    
                    <!-- Step 2: Shipping -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="step w-8 h-8 sm:w-10 sm:h-10 bg-blue-500 rounded-full flex items-center text-white justify-center font-semibold mb-1 sm:mb-2">2</div>
                        <span class="text-xs text-gray-600 font-medium text-center">Shipping</span>
                    </div>
                    
                    <!-- Connector Line -->
                    <div class="flex-1 h-1 bg-gray-300 mx-1 sm:mx-2"></div>
                    
                    <!-- Step 3: Payment -->
                    <div class="flex flex-col items-center flex-1">
                        <div class="step w-8 h-8 sm:w-10 sm:h-10 bg-gray-300 rounded-full flex items-center justify-center font-semibold mb-1 sm:mb-2">3</div>
                        <span class="text-xs text-gray-600 font-medium text-center">Payment</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
            <div class="grid lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
                <!-- Left Column: Forms -->
                <div class="lg:col-span-2 space-y-4 sm:space-y-6">
                    <!-- Shipping Information Card -->
                    <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 sm:mb-6 relative">
                            <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-2 sm:mb-0">Shipping Information</h2>
                            
                            <div class="relative self-end sm:self-auto">
                                <button 
                                    id="addressDropdownBtn"
                                    class="text-sm text-purple-600 font-medium cursor-pointer hover:text-purple-700 focus:outline-none"
                                >
                                    Use saved address
                                </button>
                                
                                <!-- Dropdown Menu -->
                                <div 
                                    id="addressDropdown"
                                    class="absolute right-0 mt-2 w-56 sm:w-64 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-10 hidden"
                                >
                                    <div class="px-4 py-2 border-b border-gray-100">
                                        <h3 class="font-medium text-gray-800 text-sm">Select an address</h3>
                                    </div>
                                    
                                    <div class="max-h-48 sm:max-h-60 overflow-y-auto">
                                        <% addresses.forEach((address, index) => { %>
                                        <div class="px-4 py-3 hover:bg-gray-50 cursor-pointer">
                                            <div class="flex items-start">
                                                <input
                                                    type="radio"
                                                    id="address_<%= index %>"
                                                    name="savedAddress"
                                                    value="<%= address._id %>"
                                                    class="mt-1 mr-3"
                                                    <%= address.isDefault ? 'checked' : '' %>
                                                    data-first-name="<%= address.firstName || '' %>"
                                                    data-last-name="<%= address.lastName || '' %>"
                                                    data-phone="<%= address.phone || '' %>"
                                                    data-line1="<%= address.streetAddress || '' %>"
                                                    data-landmark="<%= address.landMark || '' %>"
                                                    data-city="<%= address.city || '' %>"
                                                    data-state="<%= address.state || '' %>"
                                                    data-pincode="<%= address.pinCode || '' %>"
                                                    data-address-type="<%= address.addressType || '' %>"
                                                >
                                                <div class="flex-1 min-w-0">
                                                    <label for="address_<%= index %>" class="font-medium text-gray-800 block text-sm truncate">
                                                        <%= address.addressType || 'Address' %>
                                                    </label>
                                                    <p class="text-xs text-gray-600 mt-1 truncate">
                                                        <%= address.streetAddress || '' %>,
                                                        <%= address.landMark || '' %>,
                                                        <%= address.city || '' %>,
                                                        <%= address.state || '' %>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <form class="space-y-4" id="form">
                            <!-- First Name & Last Name -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
                                <!-- First Name -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        First Name *
                                    </label>
                                    <input
                                        type="text"
                                        id="first-name"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                        placeholder="Enter first name"
                                    >
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="firstNameError"></p>
                                </div>

                                <!-- Last Name -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        Last Name *
                                    </label>
                                    <input
                                        type="text"
                                        id="last-name"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                        placeholder="Enter last name"
                                    >
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="lastNameError"></p>
                                </div>
                            </div>

                            <!-- Phone Number -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                    Phone Number *
                                </label>
                                <input
                                    type="tel"
                                    id="phone"
                                    class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                    placeholder="Enter phone number"
                                >
                                <p class="text-xs sm:text-sm text-red-500 mt-1" id="phoneError"></p>
                            </div>

                            <!-- Address Line 1 -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                    Street Address *
                                    </label>
                                <input
                                    type="text"
                                    id="line1"
                                    class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                    placeholder="House No, Building Name"
                                >
                                <p class="text-xs sm:text-sm text-red-500 mt-1" id="line1Error"></p>
                            </div>

                            <!-- Landmark -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                    Landmark (Optional)
                                </label>
                                <input
                                    type="text"
                                    id="landmark"
                                    class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                    placeholder="Near school, hospital etc."
                                >
                            </div>

                            <!-- City / State / PIN -->
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
                                <!-- City -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        City *
                                    </label>
                                    <input
                                        type="text"
                                        id="city"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                        placeholder="City"
                                    >
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="cityError"></p>
                                </div>

                                <!-- State -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        State *
                                    </label>
                                    <select
                                        id="state"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                    >
                                        <option value="">Select State</option>
                                        <option value="Kerala">Kerala</option>
                                        <option value="Tamil Nadu">Tamil Nadu</option>
                                        <option value="Karnataka">Karnataka</option>
                                        <option value="Maharashtra">Maharashtra</option>
                                    </select>
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="stateError"></p>
                                </div>

                                <!-- PIN -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        PIN Code *
                                    </label>
                                    <input
                                        type="text"
                                        id="pincode"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 text-sm sm:text-base"
                                        placeholder="PIN Code"
                                    >
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="pincodeError"></p>
                                </div>
                            </div>

                            <!-- Address Type -->
                            
                            <!-- Buttons -->
                            
                        </form>
                    </div>

                    <!-- Payment Method Card -->
                    <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6">
                        <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4 sm:mb-6">Payment Method</h2>

                        <div class="space-y-3 sm:space-y-4">
                            <!-- Razorpay -->
                            <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer">
                                <label class="flex items-center justify-between cursor-pointer">
                                    <div class="flex items-center">
                                        <input type="radio" name="payment" value="Razorpay" class="w-4 h-4 text-purple-600">
                                        <span class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Razorpay</span>
                                    </div>
                                    <svg viewBox="0 0 200 50" class="h-5 sm:h-6">
                                        <text x="0" y="35" font-family="Arial, sans-serif" font-size="30" font-weight="bold" fill="#072654">Razorpay</text>
                                    </svg>
                                </label>
                                <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">UPI, Cards, Wallets, NetBanking and more</p>
                            </div>

                            <!-- Wallet -->
                            <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer">
                                <label class="flex items-center justify-between cursor-pointer">
                                    <div class="flex items-center">
                                        <input type="radio" name="payment" value="wallet" class="w-4 h-4 text-purple-600">
                                        <span class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Wallet</span>
                                    </div>
                                </label>
                                <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">Pay securely with your PayPal account</p>
                            </div>

                            <!-- Cash on Delivery -->
                            <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer">
                                <label class="flex items-center cursor-pointer">
                                    <input type="radio" name="payment" value="cod" class="w-4 h-4 text-purple-600">
                                    <span class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Cash on Delivery</span>
                                </label>
                                <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">Pay when you receive your order</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Order Summary -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6 sticky top-4">
                        <h2 class="text-lg sm:text-xl font-bold text-gray-800 mb-4 sm:mb-6">Order Summary</h2>
                        
                        <!-- Order Items with Offers -->
                        <div class="space-y-4 sm:space-y-5 mb-4 sm:mb-6 pb-4 sm:pb-6 border-b">
                            <% 
                            let totalSavings = 0;
                            cartItems.forEach((item, index) => { 
                                const originalPrice = item.variant ? item.variant.salePrice : item.salePrice;
                                const savingsPerItem = item.finalPrice ? ((originalPrice * (item.quantity || 1)) - item.finalPrice) : 0;
                                totalSavings += savingsPerItem;
                            %>
                            <div class="bg-white rounded-lg border border-gray-200 p-3 sm:p-4">
                                <div class="flex items-center space-x-3 mb-2">
                                    <!-- Product Image -->
                                    <div class="w-12 h-12 sm:w-16 sm:h-16 flex items-center justify-center flex-shrink-0">
                                        <% if (item.mainImage?.url) { %>
                                        <img
                                            src="<%= item.mainImage.url %>"
                                            alt="<%= item.product.name %>"
                                            class="w-full h-full object-contain rounded-md"
                                        />
                                        <% } else { %>
                                        <div class="w-full h-full bg-gray-200 rounded-md flex items-center justify-center">
                                            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                            </svg>
                                        </div>
                                        <% } %>
                                    </div>
                                    
                                    <!-- Product Details -->
                                    <div class="flex-1 min-w-0">
                                        <h4 class="font-semibold text-gray-800 text-xs sm:text-sm truncate"><%= item.product.name %></h4>
                                        <p class="text-xs text-gray-500 mt-1">
                                            Qty: <%= item.quantity || 1 %>
                                        </p>
                                    </div>
                                    
                                    <!-- Price with Original Price Striked -->
                                    <div class="text-right whitespace-nowrap">
                                        <div class="font-semibold text-gray-800 text-sm sm:text-base">
                                            ₹ <%= item.finalPrice || (originalPrice * (item.quantity || 1)).toFixed(2) %>
                                        </div>
                                        <% if (item.finalPrice && savingsPerItem > 0) { %>
                                        <div class="text-xs text-gray-400 line-through">
                                            ₹ <%= item.variant?.salePrice||item.salePrice %>
                                        </div>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- Offer Badge -->
                                <% if (item.appliedOffer && item.appliedOffer !== null) { %>
                                <div class="mt-2 flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.2 6.5 10.266a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/>
                                            </svg>
                                            Offer
                                        </span>
                                        <span class="text-xs font-medium text-blue-600">
                                            <%= item.appliedOffer.value || '' %>%Applied
                                        </span>
                                    </div>
                                    <% if (savingsPerItem > 0) { %>
                                    <span class="text-xs font-semibold text-green-600">
                                        Save ₹<%= savingsPerItem.toFixed(2) %>
                                    </span>
                                    <% } %>
                                </div>
                                <% } %>
                            </div>
                            <% }) %>
                        </div>

                        <!-- Promo Code Section -->
                        <div class="bg-white rounded-lg p-4 mb-4 sm:mb-6 border border-gray-200">
                            <div class="mb-3">
                                <button id="toggleCoupon" class="flex items-center justify-between w-full text-left">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                                        </svg>
                                        <span class="text-xs sm:text-sm font-medium text-gray-700">Have a coupon code?</span>
                                    </div>
                                    <svg id="chevron" class="w-4 h-4 sm:w-5 sm:h-5 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </button>
                            </div>

                            <!-- Coupon Input (Initially Hidden) -->
                            <div id="couponForm" class="hidden mb-3">
                                <div class="slide-down">
                                    <div class="flex gap-2 mb-3">
                                        <input 
                                            type="text" 
                                            id="couponInput"
                                            placeholder="Enter coupon code"
                                            class="flex-1 px-3 sm:px-4 py-2 border border-gray-300 rounded-lg text-xs sm:text-sm focus:ring-2 focus:ring-indigo-500"
                                        >
                                        <button 
                                            id="applyBtn"
                                            class="px-4 sm:px-6 py-2 bg-indigo-600 text-white text-xs sm:text-sm font-medium rounded-lg hover:bg-indigo-700"
                                        >
                                            Apply
                                        </button>
                                    </div>
                                    
                                    <!-- Available Coupons List -->
                                    <div class="space-y-2">
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Available Coupons</p>
                                        
                                        <!-- Flat Discount Coupon -->
                                        <div class="border border-dashed border-green-200 rounded-lg p-3 hover:border-green-400 hover:bg-green-50 cursor-pointer group" onclick="applyCoupon('FLAT500', 'Get ₹500 off on orders above ₹2000')">
                                            <div class="flex items-center justify-between">
                                                <div class="flex-1 min-w-0">
                                                    <div class="flex items-center gap-2 mb-1">
                                                        <span class="text-sm font-bold text-green-600 font-mono truncate">FLAT500</span>
                                                        <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full whitespace-nowrap">Most Popular</span>
                                                    </div>
                                                    <p class="text-xs text-gray-600">Get ₹500 off on orders above ₹2000</p>
                                                    <p class="text-xs text-gray-400 mt-1">Valid till: 31 Dec 2024</p>
                                                </div>
                                                <button class="text-xs text-green-600 font-medium group-hover:underline whitespace-nowrap ml-2">Apply</button>
                                            </div>
                                        </div>

                                        <!-- Percentage Coupon -->
                                        <div class="border border-dashed border-blue-200 rounded-lg p-3 hover:border-blue-400 hover:bg-blue-50 cursor-pointer group" onclick="applyCoupon('SAVE20', 'Get 20% off on all orders')">
                                            <div class="flex items-center justify-between">
                                                <div class="flex-1 min-w-0">
                                                    <div class="flex items-center gap-2 mb-1">
                                                        <span class="text-sm font-bold text-blue-600 font-mono truncate">SAVE20</span>
                                                        <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap">Best Value</span>
                                                    </div>
                                                    <p class="text-xs text-gray-600">Get 20% off on all orders</p>
                                                    <p class="text-xs text-gray-400 mt-1">Max discount: ₹1000</p>
                                                </div>
                                                <button class="text-xs text-blue-600 font-medium group-hover:underline whitespace-nowrap ml-2">Apply</button>
                                            </div>
                                        </div>

                                        <!-- Free Shipping Coupon -->
                                        <div class="border border-dashed border-purple-200 rounded-lg p-3 hover:border-purple-400 hover:bg-purple-50 cursor-pointer group" onclick="applyCoupon('FREESHIP', 'Free shipping on all orders')">
                                            <div class="flex items-center justify-between">
                                                <div class="flex-1 min-w-0">
                                                    <div class="flex items-center gap-2 mb-1">
                                                        <span class="text-sm font-bold text-purple-600 font-mono truncate">FREESHIP</span>
                                                        <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full whitespace-nowrap">Free Shipping</span>
                                                    </div>
                                                    <p class="text-xs text-gray-600">Free shipping on all orders</p>
                                                    <p class="text-xs text-gray-400 mt-1">No minimum order</p>
                                                </div>
                                                <button class="text-xs text-purple-600 font-medium group-hover:underline whitespace-nowrap ml-2">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Applied Coupon Display -->
                            <div id="appliedCoupon" class="hidden mb-3">
                                <div class="bg-green-50 border border-green-200 rounded-lg p-2 sm:p-3 flex items-center justify-between slide-down">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        <div class="min-w-0">
                                            <p class="text-xs sm:text-sm font-medium text-green-800 truncate" id="appliedCode"></p>
                                            <p class="text-xs text-green-600 truncate" id="appliedDescription"></p>
                                        </div>
                                    </div>
                                    <button onclick="removeCoupon()" class="text-red-600 hover:text-red-700 ml-2">
                                        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Price Breakdown -->
                        <div class="space-y-2 sm:space-y-3 mb-4 sm:mb-6">
                            <div class="flex justify-between text-gray-600 text-sm">
                                <span>Subtotal</span>
                                <span>₹<%= subtotal %></span>
                            </div>
                            
                            <!-- Product Savings -->
                            <% if (totalSavings > 0) { %>
                            <div class="flex justify-between text-green-600 text-sm">
                                <span>Product Savings</span>
                                <span>₹<%= totalSavings.toFixed(2) %></span>
                            </div>
                            <% } %>
                            
                            <!-- Coupon Discount (if any) -->
                            <div class="flex justify-between text-green-600 text-sm" id="couponDiscount" style="display: none;">
                                <span>Coupon Discount</span>
                                <span id="couponDiscountValue">-₹0</span>
                            </div>
                            
                            <div class="flex justify-between text-gray-600 text-sm">
                                <span>Shipping</span>
                                <span class="text-green-600 font-semibold"><%= shipping===0?"Free":shipping %></span>
                            </div>
                            
                            <div class="border-t pt-2 sm:pt-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-base sm:text-lg font-bold text-gray-800">Total</span>
                                    <span class="text-xl sm:text-2xl font-bold text-purple-600" id="finalTotal">₹<%= finalAmount %></span>
                                </div>
                                <% if (totalSavings > 0) { %>
                                <p class="text-xs text-green-600 mt-1 font-medium">
                                    You saved ₹<%= totalSavings.toFixed(2) %> on this order!
                                </p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Place Order Button -->
                        <button onclick="placeOrder()" class="w-full gradient-bg text-white py-3 sm:py-4 rounded-lg font-semibold hover:opacity-90 transition mb-3 sm:mb-4 text-sm sm:text-base">
                            Place Order
                        </button>

                        <!-- Terms and Conditions -->
                        <div class="text-center text-xs text-gray-500">
                            <p>By placing your order, you agree to our</p>
                            <p>
                                <a href="#" class="text-purple-600 hover:underline">Terms & Conditions</a> 
                                and 
                                <a href="#" class="text-purple-600 hover:underline">Privacy Policy</a>
                            </p>
                        </div>

                        <!-- Security Badges -->
                        <div class="mt-4 sm:mt-6 pt-4 sm:pt-6 border-t">
                            <div class="flex items-center justify-center space-x-3 sm:space-x-4 text-xs sm:text-sm text-gray-600">
                                <div class="flex items-center space-x-1">
                                    <svg class="w-4 h-4 sm:w-5 sm:h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                                    </svg>
                                    <span class="text-xs">Secure</span>
                                </div>
                                <div class="flex items-center space-x-1">
                                    <svg class="w-4 h-4 sm:w-5 sm:h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                    <span class="text-xs">SSL Encrypted</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/checkout.js"></script>

<script>
// Coupon functions
function applyCoupon(code, description) {
    document.getElementById('appliedCode').textContent = code;
    document.getElementById('appliedDescription').textContent = description;
    document.getElementById('appliedCoupon').classList.remove('hidden');
    document.getElementById('couponForm').classList.add('hidden');
    document.getElementById('toggleCoupon').style.display = 'none';
    
    // Show coupon discount in price breakdown
    document.getElementById('couponDiscount').style.display = 'flex';
    
    // Calculate discount based on coupon
    let discount = 0;
    if (code === 'FLAT500') {
        discount = 500;
    } else if (code === 'SAVE20') {
        discount = Math.min(Math.round(<%= subtotal %> * 0.20), 1000);
    } else if (code === 'FREESHIP') {
        discount = <%= shipping %>;
    }
    
    document.getElementById('couponDiscountValue').textContent = '-₹' + discount;
    
    // Update final total
    const originalTotal = <%= finalAmount %>;
    const productSavings = <%= totalSavings.toFixed(2) %>;
    const newTotal = originalTotal - discount;
    document.getElementById('finalTotal').textContent = '₹' + newTotal.toFixed(2);
    
    // Update savings message
    const totalSavings = productSavings + discount;
    const savingsElement = document.querySelector('.text-xs.text-green-600.mt-1');
    if (savingsElement) {
        savingsElement.textContent = `You saved ₹${totalSavings.toFixed(2)} on this order!`;
    }
    
    // Show success message
    Swal.fire({
        icon: 'success',
        title: 'Coupon Applied!',
        text: description,
        timer: 1500,
        showConfirmButton: false
    });
}

function removeCoupon() {
    document.getElementById('appliedCoupon').classList.add('hidden');
    document.getElementById('couponDiscount').style.display = 'none';
    document.getElementById('toggleCoupon').style.display = 'flex';
    
    // Reset final total
    document.getElementById('finalTotal').textContent = '₹<%= finalAmount %>';
    
    // Reset savings message
    const savingsElement = document.querySelector('.text-xs.text-green-600.mt-1');
    if (savingsElement) {
        savingsElement.textContent = `You saved ₹<%= totalSavings.toFixed(2) %> on this order!`;
    }
}

// Toggle coupon form
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('toggleCoupon');
    const couponForm = document.getElementById('couponForm');
    const chevron = document.getElementById('chevron');
    
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
            couponForm.classList.toggle('hidden');
            chevron.classList.toggle('rotate-180');
        });
    }
});
</script>

<style>
.slide-down {
    animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.rotate-180 {
    transform: rotate(180deg);
}

.gradient-bg {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.line-through {
    text-decoration: line-through;
}
</style>


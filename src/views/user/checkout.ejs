                                                                                    <%= coupon.discountValue %>% OFF
                                                                                        <% } else { %>
                                                                                            ₹<%= coupon.discountValue %>
                                                                                                OFF
                                                                                                <% } %>
                                                                            </span>
                                                                        </div>
                                                                        <p
                                                                            class="text-xs sm:text-sm font-semibold text-gray-800 mb-1">
                                                                            <%= coupon.title %>
                                                                        </p>

<%- include('../partials/user/header') %>

<main class="bg-obsidian min-h-screen text-ivory pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-6 sm:px-8">
        
        <!-- Progress Indicator -->
        <div class="mb-12 border-b border-gold-light/5 pb-8">
            <div class="flex items-center justify-between max-w-md mx-auto">
                <div class="flex flex-col items-center">
                    <span class="w-7 h-7 rounded-full bg-gold-light text-obsidian flex items-center justify-center text-xs font-bold shadow-md">✓</span>
                    <span class="text-[9px] uppercase tracking-widest text-gold-light mt-2">Bag</span>
                </div>
                <div class="flex-1 h-[1px] bg-gold-light/40 mx-4"></div>
                <div class="flex flex-col items-center">
                    <span class="w-7 h-7 rounded-full border border-gold-accent bg-gold-light/10 text-gold-accent flex items-center justify-center text-xs font-bold shadow-md">2</span>
                    <span class="text-[9px] uppercase tracking-widest text-gold-accent mt-2">Checkout</span>
                </div>
                <div class="flex-1 h-[1px] bg-gold-light/10 mx-4"></div>
                <div class="flex flex-col items-center">
                    <span class="w-7 h-7 rounded-full border border-gold-light/10 text-gray-500 flex items-center justify-center text-xs">3</span>
                    <span class="text-[9px] uppercase tracking-widest text-gray-500 mt-2">Order</span>
                </div>
            </div>
        </div>

        <!-- Linear Checkout Content -->
        <div class="space-y-12">
            
            <!-- Section 1: Order Review Summary -->
            <div class="border border-gold-light/10 bg-obsidian-light p-6 rounded-sm space-y-6">
                <div class="flex justify-between items-center border-b border-gold-light/5 pb-4">
                    <h2 class="font-display text-lg tracking-wide text-gold-light">Order Summary</h2>
                    <span class="text-[10px] text-gray-500 uppercase tracking-widest"><%= cartItems.length %> Items</span>
                </div>
                
                <div class="divide-y divide-gold-light/5 max-h-48 overflow-y-auto pr-2 no-scrollbar">
                    <% cartItems.forEach((item) => { %>
                        <div class="py-4 flex gap-4 first:pt-0 last:pb-0">
                            <!-- Image -->
                            <div class="w-12 h-16 bg-obsidian border border-gold-light/5 rounded p-1 flex items-center justify-center flex-shrink-0">
                                <img src="<%= item.mainImage?.url || '/img/placeholder.jpg' %>" alt="<%= item.product.name %>" class="w-full h-full object-contain">
                            </div>
                            <!-- Details -->
                            <div class="flex-1 min-w-0">
                                <h4 class="text-xs font-medium text-gold-light truncate"><%= item.product.name %></h4>
                                <p class="text-[10px] text-gray-500 mt-0.5"><%= item.variant?.deviceModel || 'Premium Case' %> × <%= item.quantity %></p>
                            </div>
                            <!-- Price -->
                            <div class="text-right">
                                <span class="text-xs text-gold-light block">₹<%= Math.floor(item.finalPrice) %></span>
                                <% if (item.orgPrice * item.quantity > item.finalPrice) { %>
                                    <span class="text-[10px] text-gray-500 line-through">₹<%= Math.floor(item.orgPrice * item.quantity) %></span>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Section 2: Shipping Details -->
            <div class="space-y-6">
                <div class="flex justify-between items-center border-b border-gold-light/10 pb-3">
                    <h3 class="font-display text-xl tracking-wide text-gold-light">1. Shipping Details</h3>
                    <div class="relative">
                        <button id="addressDropdownBtn" class="text-[10px] uppercase tracking-widest text-gold-accent hover:underline flex items-center gap-1">
                            Use Saved Address <i class="fas fa-chevron-down text-[8px]"></i>
                        </button>
                        <!-- Address selection dropdown -->
                        <div id="addressDropdown" class="absolute right-0 mt-2 w-72 bg-obsidian-light border border-gold-light/10 rounded-sm py-2 z-50 shadow-2xl hidden">
                            <div class="px-4 py-2 border-b border-gold-light/5 bg-obsidian">
                                <h4 class="text-[10px] uppercase tracking-widest text-gold-accent font-semibold">Select Saved Address</h4>
                            </div>
                            <div class="max-h-56 overflow-y-auto no-scrollbar">
                                <% if (addresses && addresses.length > 0) { %>
                                    <% addresses.forEach((address, index) => { %>
                                        <div class="px-4 py-3 hover:bg-gold-light/5 cursor-pointer border-b border-gold-light/5 last:border-0"
                                             onclick="document.getElementById('address_<%= index %>').click()">
                                            <div class="flex items-start">
                                                <input type="radio" id="address_<%= index %>" name="savedAddress" value="<%= address._id %>" class="mt-1 mr-3 accent-gold-accent"
                                                       data-first-name="<%= address.firstName || '' %>"
                                                       data-last-name="<%= address.lastName || '' %>"
                                                       data-phone="<%= address.phone || '' %>"
                                                       data-line1="<%= address.streetAddress || '' %>"
                                                       data-landmark="<%= address.landMark || '' %>"
                                                       data-city="<%= address.city || '' %>"
                                                       data-state="<%= address.state || '' %>"
                                                       data-pincode="<%= address.pinCode || '' %>"
                                                       data-address-type="<%= address.addressType || '' %>">
                                                <div class="min-w-0">
                                                    <span class="text-xs font-semibold text-gold-light block"><%= address.addressType || 'Address' %></span>
                                                    <p class="text-[10px] text-gray-400 mt-1 truncate"><%= address.streetAddress %>, <%= address.city %></p>
                                                    <p class="text-[9px] text-gray-500 mt-0.5"><%= address.firstName %> | <%= address.phone %></p>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="p-4 text-center text-xs text-gray-500">No saved addresses found.</div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <form id="shippingForm" class="grid grid-cols-1 sm:grid-cols-2 gap-5" novalidate>
                    <!-- First & Last Name -->
                    <div>
                        <label for="first-name" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">First Name *</label>
                        <input type="text" id="first-name" name="firstName" required
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="first-nameError"></p>
                    </div>
                    <div>
                        <label for="last-name" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">Last Name *</label>
                        <input type="text" id="last-name" name="lastName" required
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="last-nameError"></p>
                    </div>
                    
                    <!-- Phone Number -->
                    <div class="sm:col-span-2">
                        <label for="phone" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">Phone Number *</label>
                        <input type="tel" id="phone" name="phone" required placeholder="10-digit number"
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="phoneError"></p>
                    </div>

                    <!-- Street Address -->
                    <div class="sm:col-span-2">
                        <label for="line1" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">Street Address *</label>
                        <input type="text" id="line1" name="line1" required placeholder="Flat, House no., Building, Company"
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="line1Error"></p>
                    </div>

                    <!-- Landmark -->
                    <div class="sm:col-span-2">
                        <label for="landmark" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">Landmark (Optional)</label>
                        <input type="text" id="landmark" name="landmark" placeholder="E.g. Near Apollo Hospital"
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                    </div>

                    <!-- City, State, Pin Code -->
                    <div>
                        <label for="city" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">City *</label>
                        <input type="text" id="city" name="city" required
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="cityError"></p>
                    </div>
                    <div>
                        <label for="state" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">State *</label>
                        <select id="state" name="state" required
                                class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors cursor-pointer">
                            <option value="">Select State</option>
                            <option value="Kerala">Kerala</option>
                            <option value="Tamil Nadu">Tamil Nadu</option>
                            <option value="Karnataka">Karnataka</option>
                            <option value="Maharashtra">Maharashtra</option>
                            <option value="Delhi">Delhi</option>
                            <option value="West Bengal">West Bengal</option>
                            <option value="Uttar Pradesh">Uttar Pradesh</option>
                            <option value="Gujarat">Gujarat</option>
                            <option value="Rajasthan">Rajasthan</option>
                            <option value="Punjab">Punjab</option>
                        </select>
                        <p class="text-[10px] text-red-400 mt-1" id="stateError"></p>
                    </div>
                    <div class="sm:col-span-2">
                        <label for="pincode" class="block text-[9px] uppercase tracking-widest text-gold-accent font-medium mb-1.5">PIN Code *</label>
                        <input type="text" id="pincode" name="pincode" required pattern="[0-9]{6}" maxlength="6" placeholder="6-digit pin"
                               class="w-full bg-obsidian-light border border-gold-light/10 text-xs text-ivory px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent transition-colors">
                        <p class="text-[10px] text-red-400 mt-1" id="pincodeError"></p>
                    </div>

                    <!-- Save address toggle option -->
                    <div class="sm:col-span-2 pt-2 border-t border-gold-light/5 flex flex-col gap-3">
                        <label class="flex items-center space-x-2.5 cursor-pointer">
                            <input id="saveAddressCheckbox" name="saveAddress" type="checkbox" class="accent-gold-accent w-4 h-4 cursor-pointer">
                            <span class="text-[10px] uppercase tracking-widest text-gold-light">Save this address to my profile</span>
                        </label>
                        <div id="addressTypeContainer" class="hidden pl-6 space-y-2">
                            <p class="text-[9px] uppercase tracking-widest text-gray-500">Address Label</p>
                            <div class="flex gap-4">
                                <label class="flex items-center space-x-2 cursor-pointer">
                                    <input type="radio" name="addressType" value="Home" checked class="accent-gold-accent w-3.5 h-3.5 cursor-pointer">
                                    <span class="text-xs text-gray-300">Home</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer">
                                    <input type="radio" name="addressType" value="Work" class="accent-gold-accent w-3.5 h-3.5 cursor-pointer">
                                    <span class="text-xs text-gray-300">Work</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Section 3: Payment Info -->
            <div class="space-y-6">
                <div class="border-b border-gold-light/10 pb-3">
                    <h3 class="font-display text-xl tracking-wide text-gold-light">2. Payment Method</h3>
                </div>

                <div class="space-y-4">
                    <!-- Razorpay Option -->
                    <div class="border border-gold-light/10 bg-obsidian-light rounded-sm p-4 hover:border-gold-accent cursor-pointer transition-all payment-option" data-payment="razorpay">
                        <label class="flex items-center justify-between cursor-pointer w-full">
                            <div class="flex items-center">
                                <input type="radio" name="payment" value="razorpay" class="accent-gold-accent w-4 h-4 cursor-pointer">
                                <span class="ml-3 text-xs uppercase tracking-widest text-gold-light font-semibold">Razorpay Online</span>
                            </div>
                            <img src="https://cdn.razorpay.com/static/assets/logo/payment.svg" alt="Razorpay" class="h-4">
                        </label>
                        <p class="text-[10px] text-gray-400 mt-2 ml-7">UPI, Cards, Wallets, and NetBanking</p>
                    </div>

                    <!-- Wallet Option -->
                    <% if (walletButton) { %>
                        <div class="border border-gold-light/10 bg-obsidian-light rounded-sm p-4 hover:border-gold-accent cursor-pointer transition-all payment-option" data-payment="wallet">
                            <label class="flex items-center justify-between cursor-pointer w-full">
                                <div class="flex items-center">
                                    <input type="radio" name="payment" value="wallet" class="accent-gold-accent w-4 h-4 cursor-pointer">
                                    <span class="ml-3 text-xs uppercase tracking-widest text-gold-light font-semibold">Wallet Balance</span>
                                </div>
                                <span class="text-xs text-gold-accent font-semibold"><i class="fas fa-wallet mr-1"></i> Pay with balance</span>
                            </label>
                            <p class="text-[10px] text-gray-400 mt-2 ml-7">Instant debit from your registered CaseCart wallet.</p>
                        </div>
                    <% } %>

                    <!-- COD Option -->
                    <% if (cod) { %>
                        <div class="border border-gold-light/10 bg-obsidian-light rounded-sm p-4 hover:border-gold-accent cursor-pointer transition-all payment-option" data-payment="cod">
                            <label class="flex items-center justify-between cursor-pointer w-full">
                                <div class="flex items-center">
                                    <input type="radio" name="payment" value="cod" class="accent-gold-accent w-4 h-4 cursor-pointer">
                                    <span class="ml-3 text-xs uppercase tracking-widest text-gold-light font-semibold">Cash on Delivery</span>
                                </div>
                                <span class="text-xs text-green-500 font-semibold"><i class="fas fa-money-bill-wave mr-1"></i> Cash</span>
                            </label>
                            <p class="text-[10px] text-gray-400 mt-2 ml-7">Pay cash to delivery executive upon package arrival.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Section 4: Coupon & Discounts -->
            <div class="space-y-6">
                <button id="toggleCoupon" class="flex justify-between items-center w-full border border-gold-light/10 bg-obsidian-light p-4 rounded-sm text-left">
                    <span class="text-xs uppercase tracking-widest text-gold-light font-medium flex items-center gap-2">
                        <i class="fas fa-ticket-alt text-gold-accent"></i> Apply Promotional Code
                    </span>
                    <i id="chevron" class="fas fa-chevron-down text-[10px] text-gray-400 transition-transform duration-300"></i>
                </button>

                <!-- Coupon Form Drawer -->
                <div id="couponForm" class="hidden border border-gold-light/5 bg-obsidian-light/40 p-5 rounded-sm space-y-5 animate-fade-in">
                    <div class="flex gap-3">
                        <input type="text" id="couponInput" placeholder="PROMOCODE"
                               class="flex-1 bg-obsidian border border-gold-light/10 text-xs text-ivory uppercase tracking-wider px-4 py-3 rounded-sm focus:outline-none focus:border-gold-accent">
                        <button id="applyBtn" class="bg-gold-light hover:bg-gold-accent text-obsidian text-xs uppercase tracking-widest font-bold px-6 py-3 rounded-sm transition-colors duration-200">
                            Apply
                        </button>
                    </div>

                    <!-- Available coupons -->
                    <div class="space-y-3 pt-3 border-t border-gold-light/5">
                        <p class="text-[9px] uppercase tracking-widest text-gray-500">Available Offers</p>
                        <div class="grid gap-3 max-h-48 overflow-y-auto pr-1 no-scrollbar">
                            <% if (coupons && coupons.length > 0) { %>
                                <% coupons.forEach(coupon => { %>
                                    <div class="coupon-card border border-dashed border-gold-light/20 hover:border-gold-accent rounded-sm p-4 transition-colors cursor-pointer"
                                         data-coupon-code="<%= coupon.couponCode %>"
                                         data-title="<%= coupon.title %>"
                                         data-description="<%= coupon.description || 'Exclusive CaseCart discount' %>"
                                         data-discount-value="<%= coupon.discountValue %>"
                                         data-discount-type="<%= coupon.discountType %>"
                                         data-min-purchase="<%= coupon.MinimumPurchaseValue %>"
                                         data-end-date="<%= coupon.endDate %>"
                                         data-id="<%= coupon._id %>"
                                         data-max-discount="<%= coupon.maximumDiscount %>"
                                         onclick="handleCouponClick(this)">
                                        <div class="flex justify-between items-start">
                                            <div class="space-y-1">
                                                <div class="flex items-center gap-2">
                                                    <span class="font-mono text-xs font-bold text-gold-accent bg-gold-light/5 border border-gold-accent/20 px-2 py-0.5"><%= coupon.couponCode %></span>
                                                    <span class="text-[9px] bg-gold-accent text-obsidian px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">
                                                        <%= coupon.discountType === 'percentage' ? coupon.discountValue + '% OFF' : '₹' + coupon.discountValue + ' OFF' %>
                                                    </span>
                                                </div>
                                                <h5 class="text-xs font-medium text-gold-light"><%= coupon.title %></h5>
                                                <p class="text-[10px] text-gray-400"><%= coupon.description %></p>
                                                <p class="text-[9px] text-gray-500">Min. Purchase: ₹<%= coupon.MinimumPurchaseValue %></p>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-xs text-gray-500 text-center py-2">No promotional campaigns available.</p>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Selected coupon badge/details -->
                <div id="selectedCouponDetails" class="hidden border border-gold-accent/20 bg-gold-light/5 p-4 rounded-sm flex justify-between items-start gap-4">
                    <div class="space-y-1 flex-1">
                        <div class="flex items-center gap-2">
                            <span id="selectedCouponCode" class="font-mono text-xs font-bold text-gold-accent px-2 py-0.5 border border-gold-accent/20 bg-gold-light/5"></span>
                            <span id="selectedCouponBadge" class="text-[9px] bg-gold-accent text-obsidian px-2 py-0.5 rounded-full font-bold uppercase tracking-wider"></span>
                        </div>
                        <p id="selectedCouponDesc" class="text-[10px] text-gray-400"></p>
                        <p class="text-[9px] text-gray-500">
                            Min. purchase: ₹<span id="selectedCouponMin"></span> | Valid till: <span id="selectedCouponDate"></span>
                        </p>
                        <p id="selectedCouponError" class="text-[9px] text-red-400 font-semibold hidden"></p>
                    </div>
                    <button onclick="removeSelectedCoupon()" class="bg-red-950/40 border border-red-500/20 text-red-400 text-[10px] uppercase tracking-widest px-3 py-1.5 rounded-sm hover:bg-red-500 hover:text-white transition-all">
                        Remove
                    </button>
                </div>
            </div>

            <!-- Section 5: Order Breakdown & Call-To-Action -->
            <div class="border-t border-gold-light/10 pt-8 space-y-6">
                <div class="space-y-3">
                    <div class="flex justify-between text-xs text-gray-400">
                        <span>Subtotal</span>
                        <span>₹<%= Math.floor(subtotal).toFixed(2) %></span>
                    </div>
                    <div class="flex justify-between text-xs text-gray-400">
                        <span>Product Savings</span>
                        <span class="text-green-500">-₹<%= Math.floor(offerDiscountTotal || 0).toFixed(2) %></span>
                    </div>
                    <div id="couponDiscount" class="flex justify-between text-xs text-gray-400 hidden">
                        <span>Coupon Savings</span>
                        <span id="couponDiscountValue" class="text-green-500">-₹0.00</span>
                    </div>
                    <div class="flex justify-between text-xs text-gray-400">
                        <span>Shipping Delivery</span>
                        <span class="<%= shipping === 0 ? 'text-green-500' : 'text-gray-400' %>">
                            <%= shipping === 0 ? 'Free Delivery' : '₹' + Math.floor(shipping).toFixed(2) %>
                        </span>
                    </div>
                    <div class="border-t border-gold-light/5 pt-4 flex justify-between items-center">
                        <span class="text-sm uppercase tracking-widest text-gold-light font-medium">Grand Total</span>
                        <span id="finalTotal" class="text-2xl font-light text-gold-light">₹<%= Math.floor(finalAmount).toFixed(2) %></span>
                    </div>
                </div>

                <!-- Place order CTA button -->
                <button onclick="placeOrder()" 
                        class="w-full bg-gold-light hover:bg-gold-accent text-obsidian py-4 rounded-sm text-xs uppercase tracking-widest font-bold transition-all duration-300 shadow-xl transform active:scale-95">
                    Place Order
                </button>
                
                <div class="text-center text-[10px] text-gray-500">
                    Secure transaction. By completing this checkout, you agree to our 
                    <a href="/terms" class="text-gold-light hover:underline">Terms of Service</a> & <a href="/privacy" class="text-gold-light hover:underline">Privacy Policy</a>.
                </div>
            </div>

        </div>
    </div>
</main>

<!-- Scripts -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/user/checkout.js"></script>

<script>
    // Ensure all values are defined and numbers
    const js_subtotal = Number('<%= subtotal %>') || 0;
    const js_shipping = Number('<%= shipping %>') || 0;
    const js_finalAmount = Number('<%= finalAmount %>') || 0;

    window.checkoutData = {
        subtotal: js_subtotal,
        shipping: js_shipping,
        finalAmount: js_finalAmount
    };
</script>

<%- include('../partials/user/footer') %>
                                                                            class="flex flex-wrap items-center gap-2 sm:gap-3 text-xs text-gray-400">
                                                                            <span
                                                                                class="flex items-center gap-1 whitespace-nowrap">
                                                                                <svg class="w-3 h-3 flex-shrink-0"
                                                                                    fill="currentColor"
                                                                                    viewBox="0 0 20 20">
                                                                                    <path fill-rule="evenodd"
                                                                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
                                                                                        clip-rule="evenodd" />
                                                                                </svg>
                                                                                Valid till: <%= formattedDate %>
                                                                            </span>
                                                                            <span
                                                                                class="flex items-center gap-1 whitespace-nowrap">
                                                                                <svg class="w-3 h-3 flex-shrink-0"
                                                                                    fill="currentColor"
                                                                                    viewBox="0 0 20 20">
                                                                                    <path fill-rule="evenodd"
                                                                                        d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 004 18h12a1 1 0 00.994-1.11l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z"
                                                                                        clip-rule="evenodd" />
                                                                                </svg>
                                                                                Min: ₹<%= coupon.MinimumPurchaseValue %>
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                    <button
                                                                        class="text-xs sm:text-sm text-green-600 font-medium hover:text-green-700 whitespace-nowrap mt-1 sm:mt-0 sm:ml-2 px-2 sm:px-3 py-1.5 rounded-md bg-green-50 hover:bg-green-100 transition-colors self-start">
                                                                        View Details
                                                                    </button>
                                                                </div>
                                                            </div>
                                                            <% }) %>
                                                                <% } else { %>
                                                                    <div class="text-center py-4">
                                                                        <svg class="w-12 h-12 text-gray-400 mx-auto mb-2"
                                                                            fill="none" stroke="currentColor"
                                                                            viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round"
                                                                                stroke-linejoin="round" stroke-width="2"
                                                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z">
                                                                            </path>
                                                                        </svg>
                                                                        <p class="text-sm text-gray-500">No coupons
                                                                            available at the moment</p>
                                                                    </div>
                                                                    <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Price Breakdown - FIXED to show subtotal - savings -->
                            <div class="space-y-2 sm:space-y-3 mb-4 sm:mb-6">
                                <div class="flex justify-between text-gray-600 text-sm">
                                    <span>Subtotal</span>
                                    <span class="font-medium">₹<%= subtotal.toFixed(2) %></span>
                                </div>

                                <!-- Product Savings -->
                                <div class="flex justify-between text-green-600 text-sm">
                                    <span>Product Savings</span>
                                    <span class="font-medium">-₹<%= (offerDiscountTotal || 0).toFixed(2) %></span>
                                </div>

                                <!-- Coupon Discount (Hidden by default) -->
                                <div class="flex justify-between text-green-600 text-sm hidden" id="couponDiscount">
                                    <span>Coupon Discount</span>
                                    <span class="font-medium" id="couponDiscountValue">-₹0.00</span>
                                </div>

                                <div class="flex justify-between text-gray-600 text-sm">
                                    <span>Shipping</span>
                                    <span class="<%= shipping===0?'text-green-600 font-semibold':'font-medium' %>">
                                        <%= shipping===0?"Free":`₹${shipping.toFixed(2)}` %>

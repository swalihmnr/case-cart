<%- include('../partials/user/header') %>

    <!-- Add CSS link in head section -->
    <!-- Removed problematic CSS link -->

    <div class="checkout-container">
        <main class="w-full">
            <!-- Progress Steps -->
            <div class="bg-white border-b">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6">
                    <div class="flex items-center justify-between max-w-3xl mx-auto">
                        <!-- Step 1: Cart -->
                        <div class="flex flex-col items-center flex-1">
                            <div
                                class="progress-step w-8 h-8 sm:w-10 sm:h-10 bg-green-500 rounded-full flex items-center justify-center font-semibold mb-1 sm:mb-2 completed">
                                <svg class="w-4 h-4 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                        clip-rule="evenodd" />
                                </svg>
                            </div>
                            <span class="text-xs text-gray-600 font-medium text-center">Cart</span>
                        </div>

                        <!-- Connector Line -->
                        <div class="flex-1 h-1 bg-green-500 mx-1 sm:mx-2"></div>

                        <!-- Step 2: Shipping -->
                        <div class="flex flex-col items-center flex-1">
                            <div
                                class="progress-step w-8 h-8 sm:w-10 sm:h-10 bg-blue-500 rounded-full flex items-center text-white justify-center font-semibold mb-1 sm:mb-2 active">
                                2</div>
                            <span class="text-xs text-gray-600 font-medium text-center">Shipping</span>
                        </div>

                        <!-- Connector Line -->
                        <div class="flex-1 h-1 bg-gray-300 mx-1 sm:mx-2"></div>

                        <!-- Step 3: Payment -->
                        <div class="flex flex-col items-center flex-1">
                            <div
                                class="progress-step w-8 h-8 sm:w-10 sm:h-10 bg-gray-300 rounded-full flex items-center justify-center font-semibold mb-1 sm:mb-2">
                                3</div>
                            <span class="text-xs text-gray-600 font-medium text-center">Payment</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Main Content Area -->
            <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-8 py-4 sm:py-6 lg:py-8">
                <div class="grid lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
                    <!-- Left Column: Forms -->
                    <div class="lg:col-span-2 space-y-4 sm:space-y-6">
                        <!-- Shipping Information Card -->
                        <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6">
                            <div
                                class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 sm:mb-6 relative">
                                <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-2 sm:mb-0">Shipping
                                    Information</h2>

                                <div class="relative self-end sm:self-auto">
                                    <button id="addressDropdownBtn"
                                        class="text-sm text-purple-600 font-medium cursor-pointer hover:text-purple-700 focus:outline-none px-3 py-2 rounded-lg hover:bg-purple-50 transition-colors">
                                        Use saved address
                                    </button>

                                    <!-- Dropdown Menu -->
                                    <div id="addressDropdown"
                                        class="absolute right-0 mt-2 w-56 sm:w-64 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-50 address-dropdown hidden">
                                        <div class="px-4 py-2 border-b border-gray-100 bg-gray-50">
                                            <h3 class="font-medium text-gray-800 text-sm">Select an address</h3>
                                        </div>

                                        <div class="max-h-48 sm:max-h-60 overflow-y-auto">
                                            <% if (addresses && addresses.length> 0) { %>
                                                <% addresses.forEach((address, index)=> { %>
                                                    <div class="px-4 py-3 hover:bg-gray-50 cursor-pointer transition-colors border-b border-gray-100 last:border-b-0"
                                                        onclick="document.getElementById('address_<%= index %>').click()">
                                                        <div class="flex items-start">
                                                            <input type="radio" id="address_<%= index %>"
                                                                name="savedAddress" value="<%= address._id %>"
                                                                class="mt-1 mr-3 cursor-pointer" <%=address.isDefault
                                                                ? 'checked' : '' %>
                                                            data-first-name="<%= address.firstName || '' %>"
                                                                data-last-name="<%= address.lastName || '' %>"
                                                                    data-phone="<%= address.phone || '' %>"
                                                                        data-line1="<%= address.streetAddress || '' %>"
                                                                            data-landmark="<%= address.landMark || '' %>
                                                                                "
                                                                                data-city="<%= address.city || '' %>"
                                                                                    data-state="<%= address.state || ''
                                                                                        %>"
                                                                                        data-pincode="<%=
                                                                                            address.pinCode || '' %>"
                                                                                            data-address-type="<%=
                                                                                                address.addressType
                                                                                                || '' %>"
                                                                                                >
                                                                                                <div
                                                                                                    class="flex-1 min-w-0">
                                                                                                    <div
                                                                                                        class="flex items-center justify-between mb-1">
                                                                                                        <label
                                                                                                            for="address_<%= index %>"
                                                                                                            class="font-medium text-gray-800 block text-sm truncate cursor-pointer">
                                                                                                            <%= address.addressType
                                                                                                                || 'Address'
                                                                                                                %>
                                                                                                        </label>
                                                                                                        <% if
                                                                                                            (address.isDefault)
                                                                                                            { %>
                                                                                                            <span
                                                                                                                class="text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">Default</span>
                                                                                                            <% } %>
                                                                                                    </div>
                                                                                                    <p
                                                                                                        class="text-xs text-gray-600 mt-1 line-clamp-2">
                                                                                                        <%= address.streetAddress
                                                                                                            || '' %>,
                                                                                                            <%= address.landMark
                                                                                                                || '' %>
                                                                                                                ,
                                                                                                                <%= address.city
                                                                                                                    || ''
                                                                                                                    %>,
                                                                                                                    <%= address.state
                                                                                                                        || ''
                                                                                                                        %>
                                                                                                                        -
                                                                                                                        <%= address.pinCode
                                                                                                                            || ''
                                                                                                                            %>
                                                                                                    </p>
                                                                                                    <p
                                                                                                        class="text-xs text-gray-500 mt-1">
                                                                                                        <%= address.firstName
                                                                                                            || '' %>
                                                                                                            <%= address.lastName
                                                                                                                || '' %>
                                                                                                                |
                                                                                                                <%= address.phone
                                                                                                                    || ''
                                                                                                                    %>
                                                                                                    </p>
                                                                                                </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="px-4 py-6 text-center">
                                                                <svg class="w-12 h-12 text-gray-400 mx-auto mb-2"
                                                                    fill="none" stroke="currentColor"
                                                                    viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2"
                                                                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4">
                                                                    </path>
                                                                </svg>
                                                                <p class="text-sm text-gray-500">No saved addresses
                                                                    found</p>
                                                            </div>
                                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <form class="space-y-4" id="shippingForm" novalidate>
                                <!-- First Name & Last Name -->
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
                                    <!-- First Name -->
                                    <div>
                                        <label for="first-name"
                                            class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                            First Name *
                                        </label>
                                        <input type="text" id="first-name" name="firstName"
                                            class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                            placeholder="Enter first name" required>
                                        <p class="text-xs sm:text-sm text-red-500 mt-1" id="first-nameError"></p>
                                    </div>

                                    <!-- Last Name -->
                                    <div>
                                        <label for="last-name"
                                            class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                            Last Name *
                                        </label>
                                        <input type="text" id="last-name" name="lastName"
                                            class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                            placeholder="Enter last name" required>
                                        <p class="text-xs sm:text-sm text-red-500 mt-1" id="last-nameError"></p>
                                    </div>
                                </div>

                                <!-- Phone Number -->
                                <div>
                                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        Phone Number *
                                    </label>
                                    <input type="tel" id="phone" name="phone"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                        placeholder="Enter phone number" pattern="[0-9]{10}" maxlength="10" required>
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="phoneError"></p>
                                </div>

                                <!-- Address Line 1 -->
                                <div>
                                    <label for="line1" class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        Street Address *
                                    </label>
                                    <input type="text" id="line1" name="line1"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                        placeholder="House No, Building Name, Street" required>
                                    <p class="text-xs sm:text-sm text-red-500 mt-1" id="line1Error"></p>
                                </div>

                                <!-- Landmark -->
                                <div>
                                    <label for="landmark" class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                        Landmark (Optional)
                                    </label>
                                    <input type="text" id="landmark" name="landmark"
                                        class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors"
                                        placeholder="Near school, hospital, etc.">
                                </div>

                                <!-- City / State / PIN -->
                                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
                                    <!-- City -->
                                    <div>
                                        <label for="city" class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                            City *
                                        </label>
                                        <input type="text" id="city" name="city"
                                            class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                            placeholder="City" required>
                                        <p class="text-xs sm:text-sm text-red-500 mt-1" id="cityError"></p>
                                    </div>

                                    <!-- State -->
                                    <div>
                                        <label for="state" class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                            State *
                                        </label>
                                        <select id="state" name="state"
                                            class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors cursor-pointer shipping-input"
                                            required>
                                            <option value="">Select State</option>
                                            <option value="Kerala">Kerala</option>
                                            <option value="Tamil Nadu">Tamil Nadu</option>
                                            <option value="Karnataka">Karnataka</option>
                                            <option value="Maharashtra">Maharashtra</option>
                                            <option value="Delhi">Delhi</option>
                                            <option value="West Bengal">West Bengal</option>
                                            <option value="Uttar Pradesh">Uttar Pradesh</option>
                                            <option value="Gujarat">Gujarat</option>
                                            <option value="Rajasthan">Rajasthan</option>
                                            <option value="Punjab">Punjab</option>
                                        </select>
                                        <p class="text-xs sm:text-sm text-red-500 mt-1" id="stateError"></p>
                                    </div>

                                    <!-- PIN -->
                                    <div>
                                        <label for="pincode"
                                            class="block text-sm font-medium text-gray-700 mb-1 sm:mb-2">
                                            PIN Code *
                                        </label>
                                        <input type="text" id="pincode" name="pincode"
                                            class="w-full px-3 sm:px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600 focus:border-transparent text-sm sm:text-base transition-colors shipping-input"
                                            placeholder="PIN Code" pattern="[0-9]{6}" maxlength="6" required>
                                        <p class="text-xs sm:text-sm text-red-500 mt-1" id="pincodeError"></p>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <!-- Payment Method Card -->
                        <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6">
                            <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4 sm:mb-6">Payment Method</h2>

                            <div class="space-y-3 sm:space-y-4">
                                <!-- Razorpay -->
                                <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer transition-all payment-option"
                                    data-payment="razorpay">
                                    <label class="flex items-center justify-between cursor-pointer w-full">
                                        <div class="flex items-center">
                                            <input type="radio" name="payment" value="razorpay"
                                                class="w-4 h-4 text-purple-600 focus:ring-purple-500 cursor-pointer">
                                            <span
                                                class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Razorpay</span>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <div class="flex items-center space-x-1">
                                                <img src="https://cdn.razorpay.com/static/assets/logo/payment.svg"
                                                    alt="Razorpay" class="h-6">
                                            </div>
                                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M9 5l7 7-7 7"></path>
                                            </svg>
                                        </div>
                                    </label>
                                    <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">UPI, Cards, Wallets,
                                        NetBanking and more</p>
                                </div>

                                <!-- Wallet -->
                                    <% if (walletButton) { %>
             
                                        <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer transition-all payment-option"
                                            data-payment="wallet">
                                            <label class="flex items-center justify-between cursor-pointer w-full">
                                                <div class="flex items-center">
                                                    <input type="radio" name="payment" value="wallet"
                                                        class="w-4 h-4 text-purple-600 focus:ring-purple-500 cursor-pointer">
                                                    <span
                                                        class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Wallet</span>
                                                </div>
                                                <div class="flex items-center space-x-2">
                                                    <div class="flex items-center space-x-1">
                                                        <div
                                                            class="w-6 h-6 bg-yellow-100 rounded-full flex items-center justify-center">
                                                            <svg class="w-4 h-4 text-yellow-600" fill="currentColor"
                                                                viewBox="0 0 20 20">
                                                                <path fill-rule="evenodd"
                                                                    d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4z"
                                                                    clip-rule="evenodd"></path>
                                                            </svg>
                                                        </div>
                                                    </div>
                                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                            d="M9 5l7 7-7 7"></path>
                                                    </svg>
                                                </div>
                                            </label>
                                            <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">Pay using your wallet balance
                                            </p>
                                        </div>
                                     <% } %>


                                <!-- Cash on Delivery -->
                                    <% if (cod) { %>
             
                                        <div class="border-2 border-gray-300 rounded-lg p-3 sm:p-4 hover:border-purple-400 cursor-pointer transition-all payment-option"
                                            data-payment="cod">
                                            <label class="flex items-center justify-between cursor-pointer w-full">
                                                <div class="flex items-center">
                                                    <input type="radio" name="payment" value="cod"
                                                        class="w-4 h-4 text-purple-600 focus:ring-purple-500 cursor-pointer">
                                                    <span class="ml-3 font-semibold text-gray-800 text-sm sm:text-base">Cash on
                                                        Delivery</span>
                                                </div>
                                                <div class="flex items-center space-x-2">
                                                    <div class="flex items-center space-x-1">
                                                        <div
                                                            class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center">
                                                            <svg class="w-4 h-4 text-green-600" fill="none"
                                                                stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z">
                                                                </path>
                                                            </svg>
                                                        </div>
                                                    </div>
                                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                            d="M9 5l7 7-7 7"></path>
                                                    </svg>
                                                </div>
                                            </label>
                                            <p class="text-xs sm:text-sm text-gray-500 mt-2 ml-7">Pay when you receive your
                                                order</p>
                                        </div>
                                    <% } %>

                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Order Summary -->
                    <div class="lg:col-span-1">
                        <div class="bg-white rounded-lg shadow-sm sm:shadow-md p-4 sm:p-6 sticky top-4">
                            <h2 class="text-lg sm:text-xl font-bold text-gray-800 mb-4 sm:mb-6">Order Summary</h2>

                            <!-- Selected Coupon Details -->
                            <div id="selectedCouponDetails"
                                class="hidden mb-4 p-3 bg-gradient-to-r from-yellow-50 to-orange-50 border border-yellow-200 rounded-lg slide-down"
                                data-coupon-id="">
                                <div class="flex justify-between items-start">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-2">
                                            <!-- Copyable Coupon Code -->
                                            <div class="relative group">
                                                <div class="flex items-center gap-1 px-3 py-1.5 bg-white border border-yellow-300 rounded-lg cursor-pointer hover:bg-yellow-50 transition-all duration-200 shadow-sm"
                                                    onclick="copyCouponCode()">
                                                    <span class="text-sm font-bold text-yellow-800 font-mono"
                                                        id="selectedCouponCode"></span>
                                                    <svg class="w-4 h-4 text-yellow-500" fill="none"
                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                                        </path>
                                                    </svg>
                                                </div>
                                                <!-- Tooltip -->
                                                <div
                                                    class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-2 py-1 bg-gray-800 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap z-50">
                                                    Click to copy
                                                    <div
                                                        class="absolute top-full left-1/2 transform -translate-x-1/2 border-4 border-transparent border-t-gray-800">
                                                    </div>
                                                </div>
                                            </div>
                                            <span id="selectedCouponBadge"
                                                class="text-xs bg-yellow-200 text-yellow-800 px-2 py-1 rounded-full font-semibold"></span>
                                        </div>
                                        <p class="text-xs text-yellow-700 mb-1" id="selectedCouponDesc"></p>
                                        <p class="text-xs text-gray-600">
                                            Min. purchase: ₹<span id="selectedCouponMin"></span> |
                                            Valid till: <span id="selectedCouponDate"></span>
                                        </p>
                                        <!-- Error Message Box -->
                                        <p id="selectedCouponError"
                                            class="text-xs text-red-600 font-semibold mt-1 hidden"></p>
                                    </div>
                                    <button onclick="removeSelectedCoupon()"
                                        class="ml-2 px-3 py-1 bg-red-600 text-white text-xs rounded-lg hover:bg-red-700 whitespace-nowrap transition-colors shadow-sm">
                                        Remove
                                    </button>
                                </div>
                            </div>

                            <!-- Order Items with Offers -->
                            <div class="space-y-4 sm:space-y-5 mb-4 sm:mb-6 pb-4 sm:pb-6 border-b border-gray-200">
                                <% cartItems.forEach((item, index)=> {
                                    const originalPrice = item.variant ? item.variant.salePrice : item.salePrice;
                                    const savingsPerItem =
                                    Math.floor((item.variant?.orgPrice*item.appliedOffer?.value)/100);

                                    %>
                                    <div
                                        class="bg-white rounded-lg border border-gray-200 p-3 sm:p-4 hover:shadow-sm transition-shadow">
                                        <div class="flex items-center space-x-3 mb-2">
                                            <!-- Product Image -->
                                            <div
                                                class="w-12 h-12 sm:w-16 sm:h-16 flex items-center justify-center flex-shrink-0 bg-gray-100 rounded-md overflow-hidden">
                                                <% if (item.mainImage?.url) { %>
                                                    <img src="<%= item.mainImage.url %>" alt="<%= item.product.name %>"
                                                        class="w-full h-full object-contain"
                                                        onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                                                    <% } else { %>
                                                        <div
                                                            class="w-full h-full bg-gray-200 flex items-center justify-center">
                                                            <svg class="w-6 h-6 text-gray-400" fill="none"
                                                                stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                                                                </path>
                                                            </svg>
                                                        </div>
                                                        <% } %>
                                            </div>


                                            <!-- Product Details -->
                                            <div class="flex-1 min-w-0">
                                                <h4 class="font-semibold text-gray-800 text-xs sm:text-sm truncate">
                                                    <%= item.product.name %>
                                                </h4>
                                                <% if (item.variant && item.variant.deviceModel) { %>
                                                    <p class="text-xs text-gray-500 mt-0.5 truncate">
                                                        <%= item.variant.deviceModel %>
                                                    </p>
                                                    <% } %>
                                                        <p class="text-xs text-gray-500 mt-1">
                                                            Qty: <%= item.quantity || 1 %>

<%- include('../partials/user/header') %>


<div class="flex">
    
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-12">
        <div class="bg-white border-b">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            <div class="flex items-center justify-between max-w-3xl mx-auto">
                <div class="flex flex-col items-center flex-1">
                    <div class="step w-10 h-10 bg-green-300 rounded-full flex items-center justify-center font-semibold mb-2">
                        <svg class="w-6 h-6 text-green-700" fill="currentColor" viewBox="0 0 20 20 ">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <span class="text-xs text-gray-600 font-medium">Cart</span>
                </div>
                <div class="flex-1 h-1 bg-green-500"></div>
                <div class="flex flex-col items-center flex-1">
                    <div class="step w-10 h-10 bg-blue-500 rounded-full flex items-center text-white justify-center font-semibold mb-2">2</div>
                    <span class="text-xs text-gray-600 font-medium">Shipping</span>
                </div>
                <div class="flex-1 h-1 bg-gray-300"></div>
                <div class="flex flex-col items-center flex-1">
                    <div class="step w-10 h-10 bg-gray-300 rounded-full flex items-center justify-center font-semibold mb-2">3</div>
                    <span class="text-xs text-gray-600 font-medium">Payment</span>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid lg:grid-cols-3 gap-8">
            <!-- Checkout Form -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Shipping Information -->
                <div class="bg-white rounded-lg shadow-md p-6">
                    <div class="flex items-center justify-between mb-6 relative">
    <h2 class="text-2xl font-bold text-gray-800">Shipping Information</h2>
    
    <div class="relative">
        <button 
            id="addressDropdownBtn"
            class="text-sm text-purple-600 font-medium cursor-pointer hover:text-purple-700 focus:outline-none"
        >
            Use saved address
        </button>
        
        <!-- Dropdown Menu -->
        <div 
            id="addressDropdown"
            class="absolute right-0 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-10 hidden"
        >
            <div class="px-4 py-2 border-b border-gray-100">
                <h3 class="font-medium text-gray-800">Select an address</h3>
            </div>
            
            <div class="max-h-60 overflow-y-auto">
                <!-- Address Option 1 -->
                <div class="px-4 py-3 hover:bg-gray-50 cursor-pointer">
                    <div class="flex items-start">
                        <input type="radio" id="address1" name="savedAddress" class="mt-1 mr-3" checked>
                        <div>
                            <label for="address1" class="font-medium text-gray-800 block">Home Address</label>
                            <p class="text-sm text-gray-600 mt-1">123 Main St, Apt 4B, New York, NY 10001, United States</p>
                        </div>
                    </div>
                </div>
                
                <!-- Address Option 2 -->
                <div class="px-4 py-3 hover:bg-gray-50 cursor-pointer">
                    <div class="flex items-start">
                        <input type="radio" id="address2" name="savedAddress" class="mt-1 mr-3">
                        <div>
                            <label for="address2" class="font-medium text-gray-800 block">Office Address</label>
                            <p class="text-sm text-gray-600 mt-1">456 Business Ave, Suite 300, San Francisco, CA 94107</p>
                        </div>
                    </div>
                </div>
                
                <!-- Add New Address Option -->
                <div class="px-4 py-3 hover:bg-gray-50 cursor-pointer border-t border-gray-100">
                    <div class="flex items-center text-purple-600">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                        <span class="font-medium">Add new address</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

                    <form class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">First Name *</label>
                                <input type="text" placeholder="John" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Last Name *</label>
                                <input type="text" placeholder="Doe" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                            </div>
                        </div>


                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
                            <input type="tel" placeholder="+91 00000-0000" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Street Address *</label>
                            <input type="text" placeholder="123 Main Street" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Land Mark</label>
                            <input type="text" placeholder="Apt 4B" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                        </div>

                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">City *</label>
                                <input type="text" placeholder="New York" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">State *</label>
                                <input type="text" placeholder="keral" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Pin Code *</label>
                                <input type="text" placeholder="10001" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                            </div>
                        </div>

                        <div>
                            
                        </div>
                    </form>
                </div>

                <!-- Payment Method -->
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-2xl font-bold text-gray-800 mb-6">Payment Method</h2>

                    <div class="space-y-4">
                        <!-- Credit Card -->
                        

                        <!-- Razorpay -->
                        <div class="border-2 border-gray-300 rounded-lg p-4 hover:border-purple-400 cursor-pointer">
                            <label class="flex items-center justify-between cursor-pointer">
                                <div class="flex items-center">
                                    <input type="radio" name="payment" class="w-4 h-4 text-purple-600">
                                    <span class="ml-3 font-semibold text-gray-800">Razorpay</span>
                                </div>
                                <svg viewBox="0 0 200 50" class="h-6">
                                    <text x="0" y="35" font-family="Arial, sans-serif" font-size="30" font-weight="bold" fill="#072654">Razorpay</text>
                                </svg>
                            </label>
                            <p class="text-sm text-gray-500 mt-2 ml-7">UPI, Cards, Wallets, NetBanking and more</p>
                        </div>

                        <!-- PayPal -->
                        <div class="border-2 border-gray-300 rounded-lg p-4 hover:border-purple-400 cursor-pointer">
                            <label class="flex items-center justify-between cursor-pointer">
                                <div class="flex items-center">
                                    <input type="radio" name="payment" class="w-4 h-4 text-purple-600">
                                    <span class="ml-3 font-semibold text-gray-800">Wallet</span>
                                </div>
                                
                            </label>
                            <p class="text-sm text-gray-500 mt-2 ml-7">Pay securely with your PayPal account</p>
                        </div>

                        <!-- Cash on Delivery -->
                        <div class="border-2 border-gray-300 rounded-lg p-4 hover:border-purple-400 cursor-pointer">
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="payment" class="w-4 h-4 text-purple-600">
                                <span class="ml-3 font-semibold text-gray-800">Cash on Delivery</span>
                            </label>
                            <p class="text-sm text-gray-500 mt-2 ml-7">Pay when you receive your order</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-lg shadow-md p-6 sticky top-4">
                    <h2 class="text-xl font-bold text-gray-800 mb-6">Order Summary</h2>

                    <!-- Order Items -->
                    <div class="space-y-4 mb-6 pb-6 border-b">
                        <% cartItems.forEach(item => { %>
                        <div class="flex items-center space-x-3">
  
  <!-- Product Image -->
                             
                            <div class="w-16 h-16 flex items-center justify-center flex-shrink-0">
                              <img
                                src="<%= item.mainImage?.url %>"
                                alt=""
                                class="w-full h-full object-contain rounded-md"
                              />
                            </div>
                            
                          
  <!-- Product Details -->
                            <div class="flex-1">
                                <h4 class="font-semibold text-gray-800 text-sm">Tropical Leaf</h4>
                                <p class="text-xs text-gray-500">Qty: <%= item.quantity %> </p>
                                 <p class="text-xs text-gray-500">Per:<%= item.variant.salePrice %></p>
                            </div>
                        
                        <!-- Price -->
                        <span class="font-semibold text-gray-800">
                            ₹ <%= item.quantity *item.variant.salePrice %>
                        </span>
                    </div>
                    <% }) %>



                    <!-- Promo Code -->
                    <div class="max-w-md mx-auto bg-white rounded-lg shadow-sm p-6">
        <!-- Coupon Section Header -->
        <div class="mb-4">
            <button id="toggleCoupon" class="flex items-center justify-between w-full text-left">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                    </svg>
                    <span class="text-sm font-medium text-gray-700">Have a coupon code?</span>
                </div>
                <svg id="chevron" class="w-5 h-5 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </button>
        </div>

        <!-- Coupon Input (Initially Hidden) -->
        <div id="couponForm" class="hidden mb-4">
            <div class="slide-down">
                <div class="flex gap-2 mb-3">
                    <input 
                        type="text" 
                        id="couponInput"
                        placeholder="Enter coupon code"
                        class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all"
                    >
                    <button 
                        id="applyBtn"
                        class="px-6 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors duration-200"
                    >
                        Apply
                    </button>
                </div>
                
                <!-- Available Coupons List -->
                <div class="space-y-2">
                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Available Coupons</p>
                    
                    <div class="border border-dashed border-indigo-200 rounded-lg p-3 hover:border-indigo-400 hover:bg-indigo-50 transition-all cursor-pointer group" onclick="applyCoupon('SAVE10', '10% off')">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-indigo-600 font-mono">SAVE10</span>
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Active</span>
                                </div>
                                <p class="text-xs text-gray-600">Get 10% off on your order</p>
                            </div>
                            <button class="text-xs text-indigo-600 font-medium group-hover:underline">Apply</button>
                        </div>
                    </div>

                    <div class="border border-dashed border-indigo-200 rounded-lg p-3 hover:border-indigo-400 hover:bg-indigo-50 transition-all cursor-pointer group" onclick="applyCoupon('FREESHIP', 'Free shipping')">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-indigo-600 font-mono">FREESHIP</span>
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Active</span>
                                </div>
                                <p class="text-xs text-gray-600">Free standard shipping on orders</p>
                            </div>
                            <button class="text-xs text-indigo-600 font-medium group-hover:underline">Apply</button>
                        </div>
                    </div>

                    <div class="border border-dashed border-indigo-200 rounded-lg p-3 hover:border-indigo-400 hover:bg-indigo-50 transition-all cursor-pointer group" onclick="applyCoupon('WELCOME20', '20% off')">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-indigo-600 font-mono">WELCOME20</span>
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Active</span>
                                </div>
                                <p class="text-xs text-gray-600">20% off for new customers</p>
                            </div>
                            <button class="text-xs text-indigo-600 font-medium group-hover:underline">Apply</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Applied Coupon Display -->
        <div id="appliedCoupon" class="hidden mb-4">
            <div class="bg-green-50 border border-green-200 rounded-lg p-3 flex items-center justify-between slide-down">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <p class="text-sm font-medium text-green-800" id="appliedCode"></p>
                        <p class="text-xs text-green-600" id="appliedDescription"></p>
                    </div>
                </div>
                <button onclick="removeCoupon()" class="text-red-600 hover:text-red-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Error Message -->
        <div id="errorMessage" class="hidden mb-4">
            <div class="bg-red-50 border border-red-200 rounded-lg p-3 flex items-start gap-2 slide-down">
                <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-sm text-red-800" id="errorText"></p>
            </div>
        </div>
    </div>

                    <!-- Price Breakdown -->
                    <div class="space-y-3 mb-6">
                        <div class="flex justify-between text-gray-600">
                            <span>Subtotal</span>
                            <span><%= subtotal %></span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Shipping</span>
                            <span class="text-green-600 font-semibold">Free</span>
                        </div>
                        <!-- <div class="flex justify-between text-gray-600">
                            <span>Tax</span>
                            <span>$3.84</span>
                        </div> -->
                        <div class="border-t pt-3">
                            <div class="flex justify-between items-center">
                                <span class="text-lg font-bold text-gray-800">Total</span>
                                <span class="text-2xl font-bold text-purple-600"><%= subtotal %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Place Order Button -->
                    <button onclick="placeOrder()" class="w-full gradient-bg text-white py-4 rounded-lg font-semibold hover:opacity-90 transition mb-4">
                        Place Order
                    </button>

                    <div class="text-center text-xs text-gray-500">
                        <p>By placing your order, you agree to our</p>
                        <p><a href="#" class="text-purple-600 hover:underline">Terms & Conditions</a> and <a href="#" class="text-purple-600 hover:underline">Privacy Policy</a></p>
                    </div>

                    <!-- Security Badges -->
                    <div class="mt-6 pt-6 border-t">
                        <div class="flex items-center justify-center space-x-4 text-sm text-gray-600">
                            <div class="flex items-center space-x-1">
                                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                                </svg>
                                <span class="text-xs">Secure</span>
                            </div>
                            <div class="flex items-center space-x-1">
                                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                </svg>
                                <span class="text-xs">SSL Encrypted</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
        
        </div>

  </main>
  
</div>
<script>
    // Toggle dropdown visibility
document.getElementById('addressDropdownBtn').addEventListener('click', function(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('addressDropdown');
    dropdown.classList.toggle('hidden');
});

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
    const dropdown = document.getElementById('addressDropdown');
    const button = document.getElementById('addressDropdownBtn');
    
    if (!dropdown.contains(e.target) && !button.contains(e.target)) {
        dropdown.classList.add('hidden');
    }
});

// Handle address selection
document.querySelectorAll('input[name="savedAddress"]').forEach(radio => {
    radio.addEventListener('change', function() {
        // Get selected address data
        const addressText = this.nextElementSibling.querySelector('.text-gray-600').textContent;
        
        // Here you would typically fill your shipping form with the selected address
        console.log('Selected address:', addressText);
        
        // Close dropdown after selection
        document.getElementById('addressDropdown').classList.add('hidden');
        
        // Update button text to show selection
        document.getElementById('addressDropdownBtn').textContent = 'Address Selected ✓';
    });
});

// Handle "Add new address" click
document.querySelector('#addressDropdown div:last-child').addEventListener('click', function() {
    // Logic to show add new address form
    console.log('Add new address clicked');
    document.getElementById('addressDropdown').classList.add('hidden');
});
</script>

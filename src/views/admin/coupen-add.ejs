<%- include('../partials/header') %>

<div class="flex">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-4 md:p-6 lg:p-8 lg:ml-0">

       <div id="add-coupon-page" class="page-content">
                <div class="mb-6">
                    <div class="flex items-center space-x-3 mb-4">
                        <button class="back-to-coupons text-purple-600 hover:text-purple-700 p-2">
                            <i class="fas fa-arrow-left"></i>
                        </button>
                        <div>
                            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">Create New Coupon</h1>
                            <p class="text-gray-600 text-sm lg:text-base">Set up a new discount coupon for customers.</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow-sm p-4">
                    <form id="couponForm" class="space-y-6" novalidate>

  <div class="grid md:grid-cols-2 gap-6">

    <!-- LEFT SIDE -->
    <div class="space-y-4">

      <h3 class="text-lg font-semibold text-gray-900 border-b pb-2">
        Coupon Information
      </h3>

      <!-- Coupon Title -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Coupon Title *
        </label>
        <input
          type="text"
          id="couponTitle"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
          placeholder="e.g. Summer Sale"
        />
        <p id="couponTitleErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Coupon Code -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Coupon Code *
        </label>
        <div class="flex gap-2">
          <input
            type="text"
            id="couponCode"
            class="flex-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500 uppercase"
            placeholder="e.g. SUMMER25"
          />
          <button
            type="button"
             onclick="generateCouponCode()"
            id="generateCodeBtn"
            class="px-4 py-2 border rounded-lg text-purple-600 hover:bg-purple-50"
          >
            Generate
          </button>
        </div>
        <p id="couponCodeErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Description *
        </label>
        <textarea
          id="couponDesc"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500 h-24"
          placeholder="Coupon description"
        ></textarea>
        <p id="couponDescErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Discount Type -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Discount Type *
        </label>
        <select
          id="discountType"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
        >
          <option value="">Select Type</option>
          <option value="percentage">Percentage Discount</option>
          <option value="fixedamount">Fixed Amount Discount</option>
        </select>
        <p id="discountTypeErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Discount Value -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Discount Value *
        </label>
        <input
          type="number"
          id="discountValue"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
          placeholder="e.g. 25"
        />
        <p id="discountValueErr" class="text-red-500 text-sm mt-1"></p>
      </div>

    </div>

    <!-- RIGHT SIDE -->
    <div class="space-y-4">

      <h3 class="text-lg font-semibold text-gray-900 border-b pb-2">
        Coupon Details
      </h3>

      <!-- Minimum Order Value -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Minimum Purchase *
        </label>
        <input
          type="number"
          id="minOrderValue"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
          placeholder="e.g. 500"
          min="0"
        />
        <p id="minOrderValueErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Usage Limit -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Usage Limit *
        </label>
        <input
          type="number"
          id="usageLimit"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
          placeholder="e.g. 100"
          min="1"
        />
        <p class="text-gray-500 text-xs mt-1">Maximum number of times this coupon can be used</p>
        <p id="usageLimitErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Start Date -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Start Date *
        </label>
        <input
          type="date"
          id="startDate"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
        />
        <p id="startDateErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- End Date -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          End Date *
        </label>
        <input
          type="date"
          id="endDate"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
        />
        <p id="endDateErr" class="text-red-500 text-sm mt-1"></p>
      </div>

      <!-- Status -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Status
        </label>
        <select
          id="couponStatus"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
        >
          <option value="scheduled">Scheduled</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
        </select>
      </div>

    </div>

  </div>

  <!-- ACTION BUTTONS -->
  <div class="flex justify-end gap-3 pt-6 border-t">
    <button
      type="button"
      id="cancelBtn"
      class="px-4 py-2 border rounded-lg text-gray-700 hover:bg-gray-100"
    >
      Cancel
    </button>

    <button
      type="submit"
      class="bg-purple-600 text-white px-6 py-2 rounded-lg hover:bg-purple-700 transition"
    >
      Create Coupon
    </button>
  </div>

</form>

                </div>
            </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/admin/coupen-add.js"></script>
<%- include('../partials/footer') %>
 
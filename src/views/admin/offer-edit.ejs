<%- include('../partials/header') %>
<div class="flex min-h-screen bg-gray-100">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-3 sm:p-4 md:p-6 lg:p-8">
    <div class="max-w-6xl mx-auto">
      <!-- HEADER -->
      <div class="mb-4 sm:mb-6 flex items-center gap-2 sm:gap-3">
        <button onclick="location.href='/admin/offers'"
          class="text-purple-600 hover:text-purple-800 transition p-2 -ml-2">
          <i class="fas fa-arrow-left text-base sm:text-lg"></i>
        </button>
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Edit Offer</h1>
          <p class="text-sm sm:text-base text-gray-600">Update existing offer</p>
        </div>
      </div>

      <!-- CARD -->
      <div class="bg-white rounded-lg sm:rounded-xl shadow-md p-4 sm:p-6">
        <form class="space-y-5 sm:space-y-6" novalidate>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
            
            <!-- LEFT COLUMN -->
            <div class="space-y-4 sm:space-y-5">
              <h3 class="font-semibold text-base sm:text-lg text-gray-800 border-b pb-2">
                Offer Information
              </h3>

              <!-- Title -->
              <div>
                <label class="block text-sm font-medium mb-1">Title *</label>
                <input
                  id="offerTitle"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                  value="<%= offer.title %>">
                <p id="offerTitleErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- Description -->
              <div>
                <label class="block text-sm font-medium mb-1">Description *</label>
                <textarea
                  id="offerDesc"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none h-20 sm:h-24 resize-none"><%= offer.description %></textarea>
                <p id="offerDescErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- Offer Type -->
              <div>
                <label class="block text-sm font-medium mb-1">Offer Type *</label>
                <select id="offerType"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none">
                  <option value="percentage"
                    <%= offer.offerType === 'percentage' ? 'selected' : '' %>>
                    Percentage
                  </option>
                </select>
              </div>

              <!-- Offer Value -->
              <div>
                <label class="block text-sm font-medium mb-1">Offer Value *</label>
                <input
                  id="offerValue"
                  type="number"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                  value="<%= offer.discountValue %>">
                <p id="offerValueErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div class="space-y-4 sm:space-y-5">
              <h3 class="font-semibold text-base sm:text-lg text-gray-800 border-b pb-2">
                Offer Details
              </h3>

              <!-- Min Order -->
              <div>
                <label class="block text-sm font-medium mb-1">Minimum Order Value *</label>
                <input
                  id="minOrderValue"
                  type="number"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                  value="<%= offer.minimumOrderValue %>">
                <p id="minOrderValueErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- Applicable On -->
              <div>
                <label class="block text-sm font-medium mb-1">Applicable On *</label>
                <select id="applicableOn"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none">
                  <option value="product"
                    <%= offer.applicableOn === 'product' ? 'selected' : '' %>>
                    Products
                  </option>
                  <option value="category"
                    <%= offer.applicableOn === 'category' ? 'selected' : '' %>>
                    Categories
                  </option>
                  <option value="global"
                    <%= offer.applicableOn === 'global' ? 'selected' : '' %>>
                    Global
                  </option>
                </select>
                <p id="applicableOnErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- PRODUCTS -->
              <div id="productSelectorContainer" class="hidden">
                <label class="block text-sm font-medium mb-1">Select Products *</label>
                <input
                  id="productSearch"
                  class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                  placeholder="Search product...">
                <div id="productSearchResults"
                  class="hidden border rounded-lg mt-1 bg-white max-h-40 overflow-y-auto shadow-sm">
                </div>
                <div id="selectedProducts"
                  class="mt-3 border rounded-lg p-2 space-y-2 bg-gray-50 min-h-[50px]">
                  <% offer.productIds.forEach(p => { %>
                    <div class="selected-product-item flex justify-between items-center bg-white p-2 rounded shadow-sm gap-2"
                      data-product-id="<%= p._id %>">
                      <span class="text-xs sm:text-sm truncate flex-1"><%= p.name %></span>
                      <button type="button"
                        class="remove-product text-red-500 hover:text-red-700 flex-shrink-0 p-1">
                        ✕
                      </button>
                    </div>
                  <% }) %>
                </div>
                <p id="productSelectorErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- CATEGORIES -->
              <div id="categorySelectorContainer" class="hidden">
                <label class="block text-sm font-medium mb-1">Select Categories *</label>
                <div class="border rounded-lg p-2 max-h-40 overflow-y-auto space-y-1 bg-gray-50">
                  <% categories.forEach(c => { %>
                    <label class="flex items-center gap-2 text-xs sm:text-sm py-1">
                      <input type="checkbox"
                        class="category-checkbox flex-shrink-0 w-4 h-4"
                        value="<%= c._id %>"
                        <%= offer.categoryIds.some(o => o._id.toString() === c._id.toString()) ? 'checked' : '' %>>
                      <span class="truncate"><%= c.name %></span>
                    </label>
                  <% }) %>
                </div>
                <p id="categorySelectorErr" class="text-red-500 text-xs sm:text-sm mt-1"></p>
              </div>

              <!-- Dates -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
                <div>
                  <label class="block text-sm font-medium mb-1">Start Date *</label>
                  <input
                    id="startDate"
                    type="date"
                    class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                    value="<%= offer.startDate.toISOString().split('T')[0] %>">
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1">End Date *</label>
                  <input
                    id="endDate"
                    type="date"
                    class="w-full px-3 py-2 text-sm sm:text-base border rounded-lg focus:ring-2 focus:ring-purple-500 focus:outline-none"
                    value="<%= offer.endDate.toISOString().split('T')[0] %>">
                </div>
              </div>
              <div>
  <label class="block text-sm font-medium text-gray-700 mb-1">
    Status
  </label>

  <select
    id="offerStatus"
    class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-purple-500"
  >
    <option value="scheduled"
      <%= offer.status === 'scheduled' ? 'selected' : '' %>>
      Scheduled
    </option>

    <option value="active"
      <%= offer.status === 'active' ? 'selected' : '' %>>
      Active
    </option>

    <option value="inactive"
      <%= offer.status === 'inactive' ? 'selected' : '' %>>
      Inactive
    </option>
  </select>
</div>

            </div>
          </div>

          <!-- ACTIONS -->
          <div class="flex flex-col-reverse sm:flex-row justify-end gap-2 sm:gap-3 pt-4 sm:pt-6 border-t">
            <button type="button"
              onclick="location.href='/admin/offers'"
              class="w-full sm:w-auto px-4 py-2 text-sm sm:text-base border rounded-lg hover:bg-gray-100 transition">
              Cancel
            </button>
            <button type="submit"
              class="w-full sm:w-auto bg-purple-600 text-white px-6 py-2 text-sm sm:text-base rounded-lg hover:bg-purple-700 transition">
              Update Offer
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<script>
   window.SPECIFIC_ITEM = <%- JSON.stringify(response || null) %>;
   window.OFFER_ID = <%- JSON.stringify(offer|| null) %>;
  window.ALL_PRODUCTS = <%- JSON.stringify(products || []) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/admin/offer-edit.js"></script>
<%- include('../partials/footer') %>
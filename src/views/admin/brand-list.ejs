<%- include('../partials/header') %>
  <div class="flex">
    <%- include('../partials/sidebar') %>
      <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen overflow-hidden">
        <div id="brands-page" class="page-content">
          <div class="mb-6">
            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
              Brand Management
            </h1>
            <p class="text-gray-600 text-sm lg:text-base">
              Organize your products by brands.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex flex-col space-y-3 mb-4">
              <h3 class="text-base lg:text-lg font-bold text-gray-900">
                Product Brands
              </h3>
              <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3">
                <input id="searchInput" type="text" value="<%= search %>" placeholder="Search brands..."
                  class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 flex-1" />
                <a href="/admin/brands/new">
                  <button class="bg-gradient-to-r from-purple-600 to-indigo-600 text-white px-5 py-2.5 rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 text-sm font-semibold flex items-center shadow-md">
                    <i class="fas fa-plus mr-2"></i> Add New Brand
                  </button>
                </a>
              </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              <% brands.forEach(brand => { %>

                <div class="bg-white border border-gray-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                  <div class="relative z-10">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center space-x-3">
                      <% if (brand.icon) { %>
                        <img src="<%= brand.icon %>" alt="<%= brand.name %>" class="w-10 h-10 object-contain rounded border" />
                      <% } else { %>
                        <div class="w-10 h-10 bg-gray-100 flex items-center justify-center rounded border">
                          <i class="fas fa-image text-gray-400"></i>
                        </div>
                      <% } %>
                      <h4 class="font-bold text-gray-900 text-base group-hover:text-purple-700 transition-colors">
                        <%= brand.name %>
                      </h4>
                    </div>
                  </div>

                  <p class="text-xs text-gray-600 mb-4">
                    <%= brand.description %>
                  </p>


                  <div class="flex justify-between items-center mt-2">

                    <div class="flex space-x-3">
                      <a href="/admin/brands/<%= brand._id %>/edit"
                        class="text-blue-600 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-full text-xs font-semibold flex items-center transition-colors">
                        <i class="fas fa-edit mr-1.5"></i> Edit
                      </a>

                      <button id="brand-block-btn-<%= brand._id %>"
                        class="text-xs font-semibold px-3 py-1.5 rounded-full flex items-center transition-colors block-btn <%= brand.isActive ? 'text-red-600 bg-red-50 hover:bg-red-100' : 'text-green-600 bg-green-50 hover:bg-green-100' %>"
                        data-id="<%= brand._id %>" data-statusmode="<%= brand.isActive ? 'block' : 'unblock' %>">
                        <i class="fas <%= brand.isActive ? 'fa-ban' : 'fa-check' %> mr-1.5"></i>
                        <% if (brand.isActive) { %> Block <% } else { %> Unblock <% } %>
                      </button>
                    </div>

                  </div>
                  </div>
                </div>

                <% }) %>
            </div>
          </div>
          <div class="flex justify-between items-center mt-4">

            <!-- Showing Count -->
            <div class="text-sm text-gray-600">
              Showing <span class="font-medium">
                <%= currentPage %> - <%= totalPages %>
              </span> of <span class="font-medium">
                <%= totalItems %>
              </span> brands
            </div>

            <!-- Pagination -->
            <div class="flex space-x-1">

              <!-- Prev Button -->
              <!-- Pagination -->
              <nav aria-label="Page navigation" class="flex justify-center mt-6">
                <ul class="flex items-center space-x-2">

                  <!-- Previous Button -->
                  <li>
                    <% if (currentPage===1) { %>
                      <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
                        Previous
                      </span>
                      <% } else { %>
                        <a href="/admin/brands?page=<%= currentPage - 1 %>&search=<%= search %>"
                          class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                          Previous
                        </a>
                        <% } %>
                  </li>

                  <!-- Page Numbers -->
                  <% for (let i=1; i <=totalPages; i++) { %>
                    <li>
                      <% if (currentPage===i) { %>
                        <span class="px-4 py-2 bg-blue-600 text-white rounded-md shadow font-semibold">
                          <%= i %>
                        </span>
                        <% } else { %>
                          <a href="/admin/brands?page=<%= i %>&search=<%= search %>"
                            class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                            <%= i %>
                          </a>
                          <% } %>
                    </li>
                    <% } %>

                      <!-- Next Button -->
                      <li>
                        <% if (currentPage===totalPages) { %>
                          <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
                            Next
                          </span>
                          <% } else { %>
                            <a href="/admin/brands?page=<%= currentPage + 1 %>&search=<%= search %>"
                              class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                              Next
                            </a>
                            <% } %>
                      </li>
                </ul>
              </nav>


            </div>
          </div>
        </div>

      </main>

  </div>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script type="module" src="/js/admin/brand-filter.js"></script>
  <script type="module" src="/js/admin/block-brand.js"></script>
  <%- include('../partials/footer') %>

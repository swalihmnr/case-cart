<%- include('../partials/header') %>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .status-badge {
            backdrop-filter: blur(10px);
        }
    </style>

    <div class="flex min-h-screen bg-gray-50">
        <%- include('../partials/sidebar') %>

            <!-- Main Content -->
            <div class="flex-1 overflow-auto">
                <!-- Page Header -->
                <div class="bg-white border-b border-gray-200 sticky top-0 z-20 transition-all duration-300">
                    <div class="px-4 sm:px-8 lg:px-10 py-4 sm:py-6 flex items-center gap-4">
                        <a href="/admin/order"
                            class="p-2 -ml-2 rounded-xl hover:bg-gray-100 text-gray-500 transition-colors">
                            <svg class="w-5 h-5 sm:w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                            </svg>
                        </a>
                        <h1 class="text-xl sm:text-3xl font-semibold text-gray-900 tracking-tight">Order Details</h1>
                    </div>
                </div>

                <div class="px-4 sm:px-8 lg:px-10 py-6 sm:py-8">
                    <% let statusColor='bg-gray-100 text-gray-700' ; if (order.orderItems.status==='placed' )
                        statusColor='bg-purple-50 text-purple-700' ; if (order.orderItems.status==='confirmed' )
                        statusColor='bg-indigo-50 text-indigo-700' ; if (order.orderItems.status==='processing' )
                        statusColor='bg-blue-50 text-blue-700' ; if (order.orderItems.status==='shipped' )
                        statusColor='bg-orange-50 text-orange-700' ; if (order.orderItems.status==='out_for_delivery' )
                        statusColor='bg-yellow-50 text-yellow-700' ; if (order.orderItems.status==='delivered' )
                        statusColor='bg-green-50 text-green-700' ; if (order.orderItems.status==='cancelled' )
                        statusColor='bg-red-50 text-red-700' ; if (order.orderItems.status==='returned' )
                        statusColor='bg-gray-100 text-gray-700' ; if (order.orderItems.status==='return_req' )
                        statusColor='bg-yellow-50 text-yellow-700' ; %>

                        <!-- Order Overview Header -->
                        <div
                            class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 sm:p-6 mb-6 sm:mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                            <div class="flex items-center space-x-4 flex-1 min-w-0">
                                <div class="flex-shrink-0">
                                    <div
                                        class="w-12 h-12 sm:w-14 sm:h-14 bg-gray-100 rounded-xl flex items-center justify-center">
                                        <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-600" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center space-x-3 mb-1">
                                        <h3 class="text-lg sm:text-xl font-semibold text-gray-900">#<%= order.orderId %>
                                        </h3>
                                        <span
                                            class="<%= statusColor %> px-2 py-0.5 sm:px-3 sm:py-1 rounded-full text-[10px] sm:text-xs font-medium status-badge">
                                            <%= order.orderItems.status %>
                                        </span>
                                    </div>
                                    <p class="text-xs sm:text-sm text-gray-500">
                                        <%= order.user.firstName %>
                                            <%= order.user.lastName %> • <%= new
                                                    Date(order.createdAt).toLocaleDateString('en-IN') %>
                                    </p>
                                </div>
                            </div>
                            <div class="flex flex-col items-start sm:items-end w-full sm:w-auto">
                                <p class="text-xl sm:text-2xl font-semibold text-green-700">₹<%= order.finalAmount %>
                                </p>
                            </div>
                        </div>

                        <div class="grid lg:grid-cols-2 gap-8">
                            <!-- Left Column -->
                            <div class="space-y-6">
                                <!-- Order Info Card -->
                                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                                    <h4 class="text-sm font-semibold text-gray-900 mb-5 uppercase tracking-wider">Order
                                        Information</h4>
                                    <div class="space-y-4">
                                        <div class="flex justify-between text-sm">
                                            <span class="text-gray-600">Order ID</span>
                                            <span class="font-medium text-gray-900">#<%= order.orderId %></span>
                                        </div>

                                        <div class="flex justify-between text-sm">
                                            <span class="text-gray-600">Order Date</span>
                                            <span class="font-medium text-gray-900">
                                                <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
                                            </span>
                                        </div>

                                        <div class="flex justify-between text-sm">
                                            <span class="text-gray-600">Delivery Date</span>
                                            <span class="font-medium text-gray-900">
                                                <%= order.orderItems.deliveredAt ? new
                                                    Date(order.orderItems.deliveredAt).toLocaleDateString('en-IN')
                                                    : 'Pending' %>
                                            </span>
                                        </div>

                                        <div class="flex justify-between text-sm">
                                            <span class="text-gray-600">Payment Status</span>
                                            <span class="font-medium text-gray-900">
                                                <%= order.orderItems.paymentStatus ? "Paid" : "Pending" %>
                                            </span>
                                        </div>

                                        <div class="flex justify-between text-sm">
                                            <span class="text-gray-600">Payment Method</span>
                                            <span class="font-medium text-gray-900 uppercase">
                                                <%= order.paymentMethod %>
                                            </span>
                                        </div>

                                        <!-- OFFER DETAILS -->
                                        <% const items=Array.isArray(order.orderItems) ? order.orderItems :
                                            [order.orderItems]; let totalSaved=0; let offerLabel=null;
                                            items.forEach(item=> {
                                            if (item && item.offer && item.offer.discountAmount > 0) {
                                            totalSaved += item.offer.discountAmount;
                                            offerLabel = item.offer.type === "percentage"
                                            ? item.offer.value + "% OFF"
                                            : "₹" + item.offer.value + " OFF";
                                            }
                                            });
                                            %>

                                            <div class="border-t border-gray-100 pt-4 mt-4">
                                                <% if (totalSaved> 0) { %>
                                                    <div class="flex justify-between text-sm mt-3">
                                                        <span class="text-gray-600">Offer Applied</span>
                                                        <span class="font-medium text-green-700">
                                                            <%= offerLabel %>
                                                        </span>
                                                    </div>
                                                    <% } %>

                                                        <% if (order.couponDiscount> 0) { %>
                                                            <div class="flex justify-between text-sm mt-3 items-center">
                                                                <span class="text-gray-600 flex items-center">
                                                                    Coupon Discount
                                                                    <% if (order.coupon && order.coupon.couponCode) { %>
                                                                        <span
                                                                            class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded ml-2 font-medium border border-purple-200">
                                                                            <%= order.coupon.couponCode %>
                                                                        </span>
                                                                        <% } %>
                                                                </span>
                                                                <span class="font-medium text-green-700">
                                                                    -₹<%= order.couponDiscount %>
                                                                </span>
                                                            </div>
                                                            <% } %>

                                                                <% if (totalSaved> 0) { %>
                                                                    <div class="flex justify-between text-sm mt-3">
                                                                        <span class="text-gray-600">You Saved
                                                                            (Offers+Coupons)</span>
                                                                        <span class="font-medium text-green-700">
                                                                            ₹<%= totalSaved + (order.couponDiscount ||
                                                                                0) %>
                                                                        </span>
                                                                    </div>
                                                                    <% } else if (order.couponDiscount> 0) { %>
                                                                        <div class="flex justify-between text-sm mt-3">
                                                                            <span class="text-gray-600">You Saved</span>
                                                                            <span class="font-medium text-green-700">
                                                                                ₹<%= order.couponDiscount %>
                                                                            </span>
                                                                        </div>
                                                                        <% } else { %>
                                                                            <div
                                                                                class="flex justify-between text-sm mt-3">
                                                                                <span class="text-gray-600">Offer</span>
                                                                                <span class="font-medium text-gray-500">
                                                                                    No offer applied
                                                                                </span>
                                                                            </div>
                                                                            <% } %>
                                            </div>
                                    </div>
                                </div>

                                <!-- Customer Card -->
                                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                                    <h4 class="text-sm font-semibold text-gray-900 mb-5 uppercase tracking-wider">
                                        Customer Details</h4>
                                    <div class="space-y-4">
                                        <div class="flex items-center">
                                            <div
                                                class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-semibold mr-4">
                                                <%= order.user.firstName.charAt(0) %>
                                                    <%= order.user.lastName.charAt(0) %>
                                            </div>
                                            <div>
                                                <p class="text-sm font-medium text-gray-900">
                                                    <%= order.user.firstName %>
                                                        <%= order.user.lastName %>
                                                </p>
                                                <p class="text-xs text-gray-500">Customer</p>
                                            </div>
                                        </div>
                                        <div class="flex items-start pt-2">
                                            <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none"
                                                stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                            </svg>
                                            <p class="text-sm text-gray-700">
                                                <%= order.user.email %>
                                            </p>
                                        </div>
                                        <div class="flex items-start">
                                            <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none"
                                                stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                            </svg>
                                            <p class="text-sm text-gray-700">
                                                <%= order.user.number %>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Product Card -->
                                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                                    <h4 class="text-sm font-semibold text-gray-900 mb-5 uppercase tracking-wider">
                                        Product Details</h4>

                                    <div class="flex items-center space-x-4">
                                        <% const mainImage=order.product.productImages.find(img=> img.isMain); %>
                                            <% if (mainImage) { %>
                                                <img src="<%= mainImage.url %>" alt="<%= order.product.name %>"
                                                    class="w-20 h-20 object-cover rounded-xl border border-gray-100" />
                                                <% } else { %>
                                                    <div
                                                        class="w-20 h-20 bg-gray-100 rounded-xl flex items-center justify-center text-gray-400">
                                                        No Image</div>
                                                    <% } %>

                                                        <div class="flex-1">
                                                            <h5 class="text-base font-medium text-gray-900 mb-1">
                                                                <%= order.product.name %>
                                                            </h5>

                                                            <p class="text-sm text-gray-500 mb-2">
                                                                <%= order.variant.deviceModel %>
                                                            </p>

                                                            <div class="flex items-center justify-between mt-3">

                                                                <!-- Quantity -->
                                                                <span class="text-sm text-gray-700">
                                                                    Qty: <strong>
                                                                        <%= order.orderItems.quantity %>
                                                                    </strong>
                                                                </span>

                                                                <!-- PRICE DISPLAY -->
                                                                <div class="flex items-center space-x-3">
                                                                    <!-- Original Price (Strikethrough) -->
                                                                    <% if (order.orderItems.price
                                                                        !==order.orderItems.finalPrice) { %>
                                                                        <span
                                                                            class="text-sm text-gray-400 line-through">
                                                                            ₹<%= order.orderItems.price %>
                                                                        </span>
                                                                        <% } %>

                                                                            <!-- Final Price -->
                                                                            <span
                                                                                class="text-lg font-semibold text-gray-900">
                                                                                ₹<%= order.orderItems.finalPrice %>
                                                                            </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!-- Right Column - Timeline -->
                            <div>
                                <% const steps=[ { key: 'placed' , label: 'Order Placed' ,
                                    desc: 'We have received the order' }, { key: 'confirmed' , label: 'Confirmed' ,
                                    desc: 'The order has been confirmed' }, { key: 'processing' , label: 'Processing' ,
                                    desc: 'Preparing the order' }, { key: 'shipped' , label: 'Shipped' ,
                                    desc: 'The order is on the way' }, { key: 'out_for_delivery' ,
                                    label: 'Out for Delivery' , desc: 'Courier is nearby' }, { key: 'delivered' ,
                                    label: 'Delivered' , desc: 'Order successfully delivered' } ]; const
                                    orderStatus=order.orderItems.status; const isCancelled=orderStatus==='cancelled' ;
                                    const isReturned=orderStatus==='returned' ; const
                                    isReturnRequested=orderStatus==='return_req' ; const
                                    currentIndex=steps.findIndex(s=> s.key === orderStatus);
                                    %>

                                    <div
                                        class="bg-white rounded-2xl p-5 sm:p-8 shadow-sm border border-gray-200 sticky top-24 lg:top-24">
                                        <h4 class="text-base font-semibold text-gray-900 mb-6 sm:mb-8 border-b pb-4">
                                            Timeline &
                                            Actions</h4>

                                        <% if (isCancelled) { %>
                                            <div class="text-center py-10">
                                                <div
                                                    class="inline-flex items-center justify-center w-20 h-20 bg-red-100 rounded-full mb-6">
                                                    <svg class="w-10 h-10 text-red-600" fill="none"
                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                                    </svg>
                                                </div>
                                                <h5 class="text-xl font-semibold text-gray-900 mb-2">Order Cancelled
                                                </h5>
                                                <p class="text-base text-gray-500">This order item has been cancelled.
                                                </p>
                                                <% if (order.orderItems.cancelReason) { %>
                                                    <div
                                                        class="mt-4 p-4 bg-gray-50 rounded-xl text-left border border-gray-100">
                                                        <span
                                                            class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Reason</span>
                                                        <span class="text-sm text-gray-700 italic">
                                                            <%= order.orderItems.cancelReason %>
                                                        </span>
                                                    </div>
                                                    <% } %>
                                            </div>
                                            <% } else if (isReturned) { %>
                                                <div class="text-center py-10">
                                                    <div
                                                        class="inline-flex items-center justify-center w-20 h-20 bg-blue-100 rounded-full mb-6">
                                                        <svg class="w-10 h-10 text-blue-600" fill="none"
                                                            stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                                                        </svg>
                                                    </div>
                                                    <h5 class="text-xl font-semibold text-gray-900 mb-2">Order Returned
                                                    </h5>
                                                    <p class="text-base text-gray-500">This order item has been returned
                                                        and refunded.</p>
                                                    <% if (order.orderItems.returnReason) { %>
                                                        <div
                                                            class="mt-4 p-4 bg-gray-50 rounded-xl text-left border border-gray-100">
                                                            <span
                                                                class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Reason</span>
                                                            <span class="text-sm text-gray-700 italic">
                                                                <%= order.orderItems.returnReason %>
                                                            </span>
                                                        </div>
                                                        <% } %>
                                                </div>
                                                <% } else if (isReturnRequested) { %>
                                                    <div class="text-center py-8">
                                                        <div
                                                            class="inline-flex items-center justify-center w-20 h-20 bg-yellow-100 rounded-full mb-6 shadow-sm border border-yellow-200">
                                                            <svg class="w-10 h-10 text-yellow-600" fill="none"
                                                                stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                            </svg>
                                                        </div>
                                                        <h5 class="text-xl font-semibold text-gray-900 mb-2">Return
                                                            Requested</h5>
                                                        <p class="text-base text-gray-600 mb-6">Customer has requested
                                                            to return this item.</p>

                                                        <div
                                                            class="mb-8 p-4 bg-gray-50 rounded-xl text-left border border-gray-200 shadow-inner">
                                                            <span
                                                                class="block text-xs text-gray-500 font-medium uppercase tracking-wider mb-2">Customer
                                                                Reason:</span>
                                                            <span class="text-sm text-gray-800">
                                                                <%= order.orderItems.returnReason
                                                                    || "No reason provided." %>
                                                            </span>
                                                        </div>

                                                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                                                            <button
                                                                onclick="approveReturn(this, '<%= order._id %>', '<%= order.orderItems._id %>')"
                                                                class="px-8 py-4 bg-green-600 text-white text-base font-bold rounded-xl hover:bg-green-700 transition-all shadow-lg shadow-green-100 w-full sm:w-1/2">
                                                                Approve Return
                                                            </button>
                                                            <button
                                                                onclick="rejectReturn(this, '<%= order._id %>', '<%= order.orderItems._id %>')"
                                                                class="px-8 py-4 bg-white text-red-600 text-base font-bold rounded-xl border-2 border-red-100 hover:bg-red-50 transition-all w-full sm:w-1/2">
                                                                Reject Return
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <% } else { %>
                                                        <!-- Timeline -->
                                                        <div class="relative space-y-8 mt-4">
                                                            <% steps.forEach((step, index)=> {
                                                                const isCompleted = index < currentIndex; const
                                                                    isCurrent=index===currentIndex; %>
                                                                    <div class="relative flex gap-6">
                                                                        <div
                                                                            class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 rounded-full flex items-center justify-center z-10 <%= isCompleted ? 'bg-green-500 ring-4 ring-green-50' : isCurrent ? 'bg-blue-600 ring-4 ring-blue-50' : 'bg-gray-100 border-2 border-gray-200' %> transition-all duration-300">
                                                                            <% if (isCompleted) { %>
                                                                                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white"
                                                                                    fill="currentColor"
                                                                                    viewBox="0 0 20 20">
                                                                                    <path fill-rule="evenodd"
                                                                                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                                                        clip-rule="evenodd" />
                                                                                </svg>
                                                                                <% } else if (isCurrent) { %>
                                                                                    <div
                                                                                        class="w-2 h-2 sm:w-3 sm:h-3 bg-white rounded-full">
                                                                                    </div>
                                                                                    <% } %>
                                                                        </div>

                                                                        <% if (index !==steps.length - 1) { %>
                                                                            <div
                                                                                class="absolute left-4 sm:left-5 top-8 sm:top-10 w-0.5 h-full <%= isCompleted ? 'bg-green-500' : 'bg-gray-200' %>">
                                                                            </div>
                                                                            <% } %>

                                                                                <div class="flex-1 pb-4 pt-1 sm:pt-2">
                                                                                    <h5
                                                                                        class="text-base font-semibold <%= isCurrent ? 'text-blue-700' : isCompleted ? 'text-gray-900' : 'text-gray-500' %> mb-1">
                                                                                        <%= step.label %>
                                                                                    </h5>
                                                                                    <p
                                                                                        class="text-sm <%= isCurrent || isCompleted ? 'text-gray-600' : 'text-gray-400' %>">
                                                                                        <%= step.desc %>
                                                                                    </p>
                                                                                </div>
                                                                    </div>
                                                                    <% }) %>
                                                        </div>

                                                        <!-- Actions -->
                                                        <div class="mt-10 pt-8 border-t border-gray-100 space-y-4">
                                                            <h5
                                                                class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-2">
                                                                Action</h5>
                                                            <% const status=order.orderItems.status; %>
                                                                <% let nextStatus='' ; let nextLabel='' ; let
                                                                    btnColor='bg-blue-600 hover:bg-blue-700' ; if
                                                                    (status==='placed' ) { nextStatus='confirmed' ;
                                                                    nextLabel='Confirm Order' ; } else if
                                                                    (status==='confirmed' ) { nextStatus='processing' ;
                                                                    nextLabel='Start Processing' ; } else if
                                                                    (status==='processing' ) { nextStatus='shipped' ;
                                                                    nextLabel='Mark as Shipped' ; } else if
                                                                    (status==='shipped' ) {
                                                                    nextStatus='out_for_delivery' ;
                                                                    nextLabel='Out for Delivery' ; } else if
                                                                    (status==='out_for_delivery' ) {
                                                                    nextStatus='delivered' ;
                                                                    nextLabel='Complete Delivery' ;
                                                                    btnColor='bg-green-600 hover:bg-green-700' ; } %>

                                                                    <% if (nextStatus) { %>
                                                                        <button
                                                                            onclick="updateOrderStatus('<%= order._id %>', '<%= order.orderItems._id %>', '<%= nextStatus %>', this)"
                                                                            class="w-full py-4 <%= btnColor %> text-white text-base font-bold rounded-xl shadow-lg shadow-blue-100 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                                                                            <span>
                                                                                <%= nextLabel %>
                                                                            </span>
                                                                            <svg class="w-5 h-5" fill="none"
                                                                                stroke="currentColor"
                                                                                viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round"
                                                                                    stroke-linejoin="round"
                                                                                    stroke-width="2"
                                                                                    d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                                                            </svg>
                                                                        </button>

                                                                        <div class="relative flex items-center py-2">
                                                                            <div
                                                                                class="flex-grow border-t border-gray-100">
                                                                            </div>
                                                                            <span
                                                                                class="flex-shrink mx-4 text-xs text-gray-400 font-medium uppercase tracking-widest">or</span>
                                                                            <div
                                                                                class="flex-grow border-t border-gray-100">
                                                                            </div>
                                                                        </div>

                                                                        <select data-prev-value="<%= status %>"
                                                                            onchange="if(this.value) updateOrderStatus('<%= order._id %>', '<%= order.orderItems._id %>', this.value, this)"
                                                                            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-600 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all appearance-none cursor-pointer">
                                                                            <option value="" disabled selected>Other
                                                                                Status Transitions...</option>
                                                                            <option value="confirmed">Set to Confirmed
                                                                            </option>
                                                                            <option value="processing">Set to Processing
                                                                            </option>
                                                                            <option value="shipped">Set to Shipped
                                                                            </option>
                                                                            <option value="out_for_delivery">Set to Out
                                                                                for Delivery</option>
                                                                            <option value="delivered">Set to Delivered
                                                                            </option>
                                                                            <option value="cancelled">Cancel Order
                                                                            </option>
                                                                        </select>

                                                                        <p
                                                                            class="text-xs text-gray-500 mt-2 ml-1 text-center">
                                                                            Changing the status will notify the customer
                                                                            regarding the new order state.
                                                                        </p>
                                                                        <% } else if (status==='delivered' ) { %>
                                                                            <div
                                                                                class="p-4 bg-green-50 border border-green-100 rounded-xl flex items-center justify-center text-green-700 font-medium">
                                                                                <svg class="w-5 h-5 mr-2" fill="none"
                                                                                    stroke="currentColor"
                                                                                    viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round"
                                                                                        stroke-linejoin="round"
                                                                                        stroke-width="2"
                                                                                        d="M5 13l4 4L19 7"></path>
                                                                                </svg>
                                                                                Order has been successfully delivered
                                                                            </div>
                                                                            <% } %>
                                                        </div>
                                    </div>
                            </div>
                        </div>
                </div>
                <% } %>
            </div>
    </div>
    </div>
    </div>
    </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

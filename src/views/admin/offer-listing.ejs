<%- include('../partials/header') %>

<div class="flex flex-col lg:flex-row min-h-screen bg-gray-50">
    <%- include('../partials/sidebar') %>
    
    <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-x-hidden">
        <% if (passFromUrl.URLID) { %>
            <div id="selectionAlertInfo"
              class="fixed top-15 left-1/2 -translate-x-1/2 flex items-center gap-3 bg-blue-600 text-white px-6 py-4 rounded-xl shadow-xl opacity-100 -translate-y-5 transition-all duration-300 z-50">
            
              <!-- Icon -->
              <i class="fas fa-info-circle text-xl"></i>
            
              <!-- Text -->
              <span id="selectionAlertInfoText" class="text-sm font-medium">
                <%= passFromUrl.item %> <%= passFromUrl.name %> Selected for add offer
              </span>
            
              <!-- Close Button -->
              <button onclick="hideSelectionAlertInfo()" class="ml-2 text-white hover:text-gray-200">
                <i class="fas fa-times"></i>
              </button>
            </div>
         
        <% } %>

        <!-- Header -->
        <div class="mb-6 sm:mb-8">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900">Special Offers</h1>
                    <p class="text-sm sm:text-base text-gray-500 mt-1">Create and manage special offers and promotions.</p>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-6 mb-6 sm:mb-8">
            <div class="bg-white rounded-lg sm:rounded-xl shadow-sm p-4 sm:p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-2 sm:mb-3">
                    <h3 class="text-xs sm:text-sm font-medium text-gray-500">Active Offers</h3>
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-green-100 rounded-full flex items-center justify-center">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                </div>
                <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900"><%= activeOfferCount %></p>
            </div>

            <div class="bg-white rounded-lg sm:rounded-xl shadow-sm p-4 sm:p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-2 sm:mb-3">
                    <h3 class="text-xs sm:text-sm font-medium text-gray-500">Scheduled</h3>
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                </div>
                <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900"><%= sheduledOfferCount %></p>
            </div>

            <div class="bg-white rounded-lg sm:rounded-xl shadow-sm p-4 sm:p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-2 sm:mb-3">
                    <h3 class="text-xs sm:text-sm font-medium text-gray-500">Total Offers</h3>
                    <div class="w-8 h-8 sm:w-10 sm:h-10 bg-purple-100 rounded-full flex items-center justify-center">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                        </svg>
                    </div>
                </div>
                <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900"><%= totalOffersCount %></p>
            </div>

           
        </div>

        <!-- Offers List Section -->
        <div class="bg-white rounded-lg sm:rounded-xl shadow-sm border border-gray-100">
            <!-- Header with filters -->
            <div class="p-4 sm:p-6 border-b border-gray-100">
                <div class="flex flex-col gap-4">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <h2 class="text-base sm:text-lg font-semibold text-gray-900">All Offers</h2>
                    <% if (passFromUrl.id) { %>
                     <a href="/admin/offer/add?id=<%= passFromUrl.id %>&item=<%= passFromUrl.item %>" class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 sm:py-2.5 rounded-lg text-sm font-medium transition-colors w-full sm:w-auto">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                            </svg>
                            Create Offer
                        </a>
                        <% } else { %>
                            <a href="/admin/offer/add" class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 sm:py-2.5 rounded-lg text-sm font-medium transition-colors w-full sm:w-auto">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                                Create Offer
                            </a>
                         
                    <% } %>
                    </div>

                    <!-- Search Bar -->
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                        </div>
                        <input type="text" id="search-offers" placeholder="Search offers by title or description..." class="w-full pl-10 pr-4 py-2 sm:py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all">
                    </div>

                    <!-- Filter Tabs -->
                   <div class="flex flex-wrap gap-2" id="filter-tabs">

  <a href="/admin/offers?page=1&search=<%= search || '' %>&filter=all"
     data-filter="all"
     class="filter-btn px-3 py-1.5 rounded-full 
     <%= filter === 'all' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-700' %>">
     All
  </a>

  <a href="/admin/offers?page=1&search=<%= search || '' %>&filter=active"
     data-filter="active"
     class="filter-btn px-3 py-1.5 rounded-full 
     <%= filter === 'active' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-700' %>">
     Active
  </a>

  <a href="/admin/offers?page=1&search=<%= search || '' %>&filter=scheduled"
     data-filter="scheduled"
     class="filter-btn px-3 py-1.5 rounded-full 
     <%= filter === 'scheduled' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-700' %>">
     Scheduled
  </a>

  <a href="/admin/offers?page=1&search=<%= search || '' %>&filter=inactive"
     data-filter="inactive"
     class="filter-btn px-3 py-1.5 rounded-full 
     <%= filter === 'inactive' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-700' %>">
     Inactive
  </a>

</div>

                </div>
            </div>

            <!-- Offers Grid -->
            <div id="offers-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 p-4 sm:p-6">
        <% offers.forEach(offer => { %>
            <div class="offer-card bg-gray-50 rounded-lg sm:rounded-xl p-4 sm:p-5 border border-gray-200 hover:border-indigo-300 hover:shadow-md transition-all" data-status="<%= (offer.status || 'unknown').toLowerCase() %>">
                <div class="flex items-start justify-between gap-3 mb-3">
                    <h3 class="font-semibold text-gray-900 text-sm sm:text-base line-clamp-1"><%= offer.title %></h3>
                 <%

let statusClass = "";

const now = Date.now();
const startDate = new Date(offer.startDate).getTime();
const endDate = new Date(offer.endDate).getTime();

// Manual override always wins
if (offer.status === "inactive") {
  statusText = "Inactive";
  statusClass = "bg-red-100 text-red-700";
}
else if (offer.status==='scheduled') {
  statusText = "Scheduled";
  statusClass = "bg-blue-100 text-blue-700";
}
else if (now > endDate) {
  statusText = "Expired";
  statusClass = "bg-gray-100 text-gray-600";
}
else {
  statusText = "Active";
  statusClass = "bg-green-100 text-green-700";
}
%>

<span class="offer-status shrink-0 px-2 py-0.5 sm:px-2.5 sm:py-1 rounded-full text-xs font-medium <%= statusClass %>">
  <%= now>offer.endDate&&offer.status==="active"?"Expired":offer.status %>
</span>

                        </div>
                        <p class="text-gray-600 text-xs sm:text-sm mb-3 sm:mb-4 line-clamp-2"><%= offer.description %></p>
                        
                        <!-- Start & End Date -->
                        <div class="flex flex-col gap-1.5 sm:gap-2 mb-3 sm:mb-4 p-2.5 sm:p-3 bg-white rounded-lg border border-gray-100">
                            <div class="flex items-center text-xs sm:text-sm text-gray-600">
                                <div class="w-5 h-5 sm:w-6 sm:h-6 bg-green-100 rounded-full flex items-center justify-center mr-2">
                                    <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                </div>
                                <span class="text-gray-500">Start:</span>
                                <span><%= new Date(offer.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                            <div class="flex items-center text-xs sm:text-sm text-gray-600">
                                <div class="w-5 h-5 sm:w-6 sm:h-6 bg-red-100 rounded-full flex items-center justify-center mr-2">
                                    <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                </div>
                                <span class="text-gray-500">End:</span>
                                <span><%= new Date(offer.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                        </div>

                        <div class="flex gap-2">
                          <a href="/admin/offer/edit?id=<%= offer._id %>&itemId=<%= passFromUrl.URLID %>&item=<%= passFromUrl.item %>" class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-1.5 sm:py-2 bg-white border border-gray-200 rounded-lg text-xs sm:text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                </svg>
                                Edit
                            </a>
                            <button onclick="deleteOffer('<%= offer._id %>')" class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-1.5 sm:py-2 bg-red-50 border border-red-200 rounded-lg text-xs sm:text-sm font-medium text-red-600 hover:bg-red-100 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                                Delete
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Empty State -->
            <div id="empty-state" class="hidden p-8 sm:p-12 text-center">
                <div class="w-16 h-16 sm:w-20 sm:h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                    </svg>
                </div>
                <p class="text-gray-500 text-sm sm:text-base mb-4">No offers found</p>
                <a href="/admin/addoffer" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 sm:px-5 py-2 sm:py-2.5 rounded-lg text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create Your First Offer
                </a>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
<nav aria-label="Page navigation" class="flex justify-center mt-6 p-4 sm:p-6 border-t border-gray-100">
  <ul class="flex items-center space-x-2">

    <!-- Previous Button -->
    <li>
      <% if (currentPage === 1) { %>
        <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
          Previous
        </span>
      <% } else { %>
        <a href="/admin/offers?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>&filter=<%= filter || 'all' %>"
           class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
          Previous
        </a>
      <% } %>
    </li>

    <!-- Page Numbers -->
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li>
        <% if (currentPage === i) { %>
          <span class="px-4 py-2 bg-blue-600 text-white rounded-md shadow font-semibold">
            <%= i %>
          </span>
        <% } else { %>
          <a href="/admin/offers?page=<%= i %><%= search ? '&search=' + search : '' %>&filter=<%= filter || 'all' %>"
             class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
            <%= i %>
          </a>
        <% } %>
      </li>
    <% } %>

    <!-- Next Button -->
    <li>
      <% if (currentPage === totalPages) { %>
        <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
          Next
        </span>
      <% } else { %>
        <a href="/admin/offers?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>&filter=<%= filter || 'all' %>"
           class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
          Next
        </a>
      <% } %>
    </li>

  </ul>
</nav>
<% } %>


            <!-- Loading State -->
            <div id="loading-state" class="hidden p-8 sm:p-12 text-center">
                <div class="w-10 h-10 sm:w-12 sm:h-12 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mx-auto mb-4"></div>
                <p class="text-gray-500 text-sm sm:text-base">Loading offers...</p>
            </div>
        </div>

    </main>
</div>
<script type="module" src="/js/admin/offer.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<%- include('../partials/footer') %>
<%- include('../partials/header') %>

    <div class="flex">
<%- include('../partials/sidebar') %>
          <main class="flex-1 p-4 md:p-6 lg:p-8 lg:ml-0">
            <div class="max-w-7xl mx-auto">
                <!-- Page Header -->
                <div class="mb-6">
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Product Management</h1>
                    <p class="text-gray-600 text-sm mt-1">Manage your product catalog and inventory.</p>
                </div>

                <!-- Products Section -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                    <!-- Section Header -->
                    <div class="p-4 md:p-6 border-b border-gray-200">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                            <h2 class="text-lg font-semibold text-gray-900">All Products</h2>
                            <div class="flex flex-col sm:flex-row gap-3">
                                <div class="relative flex-1 sm:flex-initial">
                                    <input type="text" id="searchInput" placeholder="Search products..." data-searchmode="product" value="<%= search %>"
                                        class="w-full sm:w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                                </div>
                                <select class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 text-sm" id="product-filter" >
                                     <option value="Select Category"><%= selectionFilter?selectionFilter:"" %></option>
                                     <option value="Select Category">Select Category</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category.name %>"><%= category.name %></option>

                                    <% }) %>
                                    
                                </select>
                                <a href="/admin/add-product">

                                    <button class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors font-medium flex items-center justify-center gap-2">
                                        <i class="fas fa-plus"></i>
                                        <span>Add Product</span>
                                    </button>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Table - Desktop View -->
                    <div class="hidden md:block overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-50 border-b border-gray-200">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Product</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Offer</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Category</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Stock</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <% products.forEach(product => { %>
                                <tbody class="divide-y divide-gray-200">
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center space-x-3">
                                               <img src="<%= product.productImages.find(img=>img.isMain).url %>" alt="Product" class="w-12 h-12 rounded-lg object-cover flex-shrink-0">

                                                <div>
                                                    <p class="font-semibold text-gray-900"><%= product.name %></p>
                                                   
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <button class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                                                add Offer
                                            </button>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-sm text-gray-900"><%= product.catgId.name %></span>
                                        </td>
                                        
                                        <td class="px-6 py-4">
                                            <span class="text-sm text-gray-900"><%= product.variants.reduce((sum, v) => sum + v.stock, 0) %>
</span>
                                        </td>
                                  <td class="px-6 py-4">
                                      <% 
                                          const totalStock = product.variants.reduce((sum, v) => sum + v.stock, 0);
                                  
                                          let status = "";
                                          let bg = "";
                                          let text = "";
                                  
                                          if (totalStock < 1) {
                                              status = "Out of Stock";
                                              bg = "bg-red-100"; 
                                              text = "text-red-700";
                                          } else if (totalStock < 6) {
                                              status = "Low Stock";
                                              bg = "bg-orange-100"; 
                                              text = "text-orange-700";
                                          } else if (totalStock < 20) {
                                              status = "Medium Stock";
                                              bg = "bg-yellow-100"; 
                                              text = "text-yellow-700";
                                          } else {
                                              status = "In Stock";
                                              bg = "bg-green-100"; 
                                              text = "text-green-700";
                                          }
                                      %>
                                  
                                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= bg %> <%= text %>">
                                          <%= status %>
                                      </span>
                                  </td>

                                        <td class="px-6 py-4">
                                            <div class="flex items-center space-x-3">
                                                <a href="/admin/product/edit/<%= product._id %>">
                                                    <button class="text-purple-600 hover:text-purple-700 transition">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                </a>
                                               <button class="text-red-600 hover:text-red-800 text-xs block-btn flex items-center"
                                                  data-id="<%= product._id %>">
                                                 <i class="fas fa-ban mr-1"></i>
                                                  <% if (product.isBlock) { %> Block <% } else { %> Unblock <%
                                                    } %>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                             
                            <% }) %>
                            
                        </table>
                    </div>

                    <!-- Card View - Mobile -->
                    <div class="md:hidden divide-y divide-gray-200">
                        <div class="p-4 hover:bg-gray-50 transition-colors">
                            <div class="flex items-start space-x-3 mb-3">
                                <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-lg flex-shrink-0"></div>
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-semibold text-gray-900 truncate">Cosmic Gradient</h3>
                                    <p class="text-sm text-gray-500">iPhone 14 Pro</p>
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700 mt-1">
                                        New Offer
                                    </span>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-3 text-sm mb-3">
                                <div>
                                    <span class="text-gray-500">Category:</span>
                                    <span class="text-gray-900 font-medium ml-1">Gradient</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">Price:</span>
                                    <span class="text-gray-900 font-semibold ml-1">$24.99</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">Stock:</span>
                                    <span class="text-gray-900 font-medium ml-1">8</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">Status:</span>
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 ml-1">
                                        Low Stock
                                    </span>
                                </div>
                            </div>
                            <div class="flex items-center space-x-3 pt-3 border-t border-gray-200">
                                <button class="flex-1 px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors text-sm font-medium">
                                    <i class="fas fa-edit mr-2"></i>Edit
                                </button>
                                <button class="px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors text-sm font-medium">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
             <div class="text-sm text-gray-600">
          Showing <span class="font-medium"><%= currentPage %> - <%= totalPages %></span> of <span class="font-medium"><%= totalItems %></span> categories
      </div>
  
      <!-- Pagination -->
      <div class="flex space-x-1">
  
          <!-- Prev Button -->
          <!-- Pagination -->
<nav aria-label="Page navigation" class="flex justify-center mt-6">
<ul class="flex items-center space-x-2">

<!-- Previous Button -->
<li>
  <% if (currentPage === 1) { %>
    <span
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed"
    >
      Previous
    </span>
  <% } else { %>
    <a
      href="/admin/product-list?page=<%= currentPage - 1 %>&search=<%= search %>"
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
    >
      Previous
    </a>
  <% } %>
</li>

<!-- Page Numbers -->
<% for (let i = 1; i <= totalPages; i++) { %>
  <li>
    <% if (currentPage === i) { %>
      <span
        class="px-4 py-2 bg-blue-600 text-white rounded-md shadow font-semibold"
      >
        <%= i %>
      </span>
    <% } else { %>
      <a
        href="/admin/product-list?page=<%= i %>&search=<%= search %>"
        class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
      >
        <%= i %>
      </a>
    <% } %>
  </li>
<% } %>

<!-- Next Button -->
<li>
  <% if (currentPage === totalPages) { %>
    <span
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed"
    >
      Next
    </span>
  <% } else { %>
    <a
      href="/admin/product-list?page=<%= currentPage + 1 %>&search=<%= search %>"
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
    >
      Next
    </a>
  <% } %>
</li>
</ul>
</nav>
        </main>
    </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/admin/product-list.js"></script>
<script type="module" src="/js/admin/product-filter.js"></script>
 <%- include('../partials/footer') %>


<%- include('../partials/header') %>

    <div class="flex">
<%- include('../partials/sidebar') %>
       <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen">
            <div class="mb-6">
                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
                    Customer Management
                </h1>
                <p class="text-gray-600 text-sm lg:text-base">
                    View and manage your customer database.
                </p>
            </div>

            <!-- Toggle Button for Stats -->
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800">Customer Overview</h2>
                <button id="toggle-stats-btn" class="toggle-stats-btn flex items-center space-x-2 text-purple-600 hover:text-purple-800 transition">
                    <span class="text-sm font-medium">Hide Stats</span>
                    <i class="fas fa-chevron-up text-xs"></i>
                </button>
            </div>

            <!-- Stats Section -->
            <div id="stats-container" class="stats-container expanded">
                <div class="grid md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Total Customers
                            </h3>
                            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-users text-green-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900"><%= totalCustomers %></p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                New This Month
                            </h3>
                            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-plus text-blue-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900"><%= thisMonth %></p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Active Customers
                            </h3>
                            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-check text-purple-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900"><%= totalActiveCount %></p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Blocked Customers
                            </h3>
                            <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-slash text-red-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900"><%= totalBlockCount %></p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-sm p-4">
                <div class="flex flex-col space-y-3 mb-4">
                    <h3 class="text-base lg:text-lg font-bold text-gray-900">
                        Customer List
                    </h3>
                    <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3">
                        <input
                            id="searchInput"
                            type="text"
                            placeholder="Search customers..."
                            value="<%= search %>"
                            data-searchmode="customer"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 flex-1"
                        />
                        <select id="customer-filter"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        >   <option > <%= selectionFilter?selectionFilter:"select" %></option>
                            <option value="all">All Status</option>
                            <option value="active">Active</option>
                            <option value="blocked">Blocked</option>
                           
                        </select>
                        <button
                            class="bg-purple-600 text-white px-3 py-2 rounded-lg hover:bg-purple-700 transition text-sm"
                        >
                            <i class="fas fa-download mr-1"></i> Export
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[600px]">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left py-2 px-2 text-xs">Customer</th>
                                <th class="text-left py-2 px-2 text-xs">Email</th>
                                <th class="text-left py-2 px-2 text-xs">Phone</th>
                                <th class="text-left py-2 px-2 text-xs">Orders</th>
                                <th class="text-left py-2 px-2 text-xs">Total Spent</th>
                                <th class="text-left py-2 px-2 text-xs">Status</th>
                                <th class="text-left py-2 px-2 text-xs">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Active Customer -->
                            <% customers.forEach(customer=>{ %>
                            <tr class="border-b border-gray-100 hover:bg-gray-50 customer-row relative">
                                <td class="py-2 px-2">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                                            <span class="text-purple-600 text-xs font-semibold"><%= (customer.firstName[0]).toUpperCase() + (customer.lastName[0]||'' ).toUpperCase()%> </span>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-sm"><%= `${customer.firstName} ${customer.lastName}` %>  </p>
                                            <p id="dateText" class="text-xs text-gray-500"><%= customer.createdAt.toDateString() %> </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-sm"><%= customer.email %> </td>
                                <td class="py-2 px-2 text-sm"><%= customer.number ? customer.number : "google auth" %>
 </td>
                                <td class="py-2 px-2 text-sm">12</td>
                                <td class="py-2 px-2 text-sm">$847.50</td>
                                <td class="py-2 px-2">
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full"><%= customer.isBlock?"blocked":"active" %> </span>
                                </td>
                                <td class="py-2 px-2">
                                    <div class="flex space-x-1">
                                        <button
                                            class="view-customer-btn text-blue-600 hover:text-blue-800 text-sm"
                                            data-customer-id="<%= customer._id %>"
                                            data-name="<%= customer.firstName %> <%= customer.lastName %>"
                                            data-email="<%= customer.email %>"
                                            data-number="<%= customer.number?customer.number:"googel auth" %>"
                                            data-createdAt="<%= customer.createdAt.toDateString() %>"
                                            data-status="<%= customer.isBlock%>"

                                        >
                                            <i class="fas fa-eye"></i>
                                        </button>

                                            <% if (customer.isBlock) { %>
                                                <button data-statusmode="unblock"
                                                 class="block-customer-btn text-green-600 hover:text-green-100 text-sm"
                                                 data-customer-id="<%= customer._id %>"
                                                   data-status="<%= customer.isBlock%>"
                                             >
                                                 <i  class="fas fa-check"></i>
                                             </button>
                                             
                                             <% } else { %>
                                                   <button data-statusMode="block"
                                                    class="block-customer-btn text-red-600 hover:text-red-800 text-sm"
                                                    data-customer-id="<%= customer._id %>"
                                                      data-status="<%= customer.isBlock%>"
                                                    
                                                >
                                                    <i  class="fas fa-ban"></i>
                                                </button>
                                               <% } %>


                                    </div>
                                </td>
                                <!-- Customer Overview on Hover -->
                                
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex justify-between items-center mt-4">

      <!-- Showing Count -->
      <div class="text-sm text-gray-600">
          Showing <span class="font-medium"><%= currentPage %> - <%= totalPages %></span> of <span class="font-medium"><%= totalItems %></span>customers
      </div>
  
      <!-- Pagination -->
      <div class="flex space-x-1">
  
          <!-- Prev Button -->
          <!-- Pagination -->
<nav aria-label="Page navigation" class="flex justify-center mt-6">
<ul class="flex items-center space-x-2">

<!-- Previous Button -->
<li>
  <% if (currentPage === 1) { %>
    <span
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed"
    >
      Previous
    </span>
  <% } else { %>
    <a
      href="/admin/customers?page=<%= currentPage - 1 %>&search=<%= search  %>"
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
    >
      Previous
    </a>
  <% } %>
</li>

<!-- Page Numbers -->
<% for (let i = 1; i <= totalPages; i++) { %>
  <li>
    <% if (currentPage === i) { %>
      <span
        class="px-4 py-2 bg-blue-600 text-white rounded-md shadow font-semibold"
      >
        <%= i %>
      </span>
    <% } else { %>
      <a
        href="/admin/customers?page=<%= i %>&search=<%= search %>"
        class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
      >
        <%= i %>
      </a>
    <% } %>
  </li>
<% } %>

<!-- Next Button -->
<li>
  <% if (currentPage === totalPages) { %>
    <span
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed"
    >
      Next
    </span>
  <% } else { %>
    <a
      href="/admin/customers?page=<%= currentPage + 1 %>&search=<%= search %>"
      class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition"
    >
      Next
    </a>
  <% } %>
</li>
</ul>
</nav>

  
      </div>
  </div>
            </div>

            <!-- Customer Details Modal -->
            <div
                id="customer-details-modal"
                class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden"
            >
                <div
                    class="bg-white rounded-lg shadow-lg w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto"
                >
                    <div class="p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-xl font-bold text-gray-900">
                                Customer Details
                            </h3>
                            <button
                                class="close-modal text-gray-500 hover:text-gray-700"
                            >
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div id="customer-details-content">
                            <!-- Customer details will be loaded here -->
                        </div>
                    </div>
                </div>
            </div>         
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="module" src="/js/admin/customers.js"></script>
<script type="module" src="/js/admin/list-search.js"></script>
<script type="module" src="/js/admin/selection-filter.js"></script>
 <%- include('../partials/footer') %>


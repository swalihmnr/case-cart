<%- include('../partials/header') %>

    <div class="flex">
<%- include('../partials/sidebar') %>
       <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen">
            <div class="mb-6">
                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
                    Customer Management
                </h1>
                <p class="text-gray-600 text-sm lg:text-base">
                    View and manage your customer database.
                </p>
            </div>

            <!-- Toggle Button for Stats -->
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800">Customer Overview</h2>
                <button id="toggle-stats-btn" class="toggle-stats-btn flex items-center space-x-2 text-purple-600 hover:text-purple-800 transition">
                    <span class="text-sm font-medium">Hide Stats</span>
                    <i class="fas fa-chevron-up text-xs"></i>
                </button>
            </div>

            <!-- Stats Section -->
            <div id="stats-container" class="stats-container expanded">
                <div class="grid md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Total Customers
                            </h3>
                            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-users text-green-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900">892</p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                New This Month
                            </h3>
                            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-plus text-blue-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900">47</p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Active Customers
                            </h3>
                            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-check text-purple-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900">723</p>
                    </div>

                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-gray-500 text-xs font-medium">
                                Blocked Customers
                            </h3>
                            <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                                <i class="fas fa-user-slash text-red-600"></i>
                            </div>
                        </div>
                        <p class="text-xl lg:text-2xl font-bold text-gray-900">12</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-sm p-4">
                <div class="flex flex-col space-y-3 mb-4">
                    <h3 class="text-base lg:text-lg font-bold text-gray-900">
                        Customer List
                    </h3>
                    <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3">
                        <input
                            type="text"
                            placeholder="Search customers..."
                            class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 flex-1"
                        />
                        <select
                            class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        >
                            <option value="all">All Status</option>
                            <option value="active">Active</option>
                            <option value="blocked">Blocked</option>
                            <option value="new">New This Month</option>
                        </select>
                        <button
                            class="bg-purple-600 text-white px-3 py-2 rounded-lg hover:bg-purple-700 transition text-sm"
                        >
                            <i class="fas fa-download mr-1"></i> Export
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[600px]">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left py-2 px-2 text-xs">Customer</th>
                                <th class="text-left py-2 px-2 text-xs">Email</th>
                                <th class="text-left py-2 px-2 text-xs">Phone</th>
                                <th class="text-left py-2 px-2 text-xs">Orders</th>
                                <th class="text-left py-2 px-2 text-xs">Total Spent</th>
                                <th class="text-left py-2 px-2 text-xs">Status</th>
                                <th class="text-left py-2 px-2 text-xs">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Active Customer -->
                            <tr class="border-b border-gray-100 hover:bg-gray-50 customer-row relative">
                                <td class="py-2 px-2">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                                            <span class="text-purple-600 text-xs font-semibold">JD</span>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-sm">John Doe</p>
                                            <p class="text-xs text-gray-500">Joined: Jan 2023</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-sm">john.doe@example.com</td>
                                <td class="py-2 px-2 text-sm">+1 (555) 123-4567</td>
                                <td class="py-2 px-2 text-sm">12</td>
                                <td class="py-2 px-2 text-sm">$847.50</td>
                                <td class="py-2 px-2">
                                    <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Active</span>
                                </td>
                                <td class="py-2 px-2">
                                    <div class="flex space-x-1">
                                        <button
                                            class="view-customer-btn text-blue-600 hover:text-blue-800 text-sm"
                                            data-customer-id="1"
                                        >
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button
                                            class="edit-customer-btn text-purple-600 hover:text-purple-800 text-sm"
                                            data-customer-id="1"
                                        >
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button
                                            class="block-customer-btn text-red-600 hover:text-red-800 text-sm"
                                            data-customer-id="1"
                                            data-status="active"
                                        >
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    </div>
                                </td>
                                <!-- Customer Overview on Hover -->
                                
                            </tr>

                            <!-- Blocked Customer -->
                            <tr class="border-b border-gray-100 hover:bg-gray-50 bg-red-50 customer-row relative">
                                <td class="py-2 px-2">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
                                            <span class="text-red-600 text-xs font-semibold">RS</span>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-sm">Robert Smith</p>
                                            <p class="text-xs text-gray-500">Joined: Mar 2023</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-sm">robert.smith@example.com</td>
                                <td class="py-2 px-2 text-sm">+1 (555) 987-6543</td>
                                <td class="py-2 px-2 text-sm">3</td>
                                <td class="py-2 px-2 text-sm">$124.99</td>
                                <td class="py-2 px-2">
                                    <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">Blocked</span>
                                </td>
                                <td class="py-2 px-2">
                                    <div class="flex space-x-1">
                                        <button
                                            class="view-customer-btn text-blue-600 hover:text-blue-800 text-sm"
                                            data-customer-id="2"
                                        >
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button
                                            class="edit-customer-btn text-purple-600 hover:text-purple-800 text-sm"
                                            data-customer-id="2"
                                        >
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button
                                            class="unblock-customer-btn text-green-600 hover:text-green-800 text-sm"
                                            data-customer-id="2"
                                            data-status="blocked"
                                        >
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </div>
                                </td>
                                <!-- Customer Overview on Hover -->
                                
                            </tr>

                            <!-- New Customer -->
                            <tr class="border-b border-gray-100 hover:bg-gray-50 customer-row relative">
                                <td class="py-2 px-2">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                                            <span class="text-blue-600 text-xs font-semibold">EJ</span>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-sm">Emma Johnson</p>
                                            <p class="text-xs text-gray-500">Joined: Feb 2024</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-2 px-2 text-sm">emma.johnson@example.com</td>
                                <td class="py-2 px-2 text-sm">+1 (555) 456-7890</td>
                                <td class="py-2 px-2 text-sm">1</td>
                                <td class="py-2 px-2 text-sm">$49.99</td>
                                <td class="py-2 px-2">
                                    <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">New</span>
                                </td>
                                <td class="py-2 px-2">
                                    <div class="flex space-x-1">
                                        <button
                                            class="view-customer-btn text-blue-600 hover:text-blue-800 text-sm"
                                            data-customer-id="3"
                                        >
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button
                                            class="edit-customer-btn text-purple-600 hover:text-purple-800 text-sm"
                                            data-customer-id="3"
                                        >
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button
                                            class="block-customer-btn text-red-600 hover:text-red-800 text-sm"
                                            data-customer-id="3"
                                            data-status="active"
                                        >
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    </div>
                                </td>
                                <!-- Customer Overview on Hover -->
                                
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex justify-between items-center mt-4">
                    <div class="text-sm text-gray-600">
                        Showing <span class="font-medium">1-3</span> of <span class="font-medium">892</span> customers
                    </div>
                    <div class="flex space-x-1">
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button class="pagination-btn active px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">1</button>
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">2</button>
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">3</button>
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">
                            <i class="fas fa-ellipsis-h"></i>
                        </button>
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">30</button>
                        <button class="pagination-btn px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Customer Details Modal -->
            <div
                id="customer-details-modal"
                class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden"
            >
                <div
                    class="bg-white rounded-lg shadow-lg w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto"
                >
                    <div class="p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-xl font-bold text-gray-900">
                                Customer Details
                            </h3>
                            <button
                                class="close-modal text-gray-500 hover:text-gray-700"
                            >
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div id="customer-details-content">
                            <!-- Customer details will be loaded here -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Block Customer Confirmation Modal -->
            <div
                id="block-customer-modal"
                class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden"
            >
                <div class="bg-white rounded-lg shadow-lg w-full max-w-md mx-4">
                    <div class="p-6">
                        <div
                            class="flex items-center justify-center w-12 h-12 mx-auto bg-red-100 rounded-full mb-4"
                        >
                            <i
                                class="fas fa-exclamation-triangle text-red-600 text-xl"
                            ></i>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 text-center mb-2">
                            Block Customer
                        </h3>
                        <p class="text-gray-600 text-sm text-center mb-6">
                            Are you sure you want to block this customer? They will not
                            be able to place orders or access their account.
                        </p>
                        <div class="flex space-x-3">
                            <button
                                class="cancel-block-btn flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition"
                            >
                                Cancel
                            </button>
                            <button
                                class="confirm-block-btn flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition"
                            >
                                Block Customer
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Unblock Customer Confirmation Modal -->
            <div
                id="unblock-customer-modal"
                class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden"
            >
                <div class="bg-white rounded-lg shadow-lg w-full max-w-md mx-4">
                    <div class="p-6">
                        <div
                            class="flex items-center justify-center w-12 h-12 mx-auto bg-green-100 rounded-full mb-4"
                        >
                            <i class="fas fa-check text-green-600 text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 text-center mb-2">
                            Unblock Customer
                        </h3>
                        <p class="text-gray-600 text-sm text-center mb-6">
                            Are you sure you want to unblock this customer? They will be
                            able to place orders and access their account again.
                        </p>
                        <div class="flex space-x-3">
                            <button
                                class="cancel-unblock-btn flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition"
                            >
                                Cancel
                            </button>
                            <button
                                class="confirm-unblock-btn flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition"
                            >
                                Unblock Customer
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

<script type="module" src="/js/admin/customers.js"></script>
 <%- include('../partials/footer') %>


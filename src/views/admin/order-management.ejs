<%- include('../partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    
    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
    
    .order-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .order-card:hover {
        transform: translateY(-2px);
    }
    
    .expand-icon {
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .expand-icon.rotated {
        transform: rotate(180deg);
    }
    
    .status-badge {
        backdrop-filter: blur(10px);
    }
</style>

<div class="flex min-h-screen bg-gray-50">
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <div class="flex-1 overflow-auto">
        <!-- Page Header -->
        <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
            <div class="px-6 sm:px-8 lg:px-10 py-6">
                <h1 class="text-3xl font-semibold text-gray-900 tracking-tight">Orders</h1>
            </div>
        </div>

        <div class="px-6 sm:px-8 lg:px-10 py-8">
            <!-- Search and Filter Bar -->
            <div class="mb-8">
                <div class="flex flex-col sm:flex-row gap-4">
                    <!-- Search Input -->
                    <div class="relative flex-1 max-w-md">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="orderSearch"
                            placeholder="Search orders" 
                            value="<%= search %>"
                            onkeyup="filterOrders()"
                            class="block w-full pl-12 pr-4 py-3 border border-gray-300 rounded-xl text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                        />
                    </div>

                    <!-- Status Filter -->
                    <div class="relative">
                        <select 
  id="statusFilter"
  onchange="filterOrders()"
  class="appearance-none bg-white border border-gray-300 rounded-xl px-4 py-3 pr-10 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">

  <option value="all" <%= selectionFilter === 'all' ? 'selected' : '' %>>
    All Status
  </option>

  <option value="placed" <%= selectionFilter === 'placed' ? 'selected' : '' %>>
    Placed
  </option>

  <option value="confirmed" <%= selectionFilter === 'confirmed' ? 'selected' : '' %>>
    Confirmed
  </option>

  <option value="processing" <%= selectionFilter === 'processing' ? 'selected' : '' %>>
    Processing
  </option>

  <option value="shipped" <%= selectionFilter === 'shipped' ? 'selected' : '' %>>
    Shipped
  </option>

  <option value="out_for_delivery" <%= selectionFilter === 'out_for_delivery' ? 'selected' : '' %>>
    Out for Delivery
  </option>

  <option value="delivered" <%= selectionFilter === 'delivered' ? 'selected' : '' %>>
    Delivered
  </option>

  <option value="cancelled" <%= selectionFilter === 'cancelled' ? 'selected' : '' %>>
    Cancelled
  </option>

  <option value="returned" <%= selectionFilter === 'returned' ? 'selected' : '' %>>
    Returned
  </option>

  <option value="return_req" <%= selectionFilter === 'return_req' ? 'selected' : '' %>>
    Return Requested
  </option>

</select>

                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </div>

                    <!-- Clear Filters Button -->
                    <!-- <button 
                        id="clearFilters"
                        onclick="clearFilters()"
                        class="hidden px-4 py-3 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors">
                        Clear Filters
                    </button> -->
                </div>

                <!-- Results Count -->
                <div id="resultsCount" class="mt-4 text-sm text-gray-600"></div>
            </div>

            <!-- Orders List -->
            <div class="space-y-3">
                <% orders.forEach((order, orderIndex) => { 
                    const uniqueId = `order_${orderIndex}_${order._id}`;
                    
                    let statusColor = 'bg-gray-100 text-gray-700';
                    if (order.orderItems.status === 'placed') statusColor = 'bg-purple-50 text-purple-700';
                    if (order.orderItems.status === 'confirmed') statusColor = 'bg-indigo-50 text-indigo-700';
                    if (order.orderItems.status === 'processing') statusColor = 'bg-blue-50 text-blue-700';
                    if (order.orderItems.status === 'shipped') statusColor = 'bg-orange-50 text-orange-700';
                    if (order.orderItems.status === 'out_for_delivery') statusColor = 'bg-yellow-50 text-yellow-700';
                    if (order.orderItems.status === 'delivered') statusColor = 'bg-green-50 text-green-700';
                    if (order.orderItems.status === 'cancelled') statusColor = 'bg-red-50 text-red-700';
                    if (order.orderItems.status === 'returned') statusColor = 'bg-gray-100 text-gray-700';
                    if (order.orderItems.status === 'return_req') statusColor = 'bg-yellow-50 text-yellow-700';
                %>
                
                <div class="order-card bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden" 
                     data-order-id="#<%= order.orderId %>"
                     data-customer-name="<%= order.user.firstName %> <%= order.user.lastName %>"
                     data-status="<%= order.orderItems.status %>">
                    <!-- Order Header -->
                    <button 
                        onclick="toggleOrder('<%= uniqueId %>')"
                        class="w-full px-6 py-5 text-left hover:bg-gray-50 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center space-x-4 flex-1 min-w-0">
                                <div class="flex-shrink-0">
                                    <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center">
                                        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                                        </svg>
                                    </div>
                                </div>
                                
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center space-x-3 mb-1">
                                        <h3 class="text-base font-semibold text-gray-900">#<%= order.orderId %></h3>
                                        <span class="<%= statusColor %> px-3 py-1 rounded-full text-xs font-medium status-badge">
                                            <%= order.orderItems.status %>
                                        </span>
                                    </div>
                                    <p class="text-sm text-gray-500"><%= order.user.firstName %> <%= order.user.lastName %></p>
                                </div>
                            </div>
                            
                            <div class="flex items-center space-x-6 ml-4">
                                <div class="hidden sm:flex flex-col items-end">
                                    <p class="text-base font-semibold text-gray-900">₹<%= order.orderItems.price %></p>
                                    <p class="text-xs text-gray-500"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></p>
                                </div>
                                
                                <svg id="icon-<%= uniqueId %>" class="expand-icon w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </div>
                        </div>
                        
                        <!-- Mobile Price -->
                        <div class="sm:hidden mt-3 flex justify-between items-center">
                            <p class="text-xs text-gray-500"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></p>
                            <p class="text-base font-semibold text-gray-900">₹<%= order.orderItems.price %></p>
                        </div>
                    </button>

                    <!-- Expandable Details -->
                    <div id="<%= uniqueId %>" class="hidden border-t border-gray-100">
                        <div class="px-6 py-6 bg-gray-50">
                            <div class="grid lg:grid-cols-2 gap-8">
                                <!-- Left Column -->
                                <div class="space-y-6">
                                    <!-- Order Info Card -->
                                    <div class="bg-white rounded-xl p-5 shadow-sm">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-4">Order Information</h4>
                                        <div class="space-y-3">
                                            <div class="flex justify-between text-sm">
                                                <span class="text-gray-600">Order ID</span>
                                                <span class="font-medium text-gray-900">#<%= order.orderId %></span>
                                            </div>
                                            <div class="flex justify-between text-sm">
                                                <span class="text-gray-600">Order Date</span>
                                                <span class="font-medium text-gray-900"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></span>
                                            </div>
                                            <div class="flex justify-between text-sm">
                                                <span class="text-gray-600">Delivery Date</span>
                                                <span class="font-medium text-gray-900"><%= order.orderItems.deliveredAt ? new Date(order.orderItems.deliveredAt).toLocaleDateString('en-IN') : 'Pending' %></span>
                                            </div>
                                            <div class="flex justify-between text-sm">
                                                <span class="text-gray-600">Payment Status</span>
                                                <span class="font-medium text-gray-900"><%= order.orderItems.paymentStatus?"Paid":"Pending" %></span>
                                            </div>
                                            <div class="flex justify-between text-sm">
                                                <span class="text-gray-600">Payment Method</span>
                                                <span class="font-medium text-gray-900 uppercase"><%= order.paymentMethod %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Customer Card -->
                                    <div class="bg-white rounded-xl p-5 shadow-sm">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-4">Customer Details</h4>
                                        <div class="space-y-3">
                                            <div class="flex items-start">
                                                <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                </svg>
                                                <div>
                                                    <p class="text-sm font-medium text-gray-900"><%= order.user.firstName %> <%= order.user.lastName %></p>
                                                </div>
                                            </div>
                                            <div class="flex items-start">
                                                <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                                </svg>
                                                <p class="text-sm text-gray-600"><%= order.user.email %></p>
                                            </div>
                                            <div class="flex items-start">
                                                <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                                </svg>
                                                <p class="text-sm text-gray-600"><%= order.user.number %></p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Product Card -->
                                    <div class="bg-white rounded-xl p-5 shadow-sm">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-4">Product Details</h4>
                                        <div class="flex items-center space-x-4">
                                            <img src="<%= order.product.productImages.find(img=>img.isMain).url %>" 
                                                 alt="Product" 
                                                 class="w-20 h-20 object-cover rounded-xl">
                                            <div class="flex-1">
                                                <h5 class="text-sm font-medium text-gray-900 mb-1"><%= order.product.name %></h5>
                                                <p class="text-xs text-gray-500 mb-2"><%= order.variant.deviceModel %></p>
                                                <div class="flex items-center justify-between">
                                                    <span class="text-xs text-gray-500">Qty: <%= order.orderItems.quantity %></span>
                                                    <span class="text-sm font-semibold text-gray-900">₹<%= order.orderItems.price %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right Column - Timeline -->
                                <div>
                                    <%
                                        const steps = [
                                            { key: 'placed', label: 'Order Placed', desc: 'We have received your order' },
                                            { key: 'confirmed', label: 'Confirmed', desc: 'Your order has been confirmed' },
                                            { key: 'processing', label: 'Processing', desc: 'Preparing your order' },
                                            { key: 'shipped', label: 'Shipped', desc: 'Your order is on the way' },
                                            { key: 'out_for_delivery', label: 'Out for Delivery', desc: 'Courier is nearby' },
                                            { key: 'delivered', label: 'Delivered', desc: 'Order successfully delivered' }
                                        ];
                                        
                                        const orderStatus = order.orderItems.status;
                                        const isCancelled = orderStatus === 'cancelled';
                                        const isReturned = orderStatus === 'returned';
                                        const isReturnRequested = orderStatus === 'return_req';
                                        const currentIndex = steps.findIndex(s => s.key === orderStatus);
                                    %>

                                    <div class="bg-white rounded-xl p-6 shadow-sm">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-6">Order Status</h4>

                                        <% if (isCancelled) { %>
                                            <div class="text-center py-8">
                                                <div class="inline-flex items-center justify-center w-16 h-16 bg-red-100 rounded-full mb-4">
                                                    <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                    </svg>
                                                </div>
                                                <h5 class="text-lg font-semibold text-gray-900 mb-2">Order Cancelled</h5>
                                                <p class="text-sm text-gray-500">This order has been cancelled</p>
                                                 <p class="text-sm text-gray-500">Reason:</p>
                                            </div>
                                        <% } else if (isReturned) { %>
                                            <div class="text-center py-8">
                                                <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mb-4">
                                                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                                    </svg>
                                                </div>
                                                <h5 class="text-lg font-semibold text-gray-900 mb-2">Order Returned</h5>
                                                <p class="text-sm text-gray-500">This order has been returned</p>
                                            </div>
                                        <% } else if (isReturnRequested) { %>
                                            <div class="text-center py-8">
                                                <div class="inline-flex items-center justify-center w-16 h-16 bg-yellow-100 rounded-full mb-4">
                                                    <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                    </svg>
                                                </div>
                                                <h5 class="text-lg font-semibold text-gray-900 mb-2">Return Requested</h5>
                                                <p class="text-sm text-gray-500 mb-6">Customer has requested a return</p>
                                                <p class="text-sm text-gray-500 mb-6">reason: <%= order.orderItems.returnReason %> </p>
                                                
                                                <div class="flex gap-3 justify-center">
                                                    <button
                                                        onclick="approveReturn('<%= order._id %>', '<%= order.orderItems._id %>')"
                                                        class="px-6 py-2.5 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-colors">
                                                        Approve
                                                    </button>
                                                    <button
                                                        onclick="rejectReturn('<%= order._id %>', '<%= order.orderItems._id %>')"
                                                        class="px-6 py-2.5 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors">
                                                        Reject
                                                    </button>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <!-- Timeline -->
                                            <div class="relative space-y-6">
                                                <% steps.forEach((step, index) => { 
                                                    const isCompleted = index < currentIndex;
                                                    const isCurrent = index === currentIndex;
                                                %>
                                                <div class="relative flex gap-4">
                                                    <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center z-10 <%= isCompleted ? 'bg-green-500' : isCurrent ? 'bg-blue-500' : 'bg-gray-200' %>">
                                                        <% if (isCompleted) { %>
                                                            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                                            </svg>
                                                        <% } else if (isCurrent) { %>
                                                            <div class="w-2 h-2 bg-white rounded-full"></div>
                                                        <% } %>
                                                    </div>
                                                    
                                                    <% if (index !== steps.length - 1) { %>
                                                        <div class="absolute left-4 top-8 w-0.5 h-full <%= isCompleted ? 'bg-green-500' : 'bg-gray-200' %>"></div>
                                                    <% } %>
                                                    
                                                    <div class="flex-1 pb-6">
                                                        <h5 class="text-sm font-medium text-gray-900 mb-1"><%= step.label %></h5>
                                                        <p class="text-xs text-gray-500"><%= step.desc %></p>
                                                    </div>
                                                </div>
                                                <% }) %>
                                            </div>
                                            
                                            <!-- Actions -->
                                            <div class="mt-6 pt-6 border-t border-gray-100 space-y-3">
                                                <% const status = order.orderItems.status; %>
                                                <% if (status !== 'return_req' && status !== 'delivered') { %>
                                                    <select
                                                        onchange="if(this.value) updateOrderStatus('<%= order._id %>', '<%= order.orderItems._id %>', this.value)"
                                                        class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                                                        <option value="" disabled selected>Update Status</option>
                                                        <% if (status === 'placed') { %>
                                                            <option value="confirmed">Mark as Confirmed</option>
                                                        <% } else if (status === 'confirmed') { %>
                                                            <option value="processing">Mark as Processing</option>
                                                        <% } else if (status === 'processing') { %>
                                                            <option value="shipped">Mark as Shipped</option>
                                                        <% } else if (status === 'shipped') { %>
                                                            <option value="out_for_delivery">Mark as Out for Delivery</option>
                                                        <% } else if (status === 'out_for_delivery') { %>
                                                            <option value="delivered">Mark as Delivered</option>
                                                        <% } %>
                                                    </select>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <div class="flex flex-col sm:flex-row justify-between items-center mt-8 pt-6 border-t border-gray-200 gap-4">
                <div class="text-sm text-gray-600">
                    Showing <span class="font-medium text-gray-900"><%= (currentPage ) %></span> to <span class="font-medium text-gray-900"><%=  totalPages %></span> <span class="font-medium text-gray-900"></span> 
                </div>
            
                <nav aria-label="Page navigation" class="flex justify-center">
                    <ul class="flex items-center space-x-1">
                        <% const qSearch = typeof search !== 'undefined' ? `&search=${search}` : ''; %>
                        <% const qStatus = typeof statusFilter !== 'undefined' ? `&status=${statusFilter}` : ''; %>
                        
                        <li>
                            <a href="<%= currentPage === 1 ? '#' : `/admin/order?page=${currentPage - 1}${qSearch}${qStatus}` %>"
                               class="px-3 py-2 rounded-lg border border-gray-300 text-sm font-medium <%= currentPage === 1 ? 'text-gray-300 cursor-not-allowed bg-gray-50' : 'text-gray-700 bg-white hover:bg-gray-50' %> transition-colors">
                                Previous
                            </a>
                        </li>

                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <% if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                                <li>
                                    <a href="/admin/order?page=<%= i %><%= qSearch %><%= qStatus %>"
                                       class="px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === i ? 'bg-blue-600 text-white shadow-sm border border-transparent' : 'bg-white text-gray-700 border border-gray-300 hover:bg-gray-50' %> transition-all">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
                                <li class="px-2 text-gray-400">...</li>
                            <% } %>
                        <% } %>

                        <li>
                            <a href="<%= currentPage === totalPages ? '#' : `/admin/order?page=${currentPage + 1}${qSearch}${qStatus}` %>"
                               class="px-3 py-2 rounded-lg border border-gray-300 text-sm font-medium <%= currentPage === totalPages ? 'text-gray-300 cursor-not-allowed bg-gray-50' : 'text-gray-700 bg-white hover:bg-gray-50' %> transition-colors">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    
</div>

<script>
    function toggleOrder(orderId) {
        const orderDetails = document.getElementById(orderId);
        const icon = document.getElementById('icon-' + orderId);
        
        if (orderDetails && icon) {
            if (orderDetails.classList.contains('hidden')) {
                orderDetails.classList.remove('hidden');
                icon.classList.add('rotated');
            } else {
                orderDetails.classList.add('hidden');
                icon.classList.remove('rotated');
            }
        }
    }

    function filterOrders() {
        const searchInput = document.getElementById('orderSearch').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value;
        const orderCards = document.querySelectorAll('.order-card');
        const clearButton = document.getElementById('clearFilters');
        const resultsCount = document.getElementById('resultsCount');
        
        let visibleCount = 0;
        let totalCount = orderCards.length;

        orderCards.forEach(card => {
            const orderId = card.getAttribute('data-order-id').toLowerCase();
            const customerName = card.getAttribute('data-customer-name').toLowerCase();
            const status = card.getAttribute('data-status');

            // Search filter
            const matchesSearch = orderId.includes(searchInput) || customerName.includes(searchInput);
            
            // Status filter
            const matchesStatus = statusFilter === 'all' || status === statusFilter;

            // Show/hide card based on both filters
            if (matchesSearch && matchesStatus) {
                card.style.display = '';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Show/hide clear button
        if (searchInput !== '' || statusFilter !== 'all') {
            clearButton.classList.remove('hidden');
        } else {
            clearButton.classList.add('hidden');
        }

        // Update results count
        if (visibleCount === totalCount) {
            resultsCount.textContent = `Showing all ${totalCount} orders`;
        } else {
            resultsCount.textContent = `Showing ${visibleCount} of ${totalCount} orders`;
        }
    }

    function clearFilters() {
        document.getElementById('orderSearch').value = '';
        document.getElementById('statusFilter').value = 'all';
        filterOrders();
    }

    // Initialize results count on page load
    document.addEventListener('DOMContentLoaded', function() {
        filterOrders();
    });
</script>

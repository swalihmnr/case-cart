<%- include('../partials/header') %>

<div class="flex min-h-screen bg-gray-50">
    <%- include('../partials/sidebar') %>
    
    <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <!-- Header Section -->
        <div class="mb-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">Dashboard Overview</h1>
                    <p class="text-sm text-gray-500 mt-1">Real-time business analytics and insights</p>
                </div>
                
                <!-- Period Filter Buttons -->
                <div class="flex flex-wrap gap-2">
                    <button onclick="filterData('daily')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 bg-gradient-to-r from-blue-600 to-blue-700 text-white shadow-md hover:shadow-lg" data-period="daily">
                        Daily
                    </button>
                    <button onclick="filterData('weekly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-gray-700 border border-gray-200 hover:bg-gray-50" data-period="weekly">
                        Weekly
                    </button>
                    <button onclick="filterData('monthly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-gray-700 border border-gray-200 hover:bg-gray-50" data-period="monthly">
                        Monthly
                    </button>
                    <button onclick="filterData('yearly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-gray-700 border border-gray-200 hover:bg-gray-50" data-period="yearly">
                        Yearly
                    </button>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-6">
            <!-- Total Revenue Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Total Revenue</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalRevenue">₹1,25,430</p>
                        <div class="flex items-center text-xs font-medium">
                            <svg class="w-3 h-3 mr-1 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-green-600" id="revenueChange">+12.5%</span>
                            <span class="text-gray-500 ml-1">vs last period</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-rupee-sign text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Total Orders Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Total Orders</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalOrders">1,234</p>
                        <div class="flex items-center text-xs font-medium">
                            <svg class="w-3 h-3 mr-1 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-green-600" id="ordersChange">+8.2%</span>
                            <span class="text-gray-500 ml-1">vs last period</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-shopping-cart text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Average Order Value Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Avg Order Value</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="avgOrderValue">₹1,020</p>
                        <div class="flex items-center text-xs font-medium">
                            <svg class="w-3 h-3 mr-1 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-green-600" id="avgChange">+5.3%</span>
                            <span class="text-gray-500 ml-1">vs last period</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-chart-line text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Total Products Sold Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Products Sold</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalProductsSold">3,456</p>
                        <div class="flex items-center text-xs font-medium">
                            <svg class="w-3 h-3 mr-1 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-green-600" id="productsChange">+15.7%</span>
                            <span class="text-gray-500 ml-1">vs last period</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-box text-white text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue Chart -->
        <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 mb-6 border border-gray-100">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
                <div>
                    <h2 class="text-lg font-bold text-gray-900">Revenue Trend</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Track your revenue performance over time</p>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="text-xs text-gray-500">Period:</span>
                    <span class="text-sm font-semibold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg" id="chartPeriod">January 2024</span>
                </div>
            </div>
            <div class="h-64 sm:h-80">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <!-- Best Selling Sections -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Best Selling Products -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Top 10 Products</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Best performing items</p>
                    </div>
                    <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-crown text-yellow-600 text-lg"></i>
                    </div>
                </div>
                <div class="space-y-1" id="bestProducts">
                    <!-- Products loaded via JavaScript -->
                </div>
            </div>

            <!-- Best Selling Categories -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Top 10 Categories</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Popular categories</p>
                    </div>
                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-tags text-green-600 text-lg"></i>
                    </div>
                </div>
                <div class="space-y-1" id="bestCategories">
                    <!-- Categories loaded via JavaScript -->
                </div>
            </div>

            <!-- Best Selling Brands -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Top 10 Brands</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Leading brands</p>
                    </div>
                    <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-building text-purple-600 text-lg"></i>
                    </div>
                </div>
                <div class="space-y-1" id="bestBrands">
                    <!-- Brands loaded via JavaScript -->
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    let revenueChart = null;
    let currentPeriod = 'daily';

    // Dummy data for different periods
    const dummyData = {
        daily: {
            revenue: '45,230',
            orders: '156',
            avgOrder: '290',
            productsSold: '423',
            revenueChange: '+5.2%',
            ordersChange: '+3.1%',
            avgChange: '+2.1%',
            productsChange: '+4.3%',
            chartPeriod: 'Today',
            chartData: [3200, 4500, 3800, 5200, 4800, 6100, 5900, 6700, 7200, 8100, 7600, 8900, 9200, 8800, 9500, 10200, 10800, 11500, 12100, 11800, 12500, 13200, 12800, 11800]
        },
        weekly: {
            revenue: '2,45,670',
            orders: '845',
            avgOrder: '291',
            productsSold: '2,134',
            revenueChange: '+15.3%',
            ordersChange: '+12.7%',
            avgChange: '+2.3%',
            productsChange: '+18.2%',
            chartPeriod: 'This Week',
            chartData: [32000, 45000, 38000, 52000, 68000, 75000, 82000]
        },
        monthly: {
            revenue: '8,92,450',
            orders: '3,234',
            avgOrder: '276',
            productsSold: '8,956',
            revenueChange: '+22.5%',
            ordersChange: '+18.9%',
            avgChange: '+3.1%',
            productsChange: '+25.4%',
            chartPeriod: 'January 2024',
            chartData: [45000, 52000, 48000, 61000, 58000, 72000, 69000, 81000, 78000, 92000, 88000, 95000, 102000, 98000, 105000, 112000, 118000, 125000, 121000, 132000, 128000, 135000, 142000, 148000, 151000, 158000, 162000, 168000, 172000, 178000, 185000]
        },
        yearly: {
            revenue: '8,54,50,000',
            orders: '28,450',
            avgOrder: '300',
            productsSold: '82,340',
            revenueChange: '+45.2%',
            ordersChange: '+38.5%',
            avgChange: '+4.8%',
            productsChange: '+52.3%',
            chartPeriod: '2024',
            chartData: [520000, 580000, 620000, 710000, 750000, 820000, 880000, 920000, 980000, 1050000, 1120000, 1250000]
        }
    };

    // Dummy best selling products
    const dummyProducts = [
        { rank: 1, name: 'iPhone 15 Pro Max', category: 'Electronics', brand: 'Apple', sold: 1234, icon: '🥇', color: 'bg-gradient-to-br from-yellow-400 to-yellow-500 text-white' },
        { rank: 2, name: 'Samsung Galaxy S24 Ultra', category: 'Electronics', brand: 'Samsung', sold: 987, icon: '🥈', color: 'bg-gradient-to-br from-gray-300 to-gray-400 text-white' },
        { rank: 3, name: 'Sony WH-1000XM4', category: 'Audio', brand: 'Sony', sold: 876, icon: '🥉', color: 'bg-gradient-to-br from-orange-400 to-orange-500 text-white' },
        { rank: 4, name: 'Nike Air Max 270', category: 'Footwear', brand: 'Nike', sold: 765, icon: '4', color: 'bg-gray-100 text-gray-700' },
        { rank: 5, name: 'Dell XPS 15', category: 'Electronics', brand: 'Dell', sold: 654, icon: '5', color: 'bg-gray-100 text-gray-700' },
        { rank: 6, name: 'Adidas Ultraboost', category: 'Footwear', brand: 'Adidas', sold: 543, icon: '6', color: 'bg-gray-100 text-gray-700' },
        { rank: 7, name: 'MacBook Air M2', category: 'Electronics', brand: 'Apple', sold: 432, icon: '7', color: 'bg-gray-100 text-gray-700' },
        { rank: 8, name: 'Canon EOS R5', category: 'Photography', brand: 'Canon', sold: 321, icon: '8', color: 'bg-gray-100 text-gray-700' },
        { rank: 9, name: 'Logitech MX Master 3', category: 'Accessories', brand: 'Logitech', sold: 210, icon: '9', color: 'bg-gray-100 text-gray-700' },
        { rank: 10, name: 'Kindle Paperwhite', category: 'Electronics', brand: 'Amazon', sold: 198, icon: '10', color: 'bg-gray-100 text-gray-700' }
    ];

    // Dummy best selling categories
    const dummyCategories = [
        { rank: 1, name: 'Electronics', sold: 3456, icon: '🥇', color: 'bg-gradient-to-br from-yellow-400 to-yellow-500 text-white' },
        { rank: 2, name: 'Footwear', sold: 2345, icon: '🥈', color: 'bg-gradient-to-br from-gray-300 to-gray-400 text-white' },
        { rank: 3, name: 'Clothing', sold: 1987, icon: '🥉', color: 'bg-gradient-to-br from-orange-400 to-orange-500 text-white' },
        { rank: 4, name: 'Home & Kitchen', sold: 1654, icon: '4', color: 'bg-gray-100 text-gray-700' },
        { rank: 5, name: 'Books', sold: 1432, icon: '5', color: 'bg-gray-100 text-gray-700' },
        { rank: 6, name: 'Sports', sold: 1232, icon: '6', color: 'bg-gray-100 text-gray-700' },
        { rank: 7, name: 'Beauty', sold: 987, icon: '7', color: 'bg-gray-100 text-gray-700' },
        { rank: 8, name: 'Toys', sold: 876, icon: '8', color: 'bg-gray-100 text-gray-700' },
        { rank: 9, name: 'Automotive', sold: 654, icon: '9', color: 'bg-gray-100 text-gray-700' },
        { rank: 10, name: 'Pet Supplies', sold: 543, icon: '10', color: 'bg-gray-100 text-gray-700' }
    ];

    // Dummy best selling brands
    const dummyBrands = [
        { rank: 1, name: 'Apple', sold: 2345, icon: '🥇', color: 'bg-gradient-to-br from-yellow-400 to-yellow-500 text-white' },
        { rank: 2, name: 'Samsung', sold: 1987, icon: '🥈', color: 'bg-gradient-to-br from-gray-300 to-gray-400 text-white' },
        { rank: 3, name: 'Nike', sold: 1654, icon: '🥉', color: 'bg-gradient-to-br from-orange-400 to-orange-500 text-white' },
        { rank: 4, name: 'Sony', sold: 1432, icon: '4', color: 'bg-gray-100 text-gray-700' },
        { rank: 5, name: 'Adidas', sold: 1234, icon: '5', color: 'bg-gray-100 text-gray-700' },
        { rank: 6, name: 'Dell', sold: 987, icon: '6', color: 'bg-gray-100 text-gray-700' },
        { rank: 7, name: 'HP', sold: 876, icon: '7', color: 'bg-gray-100 text-gray-700' },
        { rank: 8, name: 'Canon', sold: 765, icon: '8', color: 'bg-gray-100 text-gray-700' },
        { rank: 9, name: 'Lenovo', sold: 654, icon: '9', color: 'bg-gray-100 text-gray-700' },
        { rank: 10, name: 'LG', sold: 543, icon: '10', color: 'bg-gray-100 text-gray-700' }
    ];

    $(document).ready(function() {
        // Load initial data
        filterData('daily');
        displayBestProducts();
        displayBestCategories();
        displayBestBrands();
        initializeChart();
    });

    function filterData(period) {
        currentPeriod = period;
        
        // Update button styles with smooth transition
        $('.period-btn').removeClass('bg-gradient-to-r from-blue-600 to-blue-700 text-white shadow-md')
                       .addClass('bg-white text-gray-700 border border-gray-200');
        
        const $activeBtn = $(`.period-btn[data-period="${period}"]`);
        $activeBtn.removeClass('bg-white text-gray-700 border border-gray-200')
                  .addClass('bg-gradient-to-r from-blue-600 to-blue-700 text-white shadow-md');

        // Update statistics with dummy data
        const data = dummyData[period];
        
        // Animate number changes
        animateValue('totalRevenue', '₹' + data.revenue);
        animateValue('totalOrders', data.orders);
        animateValue('avgOrderValue', '₹' + data.avgOrder);
        animateValue('totalProductsSold', data.productsSold);
        
        $('#revenueChange').text(data.revenueChange);
        $('#ordersChange').text(data.ordersChange);
        $('#avgChange').text(data.avgChange);
        $('#productsChange').text(data.productsChange);
        
        $('#chartPeriod').text(data.chartPeriod);
        
        // Update chart
        updateChart(period);
    }

    function animateValue(id, newValue) {
        const element = document.getElementById(id);
        element.style.transform = 'scale(1.1)';
        setTimeout(() => {
            element.textContent = newValue;
            element.style.transform = 'scale(1)';
        }, 100);
    }

    function initializeChart() {
        const ctx = document.getElementById('revenueChart').getContext('2d');
        
        revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: getLabels('daily'),
                datasets: [{
                    label: 'Revenue (₹)',
                    data: dummyData.daily.chartData,
                    borderColor: 'rgb(59, 130, 246)',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: 'rgb(59, 130, 246)',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    intersect: false,
                    mode: 'index'
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        padding: 12,
                        titleColor: 'white',
                        titleFont: {
                            size: 13,
                            weight: 'bold'
                        },
                        bodyColor: 'white',
                        bodyFont: {
                            size: 12
                        },
                        borderColor: 'rgba(255, 255, 255, 0.1)',
                        borderWidth: 1,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return 'Revenue: ₹' + context.raw.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            font: {
                                size: 11
                            }
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(0, 0, 0, 0.05)'
                        },
                        ticks: {
                            font: {
                                size: 11
                            },
                            callback: function(value) {
                                return '₹' + (value / 1000) + 'k';
                            }
                        }
                    }
                }
            }
        });
    }

    function updateChart(period) {
        const labels = getLabels(period);
        const data = dummyData[period].chartData;
        
        revenueChart.data.labels = labels;
        revenueChart.data.datasets[0].data = data;
        revenueChart.update('active');
    }

    function getLabels(period) {
        switch(period) {
            case 'daily':
                return Array.from({length: 24}, (_, i) => `${i}:00`);
            case 'weekly':
                return ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            case 'monthly':
                return Array.from({length: 31}, (_, i) => `${i + 1}`);
            case 'yearly':
                return ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            default:
                return [];
        }
    }

    function displayBestProducts() {
        let html = '';
        dummyProducts.forEach(product => {
            html += `
                <div class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-gray-50 transition-colors duration-150 cursor-pointer group">
                    <div class="flex items-center flex-1 min-w-0">
                        <span class="w-8 h-8 rounded-lg ${product.color} flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0 shadow-sm">
                            ${product.icon}
                        </span>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-gray-900 text-sm truncate group-hover:text-blue-600 transition-colors">${product.name}</p>
                            <p class="text-xs text-gray-500 truncate">
                                ${product.category} • ${product.brand}
                            </p>
                        </div>
                    </div>
                    <div class="text-right ml-3 flex-shrink-0">
                        <p class="font-bold text-gray-900 text-sm">${product.sold.toLocaleString()}</p>
                        <p class="text-xs text-gray-500">sold</p>
                    </div>
                </div>
            `;
        });
        $('#bestProducts').html(html);
    }

    function displayBestCategories() {
        let html = '';
        dummyCategories.forEach(category => {
            html += `
                <div class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-gray-50 transition-colors duration-150 cursor-pointer group">
                    <div class="flex items-center flex-1 min-w-0">
                        <span class="w-8 h-8 rounded-lg ${category.color} flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0 shadow-sm">
                            ${category.icon}
                        </span>
                        <p class="font-semibold text-gray-900 text-sm truncate group-hover:text-green-600 transition-colors">${category.name}</p>
                    </div>
                    <div class="text-right ml-3 flex-shrink-0">
                        <p class="font-bold text-gray-900 text-sm">${category.sold.toLocaleString()}</p>
                        <p class="text-xs text-gray-500">sold</p>
                    </div>
                </div>
            `;
        });
        $('#bestCategories').html(html);
    }

    function displayBestBrands() {
        let html = '';
        dummyBrands.forEach(brand => {
            html += `
                <div class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-gray-50 transition-colors duration-150 cursor-pointer group">
                    <div class="flex items-center flex-1 min-w-0">
                        <span class="w-8 h-8 rounded-lg ${brand.color} flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0 shadow-sm">
                            ${brand.icon}
                        </span>
                        <p class="font-semibold text-gray-900 text-sm truncate group-hover:text-purple-600 transition-colors">${brand.name}</p>
                    </div>
                    <div class="text-right ml-3 flex-shrink-0">
                        <p class="font-bold text-gray-900 text-sm">${brand.sold.toLocaleString()}</p>
                        <p class="text-xs text-gray-500">sold</p>
                    </div>
                </div>
            `;
        });
        $('#bestBrands').html(html);
    }

    // Show notification function
    function showNotification(message, type = 'success') {
        const colors = {
            success: 'bg-gradient-to-r from-green-500 to-green-600',
            error: 'bg-gradient-to-r from-red-500 to-red-600',
            info: 'bg-gradient-to-r from-blue-500 to-blue-600'
        };
        
        const icons = {
            success: 'fa-check-circle',
            error: 'fa-exclamation-circle',
            info: 'fa-info-circle'
        };
        
        const notification = document.createElement('div');
        notification.className = `fixed top-4 right-4 p-4 rounded-xl shadow-2xl z-50 transform transition-all duration-300 translate-x-full ${colors[type]} text-white`;
        notification.style.maxWidth = '350px';
        notification.innerHTML = `
            <div class="flex items-center">
                <i class="fas ${icons[type]} mr-3 text-lg"></i>
                <span class="font-medium">${message}</span>
            </div>
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.classList.remove('translate-x-full');
        }, 100);
        
        setTimeout(() => {
            notification.classList.add('translate-x-full');
            setTimeout(() => {
                notification.remove();
            }, 300);
        }, 3000);
    }

    // Optional: Add auto-refresh simulation
    setInterval(function() {
        showNotification('Dashboard data refreshed', 'info');
    }, 120000); // Every 2 minutes
</script>


<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<div class="flex min-h-screen bg-gray-50">
    <%- include('../partials/sidebar') %>
    
    <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <!-- Header Section -->
        <div class="mb-8">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">Dashboard Overview</h1>
                    <p class="text-sm text-gray-500 mt-1">Real-time business analytics and insights</p>
                </div>
                
                <!-- Period Filter Buttons -->
                <div class="flex flex-wrap gap-2 bg-white p-1 rounded-lg shadow-sm border border-gray-200">
                    <button onclick="filterData('daily')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200" data-period="daily">
                        Daily
                    </button>
                    <button onclick="filterData('weekly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200" data-period="weekly">
                        Weekly
                    </button>
                    <button onclick="filterData('monthly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200" data-period="monthly">
                        Monthly
                    </button>
                    <button onclick="filterData('yearly')" class="period-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200" data-period="yearly">
                        Yearly
                    </button>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-8">
            <!-- Total Revenue Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 p-6 border border-gray-100 group">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Total Revenue</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalRevenue">₹ <%= revenueDatas[0]?.totalRevenue?.toLocaleString('en-IN') || 0 %></p>
                        
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                        <i class="fas fa-rupee-sign text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Total Orders Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 p-6 border border-gray-100 group">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Total Orders</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalOrders"><%= revenueDatas[0]?.totalOrders?.toLocaleString('en-IN') || 0 %></p>
                        
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                        <i class="fas fa-shopping-cart text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Average Order Value Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 p-6 border border-gray-100 group">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Avg Order Value</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="avgOrderValue">₹ <%= revenueDatas[0]?.avarageOrderValue?.toFixed(2) || 0 %></p>
                        
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                        <i class="fas fa-chart-line text-white text-xl"></i>
                    </div>
                </div>
            </div>

            <!-- Total Products Sold Card -->
            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 p-6 border border-gray-100 group">
                <div class="flex items-center justify-between">
                    <div class="flex-1">
                        <p class="text-xs sm:text-sm text-gray-600 font-medium mb-1">Products Sold</p>
                        <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" id="totalProductsSold"><%= revenueDatas[0]?.productSold?.toLocaleString('en-IN') || 0 %></p>
                       
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                        <i class="fas fa-box text-white text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <!-- Revenue Chart -->
            <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Revenue Trend</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Last 7 days performance</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-3 h-3 bg-blue-500 rounded-full"></span>
                        <span class="text-xs text-gray-600">Revenue (₹)</span>
                    </div>
                </div>
                <div class="h-80">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>

            <!-- Pie Chart -->
            <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                <h2 class="text-lg font-bold text-gray-900 mb-6">Order Status Distribution</h2>
                <div class="flex flex-col items-center justify-center h-80">
                    <canvas id="statusPieChart" class="max-h-64 max-w-64"></canvas>
                    <div class="flex flex-wrap justify-center gap-4 mt-6">
                        <% if (chartStatusData && chartStatusData.length > 0) { %>
                            <% chartStatusData.forEach((item, index) => { %>
                                <div class="flex items-center gap-2">
                                    <span class="w-3 h-3 rounded-full" style="background-color: <%= ['#10B981', '#F59E0B', '#EF4444', '#3B82F6'][index % 4] %>"></span>
                                    <span class="text-xs text-gray-600"><%= item._id %>: <%= item.count %></span>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Best Selling Sections -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Best Selling Products -->
            <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Top 10 Products</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Best performing items</p>
                    </div>
                    <div class="w-10 h-10 bg-yellow-100 rounded-xl flex items-center justify-center">
                        <i class="fas fa-crown text-yellow-600 text-lg"></i>
                    </div>
                </div>
                <div class="space-y-3" id="bestProducts">
                    <% if (productDatas && productDatas.length > 0) { %>
                        <% productDatas.slice(0, 10).forEach((product, index) => { %>
                            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0 group hover:bg-gray-50 px-2 rounded-lg transition-all duration-200">
                                <div class="flex items-center gap-4">
                                    <span class="text-sm font-semibold <%= index < 3 ? 'text-yellow-600' : 'text-gray-400' %> w-8"><%= index + 1 %></span>
                                    <span class="text-sm font-medium text-gray-800"><%= product.productName %></span>
                                </div>
                                <span class="text-sm font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full"><%= product.totalSold %> sold</span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-center text-gray-500 py-4">No product data available</p>
                    <% } %>
                </div>
            </div>

            <!-- Best Selling Categories -->
            <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Top 10 Categories</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Popular categories</p>
                    </div>
                    <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
                        <i class="fas fa-tags text-green-600 text-lg"></i>
                    </div>
                </div>
                <div class="space-y-3" id="bestCategories">
                    <% if (categoryDatas && categoryDatas.length > 0) { %>
                        <% categoryDatas.slice(0, 10).forEach((category, index) => { %>
                            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0 group hover:bg-gray-50 px-2 rounded-lg transition-all duration-200">
                                <div class="flex items-center gap-4">
                                    <span class="text-sm font-semibold <%= index < 3 ? 'text-yellow-600' : 'text-gray-400' %> w-8"><%= index + 1 %></span>
                                    <span class="text-sm font-medium text-gray-800"><%= category.categoryName %></span>
                                </div>
                                <span class="text-sm font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full"><%= category.categorySold %> items</span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-center text-gray-500 py-4">No category data available</p>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    // Filter function
    function filterData(period) {
        const currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('filter', period);
        window.location.href = currentUrl.toString();
    }

    // Set active period button
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const activePeriod = urlParams.get('filter') || 'daily';
        
        document.querySelectorAll('.period-btn').forEach(btn => {
            const period = btn.getAttribute('onclick')?.match(/'([^']+)'/)?.[1];
            if (period === activePeriod) {
                btn.classList.add('bg-gradient-to-r', 'from-blue-600', 'to-blue-700', 'text-white', 'shadow-md');
                btn.classList.remove('bg-white', 'text-gray-700', 'border', 'border-gray-200', 'hover:bg-gray-50');
            } else {
                btn.classList.remove('bg-gradient-to-r', 'from-blue-600', 'to-blue-700', 'text-white', 'shadow-md');
                btn.classList.add('bg-white', 'text-gray-700', 'border', 'border-gray-200', 'hover:bg-gray-50');
            }
        });
    });

    // Chart Data
    const statusChartData = <%- JSON.stringify(chartStatusData || []) %>;
    const revenueTrendData = <%- JSON.stringify(revenueTrend || []) %>;

    // Revenue Chart
    if (revenueTrendData && revenueTrendData.length > 0) {
        const lineLabels = revenueTrendData.map(item => {
            const date = new Date(item._id);
            return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
        });
        const lineRevenue = revenueTrendData.map(item => item.totalRevenue);

        new Chart(document.getElementById("revenueChart"), {
            type: "line",
            data: {
                labels: lineLabels,
                datasets: [{
                    label: "Revenue (₹)",
                    data: lineRevenue,
                    borderColor: "#3b82f6",
                    backgroundColor: "rgba(59, 130, 246, 0.1)",
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: "#3b82f6",
                    pointBorderColor: "#fff",
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `₹ ${context.raw.toLocaleString('en-IN')}`;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '₹' + value.toLocaleString('en-IN');
                            }
                        }
                    }
                }
            }
        });
    }

    // Pie Chart
    if (statusChartData && statusChartData.length > 0) {
        const pieLabels = statusChartData.map(item => item._id);
        const pieCounts = statusChartData.map(item => item.count);

        new Chart(document.getElementById("statusPieChart"), {
            type: "pie",
            data: {
                labels: pieLabels,
                datasets: [{
                    data: pieCounts,
                    backgroundColor: [
                        "#10B981", // Green - Delivered
                        "#F59E0B", // Orange - Processing
                        "#EF4444", // Red - Cancelled
                        "#3B82F6", // Blue - Pending
                        "#8B5CF6", // Purple - Shipped
                        "#EC4899"  // Pink - Returned
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                const percentage = ((context.raw / total) * 100).toFixed(1);
                                return `${context.label}: ${context.raw} (${percentage}%)`;
                            }
                        }
                    }
                }
            }
        });
    }
</script>

<style>
    .period-btn {
        transition: all 0.2s ease;
    }
    
    .period-btn:hover {
        transform: translateY(-1px);
    }
    
    .group:hover .group-hover\:scale-110 {
        transform: scale(1.1);
    }
</style>

<%- include('../partials/footer') %>
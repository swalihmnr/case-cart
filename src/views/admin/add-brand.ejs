<%- include('../partials/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />


<div class="flex">
  <%- include('../partials/sidebar') %>
  <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen">
    <!-- Page Header -->
    <div class="mb-6">
      <div class="flex items-center justify-between">
        <div>
          <div class="flex items-center space-x-3 mb-2">
            <a
              href="/admin/brands"
              class="text-purple-600 hover:text-purple-700 p-2"
            >
              <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="text-3xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-indigo-600">
              Add New Brand
            </h1>
          </div>
          <p class="text-gray-600 text-sm lg:text-base">
            Create a new brand for your products.
          </p>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Main Form -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Basic Information -->
        <div class="bg-white rounded-lg shadow-sm p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">
            Basic Information
          </h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Brand Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="brandName"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200"
                placeholder="Enter brand name"
                required
              />
            </div>
            <p id="nameErr" class="text-red-500"></p>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Description <span class="text-red-500">*</span>
              </label>
              <textarea
                id="brandDescription"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent h-32 transition-all duration-200"
                placeholder="Enter brand description"
                required
              ></textarea>
            </div>
            <p id="desErr" class="text-red-500"></p>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Brand Icon <span class="text-gray-400">(Optional)</span>
              </label>
              <input
                type="file"
                id="brandIcon"
                accept="image/*"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-lg shadow-sm p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">
            Quick Actions
          </h3>
          <div class="space-y-3">
            <button
              onclick="submitBrand(event)"
              data-mode="add"
              data-action="save"
              class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white py-3.5 rounded-xl font-bold shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center space-x-2"
            >
              <i class="fas fa-save"></i>
              <span>Save Brand</span>
            </button>
            <button
              onclick="submitBrand(event)"
              data-mode="add"
              data-action="save_and"
              class="w-full border-2 border-purple-200 text-purple-700 bg-purple-50 py-3.5 rounded-xl font-bold hover:bg-purple-100 hover:border-purple-300 transition-all duration-200 flex items-center justify-center space-x-2"
            >
              <i class="fas fa-plus"></i>
              <span>Save & Add Another</span>
            </button>
            <a
              href="/admin/brands"
              class="w-full border border-gray-200 text-gray-600 bg-white py-3.5 rounded-xl font-bold hover:bg-gray-50 hover:text-gray-900 transition-all duration-200 flex items-center justify-center space-x-2"
            >
              <i class="fas fa-times"></i>
              <span>Cancel</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Crop Modal -->
<div id="cropModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-2xl w-full">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900">Crop Image</h2>
            <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>

        <!-- Cropper Container -->
        <div class="w-full" style="max-height: 400px; overflow: hidden;">
            <img id="cropImage" class="max-w-full block" style="display: none;" />
        </div>

        <div class="flex justify-end gap-3 mt-6">
            <button onclick="closeCropModal()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
            <button onclick="cropAndSave()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">Crop & Save</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<script type="module" src="/js/admin/add-brand.js"></script>
<%- include('../partials/footer') %>

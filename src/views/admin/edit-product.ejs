<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Product Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.12/dist/cropper.min.css">
    <link rel="stylesheet" href="/css/admin-common.css">
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #818cf8;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-600: #4b5563;
            --gray-900: #111827;
        }

        .premium-card {
            background: white;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            border: 1px solid var(--gray-200);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .premium-card:hover {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08);
        }

        .btn-premium {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            font-weight: 600;
            padding: 0.625rem 1.25rem;
            border-radius: 0.75rem;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-premium:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
            filter: brightness(1.1);
        }

        .btn-premium:active {
            transform: translateY(0);
        }

        .btn-secondary-premium {
            background: white;
            color: var(--gray-900);
            border: 1px solid var(--gray-200);
            font-weight: 600;
            padding: 0.625rem 1.25rem;
            border-radius: 0.75rem;
            transition: all 0.2s;
        }

        .btn-secondary-premium:hover {
            background: var(--gray-50);
            border-color: var(--gray-600);
        }

        .image-container {
            position: relative;
            overflow: hidden;
            border-radius: 0.75rem;
        }

        .image-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(2px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.3s;
        }

        .image-container:hover .image-overlay {
            opacity: 1;
        }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .status-badge-success { background: #ecfdf5; color: #065f46; }
        .status-badge-warning { background: #fffbeb; color: #92400e; }
        .status-badge-danger { background: #fef2f2; color: #991b1b; }

        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner {
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid rgba(0, 0, 0, 0.1);
            border-radius: 50%;
            border-top-color: var(--primary);
            animation: spin 0.6s linear infinite;
        }

        #global-loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .hidden-overlay { opacity: 0; pointer-events: none; }

        .form-input {
            width: 100%;
            padding: 0.625rem 1rem;
            border: 1px solid var(--gray-200);
            border-radius: 0.75rem;
            transition: all 0.2s;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }
    </style>
</head>

<body class="bg-gray-50">
    <!-- Global Loading Overlay -->
    <div id="global-loading-overlay" class="hidden-overlay">
        <div class="flex flex-col items-center">
            <span class="loader-glow"></span>
            <p class="mt-4 text-blue-900 font-bold text-sm tracking-widest animate-pulse">PROCESSING...</p>
        </div>
    </div>
    <!-- Header -->
    <header class="bg-white border-b sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button onclick="window.location.href='/admin/product-list'" class="p-2 hover:bg-gray-100 rounded-full transition-colors">
                        <i class="fas fa-arrow-left text-gray-600"></i>
                    </button>
                    <div>
                        <div class="flex items-center gap-2 text-xs text-gray-500 mb-0.5">
                            <a href="/admin/dashboard" class="hover:text-primary">Dashboard</a>
                            <i class="fas fa-chevron-right text-[10px]"></i>
                            <a href="/admin/product-list" class="hover:text-primary">Products</a>
                            <i class="fas fa-chevron-right text-[10px]"></i>
                            <span class="text-gray-900">Edit</span>
                        </div>
                        <h1 class="text-xl font-bold text-gray-900 leading-none">Product Details</h1>
                    </div>
                </div>
                
                <div class="flex items-center gap-3">
                    <button onclick="window.location.reload()" class="p-2 text-gray-500 hover:text-primary transition-colors" title="Refresh">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                    <div class="h-6 w-px bg-gray-200"></div>
                    <span class="text-sm font-medium text-gray-600">ID: <%= product._id.toString().slice(-6).toUpperCase() %></span>
                </div>
            </div>
        </div>
    </header>

    <%- include("../partials/flash") %>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Left Column - Product Images & Details -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Product Images Moved to Variant Modal -->

                    <!-- Basic Information -->
                    <div class="premium-card p-6" id="basicInfoSection">
                        <div class="flex items-center justify-between mb-6">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                                    <i class="fas fa-info-circle"></i>
                                </div>
                                <h2 class="text-lg font-bold text-gray-900">Basic Information</h2>
                            </div>
                            <button id="editBasicInfoBtn" class="text-sm font-semibold text-indigo-600 hover:text-indigo-700 flex items-center gap-1">
                                <i class="fas fa-edit"></i> Edit Details
                            </button>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-4">
                                <div>
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Product Name</label>
                                    <p id="productNameDisplay" class="text-gray-900 font-semibold mt-1">
                                        <%= product.name %>
                                    </p>
                                    <input id="productNameEdit" type="text" class="hidden form-input mt-1" value="<%= product.name %>">
                                </div>

                                <div>
                                    <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Category</label>
                                    <p id="categoryDisplay" class="text-gray-900 font-semibold mt-1" data-category-id="<%= product.catgId ? product.catgId._id : '' %>">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                            <%= product.catgId ? product.catgId.name : 'No Category' %>
                                        </span>
                                    </p>
                                    <select id="categoryEdit" class="hidden form-input mt-1">
                                        <% categories.forEach(category=> { %>
                                            <option value="<%= category._id %>" <%= product.catgId && product.catgId._id.toString() === category._id.toString() ? 'selected' : '' %>>
                                                <%= category.name %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Description</label>
                                <p id="descriptionDisplay" class="text-gray-600 mt-1 text-sm leading-relaxed line-clamp-4">
                                    <%= product.description %>
                                </p>
                                <textarea id="descriptionEdit" class="hidden form-input mt-1" rows="4"><%= product.description %></textarea>
                            </div>
                        </div>

                        <div id="basicInfoActions" class="hidden mt-6 pt-6 border-t border-gray-100 flex justify-end gap-3">
                            <button id="cancelBasicInfoBtn" class="btn-secondary-premium">Cancel</button>
                            <button id="saveBasicInfoBtn" class="btn-premium">Save Changes</button>
                        </div>
                    </div>


                    <!-- Pricing & Stock -->


                    <!-- Variants -->
                    <div class="premium-card p-6">
                        <div class="flex items-center justify-between mb-6">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
                                    <i class="fas fa-layer-group"></i>
                                </div>
                                <h2 class="text-lg font-bold text-gray-900">Product Variants</h2>
                            </div>
                            <button onclick="openAddVariantModal()" class="btn-premium">
                                <i class="fas fa-plus"></i> Add Variant
                            </button>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50/50">
                                    <tr>
                                        <th class="px-4 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Images</th>
                                        <th class="px-4 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Model</th>
                                        <th class="px-4 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Stock</th>
                                        <th class="px-4 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Prices</th>
                                        <th class="px-4 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-widest">Status</th>
                                        <th class="px-4 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-widest">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    <% product.variants.forEach(veriant=> { %>
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-4 py-4">
                                                <div class="flex -space-x-3 overflow-hidden p-1">
                                                    <% if (veriant.images && veriant.images.length > 0) { %>
                                                        <% veriant.images.forEach((img, i) => { %>
                                                            <div class="relative group">
                                                                <img class="inline-block h-12 w-12 rounded-xl ring-2 ring-white object-cover shadow-sm transition-transform group-hover:scale-110 group-hover:z-10" 
                                                                     src="<%= img.url %>" 
                                                                     alt="Variant image <%= i + 1 %>">
                                                                <% if (img.isMain) { %>
                                                                    <div class="absolute -top-1 -right-1 w-3 h-3 bg-blue-500 border-2 border-white rounded-full"></div>
                                                                <% } %>
                                                            </div>
                                                        <% }) %>
                                                    <% } else { %>
                                                        <div class="h-12 w-32 bg-gray-50 border border-dashed border-gray-200 rounded-xl flex items-center justify-center">
                                                            <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">No Assets</span>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>

                                            <td class="px-4 py-4">
                                                <div class="text-sm font-bold text-gray-900 mb-0.5"><%= veriant.deviceModel %></div>
                                                <div class="flex items-center gap-2">
                                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-indigo-50 text-indigo-600 uppercase tracking-wider">
                                                        <%= veriant.brandId ? veriant.brandId.name : 'Generic' %>
                                                    </span>
                                                    <span class="text-[10px] text-gray-400 font-medium tracking-tighter">
                                                        #<%= veriant._id.toString().slice(-6).toUpperCase() %>
                                                    </span>
                                                </div>
                                            </td>

                                            <td class="px-4 py-4 text-sm font-medium text-gray-600">
                                                <%= veriant.stock %> units
                                            </td>
                                            <td class="px-4 py-4">
                                                <div class="text-sm font-bold text-indigo-600">₹<%= veriant.salePrice %></div>
                                                <div class="text-xs text-gray-400 line-through">₹<%= veriant.orgPrice %></div>
                                            </td>
                                            <td class="px-4 py-4">
                                                <% if (veriant.stock > 20) { %>
                                                    <span class="status-badge status-badge-success">
                                                        <i class="fas fa-check-circle text-[10px]"></i> In Stock
                                                    </span>
                                                <% } else if (veriant.stock > 0) { %>
                                                    <span class="status-badge status-badge-warning">
                                                        <i class="fas fa-exclamation-circle text-[10px]"></i> Low Stock
                                                    </span>
                                                <% } else { %>
                                                    <span class="status-badge status-badge-danger">
                                                        <i class="fas fa-times-circle text-[10px]"></i> Out of Stock
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td class="px-4 py-4 text-right">
                                                <div class="flex items-center justify-end gap-2">
                                                    <button onclick="manageVariantImages('<%= veriant._id %>')" 
                                                        class="p-2 text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="Manage Images">
                                                        <i class="fas fa-images"></i>
                                                    </button>
                                                    <button onclick="openEditVariantModal('<%= veriant._id %>')" 
                                                        class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Edit Info">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button onclick="toggleListUnlist('<%= veriant._id %>', this)" 
                                                        id="listing-btn-<%= veriant._id %>"
                                                        class="p-2 <%= veriant.isListed ? 'text-amber-600 hover:bg-amber-50' : 'text-emerald-600 hover:bg-emerald-50' %> rounded-lg transition-colors" 
                                                        title="<%= veriant.isListed ? 'Unlist' : 'List' %>">
                                                        <i class="fas <%= veriant.isListed ? 'fa-eye-slash' : 'fa-eye' %>"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Stats & Actions -->
                <!-- <div class="space-y-6">
                
                <div class="bg-white rounded-lg shadow-sm p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Stats</h2>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Total Sales</p>
                                <p class="text-2xl font-bold text-blue-600">1,284</p>
                            </div>
                            <i class="fas fa-shopping-cart text-blue-600 text-2xl"></i>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                            <div>
                                <p class="text-sm text-gray-600">Revenue</p>
                                <p class="text-2xl font-bold text-green-600">₹160,487</p>
                            </div>
                            <i class="fas fa-dollar-sign text-green-600 text-2xl"></i>
                        </div>
                    </div>
                </div>

                
            </div> -->
            </div>
        </main>

        <!-- Edit Variant Modal -->
        <div id="editVariantModal"
            class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-lg shadow-xl w-full max-w-md">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-semibold text-gray-900">Edit Variant</h3>
                </div>
                <div class="px-6 py-4 space-y-4">
                    <div>
                        <label for="editVariantModel" class="block text-sm font-medium text-gray-700 mb-1">Model
                            Name</label>
                        <input type="text" id="editVariantModel"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label for="editVariantBrand" class="block text-sm font-medium text-gray-700 mb-1">Brand</label>
                        <select id="editVariantBrand" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">Select Brand</option>
                            <% if (typeof brands !== 'undefined' && brands.length > 0) { %>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand._id %>"><%= brand.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label for="editVariantStock" class="block text-sm font-medium text-gray-700 mb-1">Stock
                            Quantity</label>
                        <input type="number" id="editVariantStock"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label for="editVariantOriginalPrice"
                            class="block text-sm font-medium text-gray-700 mb-1">Original Price (₹)</label>
                        <input type="number" step="0.01" id="editVariantOriginalPrice"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label for="editVariantSalePrice" class="block text-sm font-medium text-gray-700 mb-1">Sale
                            Price (₹)</label>
                        <input type="number" step="0.01" id="editVariantSalePrice"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-gray-200 flex justify-end space-x-3">
                    <button onclick="closeModal()"
                        class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button onclick="saveVariantChanges()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- Add Variant Modal -->
        <div id="addVariantModal"
            class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-lg shadow-xl w-full max-w-md">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-semibold text-gray-900">Add New Variant</h3>
                </div>
                <div class="px-6 py-4 space-y-4">
                    <div>
                        <label for="addVariantModel" class="block text-sm font-medium text-gray-700 mb-1">Model Name</label>
                        <input type="text" id="addVariantModel" placeholder="e.g. iPhone 15 Pro"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500">
                    </div>
                    <div>
                        <label for="addVariantBrand" class="block text-sm font-medium text-gray-700 mb-1">Brand</label>
                        <select id="addVariantBrand" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500">
                            <option value="">Select Brand</option>
                            <% if (typeof brands !== 'undefined' && brands.length > 0) { %>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand._id %>"><%= brand.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="addVariantStock" class="block text-sm font-medium text-gray-700 mb-1">Stock</label>
                            <input type="number" id="addVariantStock" placeholder="0"
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500">
                        </div>
                        <div>
                            <label for="addVariantOriginalPrice" class="block text-sm font-medium text-gray-700 mb-1">Org. Price (₹)</label>
                            <input type="number" step="0.01" id="addVariantOriginalPrice" placeholder="0.00"
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500">
                        </div>
                    </div>
                    <div>
                        <label for="addVariantSalePrice" class="block text-sm font-medium text-gray-700 mb-1">Sale Price (₹)</label>
                        <input type="number" step="0.01" id="addVariantSalePrice" placeholder="0.00"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500">
                    </div>

                    <div class="pt-4 border-t border-gray-100">
                        <label class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wider">Variant Images</label>
                        <input type="file" id="addVariantImages" accept="image/*" multiple class="hidden" onchange="handleAddVariantImages(event)">
                        <div onclick="document.getElementById('addVariantImages').click()" 
                             class="border-2 border-dashed border-gray-200 rounded-xl p-4 text-center hover:border-indigo-400 hover:bg-indigo-50 transition-all cursor-pointer">
                            <i class="fas fa-cloud-upload-alt text-gray-400 mb-2 text-2xl"></i>
                            <p class="text-xs font-medium text-gray-600">Click to upload images</p>
                            <p class="text-[10px] text-gray-400 mt-1">Up to 5 images (1:1 recommended)</p>
                        </div>
                        <div id="addVariantImagesPreview" class="grid grid-cols-4 gap-2 mt-3"></div>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-gray-200 flex justify-end space-x-3">
                    <button onclick="closeAddVariantModal()"
                        class="px-5 py-2.5 border border-gray-200 text-gray-600 rounded-xl hover:bg-gray-50 transition-all font-medium">
                        Cancel
                    </button>
                    <button id="saveNewVariantBtn" onclick="saveNewVariant()"
                        class="px-8 py-2.5 btn-premium text-white rounded-xl shadow-md transition-all">
                        Add Variant
                    </button>
                </div>
            </div>
        </div>

        <!-- Manage Images Modal -->
        <div id="manageVariantImagesModal"
            class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-lg shadow-xl w-full max-w-4xl">
                <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                    <h3 class="text-lg font-semibold text-gray-900">Manage Variant Images</h3>
                    <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <div class="px-6 py-4 max-h-[70vh] overflow-y-auto">
                    <!-- Current Images -->
                    <div class="mb-8">
                        <div class="flex items-center justify-between mb-4">
                            <h4 class="text-sm font-bold text-gray-700 uppercase tracking-wider">Current Assets</h4>
                            <span class="text-xs text-gray-500" id="imageCount">0 Images</span>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4" id="productImagesContainer">
                            <!-- Images dynamically loaded here -->
                        </div>
                    </div>


                    <hr class="mb-6 border-gray-200">

                    <h4 class="text-md font-medium text-gray-800 mb-3">Add New Images</h4>
                    <input type="file" id="productImages" accept="image/*" multiple class="hidden"
                        onchange="handleImagesUpload(event)">
                    <div onclick="document.getElementById('productImages').click()"
                        class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-purple-400 transition-colors cursor-pointer mb-4">
                        <svg class="mx-auto text-gray-400 mb-2" width="32" height="32" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12">
                            </path>
                        </svg>
                        <p class="text-sm font-medium text-gray-700">Upload Variant Images</p>
                        <p class="text-xs text-gray-500 mt-1">PNG, JPG up to 5MB each (Multiple files)</p>
                        <p class="text-xs text-purple-600 mt-1">First image uploaded will become main if none exists</p>
                    </div>

                    <!-- Images Preview Grid -->
                    <div id="imagesPreview" class="grid grid-cols-2 gap-3"></div>
                </div>
                <div class="px-6 py-4 border-t border-gray-200 flex justify-end space-x-3">
                    <button onclick="closeModal()"
                        class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button onclick="saveImages()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- Crop Modal -->
        <div id="cropModal"
            class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-xl shadow-xl p-6 max-w-4xl w-full">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-xl font-bold text-gray-900">Crop Image</h2>
                    <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <!-- Cropper Container -->
                <div class="w-full flex">
                    <div class="w-2/3 pr-4">
                        <div class="border rounded-lg overflow-hidden" style="height: 400px;">
                            <img id="cropImage" class="block" style="max-width: 100%; max-height: 100%;" />
                        </div>
                    </div>
                    <div class="w-1/3 pl-4">
                        <h3 class="font-medium text-gray-900 mb-3">Crop Options</h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Aspect Ratio</label>
                                <select id="aspectRatio"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                                    onchange="updateAspectRatio()">
                                    <option value="1">Square (1:1)</option>
                                    <option value="4/3">Standard (4:3)</option>
                                    <option value="16/9">Widescreen (16:9)</option>
                                    <option value="0">Free</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Rotation</label>
                                <div class="flex items-center space-x-2">
                                    <button onclick="rotateImage(-90)"
                                        class="p-2 border border-gray-300 rounded-md hover:bg-gray-50">
                                        <i class="fas fa-undo"></i>
                                    </button>
                                    <button onclick="rotateImage(90)"
                                        class="p-2 border border-gray-300 rounded-md hover:bg-gray-50">
                                        <i class="fas fa-redo"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="bg-blue-50 p-3 rounded-lg">
                                <p class="text-sm text-blue-700">Drag the corners to adjust the crop area. The preview
                                    will show how your image will look.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex justify-between items-center mt-6">
                    <div class="text-sm text-gray-500">
                        Editing: <span id="editingImageName" class="font-medium">New Image</span>
                    </div>
                    <div class="flex gap-3">
                        <button onclick="closeCropModal()"
                            class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
                        <button onclick="cropAndSave()"
                            class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">Apply
                            Crop</button>
                    </div>
                </div>
            </div>
        </div>
        <script>
            const product = '<%- JSON.stringify(product) %>';
            window.product = JSON.parse(product);
            // Variant images will be populated when clicking Manage Images
            window.productImages = [];
        </script>

        <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.12/dist/cropper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script type="module" src="/js/ui-helpers.js"></script>
        <script type="module" src="/js/admin/view-product.js"></script>
</body>

</html>
<%- include('../partials/header') %>

    <div class="flex min-h-screen bg-gray-50">
        <%- include('../partials/sidebar') %>

            <main class="flex-1 flex flex-col min-h-screen overflow-auto">
                <!-- Top Navigation Bar -->
                <header
                    class="bg-white border-b border-gray-200 px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between sticky top-0 z-20 shadow-sm">
                    <div>
                        <h1 class="text-xl lg:text-2xl font-bold text-gray-900">Reports & Analytics</h1>
                        <p class="text-xs sm:text-sm text-gray-500 mt-0.5">Detailed analytics and business reports</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <!-- Notification Icon -->
                        <!-- <button class="relative p-2 hover:bg-gray-100 rounded-lg transition-colors">
                            <span
                                class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M15 17H20L18.595 15.595A1 1 0 0118 14.806V11a6 6 0 10-12 0v3.806a1 1 0 01-.595.788L4 17H9m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                            </svg>
                        </button> -->

                        <!-- User Profile -->
                        <!-- <div class="hidden sm:flex items-center gap-3 pl-3 border-l border-gray-200">
                            <div
                                class="w-9 h-9 rounded-full bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center text-white text-sm font-bold shadow-md">
                                AU
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-semibold text-gray-800">Admin User</p>
                                <p class="text-[10px] text-gray-500">admin@casecart.com</p>
                            </div>
                        </div> -->
                    </div>
                </header>

                <!-- Main Content -->
                <div class="flex-1 p-4 sm:p-6 lg:p-8 space-y-6">
                    <!-- Charts Row -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Sales Report Chart -->
                        <!-- <div
                            class="bg-white rounded-xl p-5 lg:p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-sm font-semibold text-gray-800">Sales Report</h2>
                                <select
                                    class="text-xs border border-gray-200 rounded-lg px-2 py-1 text-gray-600 focus:outline-none focus:ring-2 focus:ring-purple-500">
                                    <option>Last 7 days</option>
                                    <option>Last 30 days</option>
                                    <option>Last 90 days</option>
                                </select>
                            </div>
                            <div class="relative w-full h-[300px]">
                                <canvas id="salesChart"></canvas>
                            </div>
                        </div> -->

                        <!-- Customer Analytics Chart -->
                        <!-- <div
                            class="bg-white rounded-xl p-5 lg:p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-sm font-semibold text-gray-800">Customer Analytics</h2>
                                <select
                                    class="text-xs border border-gray-200 rounded-lg px-2 py-1 text-gray-600 focus:outline-none focus:ring-2 focus:ring-purple-500">
                                    <option>This month</option>
                                    <option>Last month</option>
                                    <option>This year</option>
                                </select>
                            </div>
                            <div class="relative w-full h-[300px]">
                                <canvas id="customerChart"></canvas>
                            </div>
                        </div> -->
                    </div>

                    <!-- Detailed Sales Report -->
                    <div
                        class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
                        <!-- Header with Export Buttons -->
                        <div
                            class="flex flex-col sm:flex-row items-start sm:items-center justify-between px-4 sm:px-6 py-4 border-b border-gray-200 gap-3">
                            <h2 class="text-sm font-semibold text-gray-800">Detailed Sales Report</h2>
                            <div class="flex gap-2 w-full sm:w-auto">
                                <a href="/admin/sales/export/pdf?dateRange=<%= filters.dateRange %>&status=<%= filters.status %>&startDate=<%= filters.startDate || '' %>&endDate=<%= filters.endDate || '' %>"
                                    class="flex-1 sm:flex-none flex items-center justify-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-xs font-medium rounded-lg hover:bg-gray-800 transition-colors shadow-sm">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path
                                            d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                                    </svg>
                                    <span class="hidden sm:inline">Export to PDF</span>
                                    <span class="sm:hidden">PDF</span>
                                </a>
                                <a href="/admin/sales/export/excel?dateRange=<%= filters.dateRange %>&status=<%= filters.status %>&startDate=<%= filters.startDate || '' %>&endDate=<%= filters.endDate || '' %>"
                                    class="flex-1 sm:flex-none flex items-center justify-center gap-1.5 px-4 py-2 bg-green-600 text-white text-xs font-medium rounded-lg hover:bg-green-700 transition-colors shadow-sm">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <rect x="3" y="3" width="18" height="18" rx="2" />
                                        <path d="M7 8h10M7 12h5" />
                                    </svg>
                                    <span>Excel</span>
                                </a>
                            </div>
                        </div>

                        <!-- Filters Section -->
                        <form id="filterForm" method="GET" action="/admin/sales/report"
                            class="px-4 sm:px-6 py-4 border-b border-gray-100 bg-gray-50">
                            <!-- Main Filters -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
                                <div>
                                    <label
                                        class="block text-[10px] text-gray-500 mb-1.5 font-semibold uppercase tracking-wide">Date
                                        Range</label>
                                    <select name="dateRange" id="dateRange"
                                        class="w-full text-xs border border-gray-300 rounded-lg px-3 py-2 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all"
                                        onchange="toggleCustomDates(this.value); if(this.value !== 'custom') this.form.submit()">
                                        <option value="all" <%=filters.dateRange==='all' ? 'selected' : '' %>>All Time
                                        </option>
                                        <option value="today" <%=filters.dateRange==='today' ? 'selected' : '' %>>Today
                                        </option>
                                        <option value="this-week" <%=filters.dateRange==='this-week' ? 'selected' : ''
                                            %>>This Week</option>
                                        <option value="this-month" <%=filters.dateRange==='this-month' ? 'selected' : ''
                                            %>>This Month</option>
                                        <option value="this-year" <%=filters.dateRange==='this-year' ? 'selected' : ''
                                            %>>This Year</option>
                                        <option value="custom" <%=filters.dateRange==='custom' ? 'selected' : '' %>
                                            >Custom Range</option>
                                    </select>
                                </div>
                                <div id="customDateContainer"
                                    class="col-span-1 sm:col-span-2 lg:col-span-2 <%= filters.dateRange === 'custom' ? 'flex' : 'hidden' %> gap-2">
                                    <div class="flex-1">
                                        <label
                                            class="block text-[10px] text-gray-500 mb-1.5 font-semibold uppercase tracking-wide">Start
                                            Date</label>
                                        <input type="date" name="startDate" value="<%= filters.startDate || '' %>"
                                            class="w-full text-xs border border-gray-300 rounded-lg px-3 py-2 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-purple-500">
                                    </div>
                                    <div class="flex-1">
                                        <label
                                            class="block text-[10px] text-gray-500 mb-1.5 font-semibold uppercase tracking-wide">End
                                            Date</label>
                                        <div class="flex gap-2">
                                            <input type="date" name="endDate" value="<%= filters.endDate || '' %>"
                                                class="w-full text-xs border border-gray-300 rounded-lg px-3 py-2 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-purple-500">
                                            <button type="submit"
                                                class="px-3 py-2 bg-purple-600 text-white rounded-lg text-xs font-semibold hover:bg-purple-700">Apply</button>
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <label
                                        class="block text-[10px] text-gray-500 mb-1.5 font-semibold uppercase tracking-wide">Status</label>
                                    <select name="status"
                                        class="w-full text-xs border border-gray-300 rounded-lg px-3 py-2 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all"
                                        onchange="this.form.submit()">
                                        <option value="all" <%=filters.status==='all' ? 'selected' : '' %>>All Status
                                        </option>
                                        <option value="delivered" <%=filters.status==='delivered' ? 'selected' : '' %>
                                            >Delivered</option>
                                        <option value="completed" <%=filters.status==='completed' ? 'selected' : '' %>
                                            >Completed</option>
                                        <option value="pending" <%=filters.status==='pending' ? 'selected' : '' %>
                                            >Pending</option>
                                        <option value="shipped" <%=filters.status==='shipped' ? 'selected' : '' %>
                                            >Shipped</option>
                                        <option value="cancelled" <%=filters.status==='cancelled' ? 'selected' : '' %>
                                            >Cancelled</option>
                                        <option value="returned" <%=filters.status==='returned' ? 'selected' : '' %>
                                            >Returned</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Quick Filters -->
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-[11px] text-gray-500 font-medium">Quick filters:</span>
                                <a href="/admin/sales/report?dateRange=today&status=<%= filters.status %>"
                                    class="px-3 py-1.5 text-[11px] border border-gray-300 rounded-lg text-gray-600 bg-white hover:bg-purple-600 hover:text-white transition-all font-medium">1
                                    Day</a>
                                <a href="/admin/sales/report?dateRange=this-week&status=<%= filters.status %>"
                                    class="px-3 py-1.5 text-[11px] border border-gray-300 rounded-lg text-gray-600 bg-white hover:bg-purple-600 hover:text-white transition-all font-medium">1
                                    Week</a>
                                <a href="/admin/sales/report?dateRange=this-month&status=<%= filters.status %>"
                                    class="px-3 py-1.5 text-[11px] border border-gray-300 rounded-lg text-gray-600 bg-white hover:bg-purple-600 hover:text-white transition-all font-medium">1
                                    Month</a>
                                <a href="/admin/sales/report"
                                    class="ml-auto text-[11px] text-purple-600 hover:text-purple-700 font-semibold flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2"
                                        viewBox="0 0 24 24">
                                        <path
                                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                    </svg>
                                    Reset Filters
                                </a>
                            </div>
                        </form>

                        <!-- Statistics Cards -->
                        <div
                            class="grid grid-cols-2 sm:grid-cols-5 divide-y sm:divide-y-0 sm:divide-x divide-gray-200 border-b border-gray-200">
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-[11px] text-gray-500 uppercase tracking-wide font-semibold mb-1">
                                    Successful Sales</p>
                                <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-1">₹<%=
                                        summary.totalSales.toFixed(2) %>
                                </p>
                            </div>
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-[11px] text-gray-500 uppercase tracking-wide font-semibold mb-1">Refund
                                    Amount
                                </p>
                                <p class="text-2xl lg:text-3xl font-bold text-red-600 mb-1">₹<%= (summary.totalRefunds
                                        || 0).toFixed(2) %>
                                </p>
                            </div>
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-[11px] text-gray-500 uppercase tracking-wide font-semibold mb-1">Orders
                                </p>
                                <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-1">
                                    <%= summary.orderCount %>
                                </p>
                            </div>
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-[11px] text-gray-500 uppercase tracking-wide font-semibold mb-1">Total
                                    Discount</p>
                                <p class="text-2xl lg:text-3xl font-bold text-green-600 mb-1">₹<%=
                                        (summary.totalDiscount + summary.totalCouponDiscount).toFixed(2) %>
                                </p>
                            </div>
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-[11px] text-gray-500 uppercase tracking-wide font-semibold mb-1">Avg
                                    Order Value</p>
                                <p class="text-2xl lg:text-3xl font-bold text-gray-900 mb-1">₹<%=
                                        avgOrderValue.toFixed(2) %>
                                </p>
                            </div>
                        </div>

                        <!-- Table - Desktop View -->
                        <div class="hidden lg:block overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="bg-gray-50">
                                    <tr
                                        class="text-[11px] uppercase tracking-wide text-gray-600 border-b border-gray-200">
                                        <th class="px-6 py-4 text-left w-12">
                                            <input type="checkbox"
                                                class="rounded border-gray-300 text-purple-600 focus:ring-purple-500" />
                                        </th>
                                        <th
                                            class="px-4 py-4 text-left font-semibold cursor-pointer hover:text-gray-900">
                                            Order ID
                                            <svg class="w-3 h-3 inline ml-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M5 12l5-5 5 5H5z" />
                                            </svg>
                                        </th>
                                        <th
                                            class="px-4 py-4 text-left font-semibold cursor-pointer hover:text-gray-900">
                                            Date
                                            <svg class="w-3 h-3 inline ml-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M5 12l5-5 5 5H5z" />
                                            </svg>
                                        </th>
                                        <th class="px-4 py-4 text-left font-semibold">Customer</th>
                                        <th
                                            class="px-4 py-4 text-left font-semibold cursor-pointer hover:text-gray-900">
                                            Products
                                            <svg class="w-3 h-3 inline ml-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M5 12l5-5 5 5H5z" />
                                            </svg>
                                        </th>
                                        <th
                                            class="px-4 py-4 text-left font-semibold cursor-pointer hover:text-gray-900">
                                            Amount
                                            <svg class="w-3 h-3 inline ml-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M5 12l5-5 5 5H5z" />
                                            </svg>
                                        </th>
                                        <th class="px-4 py-4 text-left font-semibold">Payment</th>
                                        <th class="px-4 py-4 text-left font-semibold">Status</th>

                                    </tr>
                                </thead>

                                <tbody class="divide-y divide-gray-100 bg-white">
                                    <% if (orders && orders.length> 0) { %>
                                        <% orders.forEach((order)=> { %>
                                            <tr class="hover:bg-gray-50 transition-colors duration-150">
                                                <td class="px-6 py-4">

                                                </td>
                                                <td class="px-4 py-4 font-mono text-xs font-semibold text-gray-800">
                                                    <%= order.orderId %>
                                                </td>
                                                <td class="px-4 py-4 text-xs text-gray-600">
                                                    <%= new Date(order.createdAt).toLocaleDateString('en-US', {
                                                        year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                                </td>
                                                <td class="px-4 py-4">
                                                    <div class="flex items-center gap-2.5">
                                                        <div
                                                            class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-[10px] font-bold flex-shrink-0">
                                                            <%= order.userId && order.userId.firstName ?
                                                                order.userId.firstName.substring(0,2).toUpperCase()
                                                                : 'U' %>
                                                        </div>
                                                        <div>
                                                            <p class="text-xs font-semibold text-gray-800">
                                                                <%= order.userId ? `${order.userId.firstName || '' }
                                                                    ${order.userId.lastName || '' }`.trim() : 'Unknown'
                                                                    %>
                                                            </p>
                                                            <p class="text-[10px] text-gray-500">
                                                                <%= order.userId ? order.userId.email : '' %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="px-4 py-4 text-xs text-gray-600">
                                                    <%= order.orderItems && order.orderItems.length> 0 ?
                                                        order.orderItems.map(item => item.productId ?
                                                        item.productId.name : 'Unknown').join(", ") : 'No Items' %>
                                                </td>
                                                <td class="px-4 py-4 text-xs font-bold text-gray-900 font-mono">₹<%=
                                                        order.finalAmount.toFixed(2) %>
                                                </td>
                                                <td class="px-4 py-4 text-xs text-gray-600 uppercase">
                                                    <%= order.paymentMethod %>
                                                </td>
                                                <td class="px-4 py-4">
                                                    <% let mainStatus=order.orderItems[0].status; %>
                                                        <% let statusColor=mainStatus==='delivered' ? 'green' :
                                                            (mainStatus==='cancelled' || mainStatus==='returned' ? 'red'
                                                            : 'yellow' ); %>
                                                            <span
                                                                class="inline-flex items-center gap-1.5 px-3 py-1 bg-<%= statusColor %>-100 text-<%= statusColor %>-700 text-[11px] font-semibold rounded-full capitalize">
                                                                <span
                                                                    class="w-1.5 h-1.5 bg-<%= statusColor %>-600 rounded-full"></span>
                                                                <%= mainStatus.replace('_', ' ' ) %>
                                                            </span>
                                                </td>

                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="9" class="px-4 py-8 text-center text-gray-500">No
                                                            orders found matching criteria.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Card View -->
                        <div class="lg:hidden divide-y divide-gray-100">
                            <% if (orders && orders.length> 0) { %>
                                <% orders.forEach((order)=> { %>
                                    <% let mainStatus=order.orderItems[0].status; %>
                                        <% let statusColor=mainStatus==='delivered' ? 'green' :
                                            (mainStatus==='cancelled' || mainStatus==='returned' ? 'red' : 'yellow' );
                                            %>
                                            <!-- Order Card -->
                                            <div class="p-4 bg-white hover:bg-gray-50 transition-colors">
                                                <div class="flex items-start justify-between mb-3">
                                                    <div class="flex items-center gap-2">
                                                        <input type="checkbox"
                                                            class="rounded border-gray-300 text-purple-600 focus:ring-purple-500" />
                                                        <span class="font-mono text-xs font-semibold text-gray-800">
                                                            <%= order.orderId %>
                                                        </span>
                                                    </div>
                                                    <span
                                                        class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-<%= statusColor %>-100 text-<%= statusColor %>-700 text-[10px] font-semibold rounded-full capitalize">
                                                        <span
                                                            class="w-1.5 h-1.5 bg-<%= statusColor %>-600 rounded-full"></span>
                                                        <%= mainStatus.replace('_', ' ' ) %>
                                                    </span>
                                                </div>
                                                <div class="flex items-center gap-2.5 mb-3">
                                                    <div
                                                        class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center text-amber-700 text-xs font-bold">
                                                        <%= order.userId && order.userId.firstName ?
                                                            order.userId.firstName.substring(0,2).toUpperCase() : 'U' %>
                                                    </div>
                                                    <div class="flex-1">
                                                        <p class="text-sm font-semibold text-gray-800">
                                                            <%= order.userId ? `${order.userId.firstName || '' }
                                                                ${order.userId.lastName || '' }`.trim() : 'Unknown' %>
                                                        </p>
                                                        <p class="text-xs text-gray-500">
                                                            <%= order.userId ? order.userId.email : '' %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <div class="grid grid-cols-2 gap-2 text-xs">
                                                    <div>
                                                        <span class="text-gray-500">Date:</span>
                                                        <span class="text-gray-800 font-medium ml-1">
                                                            <%= new Date(order.createdAt).toLocaleDateString('en-US', {
                                                                year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                                        </span>
                                                    </div>
                                                    <span class="text-gray-500">Products:</span>
                                                    <span
                                                        class="text-gray-800 font-medium ml-1 truncate block max-w-full">
                                                        <%= order.orderItems && order.orderItems.length> 0 ?
                                                            order.orderItems.map(item => item.productId ?
                                                            item.productId.name : 'Unknown').join(", ") : 'No Items' %>
                                                    </span>
                                                    <div>
                                                        <span class="text-gray-500">Payment:</span>
                                                        <span class="text-gray-800 font-medium ml-1 uppercase">
                                                            <%= order.paymentMethod %>
                                                        </span>
                                                    </div>
                                                    <div>
                                                        <span class="text-gray-500">Amount:</span>
                                                        <span class="text-gray-900 font-bold font-mono ml-1">₹<%=
                                                                order.finalAmount.toFixed(2) %></span>
                                                    </div>
                                                </div>

                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="p-4 bg-white text-center text-gray-500 text-sm">No
                                                        orders found matching criteria.</div>
                                                    <% } %>
                        </div>

                        <!-- Pagination -->
                        <div
                            class="flex flex-col sm:flex-row items-center justify-between px-4 sm:px-6 py-4 border-t border-gray-200 gap-3">
                            <p class="text-xs text-gray-600">Showing page <span class="font-semibold">
                                    <%= currentPage %>
                                </span> of <span class="font-semibold">
                                    <%= totalPages || 1 %>
                                </span></p>
                            <div class="flex items-center gap-1">
                                <% if (currentPage> 1) { %>
                                    <a href="/admin/sales/report?page=<%= currentPage - 1 %>&dateRange=<%= filters.dateRange %>&status=<%= filters.status %>"
                                        class="px-3 py-2 text-xs border border-gray-300 rounded-lg text-gray-600 bg-white hover:bg-gray-50 transition-colors font-medium">←
                                        Previous</a>
                                    <% } else { %>
                                        <button disabled
                                            class="px-3 py-2 text-xs border border-gray-200 rounded-lg text-gray-400 bg-gray-50 font-medium cursor-not-allowed">←
                                            Previous</button>
                                        <% } %>

                                            <button
                                                class="px-3 py-2 text-xs bg-purple-600 text-white rounded-lg font-semibold shadow-sm">
                                                <%= currentPage %>
                                            </button>

                                            <% if (currentPage < totalPages) { %>
                                                <a href="/admin/sales/report?page=<%= currentPage + 1 %>&dateRange=<%= filters.dateRange %>&status=<%= filters.status %>"
                                                    class="px-3 py-2 text-xs border border-gray-300 rounded-lg text-gray-600 bg-white hover:bg-gray-50 transition-colors font-medium">Next
                                                    →</a>
                                                <% } else { %>
                                                    <button disabled
                                                        class="px-3 py-2 text-xs border border-gray-200 rounded-lg text-gray-400 bg-gray-50 font-medium cursor-not-allowed">Next
                                                        →</button>
                                                    <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <div id="chartDataContainer" data-chart="<%= chartData %>" style="display: none;"></div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function toggleCustomDates(value) {
            const container = document.getElementById('customDateContainer');
            if (!container) return;
            if (value === 'custom') {
                container.classList.remove('hidden');
                container.classList.add('flex');
            } else {
                container.classList.remove('flex');
                container.classList.add('hidden');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            let chartData = { labels: [], revenue: [], count: [] };
            try {
                const chartDataRaw = document.getElementById('chartDataContainer').dataset.chart;
                if (chartDataRaw) {
                    chartData = JSON.parse(chartDataRaw);
                }
            } catch (e) {
                console.error("Error parsing chart data", e);
            }

            const salesCtx = document.getElementById('salesChart');
            if (salesCtx) {
                new Chart(salesCtx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: chartData.labels,
                        datasets: [{
                            label: 'Revenue (₹)',
                            data: chartData.revenue,
                            backgroundColor: '#8b5cf6',
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f3f4f6' },
                                border: { dash: [4, 4] },
                                ticks: {
                                    callback: function (value) {
                                        if (value >= 1000) {
                                            return '₹' + (value / 1000) + 'K';
                                        }
                                        return '₹' + value;
                                    }
                                }
                            },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }

            const customerCtx = document.getElementById('customerChart');
            if (customerCtx) {
                new Chart(customerCtx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: chartData.labels,
                        datasets: [{
                            label: 'Orders',
                            data: chartData.count,
                            borderColor: '#34d399',
                            backgroundColor: 'rgba(52, 211, 153, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#34d399',
                            pointBorderWidth: 2,
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, grid: { color: '#f3f4f6' }, border: { dash: [4, 4] }, ticks: { stepSize: 1 } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }
        });
    </script>
    <%- include('../partials/footer') %>
<%- include('../partials/header') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />


    <div class="flex">
<%- include('../partials/sidebar') %>
          <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen">
        
                <button class="text-purple-600 hover:text-purple-700 mb-4 flex items-center gap-2">← Back</button>
                <h1 class="text-3xl font-bold text-gray-900">Add New Product</h1>
                <p class="text-gray-600 mt-1">Create a new product for your store.</p>
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column - Product Information -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-6">Product Information</h2>
                        
                        <div class="space-y-5">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    Product Name <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="productName" placeholder="Enter product name"
                                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 transition-shadow">
                                <p id="productNameError" class="hidden mt-1 text-sm text-red-600 flex items-center gap-1">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                    </svg>
                                    <span>Product name is required</span>
                                </p>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    Description <span class="text-red-500">*</span>
                                </label>
                                <textarea id="description" placeholder="Enter product description" rows="4"
                                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 transition-shadow resize-none"></textarea>
                                <p id="descriptionError" class="hidden mt-1 text-sm text-red-600 flex items-center gap-1">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                    </svg>
                                    <span>Description is required</span>
                                </p>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    Category <span class="text-red-500">*</span>
                                </label>
                                <select id="category" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 transition-shadow">
                                    <option value="">Choose category</option>
                                        <% categories.forEach(category => { %>
                                            
                                            <option value="<%= category._id %>"><%= category.name %></option>
                                        <% }) %>
                                    
                                </select>
                                <p id="categoryError" class="hidden mt-1 text-sm text-red-600 flex items-center gap-1">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                    </svg>
                                    <span>Please select a category</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Product Images -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-6">Product Images</h2>
                        
                        <div>
                            <input type="file" id="productImages" accept="image/*" multiple class="hidden" onchange="handleImagesUpload(event)">
                            <div onclick="document.getElementById('productImages').click()" class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-purple-400 transition-colors cursor-pointer mb-4">
                                <svg class="mx-auto text-gray-400 mb-2" width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                                </svg>
                                <p class="text-sm font-medium text-gray-700">Upload Product Images</p>
                                <p class="text-xs text-gray-500 mt-1">PNG, JPG up to 5MB each (Multiple files)</p>
                                <p class="text-xs text-purple-600 mt-1">First image will be the main image</p>
                            </div>
                            
                            <!-- Images Preview Grid -->
                            <div id="imagesPreview" class="grid grid-cols-2 gap-3"></div>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Product Details -->
                <div class="space-y-6">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <div class="flex items-center justify-between mb-6">
                            <h2 class="text-lg font-semibold text-gray-900">Compatible Devices</h2>
                            <button onclick="openDeviceModal()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors text-sm font-medium flex items-center gap-2">
                                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                </svg>
                                Add Device
                            </button>
                        </div>

                        <div id="devicesError" class="hidden mb-4 bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-2">
                            <svg class="text-red-600" width="16" height="16" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-sm text-red-800">At least one compatible device is required</span>
                        </div>

                        <div id="devicesList" class="space-y-3">
                            <p class="text-center text-gray-500 text-sm py-8">No devices added yet</p>
                        </div>
                    </div>

                    <!-- Product Status -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-4">Product Status</h2>
                        <div class="space-y-2">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="radio" name="status" value="active" checked class="w-4 h-4 text-purple-600">
                                <span class="text-gray-700">Active</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="radio" name="status" value="inactive" class="w-4 h-4 text-purple-600">
                                <span class="text-gray-700">Inactive</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="flex justify-end gap-4 mt-8">
                <button onclick="cancelForm()" class="px-6 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">Cancel</button>
                <button onclick="createProduct()" class="px-6 py-2.5 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors font-medium shadow-sm">Create Product</button>
            </div>

<div id="deviceModal" class="modal fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4 hidden" onclick="if(event.target === this) closeDeviceModal()">
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6 fade-in">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-900">Add Compatible Device</h2>
            <button onclick="closeDeviceModal()" class="text-gray-400 hover:text-gray-600">
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Device Name <span class="text-red-500">*</span>
                </label>
                <input type="text" id="deviceName" placeholder="e.g., iPhone 14 Pro"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                <p id="deviceNameError" class="hidden mt-1 text-sm text-red-600">Device name is required</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Original Price <span class="text-red-500">*</span>
                    </label>
                    <input type="number" id="originalPrice" step="0.01" placeholder="0.00"
                        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                    <p id="originalPriceError" class="hidden mt-1 text-sm text-red-600">Must be greater than 0</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Sale Price <span class="text-red-500">*</span>
                    </label>
                    <input type="number" id="salePrice" step="0.01" placeholder="0.00"
                        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                    <p id="salePriceError" class="hidden mt-1 text-sm text-red-600">Must be valid and ≤ original</p>
                </div>
            </div>






            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Stock <span class="text-red-500">*</span>
                </label>
                <input type="number" id="stock" placeholder="0"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                <p id="stockError" class="hidden mt-1 text-sm text-red-600">Stock cannot be negative</p>
            </div>
        </div>
        

        <div class="flex gap-3 mt-6">
            <button onclick="closeDeviceModal()" class="flex-1 px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">Cancel</button>
            <button onclick="addDevice()" class="flex-1 px-4 py-2.5 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors font-medium">Add Device</button>
        </div>
    </div>
</div>


  </div>
        </main>
    </div>
<!-- Crop Modal - Place before closing </body> tag -->
<div id="cropModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-2xl w-full">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-900">Crop Image</h2>
            <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600">
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Cropper Container -->
        <div class="w-full" style="max-height: 400px; overflow: hidden;">
            <img id="cropImage" class="max-w-full block" style="display: none;" />
        </div>

        <div class="flex justify-end gap-3 mt-6">
            <button onclick="closeCropModal()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
            <button onclick="cropAndSave()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">Crop & Add</button>
        </div>
    </div>
</div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script type="module" src="/js/admin/add-product.js"></script>
 <%- include('../partials/footer') %>


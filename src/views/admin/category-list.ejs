<%- include('../partials/header') %>
  <div class="flex">
    <%- include('../partials/sidebar') %>
      <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen overflow-hidden">
        <div id="categories-page" class="page-content">
          <div class="mb-6">
            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
              Category Management
            </h1>
            <p class="text-gray-600 text-sm lg:text-base">
              Organize your products into categories.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex flex-col space-y-3 mb-4">
              <h3 class="text-base lg:text-lg font-bold text-gray-900">
                Product Categories
              </h3>
              <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3">
                <input id="searchInput" type="text" value="<%= search %>" placeholder="Search categories..."
                  class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 flex-1" />
                <a href="/admin/add-category">
                  <button class="bg-purple-600 text-white px-3 py-2 rounded-lg hover:bg-purple-700 transition text-sm">
                    <i class="fas fa-plus mr-1"></i> Add Category
                  </button>
                </a>
              </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              <% categories.forEach(Category=> { %>

                <div class="border border-gray-200 rounded-lg p-4 duration-300 hover:opacity-80">
                  <div class="flex items-center justify-between mb-3">
                    <h4 class="font-semibold text-sm">
                      <%= Category.name %>
                    </h4>

                  </div>

                  <p class="text-xs text-gray-600 mb-4">
                    <%= Category.description %>
                  </p>


                  <div class="flex justify-between items-center mt-2">

                    <div class="flex space-x-3">
                      <a href="/admin/category/edit/<%= Category._id %>"
                        class="text-blue-600 hover:text-blue-800 text-xs flex items-center edit-btn">
                        <i class="fas fa-edit mr-1"></i> Edit
                      </a>

                      <button id="category-block-btn-<%= Category._id %>"
                        class="text-red-600 hover:text-red-800 text-xs block-btn flex items-center"
                        data-id="<%= Category._id %>" data-statusmode="<%= Category.isActive ? 'block' : 'unblock' %>">
                        <i class="fas <%= Category.isActive ? 'fa-ban' : 'fa-check' %> mr-1"></i>
                        <% if (Category.isActive) { %> Block <% } else { %> Unblock <% } %>
                      </button>
                    </div>



                    <a href="/admin/offers?categoryId=<%= Category._id %>">
                      <span class="bg-purple-100 text-purple-600 text-xs px-2 py-1 rounded cursor-pointer">
                        add offer
                      </span>
                    </a>
                  </div>
                </div>

                <% }) %>
            </div>
          </div>
          <div class="flex justify-between items-center mt-4">

            <!-- Showing Count -->
            <div class="text-sm text-gray-600">
              Showing <span class="font-medium">
                <%= currentPage %> - <%= totalPages %>
              </span> of <span class="font-medium">
                <%= totalItems %>
              </span> categories
            </div>

            <!-- Pagination -->
            <div class="flex space-x-1">

              <!-- Prev Button -->
              <!-- Pagination -->
              <nav aria-label="Page navigation" class="flex justify-center mt-6">
                <ul class="flex items-center space-x-2">

                  <!-- Previous Button -->
                  <li>
                    <% if (currentPage===1) { %>
                      <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
                        Previous
                      </span>
                      <% } else { %>
                        <a href="/admin/category?page=<%= currentPage - 1 %>&search=<%= search %>"
                          class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                          Previous
                        </a>
                        <% } %>
                  </li>

                  <!-- Page Numbers -->
                  <% for (let i=1; i <=totalPages; i++) { %>
                    <li>
                      <% if (currentPage===i) { %>
                        <span class="px-4 py-2 bg-blue-600 text-white rounded-md shadow font-semibold">
                          <%= i %>
                        </span>
                        <% } else { %>
                          <a href="/admin/category?page=<%= i %>&search=<%= search %>"
                            class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                            <%= i %>
                          </a>
                          <% } %>
                    </li>
                    <% } %>

                      <!-- Next Button -->
                      <li>
                        <% if (currentPage===totalPages) { %>
                          <span class="px-4 py-2 border border-gray-300 rounded-md text-gray-400 cursor-not-allowed">
                            Next
                          </span>
                          <% } else { %>
                            <a href="/admin/category?page=<%= currentPage + 1 %>&search=<%= search %>"
                              class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 transition">
                              Next
                            </a>
                            <% } %>
                      </li>
                </ul>
              </nav>


            </div>
          </div>
        </div>

      </main>

  </div>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script type="module" src="/js/admin/category-filter.js"></script>
  <script type="module" src="/js/admin/block-category.js"></script>
  <%- include('../partials/footer') %>
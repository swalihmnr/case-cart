<%- include('../partials/header') %>

    <div class="flex">
<%- include('../partials/sidebar') %>
          <main class="flex-1 p-3 lg:p-6 lg:ml-0 min-h-screen">
            <div id="categories-page" class="page-content ">
          <div class="mb-6">
            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
              Category Management
            </h1>
            <p class="text-gray-600 text-sm lg:text-base">
              Organize your products into categories.
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-4">
            <div class="flex flex-col space-y-3 mb-4">
              <h3 class="text-base lg:text-lg font-bold text-gray-900">
                Product Categories
              </h3>
              <div
                class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-3"
              >
                <input
                  type="text"
                  placeholder="Search categories..."
                  class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 flex-1"
                />
                <button
                  class="bg-purple-600 text-white px-3 py-2 rounded-lg hover:bg-purple-700 transition text-sm"
                >
                  <i class="fas fa-plus mr-1"></i> Add Category
                </button>
              </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div class="border border-gray-200 rounded-lg p-4">
                <div class="flex items-center justify-between mb-3">
                  <h4 class="font-semibold text-sm">Gradient Cases</h4>
                  <span
                    class="bg-purple-100 text-purple-600 text-xs px-2 py-1 rounded"
                    >24 Products</span
                  >
                </div>
                <p class="text-xs text-gray-600 mb-4">
                  Colorful gradient pattern phone cases
                </p>
                <div class="flex space-x-2">
                  <button class="text-blue-600 hover:text-blue-800 text-xs">
                    <i class="fas fa-edit mr-1"></i> Edit
                  </button>
                  <button class="text-red-600 hover:text-red-800 text-xs">
                    <i class="fas fa-trash mr-1"></i> Delete
                  </button>
                </div>
              </div>

              <div class="border border-gray-200 rounded-lg p-4">
                <div class="flex items-center justify-between mb-3">
                  <h4 class="font-semibold text-sm">Protective Cases</h4>
                  <span
                    class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded"
                    >18 Products</span
                  >
                </div>
                <p class="text-xs text-gray-600 mb-4">
                  Military grade protection cases
                </p>
                <div class="flex space-x-2">
                  <button class="text-blue-600 hover:text-blue-800 text-xs">
                    <i class="fas fa-edit mr-1"></i> Edit
                  </button>
                  <button class="text-red-600 hover:text-red-800 text-xs">
                    <i class="fas fa-trash mr-1"></i> Delete
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
            
        </main>
    </div>

<script type="module" src="/js/admin/add-category.js"></script>
 <%- include('../partials/footer') %>

